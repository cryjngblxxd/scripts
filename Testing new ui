		local n = Options.ConfigDropdown_internal and Options.ConfigDropdown_internal.Value or ""
		if n ~= "" then ConfigSystem:Load(n) end
	end})
	sec:AddButton({Text = "Delete Config", Func = function()
		local n = Options.ConfigDropdown_internal and Options.ConfigDropdown_internal.Value or ""
		if n ~= "" then
			ConfigSystem:Delete(n)
			local c = ConfigSystem:GetConfigs(); if #c==0 then c={"default"} end
			if Options.ConfigDropdown_internal then Options.ConfigDropdown_internal:SetValues(c) end
		end
	end})
	sec:AddButton({Text = "Set Auto Load", Func = function()
		local n = Options.ConfigDropdown_internal and Options.ConfigDropdown_internal.Value or ""
		if n ~= "" then ConfigSystem:SetAutoLoad(n) end
	end})
	sec:AddButton({Text = "Remove Auto Load", Func = function() ConfigSystem:RemoveAutoLoad() end})
end

