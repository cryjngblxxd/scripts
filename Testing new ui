function library:tab(properties)
    local cfg = {name=properties.name or "Tab", icon=properties.icon or nil, items={}}
    local items = cfg.items

    items["tab_content"] = library:create("Frame",{Parent=library.cache,Visible=false,BackgroundTransparency=1,Size=dim2(1,0,1,0),BorderSizePixel=0,ZIndex=3})

    items["button"] = library:create("TextButton",{FontFace=fonts.regular,Text="",Parent=self.items["tab_buttons"],AutoButtonColor=false,Size=dim2(0,0,1,0),BorderSizePixel=0,BackgroundColor3=palette.tab,TextColor3=palette.text_dim,TextSize=11,AutomaticSize=Enum.AutomaticSize.X,ZIndex=3})

    local btn_content = library:create("Frame",{Parent=items["button"],BackgroundTransparency=1,Size=dim2(1,0,1,0),ZIndex=3})
