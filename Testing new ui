function library:tween(obj, props, dur, style)
    tween_service:Create(obj, TweenInfo.new(dur or 0.12, style or Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

function library:next_flag()
    local i = 0
    for _ in pairs(flags) do i = i + 1 end
    return "flag_" .. i + 1
end

function library:draggify(frame, handle)
    local dragging, start, startPos = false, nil, nil
    local dt = handle or frame
    dt.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            dragging = true; start = i.Position; startPos = frame.Position
        end
    end)
    dt.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
    end)
    library:connection(uis.InputChanged, function(i)
        if dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local vx, vy = camera.ViewportSize.X, camera.ViewportSize.Y
            local nx = clamp(startPos.X.Offset + (i.Position.X - start.X), 0, vx - frame.AbsoluteSize.X)
            local ny = clamp(startPos.Y.Offset + (i.Position.Y - start.Y), 0, vy - frame.AbsoluteSize.Y)
            frame.Position = dim2(0, nx, 0, ny)
            library:close_element()
        end
    end)
end

function library:convert_enum(e)
    local p = {}
    for pt in string.gmatch(e, "[%w_]+") do insert(p, pt) end
    local t = Enum
    for i = 2, #p do t = t[p[i]] end
    return t
end

function library:connection(s, cb)
    local c = s:Connect(cb)
    insert(library.connections, c)
    return c
end

function library:close_element(np)
    local o = library.current_open
    if o and np ~= o then
        pcall(function() o.set_visible(false); o.open = false end)
    end
    if np ~= o then library.current_open = np or nil end
end

function library:create(inst, opts)
    local i = Instance.new(inst)
    for p, v in pairs(opts) do pcall(function() i[p] = v end) end
    return i
end

function library:round(n, f)
    local m = 1 / (f or 1)
    return floor(n * m + 0.5) / m
end

function library:apply_theme(i, t, p)
    insert(themes.utility[t][p], i)
end

function library:update_theme(t, nc)
    for p, o in pairs(themes.utility[t]) do
        for _, obj in pairs(o) do
            pcall(function() if obj[p] then obj[p] = nc end end)
        end
    end
    themes.preset[t] = nc
end

function library:unload_menu()
    pcall(function()
        if library["items"] then library["items"]:Destroy() end
        if library["overlay"] then library["overlay"]:Destroy() end
        for _, c in pairs(library.connections) do c:Disconnect() end
    end)
end

-- ══════════════════════════════════════════════════════════════
-- Settings persistence
-- ══════════════════════════════════════════════════════════════
function library:get_settings_path() return library.directory .. "/library_settings.json" end

function library:save_library_settings()
    pcall(function()
        writefile(library:get_settings_path(), http_service:JSONEncode({
            auto_load_config = library.auto_load_config_name,
            notifications_enabled = library.notifications_on,
            watermark_enabled = library.watermark_on,
            keybind_list_enabled = library.keybind_list_on,
            notif_position = library.notif_position,
        }))
    end)
end

function library:load_library_settings()
    pcall(function()
        if isfile(library:get_settings_path()) then
            local d = http_service:JSONDecode(readfile(library:get_settings_path()))
            library.auto_load_config_name = d.auto_load_config
            library.notifications_on = d.notifications_enabled ~= false
            library.watermark_on = d.watermark_enabled ~= false
            library.keybind_list_on = d.keybind_list_enabled ~= false
            library.notif_position = d.notif_position or "TopRight"
            notifications.enabled = library.notifications_on
        end
    end)
end

function library:set_auto_load(n) library.auto_load_config_name = n; library:save_library_settings() end
function library:clear_auto_load() library.auto_load_config_name = nil; library:save_library_settings() end
function library:toggle_notifications(e) library.notifications_on = e; notifications.enabled = e; library:save_library_settings() end

function library:do_auto_load()
    library:load_library_settings()
    if library.auto_load_config_name then
        local p = library.directory .. "/configs/" .. library.auto_load_config_name .. ".cfg"
        pcall(function()
            if isfile(p) then
                task.spawn(function()
                    task.wait(0.5)
                    library:load_config(readfile(p))
                    if notifications.enabled then
                        notifications:create_notification({name = "Auto Load", info = "Loaded: " .. library.auto_load_config_name})
                    end
                end)
            end
        end)
    end
end

