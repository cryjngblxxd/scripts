function library:tween(obj, props, dur, style)
    tween_service:Create(obj, TweenInfo.new(dur or 0.12, style or Enum.EasingStyle.Quad, Enum.EasingDirection.Out), props):Play()
end

function library:next_flag()
    local i=0; for _ in pairs(flags) do i=i+1 end; return "flag_"..i+1
end

function library:draggify(frame, handle)
    local d,s,sp = false,nil,nil
    local dt = handle or frame
    dt.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then d=true;s=i.Position;sp=frame.Position end end)
    dt.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then d=false end end)
    library:connection(uis.InputChanged, function(i) if d and i.UserInputType==Enum.UserInputType.MouseMovement then
        local vx,vy=camera.ViewportSize.X,camera.ViewportSize.Y
        frame.Position=dim2(0,clamp(sp.X.Offset+(i.Position.X-s.X),0,vx-frame.AbsoluteSize.X),0,clamp(sp.Y.Offset+(i.Position.Y-s.Y),0,vy-frame.AbsoluteSize.Y))
    end end)
end

function library:convert_enum(e) local p={}; for pt in string.gmatch(e,"[%w_]+") do insert(p,pt) end; local t=Enum; for i=2,#p do t=t[p[i]] end; return t end
function library:connection(s,cb) local c=s:Connect(cb); insert(library.connections,c); return c end
function library:create(inst,opts) local i=Instance.new(inst); for p,v in pairs(opts) do pcall(function() i[p]=v end) end; return i end
function library:round(n,f) local m=1/(f or 1); return floor(n*m+0.5)/m end
function library:apply_theme(i,t,p) insert(themes.utility[t][p], i) end
function library:update_theme(t,nc) for p,o in pairs(themes.utility[t]) do for _,obj in pairs(o) do pcall(function() if obj[p] then obj[p]=nc end end) end end; themes.preset[t]=nc end

function library:close_all_popups(except)
    for _, popup in pairs(library.popups) do
        if popup ~= except and popup.holder then
            pcall(function() if popup.holder.Visible then popup.holder.Visible=false; popup.is_open=false end end)
        end
    end
end

function library:register_popup(pd) insert(library.popups, pd) end

function library:unload_menu()
    pcall(function()
        if library["items"] then library["items"]:Destroy() end
        if library["popup_gui"] then library["popup_gui"]:Destroy() end
        if library["overlay"] then library["overlay"]:Destroy() end
        for _,c in pairs(library.connections) do c:Disconnect() end
    end)
end

function library:get_settings_path() return library.directory.."/library_settings.json" end
function library:save_library_settings() pcall(function() writefile(library:get_settings_path(), http_service:JSONEncode({auto_load_config=library.auto_load_config_name,notifications_enabled=library.notifications_on,watermark_enabled=library.watermark_on,keybind_list_enabled=library.keybind_list_on,notif_position=library.notif_position})) end) end
function library:load_library_settings() pcall(function() if isfile(library:get_settings_path()) then local d=http_service:JSONDecode(readfile(library:get_settings_path())); library.auto_load_config_name=d.auto_load_config; library.notifications_on=d.notifications_enabled~=false; library.watermark_on=d.watermark_enabled~=false; library.keybind_list_on=d.keybind_list_enabled~=false; library.notif_position=d.notif_position or "TopRight"; notifications.enabled=library.notifications_on end end) end
function library:set_auto_load(n) library.auto_load_config_name=n; library:save_library_settings() end
function library:clear_auto_load() library.auto_load_config_name=nil; library:save_library_settings() end
function library:toggle_notifications(e) library.notifications_on=e; notifications.enabled=e; library:save_library_settings() end

function library:do_auto_load()
    library:load_library_settings()
    if library.auto_load_config_name then
        local p=library.directory.."/configs/"..library.auto_load_config_name..".cfg"
        pcall(function() if isfile(p) then task.spawn(function() task.wait(0.5); library:load_config(readfile(p)); if notifications.enabled then notifications:create_notification({name="Auto Load",info="Loaded: "..library.auto_load_config_name}) end end) end end)
    end
end

local config_holder
function library:update_config_list() if not config_holder then return end; local l={}; pcall(function() for _,f in ipairs(listfiles(library.directory.."/configs")) do local n=f:match("([^/\\]+)%.cfg$"); if n then l[#l+1]=n end end end); if #l==0 then l={"No Configs"} end; config_holder.refresh_options(l) end
function library:get_config() local C={}; for f,v in pairs(flags) do if type(v)=="table" and v.key then C[f]={active=v.active,mode=v.mode,key=tostring(v.key)} elseif type(v)=="table" and v["Transparency"] and v["Color"] then C[f]={Transparency=v["Transparency"],Color=v["Color"]:ToHex()} else C[f]=v end end; return http_service:JSONEncode(C) end
function library:load_config(j) local ok,c=pcall(function() return http_service:JSONDecode(j) end); if not ok then return end; for f,v in pairs(c) do local s=config_flags[f]; if f=="config_name_list" then continue end; if s then pcall(function() if type(v)=="table" and v["Transparency"] and v["Color"] then s(hex(v["Color"]),v["Transparency"]) elseif type(v)=="table" and v["active"] then s(v) else s(v) end end) end end end

function library:setup_click_outside()
    library:connection(uis.InputBegan, function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 then
            task.defer(function()
                local mp = uis:GetMouseLocation()
                for _, popup in pairs(library.popups) do
                    if popup.holder and popup.holder.Visible then
                        local pos,size = popup.holder.AbsolutePosition, popup.holder.AbsoluteSize
                        local inside = mp.X>=pos.X and mp.X<=pos.X+size.X and mp.Y>=pos.Y and mp.Y<=pos.Y+size.Y
                        if not inside then
                            local t_inside = false
                            if popup.trigger then
                                local tp,ts = popup.trigger.AbsolutePosition, popup.trigger.AbsoluteSize
                                t_inside = mp.X>=tp.X and mp.X<=tp.X+ts.X and mp.Y>=tp.Y and mp.Y<=tp.Y+ts.Y
                            end
                            if not t_inside then popup.holder.Visible=false; popup.is_open=false end
                        end
                    end
                end
            end)
        end
    end)
end

function library:update_keybind_list()
    if not library.keybind_list_elements then return end
    for _, child in pairs(library.keybind_list_elements:GetChildren()) do if child:IsA("Frame") then child:Destroy() end end
    local has = false
    for _, bd in pairs(library.active_keybinds) do
        if bd.active and bd.name and bd.key_text~="None" then
            has = true
            local row = library:create("Frame",{Parent=library.keybind_list_elements,BackgroundTransparency=1,Size=dim2(1,0,0,16)})
            library:create("TextLabel",{FontFace=fonts.regular,Text=bd.name,TextColor3=palette.text,Parent=row,Size=dim2(1,-50,1,0),BackgroundTransparency=1,TextXAlignment=Enum.TextXAlignment.Left,TextSize=11})
