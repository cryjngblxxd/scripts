-- SLIDER (ImGui slider style)
-- ══════════════════════════════════════════════════════════════
function library:slider(o)
    local cfg = {
        name = o.name or "Slider",
        suffix = o.suffix or "",
        flag = o.flag or library:next_flag(),
        callback = o.callback or function() end,
        min = o.min or 0, max = o.max or 100,
        intervals = o.interval or 1,
        default = o.default or 10,
        value = o.default or 10,
        dragging = false,
        items = {},
    }
    flags[cfg.flag] = cfg.default
    local items = cfg.items

    items["slider_object"] = library:create("TextButton", {
        Text = "", Parent = self.items["elements"], BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 32), BorderSizePixel = 0, ZIndex = 3,
    })

    -- Label
    items["name"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = cfg.name, Parent = items["slider_object"],
        Size = dim2(0.6, 0, 0, 14), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0,
        TextSize = 12, ZIndex = 3,
    })

    -- Value display
    items["value"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text_dim,
        Text = tostring(cfg.default) .. cfg.suffix, Parent = items["slider_object"],
        Size = dim2(0.4, 0, 0, 14), Position = dim2(0.6, 0, 0, 0),
        BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Right,
        BorderSizePixel = 0, TextSize = 11, ZIndex = 3,
    })

    -- Track
    items["track"] = library:create("TextButton", {
        Text = "", AutoButtonColor = false, Parent = items["slider_object"],
        Position = dim2(0, 0, 0, 18), Size = dim2(1, 0, 0, 14),
        BorderSizePixel = 0, BackgroundColor3 = palette.frame_bg, ZIndex = 3,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["track"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Fill
    items["fill"] = library:create("Frame", {
        Parent = items["track"], Size = dim2(0.5, 0, 1, 0),
        BorderSizePixel = 0, BackgroundColor3 = themes.preset.accent,
        BackgroundTransparency = 0.6, ZIndex = 4,
    })
    library:apply_theme(items["fill"], "accent", "BackgroundColor3")

    -- Value overlay text (centered in track, imgui style)
    items["track_text"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = tostring(cfg.default) .. cfg.suffix, Parent = items["track"],
        Size = dim2(1, 0, 1, 0), BackgroundTransparency = 1,
        TextSize = 10, ZIndex = 5,
    })

    function cfg.set(v)
        cfg.value = clamp(library:round(v, cfg.intervals), cfg.min, cfg.max)
        local ratio = (cfg.value - cfg.min) / (cfg.max - cfg.min)
        items["fill"].Size = dim2(ratio, 0, 1, 0)
        local txt = tostring(cfg.value) .. cfg.suffix
        items["value"].Text = txt
        items["track_text"].Text = txt
        flags[cfg.flag] = cfg.value
        cfg.callback(cfg.value)
    end

    items["track"].MouseButton1Down:Connect(function()
        cfg.dragging = true
        library:tween(items["fill"], {BackgroundTransparency = 0.4}, 0.06)
    end)

    library:connection(uis.InputChanged, function(i)
        if cfg.dragging and i.UserInputType == Enum.UserInputType.MouseMovement then
            local ratio = clamp((i.Position.X - items["track"].AbsolutePosition.X) / items["track"].AbsoluteSize.X, 0, 1)
            cfg.set(cfg.min + (cfg.max - cfg.min) * ratio)
        end
    end)

    library:connection(uis.InputEnded, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            cfg.dragging = false
            library:tween(items["fill"], {BackgroundTransparency = 0.6}, 0.06)
        end
    end)

    cfg.set(cfg.default)
    config_flags[cfg.flag] = cfg.set
    return setmetatable(cfg, library)
end

