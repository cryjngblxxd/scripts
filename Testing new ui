-- Config management
-- ══════════════════════════════════════════════════════════════
local config_holder

function library:update_config_list()
    if not config_holder then return end
    local l = {}
    pcall(function()
        for _, f in ipairs(listfiles(library.directory .. "/configs")) do
            local n = f:match("([^/\\]+)%.cfg$")
            if n then l[#l + 1] = n end
        end
    end)
    if #l == 0 then l = {"No Configs"} end
    config_holder.refresh_options(l)
end

function library:get_config()
    local C = {}
    for f, v in pairs(flags) do
        if type(v) == "table" and v.key then
            C[f] = {active = v.active, mode = v.mode, key = tostring(v.key)}
        elseif type(v) == "table" and v["Transparency"] and v["Color"] then
            C[f] = {Transparency = v["Transparency"], Color = v["Color"]:ToHex()}
        else
            C[f] = v
        end
    end
    return http_service:JSONEncode(C)
end

function library:load_config(j)
    local ok, c = pcall(function() return http_service:JSONDecode(j) end)
    if not ok then return end
    for f, v in pairs(c) do
        local s = config_flags[f]
        if f == "config_name_list" then continue end
        if s then
            pcall(function()
                if type(v) == "table" and v["Transparency"] and v["Color"] then
                    s(hex(v["Color"]), v["Transparency"])
                elseif type(v) == "table" and v["active"] then
                    s(v)
                else
                    s(v)
                end
            end)
        end
    end
end

-- ══════════════════════════════════════════════════════════════
-- Click outside to close popups
-- ══════════════════════════════════════════════════════════════
function library:setup_click_outside()
    library:connection(uis.InputBegan, function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            local open = library.current_open
            if not open then return end
            task.defer(function()
                local holder = nil
                pcall(function()
                    if open.items then
                        holder = open.items["colorpicker_holder"] or open.items["dropdown_holder"] or open.items["mode_popup"]
                    end
                end)
                if not holder then return end
                if not holder.Visible then return end
                local mp = uis:GetMouseLocation()
                local pos, size = holder.AbsolutePosition, holder.AbsoluteSize
                local inside = mp.X >= pos.X and mp.X <= pos.X + size.X and mp.Y >= pos.Y and mp.Y <= pos.Y + size.Y
                if inside then return end
                local trigger = nil
                pcall(function()
                    trigger = open.items["colorpicker"] or open.items["dropdown_btn"] or open.items["keybind_btn"]
                end)
                if trigger then
                    local tp, ts = trigger.AbsolutePosition, trigger.AbsoluteSize
                    if mp.X >= tp.X and mp.X <= tp.X + ts.X and mp.Y >= tp.Y and mp.Y <= tp.Y + ts.Y then return end
                end
                library:close_element()
            end)
        end
    end)
end

