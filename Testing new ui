-- DROPDOWN (ImGui combo style)
-- ══════════════════════════════════════════════════════════════
function library:dropdown(o)
    local cfg = {
        name = o.name or "Dropdown",
        flag = o.flag or library:next_flag(),
        options = o.items or {"Option 1"},
        callback = o.callback or function() end,
        multi = o.multi or false,
        open = false,
        option_instances = {},
        multi_items = {},
        items = {},
        y_size = 0,
    }
    cfg.default = o.default or (cfg.multi and {cfg.options[1]}) or cfg.options[1] or "None"
    flags[cfg.flag] = cfg.default
    local items = cfg.items

    items["dropdown_object"] = library:create("TextButton", {
        Text = "", Parent = self.items["elements"], BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 36), BorderSizePixel = 0, ZIndex = 3,
    })

    -- Label
    items["name"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = cfg.name, Parent = items["dropdown_object"],
        Size = dim2(1, 0, 0, 14), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0,
        TextSize = 12, ZIndex = 3,
    })

    -- Combo button
    items["dropdown_btn"] = library:create("TextButton", {
        Text = "", AutoButtonColor = false, Parent = items["dropdown_object"],
        Position = dim2(0, 0, 0, 16), Size = dim2(1, 0, 0, 20),
        BorderSizePixel = 0, BackgroundColor3 = palette.frame_bg, ZIndex = 3,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["dropdown_btn"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Selected text
    items["selected_text"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = "", Parent = items["dropdown_btn"],
        Size = dim2(1, -22, 1, 0), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left,
        TextTruncate = Enum.TextTruncate.AtEnd, TextSize = 11,
        BorderSizePixel = 0, ZIndex = 3,
    })
    library:create("UIPadding", {Parent = items["selected_text"], PaddingLeft = dim(0, 6)})

    -- Arrow
    items["arrow"] = library:create("TextLabel", {
        FontFace = fonts.regular, Text = "▼", TextColor3 = palette.text_dim,
        Parent = items["dropdown_btn"], AnchorPoint = vec2(1, 0.5),
        Position = dim2(1, -6, 0.5, 0), Size = dim2(0, 10, 0, 10),
        BackgroundTransparency = 1, TextSize = 8, ZIndex = 3,
    })

    -- Popup holder
    items["dropdown_holder"] = library:create("Frame", {
        Parent = library["items"], Visible = false,
        Size = dim2(0, 0, 0, 0), BorderSizePixel = 0, ZIndex = 20,
        BackgroundTransparency = 1,
    })
    items["popup"] = library:create("Frame", {
        Parent = items["dropdown_holder"], Size = dim2(1, 0, 1, 0),
        ClipsDescendants = true, BorderSizePixel = 0,
        BackgroundColor3 = palette.bg_popup, ZIndex = 20,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["popup"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    library:create("UIPadding", {
        PaddingBottom = dim(0, 3), PaddingTop = dim(0, 3),
        PaddingLeft = dim(0, 3), PaddingRight = dim(0, 3),
        Parent = items["popup"],
    })
    library:create("UIListLayout", {
        Parent = items["popup"], Padding = dim(0, 1),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    function cfg.render_option(t)
        local b = library:create("TextButton", {
            FontFace = fonts.regular, TextColor3 = palette.text_dim,
            Text = t, Parent = items["popup"],
            Size = dim2(1, 0, 0, 18), BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0,
            AutoButtonColor = false, TextSize = 11, ZIndex = 20,
        })
        library:create("UIPadding", {Parent = b, PaddingLeft = dim(0, 6)})
        return b
    end

    function cfg.set_visible(b)
        items["dropdown_holder"].Visible = b
        items["arrow"].Text = b and "▲" or "▼"
        if b then
            items["dropdown_holder"].Size = dim_offset(
                items["dropdown_btn"].AbsoluteSize.X,
                math.min(cfg.y_size, 200)
            )
            items["dropdown_holder"].Position = dim2(
                0, items["dropdown_btn"].AbsolutePosition.X,
                0, items["dropdown_btn"].AbsolutePosition.Y + items["dropdown_btn"].AbsoluteSize.Y + 1
            )
        end
        library:close_element(cfg)
    end

    function cfg.set(v)
        local s = {}
        local isT = type(v) == "table"
        for _, o in pairs(cfg.option_instances) do
            if o.Text == v or (isT and find(v, o.Text)) then
                insert(s, o.Text)
                cfg.multi_items = s
                o.TextColor3 = themes.preset.accent
                o.BackgroundTransparency = 0.9
                o.BackgroundColor3 = themes.preset.accent
            else
                o.TextColor3 = palette.text_dim
                o.BackgroundTransparency = 1
            end
        end
        items["selected_text"].Text = isT and concat(s, ", ") or s[1] or ""
        flags[cfg.flag] = isT and s or s[1]
        cfg.callback(flags[cfg.flag])
    end

    function cfg.refresh_options(l)
        cfg.y_size = 0
        for _, o in pairs(cfg.option_instances) do o:Destroy() end
        cfg.option_instances = {}
        for _, opt in ipairs(l) do
            local b = cfg.render_option(opt)
            cfg.y_size = cfg.y_size + 19
            insert(cfg.option_instances, b)
            b.MouseButton1Down:Connect(function()
                if cfg.multi then
                    local si = find(cfg.multi_items, b.Text)
                    if si then remove(cfg.multi_items, si) else insert(cfg.multi_items, b.Text) end
                    cfg.set(cfg.multi_items)
                else
                    cfg.set_visible(false); cfg.open = false; cfg.set(b.Text)
                end
            end)
            b.MouseEnter:Connect(function()
                if b.TextColor3 ~= themes.preset.accent then
                    library:tween(b, {BackgroundTransparency = 0.92, BackgroundColor3 = palette.header_hover}, 0.06)
                end
            end)
            b.MouseLeave:Connect(function()
                if b.TextColor3 ~= themes.preset.accent then
                    library:tween(b, {BackgroundTransparency = 1}, 0.06)
                end
            end)
        end
        cfg.y_size = cfg.y_size + 6
    end

    items["dropdown_btn"].MouseButton1Click:Connect(function()
        cfg.open = not cfg.open; cfg.set_visible(cfg.open)
    end)
    items["dropdown_btn"].MouseEnter:Connect(function()
        library:tween(items["dropdown_btn"], {BackgroundColor3 = palette.frame_bg_hover}, 0.06)
    end)
    items["dropdown_btn"].MouseLeave:Connect(function()
        library:tween(items["dropdown_btn"], {BackgroundColor3 = palette.frame_bg}, 0.06)
    end)

    config_flags[cfg.flag] = cfg.set
    cfg.refresh_options(cfg.options)
    cfg.set(cfg.default)
    return setmetatable(cfg, library)
end

