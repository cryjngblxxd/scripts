-- TAB
-- ══════════════════════════════════════════════════════════════
function library:tab(properties)
    local cfg = {
        name = properties.name or "Tab",
        pages = {},
        current_multi = nil,
        items = {},
    }
    local items = cfg.items

    -- Tab content holder
    items["tab_content"] = library:create("Frame", {
        Parent = library.cache, Visible = false, BackgroundTransparency = 1,
        Size = dim2(1, 0, 1, 0), BorderSizePixel = 0, ZIndex = 3,
    })

    -- Tab button
    items["button"] = library:create("TextButton", {
        FontFace = fonts.regular, Text = cfg.name,
        Parent = self.items["tab_buttons"], AutoButtonColor = false,
        Size = dim2(0, 0, 1, -1), BorderSizePixel = 0,
        BackgroundColor3 = palette.tab, BackgroundTransparency = 0,
        TextColor3 = palette.text_dim, TextSize = 11,
        AutomaticSize = Enum.AutomaticSize.X, ZIndex = 3,
    })
    library:create("UIPadding", {Parent = items["button"], PaddingLeft = dim(0, 12), PaddingRight = dim(0, 12)})

    -- Active indicator (bottom line on tab button)
    items["indicator"] = library:create("Frame", {
        Parent = items["button"], AnchorPoint = vec2(0.5, 1),
        Position = dim2(0.5, 0, 1, 0), Size = dim2(1, 0, 0, 2),
        BorderSizePixel = 0, BackgroundColor3 = themes.preset.accent,
        BackgroundTransparency = 1, ZIndex = 5,
    })
    library:apply_theme(items["indicator"], "accent", "BackgroundColor3")

    -- Right border on tab
    library:create("Frame", {
        Parent = items["button"], AnchorPoint = vec2(1, 0),
        Position = dim2(1, 0, 0, 2), Size = dim2(0, 1, 1, -4),
        BorderSizePixel = 0, BackgroundColor3 = palette.border, ZIndex = 4,
    })

    -- Two-column layout inside tab content
    items["columns_holder"] = library:create("Frame", {
        Parent = items["tab_content"], BackgroundTransparency = 1,
        Size = dim2(1, -12, 1, -6), Position = dim2(0, 6, 0, 3),
        BorderSizePixel = 0, ZIndex = 3,
    })
    library:create("UIListLayout", {
        Parent = items["columns_holder"],
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalFlex = Enum.UIFlexAlignment.Fill,
        VerticalFlex = Enum.UIFlexAlignment.Fill,
        Padding = dim(0, 6), SortOrder = Enum.SortOrder.LayoutOrder,
    })

    -- Tab page data (single page per tab for imgui-style)
    local data = {items = items, parent = items["columns_holder"]}

    function cfg.open_tab()
        local st = self.selected_tab
        if st then
            library:tween(st.items["button"], {BackgroundColor3 = palette.tab}, 0.1)
            library:tween(st.items["button"], {TextColor3 = palette.text_dim}, 0.1)
            st.items["indicator"].BackgroundTransparency = 1
            st.items["tab_content"].Visible = false
            st.items["tab_content"].Parent = library.cache
        end
        library:tween(items["button"], {BackgroundColor3 = palette.bg}, 0.1)
        library:tween(items["button"], {TextColor3 = palette.text}, 0.1)
        items["indicator"].BackgroundTransparency = 0
        items["tab_content"].Visible = true
        items["tab_content"].Parent = self.items["content"]
        self.selected_tab = cfg
        library:close_element()
    end

    items["button"].MouseButton1Down:Connect(function() cfg.open_tab() end)
    items["button"].MouseEnter:Connect(function()
        if self.selected_tab ~= cfg then
            library:tween(items["button"], {BackgroundColor3 = palette.tab_hover}, 0.08)
        end
    end)
    items["button"].MouseLeave:Connect(function()
        if self.selected_tab ~= cfg then
            library:tween(items["button"], {BackgroundColor3 = palette.tab}, 0.08)
        end
    end)

    if not self.selected_tab then cfg.open_tab() end
    return setmetatable(data, library)
end

