-- SEPARATOR
-- ══════════════════════════════════════════════════════════════
function library:separator(p)
    local sep = library:create("Frame", {
        Parent = self.items["elements"], Size = dim2(1, 0, 0, 8),
        BackgroundTransparency = 1, BorderSizePixel = 0, ZIndex = 3,
    })
    local line = library:create("Frame", {
        Parent = sep, AnchorPoint = vec2(0, 0.5),
        Position = dim2(0, 0, 0.5, 0), Size = dim2(1, 0, 0, 1),
        BorderSizePixel = 0, BackgroundColor3 = palette.separator, ZIndex = 3,
    })
    if p and p.name and p.name ~= "" then
        local lbl = library:create("TextLabel", {
            FontFace = fonts.regular, TextColor3 = palette.text_disabled,
            Text = string.upper(p.name), Parent = sep,
            Size = dim2(0, 0, 1, 0), Position = dim2(0, 0, 0, 0),
            BackgroundTransparency = 1, AutomaticSize = Enum.AutomaticSize.X,
            TextSize = 9, ZIndex = 4, BackgroundColor3 = palette.bg_child,
        })
        library:create("UIPadding", {Parent = lbl, PaddingLeft = dim(0, 4), PaddingRight = dim(0, 4)})
    end
    return setmetatable({items = {separator = sep}}, library)
end

-- ══════════════════════════════════════════════════════════════
-- COLORPICKER (ImGui style)
-- ══════════════════════════════════════════════════════════════
function library:colorpicker(o)
    local cfg = {
        name = o.name or "Color",
        flag = o.flag or library:next_flag(),
        color = o.color or color(1, 1, 1),
        alpha = o.alpha and 1 - o.alpha or 0,
        open = false,
        callback = o.callback or function() end,
        items = {},
    }
    local ds, dh, da = false, false, false
    local h, s, v = cfg.color:ToHSV()
    local a = cfg.alpha
    flags[cfg.flag] = {Color = cfg.color, Transparency = cfg.alpha}

    local label
    if not self.items.right_components then
        label = self:label({name = cfg.name})
    end
    local items = cfg.items

    -- Color preview button
    items["colorpicker"] = library:create("TextButton", {
        Text = "", AutoButtonColor = false,
        Parent = label and label.items.right_components or self.items["right_components"],
        Size = dim2(0, 22, 0, 14), BorderSizePixel = 0,
        BackgroundColor3 = cfg.color, ZIndex = 3,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["colorpicker"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Picker popup
    items["colorpicker_holder"] = library:create("Frame", {
        Parent = library["items"], Size = dim2(0, 200, 0, 195),
        BorderSizePixel = 0, Visible = false,
        BackgroundColor3 = palette.bg_popup, ZIndex = 25,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["colorpicker_holder"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Title
    library:create("TextLabel", {
        FontFace = fonts.bold, Text = cfg.name, TextColor3 = palette.text,
        Parent = items["colorpicker_holder"], Size = dim2(1, 0, 0, 20),
        Position = dim2(0, 8, 0, 4), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left, TextSize = 10, ZIndex = 25,
    })

    -- SV square
    items["sat_holder"] = library:create("Frame", {
        Parent = items["colorpicker_holder"], Position = dim2(0, 8, 0, 26),
        Size = dim2(1, -16, 0, 120), BorderSizePixel = 0,
        BackgroundColor3 = hsv(h, 1, 1), ZIndex = 25,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["sat_holder"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    items["sat"] = library:create("TextButton", {
        Parent = items["sat_holder"], Size = dim2(1, 0, 1, 0),
        Text = "", AutoButtonColor = false, ZIndex = 26,
        BorderSizePixel = 0, BackgroundColor3 = rgb(255, 255, 255),
    })
    library:create("UIGradient", {
        Rotation = 270, Transparency = numseq{numkey(0, 0), numkey(1, 1)},
        Parent = items["sat"], Color = rgbseq{rgbkey(0, rgb(0, 0, 0)), rgbkey(1, rgb(0, 0, 0))},
    })
    items["val"] = library:create("Frame", {
        Parent = items["sat_holder"], Size = dim2(1, 0, 1, 0),
        BorderSizePixel = 0, BackgroundColor3 = rgb(255, 255, 255), ZIndex = 25,
    })
    library:create("UIGradient", {Parent = items["val"], Transparency = numseq{numkey(0, 0), numkey(1, 1)}})

    -- SV pointer (crosshair style)
    items["svp"] = library:create("Frame", {
        AnchorPoint = vec2(0.5, 0.5), Parent = items["sat_holder"],
        Position = dim2(s, 0, 1 - v, 0), Size = dim2(0, 8, 0, 8),
        ZIndex = 27, BorderSizePixel = 0, BackgroundTransparency = 1,
    })
    library:create("UIStroke", {
        Color = rgb(255, 255, 255), Parent = items["svp"],
        Thickness = 1.5, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Hue bar
    items["hue_bar"] = library:create("TextButton", {
        Parent = items["colorpicker_holder"], Position = dim2(0, 8, 1, -38),
        Size = dim2(1, -16, 0, 10), BorderSizePixel = 0,
        BackgroundColor3 = rgb(255, 255, 255), AutoButtonColor = false,
        Text = "", ZIndex = 25,
    })
    library:create("UIGradient", {
        Color = rgbseq{
            rgbkey(0, rgb(255, 0, 0)), rgbkey(0.17, rgb(255, 255, 0)),
            rgbkey(0.33, rgb(0, 255, 0)), rgbkey(0.5, rgb(0, 255, 255)),
            rgbkey(0.67, rgb(0, 0, 255)), rgbkey(0.83, rgb(255, 0, 255)),
            rgbkey(1, rgb(255, 0, 0)),
        }, Parent = items["hue_bar"],
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["hue_bar"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    items["hp"] = library:create("Frame", {
        AnchorPoint = vec2(0.5, 0.5), Parent = items["hue_bar"],
        Position = dim2(h, 0, 0.5, 0), Size = dim2(0, 4, 0, 14),
        ZIndex = 26, BorderSizePixel = 0, BackgroundColor3 = rgb(255, 255, 255),
    })

    -- Alpha bar
    items["alpha_bar"] = library:create("TextButton", {
        Parent = items["colorpicker_holder"], Position = dim2(0, 8, 1, -22),
        Size = dim2(1, -16, 0, 10), BorderSizePixel = 0,
        BackgroundColor3 = palette.frame_bg, AutoButtonColor = false,
        Text = "", ZIndex = 25,
    })
    library:create("UIGradient", {
        Color = rgbseq{rgbkey(0, rgb(0, 0, 0)), rgbkey(1, rgb(255, 255, 255))},
        Parent = items["alpha_bar"],
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["alpha_bar"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    items["ap"] = library:create("Frame", {
        AnchorPoint = vec2(0.5, 0.5), Parent = items["alpha_bar"],
        Position = dim2(1 - a, 0, 0.5, 0), Size = dim2(0, 4, 0, 14),
        ZIndex = 26, BorderSizePixel = 0, BackgroundColor3 = rgb(255, 255, 255),
    })

    function cfg.set_visible(b)
        items["colorpicker_holder"].Visible = b
        if b then
            items["colorpicker_holder"].Position = dim_offset(
                items["colorpicker"].AbsolutePosition.X - 178,
                items["colorpicker"].AbsolutePosition.Y + items["colorpicker"].AbsoluteSize.Y + 4
            )
        end
        library:close_element(cfg)
    end

    function cfg.set(nc, av)
        if type(nc) == "boolean" then return end
        if nc then h, s, v = nc:ToHSV() end
        if av then a = av end
        local C = hsv(h, s, v)
        items["hp"].Position = dim2(h, 0, 0.5, 0)
        items["ap"].Position = dim2(1 - a, 0, 0.5, 0)
        items["svp"].Position = dim2(s, 0, 1 - v, 0)
        items["colorpicker"].BackgroundColor3 = C
        items["sat_holder"].BackgroundColor3 = hsv(h, 1, 1)
        flags[cfg.flag] = {Color = C, Transparency = a}
        cfg.callback(C, a)
    end

    function cfg.update_color()
        local mp = uis:GetMouseLocation()
        local ox = vec2(mp.X, mp.Y - gui_offset)
        if ds then
            s = clamp((ox.X - items["sat"].AbsolutePosition.X) / items["sat"].AbsoluteSize.X, 0, 1)
            v = 1 - clamp((ox.Y - items["sat"].AbsolutePosition.Y) / items["sat"].AbsoluteSize.Y, 0, 1)
        elseif dh then
            h = clamp((ox.X - items["hue_bar"].AbsolutePosition.X) / items["hue_bar"].AbsoluteSize.X, 0, 1)
        elseif da then
            a = 1 - clamp((ox.X - items["alpha_bar"].AbsolutePosition.X) / items["alpha_bar"].AbsoluteSize.X, 0, 1)
        end
        cfg.set()
    end

    items["colorpicker"].MouseButton1Click:Connect(function()
        cfg.open = not cfg.open; cfg.set_visible(cfg.open)
    end)
    uis.InputChanged:Connect(function(i)
        if (ds or dh or da) and i.UserInputType == Enum.UserInputType.MouseMovement then
            cfg.update_color()
        end
    end)
    library:connection(uis.InputEnded, function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            ds = false; dh = false; da = false
        end
    end)
    items["alpha_bar"].MouseButton1Down:Connect(function() da = true end)
    items["hue_bar"].MouseButton1Down:Connect(function() dh = true end)
    items["sat"].MouseButton1Down:Connect(function() ds = true end)

    cfg.set(cfg.color, cfg.alpha)
    config_flags[cfg.flag] = cfg.set
    return setmetatable(cfg, library)
end

-- ══════════════════════════════════════════════════════════════
-- TEXTBOX (ImGui input text style)
-- ══════════════════════════════════════════════════════════════
function library:textbox(o)
    local cfg = {
        name = o.name or "TextBox",
        placeholder = o.placeholder or "...",
        default = o.default or "",
        flag = o.flag or library:next_flag(),
        callback = o.callback or function() end,
        items = {},
    }
    flags[cfg.flag] = cfg.default
    local items = cfg.items

    items["textbox"] = library:create("Frame", {
        Parent = self.items["elements"], BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 34), BorderSizePixel = 0, ZIndex = 3,
    })
    items["name"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = cfg.name, Parent = items["textbox"],
        Size = dim2(1, 0, 0, 14), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0,
        TextSize = 12, ZIndex = 3,
    })
    items["input"] = library:create("TextBox", {
        FontFace = fonts.regular, Text = cfg.default,
        Parent = items["textbox"], TextTruncate = Enum.TextTruncate.AtEnd,
        BorderSizePixel = 0, PlaceholderText = cfg.placeholder,
        PlaceholderColor3 = palette.text_disabled, CursorPosition = -1,
        ClearTextOnFocus = false, TextSize = 11, TextColor3 = palette.text,
        TextXAlignment = Enum.TextXAlignment.Left,
        Position = dim2(0, 0, 0, 16), Size = dim2(1, 0, 0, 18),
        BackgroundColor3 = palette.frame_bg, ZIndex = 3,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["input"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    library:create("UIPadding", {Parent = items["input"], PaddingLeft = dim(0, 6), PaddingRight = dim(0, 6)})

    function cfg.set(t) flags[cfg.flag] = t; items["input"].Text = t; cfg.callback(t) end
    items["input"]:GetPropertyChangedSignal("Text"):Connect(function() cfg.set(items["input"].Text) end)
    items["input"].Focused:Connect(function()
        local stroke = items["input"]:FindFirstChildWhichIsA("UIStroke")
        if stroke then library:tween(stroke, {Color = themes.preset.accent}, 0.06) end
    end)
    items["input"].FocusLost:Connect(function()
        local stroke = items["input"]:FindFirstChildWhichIsA("UIStroke")
        if stroke then library:tween(stroke, {Color = palette.border}, 0.06) end
    end)
    config_flags[cfg.flag] = cfg.set
    return setmetatable(cfg, library)
end

-- ══════════════════════════════════════════════════════════════
-- KEYBIND
-- ══════════════════════════════════════════════════════════════
function library:keybind(o)
    local cfg = {
        flag = o.flag or library:next_flag(),
        callback = o.callback or function() end,
        name = o.name or nil,
        key = o.key or nil,
        mode = o.mode or "Toggle",
        active = o.default or false,
        open = false,
        binding = nil,
        hold_instances = {},
        items = {},
    }
    flags[cfg.flag] = {mode = cfg.mode, key = cfg.key, active = cfg.active}
    local items = cfg.items

    items["keybind_element"] = library:create("TextButton", {
        Text = "", Parent = self.items["elements"], BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 18), BorderSizePixel = 0, ZIndex = 3,
    })
    items["name"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = cfg.name or "Keybind", Parent = items["keybind_element"],
        Size = dim2(1, -80, 1, 0), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0,
        TextSize = 12, ZIndex = 3,
    })
    items["right_components"] = library:create("Frame", {
        Parent = items["keybind_element"], Position = dim2(1, 0, 0, 0),
        Size = dim2(0, 0, 1, 0), BorderSizePixel = 0,
        BackgroundTransparency = 1, ZIndex = 3,
    })
    library:create("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        Parent = items["right_components"], Padding = dim(0, 4),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    -- Keybind button
    items["keybind_btn"] = library:create("TextButton", {
        FontFace = fonts.regular, Text = "", Parent = items["right_components"],
        AutoButtonColor = false, Size = dim2(0, 0, 0, 18),
        BorderSizePixel = 0, AutomaticSize = Enum.AutomaticSize.X,
        BackgroundColor3 = palette.frame_bg, ZIndex = 3,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["keybind_btn"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    items["key"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text_dim,
        Text = "None", Parent = items["keybind_btn"],
        Size = dim2(1, 0, 1, 0), BackgroundTransparency = 1,
        TextXAlignment = Enum.TextXAlignment.Center, BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.X, TextSize = 10, ZIndex = 3,
    })
    library:create("UIPadding", {Parent = items["key"], PaddingRight = dim(0, 6), PaddingLeft = dim(0, 6)})

    -- Mode popup
    items["mode_popup"] = library:create("Frame", {
        Parent = library["items"], Size = dim2(0, 75, 0, 0),
        BorderSizePixel = 0, ZIndex = 30, Visible = false, BackgroundTransparency = 1,
    })
    local mode_inner = library:create("Frame", {
        Parent = items["mode_popup"], Size = dim2(1, 0, 1, 0),
        ClipsDescendants = true, BorderSizePixel = 0,
        BackgroundColor3 = palette.bg_popup, ZIndex = 30,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = mode_inner,
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })
    library:create("UIPadding", {
        PaddingBottom = dim(0, 3), PaddingTop = dim(0, 3),
        PaddingLeft = dim(0, 3), PaddingRight = dim(0, 3),
        Parent = mode_inner,
    })
    library:create("UIListLayout", {Parent = mode_inner, Padding = dim(0, 1), SortOrder = Enum.SortOrder.LayoutOrder})

    local modes = {"Toggle", "Hold", "Always"}
    local popup_height = 6
    for _, option in ipairs(modes) do
        local mb = library:create("TextButton", {
            FontFace = fonts.regular, TextColor3 = palette.text_dim,
            Text = option, Parent = mode_inner, Size = dim2(1, 0, 0, 16),
            BackgroundTransparency = 1, AutoButtonColor = false,
            TextXAlignment = Enum.TextXAlignment.Left, BorderSizePixel = 0,
            TextSize = 10, ZIndex = 30,
        })
        cfg.hold_instances[option] = mb
        popup_height = popup_height + 17
        library:create("UIPadding", {Parent = mb, PaddingLeft = dim(0, 4)})
        mb.MouseButton1Click:Connect(function()
            cfg.set(option); cfg.set_visible(false); cfg.open = false
        end)
        mb.MouseEnter:Connect(function()
            if mb.TextColor3 ~= themes.preset.accent then
                library:tween(mb, {TextColor3 = palette.text}, 0.06)
            end
        end)
        mb.MouseLeave:Connect(function()
            if mb.TextColor3 ~= themes.preset.accent then
                library:tween(mb, {TextColor3 = palette.text_dim}, 0.06)
            end
        end)
    end
    cfg.popup_height = popup_height

    function cfg.modify_mode_color(p)
        for _, v in pairs(cfg.hold_instances) do v.TextColor3 = palette.text_dim end
        if cfg.hold_instances[p] then cfg.hold_instances[p].TextColor3 = themes.preset.accent end
    end

    function cfg.set_mode(m)
        cfg.mode = m
        if m == "Always" then cfg.set(true) elseif m == "Hold" then cfg.set(false) end
        flags[cfg.flag]["mode"] = m
        cfg.modify_mode_color(m)
    end

    function cfg.set(input)
        if type(input) == "boolean" then
            cfg.active = input
            if cfg.mode == "Always" then cfg.active = true end
        elseif tostring(input):find("Enum") then
            input = input.Name == "Escape" and "NONE" or input
            cfg.key = input or "NONE"
        elseif find({"Toggle", "Hold", "Always"}, input) then
            if input == "Always" then cfg.active = true end
            cfg.mode = input; cfg.set_mode(cfg.mode)
        elseif type(input) == "table" then
            if type(input.key) == "string" and input.key ~= "NONE" then
                pcall(function() input.key = library:convert_enum(input.key) end)
            end
            if input.key == Enum.KeyCode.Escape then input.key = "NONE" end
            cfg.key = input.key or "NONE"
            cfg.mode = input.mode or "Toggle"
            if input.active then cfg.active = input.active end
            cfg.set_mode(cfg.mode)
        end
        cfg.callback(cfg.active)
        local text = "None"
        if cfg.key and tostring(cfg.key) ~= "Enums" and cfg.key ~= "NONE" then
            text = keys[cfg.key] or tostring(cfg.key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
        end
        items["key"].Text = text
        flags[cfg.flag] = {mode = cfg.mode, key = cfg.key, active = cfg.active}
        library.active_keybinds[cfg.flag] = {
            name = cfg.name or "Keybind", key_text = text,
            active = cfg.active, mode = cfg.mode,
        }
        pcall(function() library:update_keybind_list() end)
    end

    function cfg.set_visible(bool)
        if bool then
            local kp = items["keybind_btn"].AbsolutePosition
            local ks = items["keybind_btn"].AbsoluteSize
            items["mode_popup"].Position = dim_offset(kp.X, kp.Y + ks.Y + 2)
            items["mode_popup"].Size = dim_offset(math.max(ks.X, 75), cfg.popup_height)
            items["mode_popup"].Visible = true
        else
            items["mode_popup"].Visible = false
        end
        library:close_element(cfg)
    end

    items["keybind_btn"].MouseButton1Down:Connect(function()
        task.wait()
        items["key"].Text = "..."
        cfg.binding = library:connection(uis.InputBegan, function(kc)
            cfg.set(kc.KeyCode ~= Enum.KeyCode.Unknown and kc.KeyCode or kc.UserInputType)
            cfg.binding:Disconnect()
            cfg.binding = nil
        end)
    end)
    items["keybind_btn"].MouseButton2Down:Connect(function()
        cfg.open = not cfg.open; cfg.set_visible(cfg.open)
    end)

    library:connection(uis.InputBegan, function(input, ge)
        if not ge then
            local sk = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
            if sk == cfg.key then
                if cfg.mode == "Toggle" then
                    cfg.active = not cfg.active; cfg.set(cfg.active)
                elseif cfg.mode == "Hold" then
                    cfg.set(true)
                end
            end
        end
    end)
    library:connection(uis.InputEnded, function(input, ge)
        if ge then return end
        local sk = input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType
        if sk == cfg.key and cfg.mode == "Hold" then cfg.set(false) end
    end)

    cfg.set({mode = cfg.mode, active = cfg.active, key = cfg.key})
    config_flags[cfg.flag] = cfg.set
    return setmetatable(cfg, library)
end

-- ══════════════════════════════════════════════════════════════
-- BUTTON (ImGui button style)
-- ══════════════════════════════════════════════════════════════
function library:button(o)
    local cfg = {
        name = o.name or "Button",
        callback = o.callback or function() end,
        items = {},
    }
    local items = cfg.items

    items["button_element"] = library:create("Frame", {
        Parent = self.items["elements"], BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 22), BorderSizePixel = 0, ZIndex = 3,
    })
    items["button"] = library:create("TextButton", {
        FontFace = fonts.regular, Text = cfg.name, AutoButtonColor = false,
        Parent = items["button_element"], Size = dim2(1, 0, 1, 0),
        BorderSizePixel = 0, TextSize = 11, TextColor3 = palette.text,
        BackgroundColor3 = palette.button, ZIndex = 3,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["button"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    items["button"].MouseEnter:Connect(function()
        library:tween(items["button"], {BackgroundColor3 = palette.button_hover}, 0.06)
    end)
    items["button"].MouseLeave:Connect(function()
        library:tween(items["button"], {BackgroundColor3 = palette.button}, 0.06)
    end)
    items["button"].MouseButton1Down:Connect(function()
        library:tween(items["button"], {BackgroundColor3 = palette.button_active}, 0.03)
    end)
    items["button"].MouseButton1Up:Connect(function()
        library:tween(items["button"], {BackgroundColor3 = palette.button_hover}, 0.06)
    end)
    items["button"].MouseButton1Click:Connect(function()
        cfg.callback()
        library:tween(items["button"], {BackgroundColor3 = themes.preset.accent}, 0.05)
        task.delay(0.2, function()
            library:tween(items["button"], {BackgroundColor3 = palette.button}, 0.15)
        end)
    end)
    return setmetatable(cfg, library)
end

-- ══════════════════════════════════════════════════════════════
-- LIST (selectable list - imgui ListBox style)
-- ══════════════════════════════════════════════════════════════
function library:list(p)
    local cfg = {
        items = {}, options = p.options or {"1"},
        flag = p.flag or library:next_flag(),
        callback = p.callback or function() end,
        data_store = {}, current_element = nil,
    }
    local items = cfg.items

    items["list"] = library:create("Frame", {
        Parent = self.items["elements"], BackgroundTransparency = 1,
        Size = dim2(1, 0, 0, 0), BorderSizePixel = 0,
        AutomaticSize = Enum.AutomaticSize.XY, ZIndex = 3,
    })
    library:create("UIListLayout", {
        Parent = items["list"], Padding = dim(0, 1),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    function cfg.refresh_options(opts)
        for _, o in pairs(cfg.data_store) do o:Destroy() end
        cfg.data_store = {}
        for _, od in ipairs(opts) do
            local b = library:create("TextButton", {
                FontFace = fonts.regular, Text = "", AutoButtonColor = false,
                Parent = items["list"], Size = dim2(1, 0, 0, 20),
                BorderSizePixel = 0, BackgroundColor3 = palette.frame_bg,
                BackgroundTransparency = 1, ZIndex = 3,
            })
            cfg.data_store[#cfg.data_store + 1] = b
            local n = library:create("TextLabel", {
                FontFace = fonts.regular, TextColor3 = palette.text_dim,
                Text = od, Parent = b, BackgroundTransparency = 1,
                Size = dim2(1, -10, 1, 0), Position = dim2(0, 8, 0, 0),
                BorderSizePixel = 0, TextXAlignment = Enum.TextXAlignment.Left,
                TextSize = 11, ZIndex = 3,
            })
            b.MouseButton1Click:Connect(function()
                if cfg.current_element and cfg.current_element ~= n then
                    library:tween(cfg.current_element, {TextColor3 = palette.text_dim}, 0.06)
                    local pb = cfg.current_element.Parent
                    if pb then library:tween(pb, {BackgroundTransparency = 1}, 0.06) end
                end
                flags[cfg.flag] = od
                cfg.callback(od)
                library:tween(n, {TextColor3 = palette.text}, 0.06)
                library:tween(b, {BackgroundTransparency = 0.85, BackgroundColor3 = themes.preset.accent}, 0.06)
                cfg.current_element = n
            end)
            b.MouseEnter:Connect(function()
                if cfg.current_element == n then return end
                library:tween(n, {TextColor3 = palette.text}, 0.06)
            end)
            b.MouseLeave:Connect(function()
                if cfg.current_element == n then return end
                library:tween(n, {TextColor3 = palette.text_dim}, 0.06)
            end)
        end
    end

    cfg.refresh_options(cfg.options)
    return setmetatable(cfg, library)
end

-- ══════════════════════════════════════════════════════════════
-- CONFIG INIT (settings tab)
-- ══════════════════════════════════════════════════════════════
function library:init_config(window)
    library:load_library_settings()

    local configs = window:tab({name = "Configs"})
    local settings = window:tab({name = "Settings"})

    -- ═══ CONFIGS ═══
    do
        local c1 = configs:column({})
        local s1 = c1:section({name = "Config List"})
        config_holder = s1:list({options = {"No Configs"}, callback = function() end, flag = "config_name_list"})
        library:update_config_list()

        local c2 = configs:column({})
        local s2 = c2:section({name = "Actions"})
        s2:textbox({name = "Config Name", flag = "config_name_text", placeholder = "name..."})
        s2:button({name = "Save", callback = function()
            local cn = flags["config_name_text"]
            if cn == "" then cn = flags["config_name_list"] end
            if cn and cn ~= "" and cn ~= "No Configs" then
                pcall(function() writefile(library.directory .. "/configs/" .. cn .. ".cfg", library:get_config()) end)
                library:update_config_list()
                if notifications.enabled then notifications:create_notification({name = "Config", info = "Saved: " .. cn}) end
            end
        end})
        s2:button({name = "Load", callback = function()
            local cn = flags["config_name_list"]
            if cn and cn ~= "No Configs" then
                pcall(function()
                    if isfile(library.directory .. "/configs/" .. cn .. ".cfg") then
                        library:load_config(readfile(library.directory .. "/configs/" .. cn .. ".cfg"))
                        library:update_config_list()
                        if notifications.enabled then notifications:create_notification({name = "Config", info = "Loaded: " .. cn}) end
                    end
                end)
            end
        end})
        s2:button({name = "Delete", callback = function()
            local cn = flags["config_name_list"]
            if cn and cn ~= "No Configs" then
                pcall(function()
                    if isfile(library.directory .. "/configs/" .. cn .. ".cfg") then
                        delfile(library.directory .. "/configs/" .. cn .. ".cfg")
                        library:update_config_list()
                        if notifications.enabled then notifications:create_notification({name = "Config", info = "Deleted: " .. cn}) end
                    end
                end)
            end
        end})
        s2:button({name = "Refresh", callback = function() library:update_config_list() end})

        local s3 = c2:section({name = "Auto Load"})
        local al = s3:label({name = "Current: " .. (library.auto_load_config_name or "None")})
        s3:button({name = "Set Auto Load", callback = function()
            local cn = flags["config_name_list"]
            if cn and cn ~= "No Configs" then library:set_auto_load(cn); al.items["name"].Text = "Current: " .. cn end
        end})
        s3:button({name = "Clear Auto Load", callback = function()
            library:clear_auto_load(); al.items["name"].Text = "Current: None"
        end})
    end

    -- ═══ SETTINGS ═══
    do
        local c1 = settings:column({})
        local us = c1:section({name = "Interface"})
        us:colorpicker({name = "Accent Color", flag = "menu_accent", callback = function(c)
            library:update_theme("accent", c)
        end, color = themes.preset.accent})
        us:keybind({name = "Menu Toggle", flag = "menu_keybind", key = Enum.KeyCode.Insert, mode = "Toggle", default = true, callback = function(b)
            window.toggle_menu(b)
        end})
        us:toggle({name = "Watermark", flag = "watermark_toggle", default = library.watermark_on, callback = function(b)
            library.watermark_on = b; library.watermark_frame.Visible = b; library:save_library_settings()
        end})
        us:toggle({name = "Keybind List", flag = "keybind_list_toggle", default = library.keybind_list_on, callback = function(b)
            library.keybind_list_on = b; library:save_library_settings()
            pcall(function() library:update_keybind_list() end)
        end})

        local c2 = settings:column({})
        local ns = c2:section({name = "Notifications"})
        ns:toggle({name = "Enable Notifications", flag = "notif_toggle", default = notifications.enabled, callback = function(b)
            library:toggle_notifications(b)
            if b then notifications:create_notification({name = "Notifications", info = "Enabled"}) end
        end})
        ns:dropdown({name = "Position", flag = "notif_position", items = {"TopRight", "TopLeft", "BottomRight", "BottomLeft"}, default = library.notif_position, callback = function(v)
            library.notif_position = v; library:save_library_settings()
        end})
        ns:button({name = "Test Notification", callback = function()
            if notifications.enabled then notifications:create_notification({name = "Test", info = "This is a test notification.", lifetime = 3}) end
        end})
    end

    task.spawn(function() task.wait(0.5); library:do_auto_load() end)
end

-- ══════════════════════════════════════════════════════════════
-- NOTIFICATIONS
-- ══════════════════════════════════════════════════════════════
function notifications:get_notif_anchor()
    local p = library.notif_position or "TopRight"
    if p == "TopRight" then return "right", "top"
    elseif p == "TopLeft" then return "left", "top"
    elseif p == "BottomRight" then return "right", "bottom"
    elseif p == "BottomLeft" then return "left", "bottom"
    end
    return "right", "top"
end

function notifications:refresh_notifs()
    local hdir, vdir = notifications:get_notif_anchor()
    local vp = camera.ViewportSize
    local offset = 8
    for _, v in pairs(notifications.notifs) do
        local x = hdir == "right" and (vp.X - 208) or 8
        local y = vdir == "top" and offset or (vp.Y - offset - v.AbsoluteSize.Y)
        library:tween(v, {Position = dim_offset(x, y)}, 0.3, Enum.EasingStyle.Quad)
        offset = offset + v.AbsoluteSize.Y + 6
    end
end

function notifications:fade(path, f)
    local t = f and 1 or 0
    library:tween(path, {BackgroundTransparency = t}, 0.4)
    for _, i in pairs(path:GetDescendants()) do
        pcall(function()
            if i:IsA("UIStroke") then library:tween(i, {Transparency = t}, 0.4)
            elseif i:IsA("TextLabel") then library:tween(i, {TextTransparency = t}, 0.4)
            elseif i:IsA("Frame") then library:tween(i, {BackgroundTransparency = f and 1 or (i:GetAttribute("bt") or 0)}, 0.4) end
        end)
    end
end

function notifications:create_notification(options)
    if not notifications.enabled then return end
    local cfg = {
        name = options.name or "Notification",
        info = options.info or "Info",
        lifetime = options.lifetime or 3,
        items = {},
    }
    local items = cfg.items
    local hdir, vdir = notifications:get_notif_anchor()
    local vp = camera.ViewportSize

    items["notification"] = library:create("Frame", {
        Parent = library["overlay"], Size = dim2(0, 200, 0, 0),
        BorderSizePixel = 0, BackgroundTransparency = 1,
        AutomaticSize = Enum.AutomaticSize.Y,
        BackgroundColor3 = palette.bg,
    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["notification"],
        Transparency = 1, Thickness = 1,
        ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Accent top line
    local na = library:create("Frame", {
        Parent = items["notification"], Size = dim2(1, 0, 0, 1),
        BorderSizePixel = 0, BackgroundColor3 = themes.preset.accent,
    })
    na:SetAttribute("bt", 0)

    -- Title
    items["title"] = library:create("TextLabel", {
        FontFace = fonts.bold, TextColor3 = palette.text,
        Text = cfg.name, Parent = items["notification"],
        BackgroundTransparency = 1, Position = dim2(0, 8, 0, 6),
        BorderSizePixel = 0, AutomaticSize = Enum.AutomaticSize.XY,
        TextSize = 11,
    })

    -- Info
    items["info"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text_dim,
        Text = cfg.info, Parent = items["notification"],
        Position = dim2(0, 8, 0, 20), BorderSizePixel = 0,
        BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
        TextWrapped = true, AutomaticSize = Enum.AutomaticSize.XY,
        TextSize = 10,
    })
    library:create("UIPadding", {PaddingBottom = dim(0, 12), PaddingRight = dim(0, 8), Parent = items["info"]})

    -- Progress bar
    items["bar"] = library:create("Frame", {
        AnchorPoint = vec2(0, 1), Parent = items["notification"],
        Position = dim2(0, 4, 1, -3), Size = dim2(0, 0, 0, 1),
        BackgroundTransparency = 1, BorderSizePixel = 0,
        BackgroundColor3 = themes.preset.accent,
    })
    items["bar"]:SetAttribute("bt", 0)

    local startX = hdir == "right" and vp.X + 10 or -220
    local startY = vdir == "top" and 8 or (vp.Y - 60)
    items["notification"].Position = dim_offset(startX, startY)

    local idx = #notifications.notifs + 1
    notifications.notifs[idx] = items["notification"]
    notifications:fade(items["notification"], false)
    notifications:refresh_notifs()
    library:tween(items["bar"], {Size = dim2(1, -8, 0, 1)}, cfg.lifetime, Enum.EasingStyle.Linear)

    task.spawn(function()
        task.wait(cfg.lifetime)
        notifications.notifs[idx] = nil
        notifications:fade(items["notification"], true)
        local endX = hdir == "right" and vp.X + 10 or -220
        library:tween(items["notification"], {Position = dim_offset(endX, items["notification"].Position.Y.Offset)}, 0.4, Enum.EasingStyle.Quad)
        task.wait(0.5)
        items["notification"]:Destroy()
        notifications:refresh_notifs()
    end)
end

return library
