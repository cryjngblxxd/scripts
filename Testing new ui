    function library:list(properties) 
        local cfg = {
            items = {},
            options = properties.options or {"1", "2", "3"},
            flag = properties.flag or library:next_flag(),
            callback = properties.callback or function() end,
            data_store = {},
            current_element = nil,
        }

        local items = cfg.items
        
        items["list"] = library:create("Frame", {
            Parent = self.items["elements"],
            BackgroundTransparency = 1,
            Size = dim2(1, 0, 0, 0),
            BorderSizePixel = 0,
            AutomaticSize = Enum.AutomaticSize.XY,
        })
        
        library:create("UIListLayout", {
            Parent = items["list"],
            Padding = dim(0, 2),
            SortOrder = Enum.SortOrder.LayoutOrder
        })

        function cfg.refresh_options(options_to_refresh)
            for _, option in pairs(cfg.data_store) do 
                option:Destroy()
            end
            cfg.data_store = {}

            for _, option_data in ipairs(options_to_refresh) do
                -- Blocky list item
                local button = library:create("TextButton", {
                    FontFace = fonts.small,
                    Text = "",
                    AutoButtonColor = false,
                    Parent = items["list"],
                    Size = dim2(1, 0, 0, 22),
                    BorderSizePixel = 0,
                    TextSize = 12,
                    BackgroundColor3 = rgb(20, 20, 26)
                })
                cfg.data_store[#cfg.data_store + 1] = button

                library:create("UIStroke", {
                    Color = rgb(30, 30, 40),
                    Parent = button,
                    Thickness = 1,
                    ApplyStrokeMode = Enum.ApplyStrokeMode.Border
                })

                local accent_bar = library:create("Frame", {
                    Parent = button,
                    Size = dim2(0, 2, 1, 0),
                    Position = dim2(0, 0, 0, 0),
                    BorderSizePixel = 0,
                    BackgroundColor3 = themes.preset.accent,
                    BackgroundTransparency = 1,
                })

                local name = library:create("TextLabel", {
                    FontFace = fonts.small,
                    TextColor3 = rgb(100, 100, 115),
                    Text = option_data,
                    Parent = button,
                    BackgroundTransparency = 1,
                    Size = dim2(1, -10, 1, 0),
                    Position = dim2(0, 8, 0, 0),
                    BorderSizePixel = 0,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    TextSize = 12,
                })

                button.MouseButton1Click:Connect(function()
                    local current = cfg.current_element 
                    if current and current ~= name then 
                        library:tween(current[1], {TextColor3 = rgb(100, 100, 115)})
                        library:tween(current[2], {BackgroundTransparency = 1})
                    end
                    flags[cfg.flag] = option_data
                    cfg.callback(option_data)
                    library:tween(name, {TextColor3 = rgb(220, 220, 235)})
                    library:tween(accent_bar, {BackgroundTransparency = 0})
                    cfg.current_element = {name, accent_bar}
                end)

                name.MouseEnter:Connect(function()
                    if cfg.current_element and cfg.current_element[1] == name then return end 
                    library:tween(name, {TextColor3 = rgb(160, 160, 175)}, Enum.EasingStyle.Quad, 0.1)
                end)

                name.MouseLeave:Connect(function()
                    if cfg.current_element and cfg.current_element[1] == name then return end 
                    library:tween(name, {TextColor3 = rgb(100, 100, 115)}, Enum.EasingStyle.Quad, 0.1)
                end)
            end
        end

        cfg.refresh_options(cfg.options)

        return setmetatable(cfg, library)
    end 

