function library:update_keybind_list()
    if not library.keybind_list_elements then return end
    for _, child in pairs(library.keybind_list_elements:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local has = false
    for _, bd in pairs(library.active_keybinds) do
        if bd.active and bd.name and bd.key_text ~= "None" then
            has = true
            local row = library:create("Frame", {Parent=library.keybind_list_elements, BackgroundTransparency=1, Size=dim2(1,0,0,18)})
            library:create("TextLabel", {FontFace=fonts.small, Text=bd.name, TextColor3=rgb(195,200,215), Parent=row, Size=dim2(1,-45,1,0), BackgroundTransparency=1, TextXAlignment=Enum.TextXAlignment.Left, TextSize=11})
            local kt = library:create("TextLabel", {FontFace=fonts.small, Text="["..bd.key_text.."]", TextColor3=themes.preset.accent, Parent=row, Size=dim2(0,40,1,0), Position=dim2(1,-40,0,0), BackgroundTransparency=1, TextXAlignment=Enum.TextXAlignment.Right, TextSize=10})
            library:apply_theme(kt, "accent", "TextColor3")
            -- Show mode
            library:create("TextLabel", {FontFace=fonts.small, Text=bd.mode or "", TextColor3=rgb(55,65,85), Parent=row, Size=dim2(1,0,0,10), Position=dim2(0,0,1,-2), BackgroundTransparency=1, TextXAlignment=Enum.TextXAlignment.Left, TextSize=8})
        end
    end
    if library.keybind_list_frame then library.keybind_list_frame.Visible = has and library.keybind_list_on end
end

