-- Config System
local ConfigSystem = {
	Folder = "OsamaHubConfigs",
	Elements = {},
	AutoLoadConfig = nil,
	IgnoreIndexes = {},
}

function ConfigSystem:Init()
	if not isfolder then return end
	if not isfolder(self.Folder) then makefolder(self.Folder) end
	local ap = self.Folder.."/autoload.txt"
	if isfile and isfile(ap) then self.AutoLoadConfig = readfile(ap) end
end

function ConfigSystem:SetFolder(f) self.Folder = f; self:Init() end
function ConfigSystem:SetIgnoreIndexes(t) for _,v in ipairs(t) do self.IgnoreIndexes[v]=true end end

function ConfigSystem:Register(id, getFn, setFn)
	self.Elements[id] = {Get=getFn, Set=setFn}
end

function ConfigSystem:Save(name)
	if not writefile then return end
	local data = {}
	for id,elem in pairs(self.Elements) do
		if not self.IgnoreIndexes[id] then data[id]=elem.Get() end
	end
	writefile(self.Folder.."/"..name..".json", HttpService:JSONEncode(data))
end

function ConfigSystem:Load(name)
	if not isfile then return end
	local path = self.Folder.."/"..name..".json"
	if not isfile(path) then return end
	local ok,data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
	if not ok then return end
	for id,val in pairs(data) do
		if self.Elements[id] and not self.IgnoreIndexes[id] then self.Elements[id].Set(val) end
	end
end

function ConfigSystem:Delete(name)
	if not delfile then return end
	local path = self.Folder.."/"..name..".json"
	if isfile and isfile(path) then delfile(path) end
end

function ConfigSystem:GetConfigs()
	if not listfiles then return {} end
	local configs = {}
	for _,file in pairs(listfiles(self.Folder)) do
		local name = file:match("([^/\\]+)%.json$")
		if name and name~="autoload" then table.insert(configs, name) end
	end
	return configs
end

function ConfigSystem:SetAutoLoad(name)
	if not writefile then return end
	self.AutoLoadConfig = name
	writefile(self.Folder.."/autoload.txt", name)
end

function ConfigSystem:RemoveAutoLoad()
	if not delfile then return end
	self.AutoLoadConfig = nil
	local p = self.Folder.."/autoload.txt"
	if isfile and isfile(p) then delfile(p) end
end

function ConfigSystem:LoadAutoloadConfig()
	if self.AutoLoadConfig then self:Load(self.AutoLoadConfig) end
end

