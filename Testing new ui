    function library:slider(options) 
        local cfg = {
            name = options.name or "Slider",
            suffix = options.suffix or "",
            flag = options.flag or library:next_flag(),
            callback = options.callback or function() end, 
            min = options.min or 0,
            max = options.max or 100,
            intervals = options.interval or 1,
            default = options.default or 10,
            value = options.default or 10, 
            seperator = options.seperator or false,
            dragging = false,
            items = {}
        } 

        flags[cfg.flag] = cfg.default

        local items = cfg.items
        
        items["slider_object"] = library:create("TextButton", {
            FontFace = fonts.small,
            Text = "",
            Parent = self.items["elements"],
            BackgroundTransparency = 1,
            Size = dim2(1, 0, 0, 32),
            BorderSizePixel = 0,
            TextSize = 13,
        })
        
        -- Name + value row
        items["name"] = library:create("TextLabel", {
            FontFace = fonts.small,
            TextColor3 = rgb(185, 185, 195),
            Text = cfg.name,
            Parent = items["slider_object"],
            Size = dim2(1, -50, 0, 14),
            Position = dim2(0, 0, 0, 0),
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Left,
            BorderSizePixel = 0,
            TextSize = 13,
        })

        items["value"] = library:create("TextLabel", {
            FontFace = fonts.small,
            TextColor3 = rgb(80, 80, 95),
            Text = tostring(cfg.default) .. cfg.suffix,
            Parent = items["slider_object"],
            Size = dim2(0, 50, 0, 14),
            Position = dim2(1, -50, 0, 0),
            BackgroundTransparency = 1,
            TextXAlignment = Enum.TextXAlignment.Right,
            BorderSizePixel = 0,
            TextSize = 12,
        })
        
        -- Blocky slider track
        items["slider"] = library:create("TextButton", {
            FontFace = fonts.small,
            Text = "",
            AutoButtonColor = false,
            Parent = items["slider_object"],
            Position = dim2(0, 0, 0, 18),
            Size = dim2(1, 0, 0, 6),
            BorderSizePixel = 0,
            TextSize = 13,
            BackgroundColor3 = rgb(28, 28, 36)
        })

        library:create("UIStroke", {
            Color = rgb(38, 38, 48),
            Parent = items["slider"],
            Thickness = 1,
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        })
        
        -- Fill bar (blocky, no radius)
        items["fill"] = library:create("Frame", {
            Parent = items["slider"],
            Size = dim2(0.5, 0, 1, 0),
            BorderSizePixel = 0,
            BackgroundColor3 = themes.preset.accent
        })
        library:apply_theme(items["fill"], "accent", "BackgroundColor3")
        
        -- Blocky slider handle
        items["circle"] = library:create("Frame", {
            AnchorPoint = vec2(1, 0.5),
            Parent = items["fill"],
            Position = dim2(1, 0, 0.5, 0),
            Size = dim2(0, 8, 0, 14),
            BorderSizePixel = 0,
            BackgroundColor3 = rgb(230, 230, 240)
        })

        library:create("UIStroke", {
            Color = rgb(180, 180, 200),
            Parent = items["circle"],
            Thickness = 1,
            ApplyStrokeMode = Enum.ApplyStrokeMode.Border
        })
        
        function cfg.set(value)
            cfg.value = clamp(library:round(value, cfg.intervals), cfg.min, cfg.max)
            library:tween(items["fill"], {Size = dim2((cfg.value - cfg.min) / (cfg.max - cfg.min), 0, 1, 0)}, Enum.EasingStyle.Linear, 0.05)
            items["value"].Text = tostring(cfg.value) .. cfg.suffix
            flags[cfg.flag] = cfg.value
            cfg.callback(cfg.value)
        end

        items["slider"].MouseButton1Down:Connect(function()
            cfg.dragging = true 
            library:tween(items["value"], {TextColor3 = themes.preset.accent}, Enum.EasingStyle.Quad, 0.15)
        end)

        library:connection(uis.InputChanged, function(input)
            if cfg.dragging and input.UserInputType == Enum.UserInputType.MouseMovement then 
                local size_x = (input.Position.X - items["slider"].AbsolutePosition.X) / items["slider"].AbsoluteSize.X
                local value = ((cfg.max - cfg.min) * size_x) + cfg.min
                cfg.set(value)
            end
        end)

        library:connection(uis.InputEnded, function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                cfg.dragging = false
                library:tween(items["value"], {TextColor3 = rgb(80, 80, 95)}, Enum.EasingStyle.Quad, 0.15) 
            end 
        end)

        if cfg.seperator then 
            library:create("Frame", {
                Parent = self.items["elements"],
                Size = dim2(1, 0, 0, 1),
                BorderSizePixel = 0,
                BackgroundColor3 = rgb(28, 28, 36)
            })
        end 

        cfg.set(cfg.default)
        config_flags[cfg.flag] = cfg.set

        return setmetatable(cfg, library)
    end 

