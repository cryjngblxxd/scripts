    function library:do_auto_load()
        library:load_library_settings()
        if library.auto_load_config_name then
            local config_path = library.directory .. "/configs/" .. library.auto_load_config_name .. ".cfg"
            pcall(function()
                if isfile(config_path) then
                    task.spawn(function()
