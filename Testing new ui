function library:keybind(o)
    local cfg = {flag=o.flag or library:next_flag(), callback=o.callback or function() end, name=o.name or nil, key=o.key or nil, mode=o.mode or "Toggle", active=o.default or false, open=false, binding=nil, hold_instances={}, items={}}
    flags[cfg.flag] = {mode=cfg.mode, key=cfg.key, active=cfg.active}; local items = cfg.items

    items["keybind_element"] = library:create("TextButton", {Text="", Parent=self.items["elements"], BackgroundTransparency=1, Size=dim2(1,0,0,20), BorderSizePixel=0, ZIndex=3})
    items["name"] = library:create("TextLabel", {FontFace=fonts.small, TextColor3=rgb(165,175,200), Text=cfg.name or "Keybind", Parent=items["keybind_element"], Size=dim2(1,-85,1,0), BackgroundTransparency=1, TextXAlignment=Enum.TextXAlignment.Left, BorderSizePixel=0, TextSize=13, ZIndex=3})
    items["right_components"] = library:create("Frame", {Parent=items["keybind_element"], Position=dim2(1,0,0,0), Size=dim2(0,0,1,0), BorderSizePixel=0, BackgroundTransparency=1, ZIndex=3})
    library:create("UIListLayout", {FillDirection=Enum.FillDirection.Horizontal, HorizontalAlignment=Enum.HorizontalAlignment.Right, Parent=items["right_components"], Padding=dim(0,4), SortOrder=Enum.SortOrder.LayoutOrder})

    items["keybind_holder"] = library:create("TextButton", {FontFace=fonts.small, Text="", Parent=items["right_components"], AutoButtonColor=false, AnchorPoint=vec2(1,0), Size=dim2(0,0,0,20), Position=dim2(1,0,0,0), BorderSizePixel=0, AutomaticSize=Enum.AutomaticSize.X, BackgroundColor3=rgb(18,22,32), ZIndex=3})
    library:create("UICorner", {Parent=items["keybind_holder"], CornerRadius=dim(0,5)})
    library:create("UIStroke", {Color=rgb(26,32,48), Parent=items["keybind_holder"], Thickness=1, ApplyStrokeMode=Enum.ApplyStrokeMode.Border})
    items["key"] = library:create("TextLabel", {FontFace=fonts.small, TextColor3=rgb(85,95,125), Text="None", Parent=items["keybind_holder"], Size=dim2(1,0,1,0), BackgroundTransparency=1, TextXAlignment=Enum.TextXAlignment.Center, BorderSizePixel=0, AutomaticSize=Enum.AutomaticSize.X, TextSize=10, ZIndex=3})
    library:create("UIPadding", {Parent=items["key"], PaddingRight=dim(0,8), PaddingLeft=dim(0,8)})

    -- MODE POPUP - Using Visible toggle to prevent line artifacts
    items["mode_popup"] = library:create("Frame", {
        Parent=library["items"], Size=dim2(0,80,0,0),
        BorderSizePixel=0, ZIndex=30, Visible=false, BackgroundTransparency=1,
    })
    local mode_inner = library:create("Frame", {
        Parent=items["mode_popup"], Size=dim2(1,0,1,0),
        ClipsDescendants=true, BorderSizePixel=0,
        BackgroundColor3=rgb(14,17,25), ZIndex=30,
    })
    library:create("UICorner", {Parent=mode_inner, CornerRadius=dim(0,6)})
    library:create("UIStroke", {Color=rgb(26,32,48), Parent=mode_inner, Thickness=1, ApplyStrokeMode=Enum.ApplyStrokeMode.Border})
    library:create("UIPadding", {PaddingBottom=dim(0,4), PaddingTop=dim(0,4), PaddingLeft=dim(0,4), PaddingRight=dim(0,4), Parent=mode_inner})
    library:create("UIListLayout", {Parent=mode_inner, Padding=dim(0,2), SortOrder=Enum.SortOrder.LayoutOrder})

    local modes = {"Toggle", "Hold", "Always"}
    local popup_height = 8
    for _, option in ipairs(modes) do
        local mb = library:create("TextButton", {
            FontFace=fonts.small, TextColor3=rgb(85,95,125), Text=option,
            Parent=mode_inner, Size=dim2(1,0,0,18), BackgroundTransparency=1,
            AutoButtonColor=false, TextXAlignment=Enum.TextXAlignment.Left,
            BorderSizePixel=0, TextSize=11, ZIndex=30,
        })
        cfg.hold_instances[option] = mb; popup_height = popup_height + 20
        library:create("UIPadding", {Parent=mb, PaddingLeft=dim(0,6)})
        library:create("UICorner", {Parent=mb, CornerRadius=dim(0,4)})
        mb.MouseButton1Click:Connect(function()
            cfg.set(option); cfg.set_visible(false); cfg.open=false
        end)
        mb.MouseEnter:Connect(function() if mb.TextColor3~=themes.preset.accent then library:tween(mb,{TextColor3=rgb(170,180,210)},Enum.EasingStyle.Quad,0.08) end end)
        mb.MouseLeave:Connect(function() if mb.TextColor3~=themes.preset.accent then library:tween(mb,{TextColor3=rgb(85,95,125)},Enum.EasingStyle.Quad,0.08) end end)
    end
    cfg.popup_height = popup_height

    function cfg.modify_mode_color(p)
        for _,v in pairs(cfg.hold_instances) do v.TextColor3=rgb(85,95,125) end
        if cfg.hold_instances[p] then cfg.hold_instances[p].TextColor3=themes.preset.accent end
    end
    function cfg.set_mode(m)
        cfg.mode=m
        if m=="Always" then cfg.set(true) elseif m=="Hold" then cfg.set(false) end
        flags[cfg.flag]["mode"]=m; cfg.modify_mode_color(m)
    end

    function cfg.set(input)
        if type(input)=="boolean" then cfg.active=input; if cfg.mode=="Always" then cfg.active=true end
        elseif tostring(input):find("Enum") then input=input.Name=="Escape" and "NONE" or input; cfg.key=input or "NONE"
        elseif find({"Toggle","Hold","Always"}, input) then if input=="Always" then cfg.active=true end; cfg.mode=input; cfg.set_mode(cfg.mode)
        elseif type(input)=="table" then
            if type(input.key)=="string" and input.key~="NONE" then pcall(function() input.key=library:convert_enum(input.key) end) end
            if input.key==Enum.KeyCode.Escape then input.key="NONE" end
            cfg.key=input.key or "NONE"; cfg.mode=input.mode or "Toggle"
            if input.active then cfg.active=input.active end; cfg.set_mode(cfg.mode)
        end
        cfg.callback(cfg.active)
        local text = "None"
        if cfg.key and tostring(cfg.key)~="Enums" and cfg.key~="NONE" then
            text = keys[cfg.key] or tostring(cfg.key):gsub("Enum.KeyCode.",""):gsub("Enum.UserInputType.","")
        end
        items["key"].Text = text
        flags[cfg.flag] = {mode=cfg.mode, key=cfg.key, active=cfg.active}
        library.active_keybinds[cfg.flag] = {name=cfg.name or "Keybind", key_text=text, active=cfg.active, mode=cfg.mode}
        pcall(function() library:update_keybind_list() end)
    end

    function cfg.set_visible(bool)
        if bool then
            local kp = items["keybind_holder"].AbsolutePosition
            local ks = items["keybind_holder"].AbsoluteSize
            items["mode_popup"].Position = dim_offset(kp.X, kp.Y + ks.Y + 4)
            items["mode_popup"].Size = dim_offset(ks.X + 16, cfg.popup_height)
            items["mode_popup"].Visible = true
        else
            items["mode_popup"].Visible = false
        end
        library:close_element(cfg)
    end

    items["keybind_holder"].MouseButton1Down:Connect(function()
        task.wait(); items["key"].Text="..."
        cfg.binding = library:connection(uis.InputBegan, function(kc)
            cfg.set(kc.KeyCode~=Enum.KeyCode.Unknown and kc.KeyCode or kc.UserInputType)
            cfg.binding:Disconnect(); cfg.binding=nil
        end)
    end)
    items["keybind_holder"].MouseButton2Down:Connect(function()
        cfg.open=not cfg.open; cfg.set_visible(cfg.open)
    end)

    library:connection(uis.InputBegan, function(input,ge) if not ge then local sk=input.UserInputType==Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType; if sk==cfg.key then if cfg.mode=="Toggle" then cfg.active=not cfg.active; cfg.set(cfg.active) elseif cfg.mode=="Hold" then cfg.set(true) end end end end)
    library:connection(uis.InputEnded, function(input,ge) if ge then return end; local sk=input.UserInputType==Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType; if sk==cfg.key and cfg.mode=="Hold" then cfg.set(false) end end)

    cfg.set({mode=cfg.mode, active=cfg.active, key=cfg.key}); config_flags[cfg.flag]=cfg.set; return setmetatable(cfg, library)
end

