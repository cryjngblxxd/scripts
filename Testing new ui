function library:update_keybind_list()
    if not library.keybind_list_elements then return end
    for _, child in pairs(library.keybind_list_elements:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end
    local has = false
    for _, bd in pairs(library.active_keybinds) do
