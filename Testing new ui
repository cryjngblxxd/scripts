function notifications:get_notif_anchor() local p=library.notif_position or "TopRight"; if p=="TopRight" then return "right","top" elseif p=="TopLeft" then return "left","top" elseif p=="BottomRight" then return "right","bottom" elseif p=="BottomLeft" then return "left","bottom" end; return "right","top" end

