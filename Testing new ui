        s2:button({name="Save",callback=function() local cn=flags["config_name_text"]; if cn=="" then cn=flags["config_name_list"] end; if cn and cn~="" and cn~="No Configs" then pcall(function() writefile(library.directory.."/configs/"..cn..".cfg",library:get_config()) end); library:update_config_list(); if notifications.enabled then notifications:create_notification({name="Saved",info=cn}) end end end})
        s2:button({name="Load",callback=function() local cn=flags["config_name_list"]; if cn and cn~="No Configs" then pcall(function() if isfile(library.directory.."/configs/"..cn..".cfg") then library:load_config(readfile(library.directory.."/configs/"..cn..".cfg")); library:update_config_list(); if notifications.enabled then notifications:create_notification({name="Loaded",info=cn}) end end end) end end})
        s2:button({name="Delete",callback=function() local cn=flags["config_name_list"]; if cn and cn~="No Configs" then pcall(function() if isfile(library.directory.."/configs/"..cn..".cfg") then delfile(library.directory.."/configs/"..cn..".cfg"); library:update_config_list(); if notifications.enabled then notifications:create_notification({name="Deleted",info=cn}) end end end) end end})
        s2:button({name="Refresh",callback=function() library:update_config_list() end})
        local as=c2:section({name="Auto Load",size=0.5,icon=icons["refresh-bold-duotone"] or ""}); local al=as:label({name="Current: "..(library.auto_load_config_name or "None")})
        as:button({name="Set Auto Load",callback=function() local cn=flags["config_name_list"]; if cn and cn~="No Configs" then library:set_auto_load(cn); al.items["name"].Text="Current: "..cn end end})
        as:button({name="Clear Auto Load",callback=function() library:clear_auto_load(); al.items["name"].Text="Current: None" end})
    end

    do -- Settings
        local c1=settings_tab:column({}); local us=c1:section({name="UI Settings",size=1,icon=icons["palette-bold-duotone"] or ""})
        us:colorpicker({name="Accent",flag="menu_accent",callback=function(c) library:update_theme("accent",c) end,color=themes.preset.accent})
        us:keybind({name="Menu Toggle",flag="menu_keybind",key=Enum.KeyCode.Insert,mode="Toggle",default=true,callback=function(b) window.toggle_menu(b) end})
        us:toggle({name="Watermark",flag="watermark_toggle",default=library.watermark_on,callback=function(b) library.watermark_on=b; library.watermark_frame.Visible=b; library:save_library_settings() end})
        us:toggle({name="Keybind List",flag="keybind_list_toggle",default=library.keybind_list_on,callback=function(b) library.keybind_list_on=b; library:save_library_settings(); pcall(function() library:update_keybind_list() end) end})
        us:toggle({name="UI Glow",flag="glow_toggle",default=library.glow_enabled,callback=function(b) library.glow_enabled=b; if library.glow_frame then library.glow_frame.Visible=b end; library:save_library_settings() end})
        us:slider({name="Glow Intensity",flag="glow_intensity",min=0,max=100,default=math.floor((1-library.glow_transparency)*100),suffix="%",callback=function(v) library.glow_transparency=1-(v/100); if library.glow_frame then library.glow_frame.ImageTransparency=library.glow_transparency end; library:save_library_settings() end})

        local c2=settings_tab:column({}); local ns=c2:section({name="Notifications",size=1,icon=icons["bell-bold-duotone"] or ""})
        ns:toggle({name="Notifications",flag="notif_toggle",default=notifications.enabled,callback=function(b) library:toggle_notifications(b); if b then notifications:create_notification({name="Notifications",info="Enabled!"}) end end})
        ns:dropdown({name="Position",flag="notif_position",items={"TopRight","TopLeft","BottomRight","BottomLeft"},default=library.notif_position,callback=function(v) library.notif_position=v; library:save_library_settings() end})
        ns:button({name="Test Notification",callback=function() if notifications.enabled then notifications:create_notification({name="Test",info="Hello!",lifetime=3}) end end})
    end
    task.spawn(function() task.wait(0.5); library:do_auto_load() end)
end

-- ══════════════════════════════════════
-- NOTIFICATIONS
-- ══════════════════════════════════════
function notifications:get_notif_anchor()
    local p=library.notif_position or "TopRight"
    if p=="TopRight" then return "right","top" elseif p=="TopLeft" then return "left","top"
    elseif p=="BottomRight" then return "right","bottom" elseif p=="BottomLeft" then return "left","bottom" end
    return "right","top"
end

function notifications:refresh_notifs()
    local hdir,vdir = notifications:get_notif_anchor()
    local vp = camera.ViewportSize; local offset = 12
    for _, v in pairs(notifications.notifs) do
        local x = hdir=="right" and (vp.X-222) or 12
        local y = vdir=="top" and offset or (vp.Y-offset-v.AbsoluteSize.Y)
        library:tween(v, {Position=dim_offset(x,y)}, Enum.EasingStyle.Quad, 0.4)
        offset = offset + v.AbsoluteSize.Y + 8
    end
end

function notifications:fade(path, f)
    local t = f and 1 or 0
    library:tween(path, {BackgroundTransparency=t}, Enum.EasingStyle.Quad, 0.5)
    for _, i in pairs(path:GetDescendants()) do pcall(function()
        if i:IsA("UIStroke") then library:tween(i,{Transparency=t},Enum.EasingStyle.Quad,0.5)
        elseif i:IsA("TextLabel") then library:tween(i,{TextTransparency=t})
        elseif i:IsA("Frame") then library:tween(i,{BackgroundTransparency=f and 1 or (i:GetAttribute("bt") or 0)},Enum.EasingStyle.Quad,0.5) end
    end) end
end

function notifications:create_notification(options)
    if not notifications.enabled then return end
    local cfg = {name=options.name or "Notification", info=options.info or "Info", lifetime=options.lifetime or 3, items={}}
    local items = cfg.items; local hdir,vdir = notifications:get_notif_anchor(); local vp = camera.ViewportSize

    items["notification"] = library:create("Frame", {Parent=library["overlay"], Size=dim2(0,215,0,0), BorderSizePixel=0, BackgroundTransparency=1, AutomaticSize=Enum.AutomaticSize.Y, BackgroundColor3=rgb(12,14,20)})
    library:create("UICorner", {Parent=items["notification"], CornerRadius=dim(0,7)})
    library:create("UIStroke", {Color=rgb(24,28,42), Parent=items["notification"], Transparency=1, Thickness=1, ApplyStrokeMode=Enum.ApplyStrokeMode.Border})

    local na = library:create("Frame", {Parent=items["notification"], Size=dim2(1,0,0,2), BorderSizePixel=0, BackgroundColor3=themes.preset.accent, ClipsDescendants=true})
    na:SetAttribute("bt",0); library:create("UICorner", {Parent=na, CornerRadius=dim(0,7)})
    library:create("Frame", {Parent=na, Size=dim2(1,0,0,2), Position=dim2(0,0,1,-2), BorderSizePixel=0, BackgroundColor3=themes.preset.accent})

    items["title"] = library:create("TextLabel", {FontFace=fonts.font, TextColor3=rgb(220,230,248), Text=cfg.name, Parent=items["notification"], BackgroundTransparency=1, Position=dim2(0,10,0,10), BorderSizePixel=0, AutomaticSize=Enum.AutomaticSize.XY, TextSize=12})
    items["info"] = library:create("TextLabel", {FontFace=fonts.small, TextColor3=rgb(105,118,150), Text=cfg.info, Parent=items["notification"], Position=dim2(0,10,0,26), BorderSizePixel=0, BackgroundTransparency=1, TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true, AutomaticSize=Enum.AutomaticSize.XY, TextSize=11})
    library:create("UIPadding", {PaddingBottom=dim(0,16), PaddingRight=dim(0,10), Parent=items["info"]})

    items["bar"] = library:create("Frame", {AnchorPoint=vec2(0,1), Parent=items["notification"], Position=dim2(0,8,1,-5), Size=dim2(0,0,0,2), BackgroundTransparency=1, BorderSizePixel=0, BackgroundColor3=themes.preset.accent})
    items["bar"]:SetAttribute("bt",0); library:create("UICorner", {Parent=items["bar"], CornerRadius=dim(0,999)})

    local startX = hdir=="right" and vp.X+10 or -220
    local startY = vdir=="top" and 12 or (vp.Y-65)
    items["notification"].Position = dim_offset(startX, startY)

    local idx = #notifications.notifs+1; notifications.notifs[idx] = items["notification"]
    notifications:fade(items["notification"], false)
    notifications:refresh_notifs()
    library:tween(items["bar"], {Size=dim2(1,-16,0,2)}, Enum.EasingStyle.Linear, cfg.lifetime)

    task.spawn(function()
        task.wait(cfg.lifetime); notifications.notifs[idx]=nil
        notifications:fade(items["notification"], true)
        local endX = hdir=="right" and vp.X+10 or -220
        library:tween(items["notification"], {Position=dim_offset(endX,items["notification"].Position.Y.Offset)}, Enum.EasingStyle.Quad, 0.5)
        task.wait(0.6); items["notification"]:Destroy(); notifications:refresh_notifs()
    end)
end

return library
