    library:create("UIPadding",{Parent=btn_content,PaddingLeft=dim(0,12),PaddingRight=dim(0,12)})

    if cfg.icon and cfg.icon ~= "" then
        items["tab_icon"] = library:create("ImageLabel",{Image=cfg.icon,ImageColor3=palette.text_dim,Parent=btn_content,BackgroundTransparency=1,Size=dim2(0,12,0,12),ZIndex=3})
    end

    items["tab_text"] = library:create("TextLabel",{FontFace=fonts.regular,Text=cfg.name,TextColor3=palette.text_dim,Parent=btn_content,BackgroundTransparency=1,Size=dim2(0,0,1,0),AutomaticSize=Enum.AutomaticSize.X,TextSize=11,ZIndex=3})

    items["indicator"] = library:create("Frame",{Parent=items["button"],AnchorPoint=vec2(0.5,1),Position=dim2(0.5,0,1,0),Size=dim2(1,0,0,2),BorderSizePixel=0,BackgroundColor3=themes.preset.accent,BackgroundTransparency=1,ZIndex=5})
    library:apply_theme(items["indicator"],"accent","BackgroundColor3")

    items["columns_holder"] = library:create("Frame",{Parent=items["tab_content"],BackgroundTransparency=1,Size=dim2(1,-12,1,-6),Position=dim2(0,6,0,3),BorderSizePixel=0,ZIndex=3})
    library:create("UIListLayout",{Parent=items["columns_holder"],FillDirection=Enum.FillDirection.Horizontal,HorizontalFlex=Enum.UIFlexAlignment.Fill,VerticalFlex=Enum.UIFlexAlignment.Fill,Padding=dim(0,6),SortOrder=Enum.SortOrder.LayoutOrder})

    local data = {items=items, parent=items["columns_holder"]}

    function cfg.open_tab()
        local st = self.selected_tab
        if st then
            library:tween(st.items["button"],{BackgroundColor3=palette.tab},0.1)
            if st.items["tab_icon"] then library:tween(st.items["tab_icon"],{ImageColor3=palette.text_dim},0.1) end
            library:tween(st.items["tab_text"],{TextColor3=palette.text_dim},0.1)
            st.items["indicator"].BackgroundTransparency=1
            st.items["tab_content"].Visible=false; st.items["tab_content"].Parent=library.cache
        end
        library:tween(items["button"],{BackgroundColor3=palette.tab_active},0.1)
        if items["tab_icon"] then library:tween(items["tab_icon"],{ImageColor3=themes.preset.accent},0.1) end
        library:tween(items["tab_text"],{TextColor3=palette.text},0.1)
        items["indicator"].BackgroundTransparency=0
        items["tab_content"].Visible=true; items["tab_content"].Parent=self.items["content"]
        self.selected_tab=cfg; library:close_all_popups()
