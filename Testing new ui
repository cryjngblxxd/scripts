		function G:AddSlider(idx, opts)
			opts = opts or {}
			local SName = opts.Text or idx
			local Min, Max = opts.Min or 0, opts.Max or 100
			local Def = opts.Default or Min
			local Suffix = opts.Suffix or ""
			local Dec = opts.Rounding or 0
			local Compact = opts.Compact or false
			local HideMax = opts.HideMax or false
			local Callback = opts.Callback or function() end
			local Val = math.clamp(Def, Min, Max)

			local optObj = {Value=Val, _changedCallbacks={}, _type="Slider"}
			function optObj:OnChanged(fn) table.insert(self._changedCallbacks, fn) end
			function optObj:SetValue(v) Val=math.clamp(v,Min,Max); self.Value=Val; Fill.Size=UDim2.new((Val-Min)/(Max-Min),0,1,0); VL.Text=Fmt(Val); Callback(Val); for _,fn in ipairs(self._changedCallbacks) do pcall(fn) end end
			Options[idx] = optObj

			local SF = Utility.Create("Frame", {Parent=container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,Compact and 10 or 28), ZIndex=11})
			local function Fmt(v) if Dec>0 then return string.format("%."..Dec.."f",v)..Suffix end; return tostring(math.floor(v))..Suffix end

			local NL, VL
			if not Compact then
				NL = Utility.Create("TextLabel", {Parent=SF, BackgroundTransparency=1, Size=UDim2.new(0.5,0,0,14), FontFace=Assets.Font, Text=SName, TextColor3=Theme.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=12})
				VL = Utility.Create("TextLabel", {Parent=SF, BackgroundTransparency=1, Position=UDim2.new(0.5,0,0,0), Size=UDim2.new(0.5,0,0,14), FontFace=Assets.FontRegular, Text=HideMax and Fmt(Val) or (Fmt(Val).."/"..Fmt(Max)), TextColor3=Theme.TextMain, TextSize=12, TextXAlignment=Enum.TextXAlignment.Right, ZIndex=12})
			else
				VL = {Text=""}
			end

			local trkY = Compact and 2 or 18
			local Trk = Utility.Create("Frame", {Parent=SF, BackgroundColor3=Theme.TrackBG, BorderSizePixel=0, Position=UDim2.new(0,0,0,trkY), Size=UDim2.new(1,0,0,5), ZIndex=12})
			Utility.Create("UIStroke", {Parent=Trk, Color=Theme.StrokeDark, Thickness=1})
			local Fill = Utility.Create("Frame", {Parent=Trk, BackgroundColor3=Color3.new(1,1,1), BorderSizePixel=0, Size=UDim2.new((Val-Min)/(Max-Min),0,1,0), ZIndex=14})
			Utility.AddGradient(Fill, Theme.Accent, 0)
			local IB = Utility.Create("TextButton", {Parent=Trk, BackgroundTransparency=1, Size=UDim2.new(1,0,1,10), Position=UDim2.new(0,0,0,-5), Text="", AutoButtonColor=false, ZIndex=16})

			local Sl = false
			local function US(inp)
				local r=math.clamp((inp.Position.X-Trk.AbsolutePosition.X)/Trk.AbsoluteSize.X,0,1)
				Val=Min+(Max-Min)*r
				if Dec<=0 then Val=math.floor(Val+0.5) else local m=10^Dec; Val=math.floor(Val*m+0.5)/m end
				Val=math.clamp(Val,Min,Max); Fill.Size=UDim2.new((Val-Min)/(Max-Min),0,1,0)
				if not Compact then VL.Text=HideMax and Fmt(Val) or (Fmt(Val).."/"..Fmt(Max)) end
				optObj.Value=Val; Callback(Val); for _,fn in ipairs(optObj._changedCallbacks) do pcall(fn) end
			end
			IB.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then Sl=true; US(i) end end)
			IB.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 then Sl=false end end)
			UserInputService.InputChanged:Connect(function(i) if Sl and i.UserInputType==Enum.UserInputType.MouseMovement then US(i) end end)

			ConfigSystem:Register(idx, function() return Val end, function(v) optObj:SetValue(v) end)
			return optObj
		end

		function G:AddDropdown(idx, opts)
			opts = opts or {}
			local DName = opts.Text or idx
			local Values = opts.Values or opts.Options or {"None"}
			local Multi = opts.Multi or false
			local Callback = opts.Callback or function() end
			local SpecialType = opts.SpecialType
			local Open = false

			-- Handle SpecialType
			if SpecialType == "Player" then
				Values = {}
				for _,p in pairs(Players:GetPlayers()) do if p~=LocalPlayer then table.insert(Values, p.Name) end end
				if #Values==0 then Values={"No players"} end
			end

			local Selected
			if Multi then
				Selected = {}
				if typeof(opts.Default)=="table" then Selected=opts.Default
				elseif typeof(opts.Default)=="number" and Values[opts.Default] then Selected[Values[opts.Default]]=true
				elseif typeof(opts.Default)=="string" then Selected[opts.Default]=true end
			else
				if typeof(opts.Default)=="number" then Selected=Values[opts.Default] or Values[1]
				elseif typeof(opts.Default)=="string" then Selected=opts.Default
				else Selected=Values[1] end
			end

			local optObj = {Value=Selected, _changedCallbacks={}, _type="Dropdown"}
			function optObj:OnChanged(fn) table.insert(self._changedCallbacks, fn) end
			function optObj:SetValue(v)
				if Multi then
					if typeof(v)=="table" then Selected=v else Selected={} end
				else
					Selected = v
				end
				self.Value=Selected; SL.Text=getDisplayText(); Callback(Selected)
				for _,fn in ipairs(self._changedCallbacks) do pcall(fn) end
			end
			function optObj:SetValues(newVals)
				Values=newVals
				if not Multi then
					if not table.find(Values, Selected) then Selected=Values[1] or "" end
				end
				self.Value=Selected; SL.Text=getDisplayText()
				if Open then Refresh(); LP.Size=UDim2.new(1,0,0,math.min(#Values*22,200)) end
			end
			Options[idx] = optObj

			local function getDisplayText()
				if Multi then
					local parts = {}
					for k,v in pairs(Selected) do if v then table.insert(parts, k) end end
					return #parts>0 and table.concat(parts, ", ") or "None"
				end
				return tostring(Selected)
			end

			local DF = Utility.Create("Frame", {Parent=container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,38), ClipsDescendants=false, ZIndex=11})
			Utility.Create("TextLabel", {Parent=DF, BackgroundTransparency=1, Size=UDim2.new(1,0,0,14), FontFace=Assets.Font, Text=DName, TextColor3=Theme.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=12})
			local Click = Utility.Create("TextButton", {Parent=DF, BackgroundColor3=Color3.new(1,1,1), BorderSizePixel=0, Position=UDim2.new(0,0,0,16), Size=UDim2.new(1,0,0,22), Text="", AutoButtonColor=false, ZIndex=12})
			Utility.Create("UIStroke", {Parent=Click, Color=Theme.StrokeDark, Thickness=1})
			Utility.AddGradient(Click, Theme.InputGradient, 90)
			Utility.Create("Frame", {Parent=Click, BackgroundColor3=Color3.fromRGB(46,46,52), BackgroundTransparency=0.7, BorderSizePixel=0, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,0,1), ZIndex=13})
			local SL = Utility.Create("TextLabel", {Parent=Click, BackgroundTransparency=1, Position=UDim2.new(0,7,0,0), Size=UDim2.new(1,-24,1,0), FontFace=Assets.FontRegular, Text=getDisplayText(), TextColor3=Theme.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=13})
			local Arr = Utility.Create("TextLabel", {Parent=Click, BackgroundTransparency=1, Position=UDim2.new(1,-18,0,0), Size=UDim2.new(0,14,1,0), FontFace=Assets.FontRegular, Text="▾", TextColor3=Color3.fromRGB(55,55,62), TextSize=10, ZIndex=13})

			local LP = Utility.Create("Frame", {Parent=container, BackgroundColor3=Color3.new(1,1,1), BorderSizePixel=0, Size=UDim2.new(1,0,0,0), ClipsDescendants=true, Visible=false, ZIndex=30})
			Utility.AddGradient(LP, Theme.SectionGradient, 90)
			Utility.Create("UIStroke", {Parent=LP, Color=Theme.PanelBorderOuter, Thickness=1})
			Utility.Create("UIListLayout", {Parent=LP, SortOrder=Enum.SortOrder.LayoutOrder})

			local function CloseDD() Open=false; LP.Visible=false; LP.Size=UDim2.new(1,0,0,0); Arr.Text="▾" end

			local function Refresh()
				for _,v in pairs(LP:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
				for i,opt in ipairs(Values) do
					local cap=opt
					local isSel = Multi and Selected[cap] or (Selected==cap)
					local OB = Utility.Create("TextButton", {Parent=LP, BackgroundColor3=isSel and Color3.fromRGB(28,30,35) or Theme.Section, BorderSizePixel=0, Size=UDim2.new(1,0,0,22), Text="", AutoButtonColor=false, ZIndex=31, LayoutOrder=i})
					Utility.Create("TextLabel", {Parent=OB, BackgroundTransparency=1, Position=UDim2.new(0,7,0,0), Size=UDim2.new(1,-14,1,0), FontFace=Assets.FontRegular, Text=cap, TextColor3=isSel and Theme.ButtonAccent or Theme.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=32})
					OB.MouseEnter:Connect(function() if not (Multi and Selected[cap] or Selected==cap) then Utility.Tween(OB,{BackgroundColor3=Color3.fromRGB(33,35,40)}) end end)
					OB.MouseLeave:Connect(function() if not (Multi and Selected[cap] or Selected==cap) then Utility.Tween(OB,{BackgroundColor3=Theme.Section}) end end)
					OB.MouseButton1Click:Connect(function()
						if Multi then
							Selected[cap] = not Selected[cap]
							optObj.Value=Selected; SL.Text=getDisplayText(); Refresh(); Callback(Selected)
							for _,fn in ipairs(optObj._changedCallbacks) do pcall(fn) end
						else
							Selected=cap; optObj.Value=Selected; SL.Text=getDisplayText(); CloseDD(); Callback(Selected)
							for _,fn in ipairs(optObj._changedCallbacks) do pcall(fn) end
						end
					end)
				end
			end

			Click.MouseButton1Click:Connect(function()
				Open=not Open
				if Open then Refresh(); LP.Visible=true; LP.Size=UDim2.new(1,0,0,math.min(#Values*22,200)); Arr.Text="▴"
				else CloseDD() end
			end)
			Refresh()

			ConfigSystem:Register(idx, function() return Selected end, function(v) optObj:SetValue(v) end)
			return optObj
		end

		function G:AddInput(idx, opts)
			opts = opts or {}
			local TName = opts.Text or idx
			local Place = opts.Placeholder or opts.Default or "..."
			local DefaultText = opts.Default or ""
			local Numeric = opts.Numeric or false
			local Finished = opts.Finished or false
			local Callback = opts.Callback or function() end
			local MaxLength = opts.MaxLength

			local optObj = {Value=DefaultText, _changedCallbacks={}, _type="Input"}
			function optObj:OnChanged(fn) table.insert(self._changedCallbacks, fn) end
			function optObj:SetValue(v) self.Value=v; Inp.Text=v end
			Options[idx] = optObj

			local F = Utility.Create("Frame", {Parent=container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,38), ZIndex=11})
			Utility.Create("TextLabel", {Parent=F, BackgroundTransparency=1, Size=UDim2.new(1,0,0,14), FontFace=Assets.Font, Text=TName, TextColor3=Theme.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=12})
			local IB = Utility.Create("Frame", {Parent=F, BackgroundColor3=Color3.new(1,1,1), BorderSizePixel=0, Position=UDim2.new(0,0,0,16), Size=UDim2.new(1,0,0,22), ZIndex=12})
			local IS = Utility.Create("UIStroke", {Parent=IB, Color=Theme.StrokeDark, Thickness=1})
			Utility.AddGradient(IB, Theme.InputGradient, 90)
			Utility.Create("Frame", {Parent=IB, BackgroundColor3=Color3.fromRGB(46,46,52), BackgroundTransparency=0.7, BorderSizePixel=0, Position=UDim2.new(0,1,0,1), Size=UDim2.new(1,-2,0,1), ZIndex=13})
			local Inp = Utility.Create("TextBox", {Parent=IB, BackgroundTransparency=1, Position=UDim2.new(0,7,0,0), Size=UDim2.new(1,-14,1,0), FontFace=Assets.FontRegular, Text=DefaultText, PlaceholderText=Place, PlaceholderColor3=Theme.TextPlaceholder, TextColor3=Theme.TextMain, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ClearTextOnFocus=false, ZIndex=13})
			Inp.Focused:Connect(function() Utility.Tween(IS,{Color=Color3.fromRGB(58,58,66)}) end)

			local function processText(enter)
				local txt = Inp.Text
				if MaxLength and #txt>MaxLength then txt=txt:sub(1,MaxLength); Inp.Text=txt end
				if Numeric then txt=txt:gsub("[^%d%.%-]",""); Inp.Text=txt end
				optObj.Value=txt
				if not Finished or enter then Callback(txt); for _,fn in ipairs(optObj._changedCallbacks) do pcall(fn) end end
			end

			Inp.FocusLost:Connect(function(enter) Utility.Tween(IS,{Color=Theme.StrokeDark}); processText(enter) end)
			if not Finished then
				Inp:GetPropertyChangedSignal("Text"):Connect(function() processText(false) end)
			end

			ConfigSystem:Register(idx, function() return optObj.Value end, function(v) optObj:SetValue(v) end)
			return optObj
		end

