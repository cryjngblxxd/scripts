    })
    library:create("UIStroke", {
        Color = palette.border, Parent = items["checkbox"],
        Thickness = 1, ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
    })

    -- Checkmark (inner fill)
    items["checkmark"] = library:create("Frame", {
        Parent = items["checkbox"], AnchorPoint = vec2(0.5, 0.5),
        Position = dim2(0.5, 0, 0.5, 0), Size = dim2(0, 8, 0, 8),
        BorderSizePixel = 0, BackgroundColor3 = themes.preset.accent,
        BackgroundTransparency = 1, ZIndex = 4,
    })
    library:apply_theme(items["checkmark"], "accent", "BackgroundColor3")

    -- Label
    items["name"] = library:create("TextLabel", {
        FontFace = fonts.regular, TextColor3 = palette.text,
        Text = cfg.name, Parent = items["toggle"],
        Size = dim2(1, -22, 1, 0), Position = dim2(0, 20, 0, 0),
        BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Left,
        BorderSizePixel = 0, TextSize = 12, ZIndex = 3,
    })

    -- Right components area
    items["right_components"] = library:create("Frame", {
        Parent = items["toggle"], Position = dim2(1, 0, 0, 0),
        Size = dim2(0, 0, 1, 0), BorderSizePixel = 0,
        BackgroundTransparency = 1, ZIndex = 3,
    })
    library:create("UIListLayout", {
        FillDirection = Enum.FillDirection.Horizontal,
        HorizontalAlignment = Enum.HorizontalAlignment.Right,
        Parent = items["right_components"], Padding = dim(0, 6),
        SortOrder = Enum.SortOrder.LayoutOrder,
    })

    function cfg.set(b)
        cfg.enabled = b
        items["checkmark"].BackgroundTransparency = b and 0 or 1
        local stroke = items["checkbox"]:FindFirstChildWhichIsA("UIStroke")
        if stroke then
            library:tween(stroke, {Color = b and themes.preset.accent or palette.border}, 0.08)
        end
        flags[cfg.flag] = b
        cfg.callback(b)
    end

    items["toggle"].MouseButton1Click:Connect(function()
        cfg.enabled = not cfg.enabled
        cfg.set(cfg.enabled)
    end)

    items["toggle"].MouseEnter:Connect(function()
        library:tween(items["checkbox"], {BackgroundColor3 = palette.frame_bg_hover}, 0.06)
    end)
    items["toggle"].MouseLeave:Connect(function()
        library:tween(items["checkbox"], {BackgroundColor3 = palette.frame_bg}, 0.06)
    end)

