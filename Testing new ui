-- Library functions 
    function library:tween(obj, properties, easing_style, time) 
        tween_service:Create(obj, TweenInfo.new(time or 0.25, easing_style or Enum.EasingStyle.Quint, Enum.EasingDirection.InOut), properties):Play()
    end

    function library:next_flag()
        local i = 0; for _ in pairs(library.flags) do i = i + 1 end
        return string.format("flag_%s", i + 1)
    end 

    function library:draggify(frame, handle)
        local dragging, start, start_size = false, nil, nil
        local dt = handle or frame
        dt.InputBegan:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = true; start = input.Position; start_size = frame.Position end end)
        dt.InputEnded:Connect(function(input) if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end end)
        library:connection(uis.InputChanged, function(input) 
            if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                local vx, vy = camera.ViewportSize.X, camera.ViewportSize.Y
                library:tween(frame, {Position = dim2(0, clamp(start_size.X.Offset + (input.Position.X - start.X), 0, vx - frame.AbsoluteSize.X), 0, clamp(start_size.Y.Offset + (input.Position.Y - start.Y), 0, vy - frame.AbsoluteSize.Y))}, Enum.EasingStyle.Linear, 0.05)
                library:close_element()
            end
        end)
    end 

    function library:convert_enum(enum)
        local parts = {}; for part in string.gmatch(enum, "[%w_]+") do insert(parts, part) end
        local t = Enum; for i = 2, #parts do t = t[parts[i]] end; return t
    end

    function library:get_settings_path() return library.directory .. "/library_settings.json" end

    function library:save_library_settings()
        pcall(function()
            writefile(library:get_settings_path(), http_service:JSONEncode({
                auto_load_config = library.auto_load_config_name,
                notifications_enabled = library.notifications_on,
                watermark_enabled = library.watermark_on,
                keybind_list_enabled = library.keybind_list_on,
                notif_position = library.notif_position,
                glow_enabled = library.glow_enabled,
                glow_transparency = library.glow_transparency,
            }))
        end)
    end

    function library:load_library_settings()
        pcall(function()
            if isfile(library:get_settings_path()) then
                local d = http_service:JSONDecode(readfile(library:get_settings_path()))
                library.auto_load_config_name = d.auto_load_config
                library.notifications_on = d.notifications_enabled ~= false
                library.watermark_on = d.watermark_enabled ~= false
                library.keybind_list_on = d.keybind_list_enabled ~= false
                library.notif_position = d.notif_position or "TopRight"
                library.glow_enabled = d.glow_enabled ~= false
                library.glow_transparency = d.glow_transparency or 0.85
                notifications.enabled = library.notifications_on
            end
        end)
    end

    function library:set_auto_load(n) library.auto_load_config_name = n; library:save_library_settings() end
    function library:clear_auto_load() library.auto_load_config_name = nil; library:save_library_settings() end
    function library:toggle_notifications(e) library.notifications_on = e; notifications.enabled = e; library:save_library_settings() end

    function library:do_auto_load()
        library:load_library_settings()
        if library.auto_load_config_name then
            local p = library.directory .. "/configs/" .. library.auto_load_config_name .. ".cfg"
            pcall(function()
                if isfile(p) then task.spawn(function() task.wait(0.5); library:load_config(readfile(p))
                    if notifications.enabled then notifications:create_notification({name = "Auto Load", info = "Loaded: " .. library.auto_load_config_name}) end
                end) end
            end)
        end
    end

