		function G:AddKeyPicker(idx, opts)
			opts = opts or {}
			local KName = opts.Text or idx
			local DefaultKey = opts.Default or "End"
			local Mode = opts.Mode or "Toggle"
			local NoUI = opts.NoUI or false
			local KCallback = opts.Callback or function() end
			local ChangedCb = opts.ChangedCallback or function() end
			local SyncToggle = opts.SyncToggleState or false

			local CurKey = ParseKeyName(DefaultKey)
			local Binding = false
			local Active = false

			local optObj = {Value=DefaultKey, _clickCallbacks={}, _changedCallbacks={}, _type="KeyPicker"}
			function optObj:OnClick(fn) table.insert(self._clickCallbacks, fn) end
			function optObj:OnChanged(fn) table.insert(self._changedCallbacks, fn) end
			function optObj:GetState() return Active end
			function optObj:SetValue(v)
				if typeof(v)=="table" then
					CurKey=ParseKeyName(v[1] or "End"); Mode=v[2] or "Toggle"
				else
					CurKey=ParseKeyName(v)
				end
				self.Value=GetKeyDisplayName(CurKey); kbData.Key=CurKey; kbData.Mode=Mode
				KB.Text="["..GetKeyDisplayName(CurKey).."]"; UpdateKeybindList()
				ChangedCb(CurKey); for _,fn in ipairs(self._changedCallbacks) do pcall(fn) end
			end
			Options[idx] = optObj

			local kbData = {Name=KName, Key=CurKey, Mode=Mode, Active=Active, NoUI=NoUI}
			Library.ActiveKeybinds[idx] = kbData

			local KF = Utility.Create("Frame", {Parent=container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,20), ZIndex=11})
			Utility.Create("TextLabel", {Parent=KF, BackgroundTransparency=1, Size=UDim2.new(1,-60,1,0), FontFace=Assets.FontRegular, Text=KName, TextColor3=Theme.TextDim, TextSize=12, TextXAlignment=Enum.TextXAlignment.Left, ZIndex=12})
			local KB = Utility.Create("TextButton", {Parent=KF, BackgroundTransparency=1, Position=UDim2.new(1,-60,0,0), Size=UDim2.new(0,60,1,0), FontFace=Assets.FontRegular, Text="["..GetKeyDisplayName(CurKey).."]", TextColor3=Theme.TextDimmer, TextSize=10, TextXAlignment=Enum.TextXAlignment.Right, AutoButtonColor=false, ZIndex=15})

			KB.MouseButton1Click:Connect(function()
				if Binding then return end; Binding=true; KB.Text="[...]"; KB.TextColor3=Theme.ButtonAccent
				local cn; cn=UserInputService.InputBegan:Connect(function(inp,gpe)
					if gpe then return end
					local newKey
					if inp.UserInputType==Enum.UserInputType.Keyboard then newKey=inp.KeyCode
					elseif inp.UserInputType==Enum.UserInputType.MouseButton1 then newKey=Enum.UserInputType.MouseButton1
					elseif inp.UserInputType==Enum.UserInputType.MouseButton2 then newKey=Enum.UserInputType.MouseButton2
					elseif inp.UserInputType==Enum.UserInputType.MouseButton3 then newKey=Enum.UserInputType.MouseButton3 end
					if newKey then
						CurKey=newKey; kbData.Key=CurKey; optObj.Value=GetKeyDisplayName(CurKey)
						KB.Text="["..GetKeyDisplayName(CurKey).."]"; KB.TextColor3=Theme.TextDimmer
						Binding=false; cn:Disconnect(); UpdateKeybindList()
						ChangedCb(CurKey); for _,fn in ipairs(optObj._changedCallbacks) do pcall(fn) end
					end
				end)
			end)

			UserInputService.InputBegan:Connect(function(inp,gp)
				if gp or Binding then return end
				local match=false
				if typeof(CurKey)=="EnumItem" then
					if CurKey.EnumType==Enum.KeyCode and inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==CurKey then match=true end
					if CurKey.EnumType==Enum.UserInputType and inp.UserInputType==CurKey then match=true end
				end
				if match then
					if Mode=="Toggle" then Active=not Active; kbData.Active=Active; UpdateKeybindList(); KCallback(Active); for _,fn in ipairs(optObj._clickCallbacks) do pcall(fn) end
					elseif Mode=="Hold" then Active=true; kbData.Active=Active; UpdateKeybindList(); KCallback(true)
					elseif Mode=="Always" then Active=true; kbData.Active=true; UpdateKeybindList(); KCallback(true) end
				end
			end)
			UserInputService.InputEnded:Connect(function(inp)
				if Binding then return end
				local match=false
				if typeof(CurKey)=="EnumItem" then
					if CurKey.EnumType==Enum.KeyCode and inp.UserInputType==Enum.UserInputType.Keyboard and inp.KeyCode==CurKey then match=true end
					if CurKey.EnumType==Enum.UserInputType and inp.UserInputType==CurKey then match=true end
				end
				if match and Mode=="Hold" then Active=false; kbData.Active=false; UpdateKeybindList(); KCallback(false) end
			end)

			ConfigSystem:Register(idx, function() return {Key=GetKeyDisplayName(CurKey), Mode=Mode} end, function(v)
				if v.Key then CurKey=ParseKeyName(v.Key); kbData.Key=CurKey; KB.Text="["..GetKeyDisplayName(CurKey).."]" end
				if v.Mode then Mode=v.Mode; kbData.Mode=Mode end
				optObj.Value=GetKeyDisplayName(CurKey); UpdateKeybindList()
			end)

			return optObj
		end

		function G:AddDependencyBox()
			local DepContainer = Utility.Create("Frame", {Parent=container, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Visible=false, ZIndex=10})
			Utility.Create("UIListLayout", {Parent=DepContainer, SortOrder=Enum.SortOrder.LayoutOrder, Padding=UDim.new(0,2)})

			local depObj = {}
			BuildElementFunctions(DepContainer, depObj)

			function depObj:SetupDependencies(deps)
				local function check()
					local visible = true
					for _,dep in ipairs(deps) do
						local toggle, expected = dep[1], dep[2]
						if toggle.Value ~= expected then visible=false; break end
					end
					DepContainer.Visible = visible
				end
				for _,dep in ipairs(deps) do
					dep[1]:OnChanged(check)
				end
				check()
			end

			return depObj
		end

		return G
	end

