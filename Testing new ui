            has = true
            local row = library:create("Frame", {
                Parent = library.keybind_list_elements, BackgroundTransparency = 1,
                Size = dim2(1, 0, 0, 16),
            })
            library:create("TextLabel", {
                FontFace = fonts.regular, Text = bd.name, TextColor3 = palette.text,
                Parent = row, Size = dim2(1, -50, 1, 0), BackgroundTransparency = 1,
                TextXAlignment = Enum.TextXAlignment.Left, TextSize = 11,
            })
            local kt = library:create("TextLabel", {
                FontFace = fonts.regular, Text = "[" .. bd.key_text .. "]",
                TextColor3 = themes.preset.accent, Parent = row,
                Size = dim2(0, 45, 1, 0), Position = dim2(1, -45, 0, 0),
                BackgroundTransparency = 1, TextXAlignment = Enum.TextXAlignment.Right, TextSize = 10,
