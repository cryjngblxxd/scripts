					Image = library_t.cursor,
					Visible = true,
					Size = UDim2.new(0, 34, 0, 34),
					Position = UDim2.new(0, mouse_location.X, 0, mouse_location.Y - 56),
					BackgroundTransparency = 1
				});
			end;

			utility_t.create_outlines(main_frame, {
				{ color = library_t.theme.outline_color_1, thickness = 1 },
				{ color = library_t.theme.outline_color_2, thickness = 1 },
				{ color = library_t.theme.outline_color_2, thickness = 1 },
				{ color = library_t.theme.outline_color_2, thickness = 1 },
				{ color = library_t.theme.outline_color_1, thickness = 1 },
				{ color = library_t.theme.outline_color_3, thickness = 1 }
			});

			local tab_frame = utility_t.new_instance("Frame", {
				Parent = main_frame,
				Position = UDim2.new(0, 18, 0, 19),
				Size = UDim2.new(1, -36, 0, 25),
				BackgroundColor3 = library_t.theme.tab_background,
				BorderSizePixel = 0,
				ClipsDescendants = true
			});

			utility_t.new_instance("UIStroke", {
				Parent = tab_frame,
				LineJoinMode = Enum.LineJoinMode.Miter,
				ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
				Color = library_t.theme.stroke_color
			});

			local tab_scroll_frame = utility_t.new_instance("ScrollingFrame", {
				Parent = tab_frame,
				Size = UDim2.new(1, 0, 1, 0),
				Position = UDim2.new(0, 0, 0, 0),
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				ScrollBarThickness = 0,
				ScrollBarImageTransparency = 1,
				ScrollingDirection = Enum.ScrollingDirection.X,
				CanvasSize = UDim2.new(0, 0, 0, 0),
				ElasticBehavior = Enum.ElasticBehavior.Never,
				ScrollingEnabled = true,
			});

			local tab_content_frame = utility_t.new_instance("Frame", {
				Parent = tab_scroll_frame,
				BackgroundTransparency = 1,
				BorderSizePixel = 0,
				Size = UDim2.new(0, 0, 1, 0),
				Position = UDim2.new(0, 0, 0, 0),
				AutomaticSize = Enum.AutomaticSize.X
			});

			local tab_list_layout = utility_t.new_instance("UIListLayout", {
				Parent = tab_content_frame,
				SortOrder = Enum.SortOrder.LayoutOrder,
				FillDirection = Enum.FillDirection.Horizontal,
				VerticalAlignment = Enum.VerticalAlignment.Center
			});

			utility_t.connect(tab_list_layout:GetPropertyChangedSignal("AbsoluteContentSize"), function()
				tab_scroll_frame.CanvasSize = UDim2.new(0, tab_list_layout.AbsoluteContentSize.X + 10, 0, 0);
			end);

			utility_t.connect(user_input_service.InputChanged, function(input)
				if library_t.base.is_open and input.UserInputType == Enum.UserInputType.MouseWheel and utility_t.is_mouse_in_frame(tab_frame) then
					local scroll_amount = input.Position.Z < 0 and 50 or -50;
					local max_scroll = math.max(0, tab_scroll_frame.CanvasSize.X.Offset - tab_scroll_frame.AbsoluteSize.X);
					tween_service:Create(tab_scroll_frame, TweenInfo.new(0.1, Enum.EasingStyle.Cubic, Enum.EasingDirection.Out), {
						CanvasPosition = Vector2.new(math.clamp(tab_scroll_frame.CanvasPosition.X + scroll_amount, 0, max_scroll), 0)
					}):Play();
				end;
			end);

			local _, drag_signal = utility_t.new_button({
				Parent = main_frame,
				Size = UDim2.new(1, 0, 0, 18),
				BackgroundTransparency = 1,
				TextTransparency = 1,
			});

			local _, resize_signal = utility_t.new_button({
				Parent = main_frame,
				Size = UDim2.new(0, 10, 0, 10),
				Position = UDim2.new(1, -10, 1, -10),
				BackgroundTransparency = 1,
				TextTransparency = 1,
			});

			utility_t.connect(resize_signal, function()
				is_resizing = true;
				initial_size = main_frame.Size;
				initial_mouse_pos_resize = user_input_service:GetMouseLocation();
			end);

			utility_t.connect(drag_signal, function()
				is_dragging = true;
				initial_frame_pos = main_frame.Position;
				initial_mouse_pos = user_input_service:GetMouseLocation();
			end);

			local set_open = function(state)
				if state then
					pcall(function()
						context_action_service:BindAction("Scrolling", function() return Enum.ContextActionResult.Sink end, false, Enum.UserInputType.MouseWheel);
					end);
				else
					pcall(function()
						context_action_service:UnbindAction("Scrolling");
					end);
				end;
			end;

			set_open(library_t.base.is_open);

			utility_t.connect(user_input_service.InputChanged, function(input)
				if input.UserInputType == Enum.UserInputType.MouseMovement then
					if is_dragging then
						local current_mouse_pos = user_input_service:GetMouseLocation();
						local delta_x = current_mouse_pos.X - initial_mouse_pos.X;
						local delta_y = current_mouse_pos.Y - initial_mouse_pos.Y;
						main_frame.Position = UDim2.new(initial_frame_pos.X.Scale, initial_frame_pos.X.Offset + delta_x, initial_frame_pos.Y.Scale, initial_frame_pos.Y.Offset + delta_y);
					end;
					if is_resizing then
						local mouse_position = user_input_service:GetMouseLocation();
						local delta_x = mouse_position.X - initial_mouse_pos_resize.X;
						local delta_y = mouse_position.Y - initial_mouse_pos_resize.Y;
						local new_size = Vector2.new(
							math.max(initial_size.X.Offset + delta_x, size.X),
							math.max(initial_size.Y.Offset + delta_y, size.Y)
						);
						main_frame.Size = UDim2.new(0, new_size.X, 0, new_size.Y);
					end;
					if cursor_frame then
						local ml = user_input_service:GetMouseLocation();
						cursor_frame.Position = UDim2.new(0, ml.X, 0, ml.Y - 56);
					end;
				end;
			end);

			utility_t.connect(user_input_service.InputEnded, function(input)
				if input.UserInputType == Enum.UserInputType.MouseButton1 then
					is_dragging = false;
					is_resizing = false;
				end;
			end);

			local main_library = setmetatable(library_t, {});

			main_library.screen_gui = screen_gui;
			main_library.tab_content_frame = tab_content_frame;
			main_library.tab_scroll_frame = tab_scroll_frame;
			main_library.tab_padding = tab_content_frame;
			main_library.main_frame = main_frame;

			main_library:set_project(project);

			utility_t.connect(user_input_service.InputBegan, function(input)
				if input.KeyCode == library_t.toggle_key then
					main_library.base.is_open = not main_library.base.is_open;
					screen_gui.Enabled = main_library.base.is_open;
					set_open(library_t.base.is_open);
				end;
			end);

			-- FIX #4: Handle both left-click and right-click for buttons
			utility_t.connect(user_input_service.InputBegan, function(input)
				if (input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2) and main_library.base.is_open then
					for _, button_object in buttons do
						if utility_t.is_mouse_in_frame(button_object.button) then
							if not utility_t.is_parents_visible(button_object.button) then
								continue;
							end;
							if input.UserInputType == Enum.UserInputType.MouseButton1 then
								button_object.pressed:fire();
							elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
								button_object.right_pressed:fire();
							end;
							break;
						end;
					end
				end;
			end);

			return main_library;
		end;

		library_t.create_settings_tab = function(self)
			local settings_tab = self:tab({ name = "settings" });

			-- Font section
			local font_section = settings_tab:section({ name = "font", side = "left", size = 80 });

			local font_names = {};
			for fname, _ in pairs(self.available_fonts) do
				table.insert(font_names, fname);
			end;
			table.sort(font_names);

			font_section:dropdown({
				name = "font family",
				options = font_names,
				default = self.current_font_name,
				flag = "__settings_font",
				callback = function(selected)
					self:change_font(selected);
				end
			});

			-- Theme section
			local theme_section = settings_tab:section({ name = "theme colors", side = "left", size = 220 });

			local theme_keys = {
				{ key = "accent", name = "accent" },
				{ key = "background_color", name = "background" },
				{ key = "background_color_picker", name = "colorpicker bg" },
				{ key = "dots_color", name = "dots pattern" },
				{ key = "text_color", name = "text" },
				{ key = "section_color", name = "section" },
				{ key = "element_color", name = "elements" },
				{ key = "border_color", name = "borders" },
				{ key = "stroke_color", name = "strokes" },
				{ key = "tab_background", name = "tab background" },
				{ key = "outline_color_1", name = "outline 1" },
				{ key = "outline_color_2", name = "outline 2" },
				{ key = "outline_color_3", name = "outline 3" },
			};

			for _, theme_info in ipairs(theme_keys) do
				theme_section:colorpicker({
					name = theme_info.name,
					default = self.theme[theme_info.key],
					flag = "__theme_" .. theme_info.key,
					info = theme_info.name,
					callback = function(data)
						local color = nil;
						if type(data) == "table" and data.color then
							color = data.color;
						elseif typeof(data) == "Color3" then
							color = data;
						end;
						if color then
							self.theme[theme_info.key] = color;
							-- FIX #1: If accent changed, propagate to all tracked objects
							if theme_info.key == "accent" then
								self:update_accent(color);
							end;
						end;
					end
				});
			end;

			-- Config section
			local config_section = settings_tab:section({ name = "configs", side = "right", size = 260 });

			local config_list = self:get_configs();

			local config_dropdown = config_section:dropdown({
				name = "config",
				options = #config_list > 0 and config_list or {"none"},
				default = #config_list > 0 and config_list[1] or "none",
				flag = "__settings_config_select"
			});

			config_section:textbox({
				name = "config name",
				placeholder = "enter name...",
				flag = "__settings_config_name"
			});

			config_section:button({
				name = "save config",
				callback = function()
					local config_name = self.flags["__settings_config_name"];
					if config_name and config_name ~= "" then
						self:save_config(config_name);
						local configs = self:get_configs();
						config_dropdown.refresh(#configs > 0 and configs or {"none"});
					end;
				end
			});

			config_section:button({
				name = "load config",
				callback = function()
					local selected = self.flags["__settings_config_select"];
					if selected and selected ~= "none" then
						self:load_config_by_name(selected);
					end;
				end
			});

			config_section:button({
				name = "delete config",
				callback = function()
					local selected = self.flags["__settings_config_select"];
					if selected and selected ~= "none" then
						self:delete_config(selected);
						local configs = self:get_configs();
						config_dropdown.refresh(#configs > 0 and configs or {"none"});
					end;
				end
			});

			config_section:button({
				name = "refresh configs",
				callback = function()
					local configs = self:get_configs();
					config_dropdown.refresh(#configs > 0 and configs or {"none"});
				end
			});

			-- Auto load section
			local autoload_section = settings_tab:section({ name = "auto load", side = "right", size = 100 });

			autoload_section:button({
				name = "set auto load",
				callback = function()
					local selected = self.flags["__settings_config_select"];
					if selected and selected ~= "none" then
						self:set_auto_load(selected);
					end;
				end
			});

			autoload_section:button({
				name = "remove auto load",
				callback = function()
					self:remove_auto_load();
				end
			});

			-- UI section
			local ui_section = settings_tab:section({ name = "ui settings", side = "right", size = 100 });

			ui_section:keybind({
				name = "toggle key",
				default = self.toggle_key,
				flag = "__settings_toggle_key",
				index_mode = true,
				callback = function(key)
					if key then
						self.toggle_key = key;
					end;
				end
			});

			ui_section:button({
				name = "unload ui",
				callback = function()
					if getgenv and getgenv().unload_ui then
						getgenv().unload_ui();
					end;
				end
			});

			return settings_tab;
		end;

		library_t.create_config = function(self)
			local cfg = {};
			for flag, value in pairs(library_t.flags) do
				if string.sub(tostring(flag), 1, 2) == "__" then
					continue;
				end;
				if not self.base.key_flags[flag] then
					cfg[flag] = value;
					if type(value) == "table" and value.color then
						cfg[flag] = {color = {value.color.R, value.color.G, value.color.B}, transparency = value.transparency or nil};
					end;
				end;
			end;
			for flag, value in pairs(self.base.key_flags) do
				if string.sub(tostring(flag), 1, 2) == "__" then
					continue;
				end;
				if value then
					cfg[flag] = value.Name;
				end;
			end;
			return http_service:JSONEncode(cfg);
		end;

		library_t.load_config = function(self, cfg)
			local success, actual_cfg = pcall(function()
				return http_service:JSONDecode(cfg);
			end);
			if not success then
				return false;
			end;
			for flag, value in pairs(actual_cfg) do
				if self.base.save_flags[flag] then
					self.base.save_flags[flag](value);
				end;
			end;
			return true;
		end;

		library_t.save_config = function(self, config_name)
			if run_service:IsStudio() then return; end;
			self:ensure_directories();
			local path = self:get_config_path() .. "/" .. config_name .. ".json";
			writefile(path, self:create_config());
		end;

		library_t.load_config_by_name = function(self, config_name)
			if run_service:IsStudio() then return false; end;
			local path = self:get_config_path() .. "/" .. config_name .. ".json";
			if isfile(path) then
				return self:load_config(readfile(path));
			end;
			return false;
		end;
	end;
end;

return library_t;
