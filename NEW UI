				if tab_layout then
					self.tab_scroll_frame.CanvasSize = UDim2.new(0, tab_layout.AbsoluteContentSize.X + 10, 0, 0);
				end;
			end;

			return tab;
		end;

		library_t.set_project = function(self, project_name)
			self.project_name = project_name;
			if not run_service:IsStudio() then
				self:ensure_directories();
			end;
		end;

		library_t.get_config_path = function(self)
			return self.assets_dir .. "/" .. self.project_name .. "/configs";
		end;

		library_t.get_settings_path = function(self)
			return self.assets_dir .. "/" .. self.project_name .. "/settings.json";
		end;

		library_t.ensure_directories = function(self)
			if run_service:IsStudio() then return; end;
			if not isfolder(self.assets_dir) then
				makefolder(self.assets_dir);
			end;
			if not isfolder(self.assets_dir .. "/" .. self.project_name) then
				makefolder(self.assets_dir .. "/" .. self.project_name);
			end;
			if not isfolder(self:get_config_path()) then
				makefolder(self:get_config_path());
			end;
		end;

		library_t.get_configs = function(self)
			if run_service:IsStudio() then return {}; end;
			self:ensure_directories();
			local configs = {};
			local success, files = pcall(function()
				return listfiles(self:get_config_path());
			end);
			if success and files then
				for _, file in ipairs(files) do
					local file_name = file:match("([^/\\]+)%.json$");
					if file_name then
						table.insert(configs, file_name);
					end;
				end;
			end;
			return configs;
		end;

		library_t.set_auto_load = function(self, config_name)
			if run_service:IsStudio() then return; end;
			self:ensure_directories();
			local settings = {};
			if isfile(self:get_settings_path()) then
				pcall(function()
					settings = http_service:JSONDecode(readfile(self:get_settings_path()));
				end);
			end;
			settings.auto_load = config_name;
			writefile(self:get_settings_path(), http_service:JSONEncode(settings));
		end;

		library_t.get_auto_load = function(self)
			if run_service:IsStudio() then return nil; end;
			self:ensure_directories();
			if isfile(self:get_settings_path()) then
				local success, settings = pcall(function()
					return http_service:JSONDecode(readfile(self:get_settings_path()));
				end);
				if success and settings and settings.auto_load then
					return settings.auto_load;
				end;
			end;
			return nil;
		end;

		library_t.remove_auto_load = function(self)
			if run_service:IsStudio() then return; end;
			self:ensure_directories();
			local settings = {};
			if isfile(self:get_settings_path()) then
				pcall(function()
					settings = http_service:JSONDecode(readfile(self:get_settings_path()));
				end);
			end;
			settings.auto_load = nil;
			writefile(self:get_settings_path(), http_service:JSONEncode(settings));
		end;

		library_t.delete_config = function(self, config_name)
			if run_service:IsStudio() then return false; end;
			local path = self:get_config_path() .. "/" .. config_name .. ".json";
			if isfile(path) then
				delfile(path);
				return true;
			end;
			return false;
		end;

