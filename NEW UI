				ApplyStrokeMode = Enum.ApplyStrokeMode.Border,
				Color = library_t.theme.border_color,
				Thickness = 1
			});

			local mode_layout = utility_t.new_instance("UIListLayout", {
				Parent = mode_popup,
				SortOrder = Enum.SortOrder.LayoutOrder,
				FillDirection = Enum.FillDirection.Vertical,
				Padding = UDim.new(0, 2),
			});

			utility_t.new_instance("UIPadding", {
				Parent = mode_popup,
				PaddingTop = UDim.new(0, 3),
				PaddingLeft = UDim.new(0, 4),
			});

			local mode_options = {"always", "toggle", "hold"};
			local mode_labels = {};

			for _, mode_name in ipairs(mode_options) do
				local mode_btn, mode_pressed = utility_t.new_button({
					Parent = mode_popup,
					Size = UDim2.new(1, -8, 0, 14),
					BackgroundTransparency = 1,
					BorderSizePixel = 0,
					ZIndex = 2001,
					FontFace = library_t.font,
					TextSize = library_t.font_size,
					TextColor3 = mode == mode_name and library_t.theme.accent or library_t.theme.text_color,
					TextXAlignment = Enum.TextXAlignment.Left,
					Text = mode_name,
				});

				utility_t.new_instance("TextLabel", {
					Parent = mode_btn,
					Size = UDim2.new(1, 0, 1, 0),
					Position = UDim2.new(0, 1, 0, 1),
					ZIndex = 2000,
					FontFace = library_t.font,
					TextSize = library_t.font_size,
					BackgroundTransparency = 1,
					TextColor3 = Color3.fromRGB(0, 0, 0),
					TextXAlignment = Enum.TextXAlignment.Left,
					Text = mode_name,
					BorderSizePixel = 0
				});

				mode_labels[mode_name] = mode_btn;

				utility_t.connect(mode_pressed, function()
					-- Update mode
					mode = mode_name;
					-- Update label colors
					for mn, ml in pairs(mode_labels) do
						ml.TextColor3 = mn == mode and library_t.theme.accent or library_t.theme.text_color;
					end;
					-- Handle "always" mode
					if mode == "always" then
						state = true;
						library_t.flags[flag] = true;
						callback(true);
					else
						if not index_mode then
							state = false;
							library_t.flags[flag] = false;
							callback(false);
						end;
					end;
					-- Close popup
					mode_popup.Visible = false;
					self.lib.base.current_keybind_menu = nil;
				end);
			end;

			local update_pos = function()
				local text_size = keybind_text.TextBounds;
				keybind_frame.Size = UDim2.new(0, text_size.X + 9, 0, 10);
				keybind_frame.Position = UDim2.new(1, -text_size.X - 4, 0, 0);
			end;

			local set_key = function(key)
				if key then
					local key_enum = nil;
					if typeof(key) == "EnumItem" then
						key_enum = key;
					elseif type(key) == "string" then
						local ok1, v1 = pcall(function() return Enum.KeyCode[key] end);
						local ok2, v2 = pcall(function() return Enum.UserInputType[key] end);
						key_enum = (ok1 and v1) or (ok2 and v2) or nil;
					end;
					if key_enum then
						current_key = key_enum;
						keybind_text.Text = "[" .. key_enum.Name:lower() .. "]";
						shadow.Text = "[" .. key_enum.Name:lower() .. "]";
						self.lib.base.key_flags[flag] = key_enum;
						if index_mode then
							library_t.flags[flag] = key_enum;
						else
							if mode == "always" then
								library_t.flags[flag] = true;
							else
								library_t.flags[flag] = false;
							end;
						end;
						update_pos();
						callback(key_enum);
					end;
				else
					current_key = nil;
					keybind_text.Text = "[none]";
					shadow.Text = "[none]";
					self.lib.base.key_flags[flag] = nil;
					if index_mode then
						library_t.flags[flag] = nil;
					else
						library_t.flags[flag] = false;
					end;
					update_pos();
					callback(nil);
				end;
			end;

			self.lib.base.save_flags[flag] = set_key;
			update_pos();

			-- Left-click: select key
			utility_t.connect(pressed_signal, function()
				if not is_selecting and self.lib.base.current_tab == self.tab and utility_t.is_in_main_frame(keybind_button, self.main_frame) then
					is_selecting = true;
					keybind_text.Text = "[...]";
					shadow.Text = "[...]";
					update_pos();
				end;
			end);

			-- Right-click: open mode menu
			utility_t.connect(right_pressed_signal, function()
				if not index_mode and not is_selecting and self.lib.base.current_tab == self.tab and utility_t.is_in_main_frame(keybind_button, self.main_frame) then
					-- Close any other open keybind menu
					if self.lib.base.current_keybind_menu and self.lib.base.current_keybind_menu ~= mode_popup then
						self.lib.base.current_keybind_menu.Visible = false;
					end;
					local abs_pos = keybind_button.AbsolutePosition;
					mode_popup.Position = UDim2.new(0, abs_pos.X, 0, abs_pos.Y + 15);
					mode_popup.Visible = not mode_popup.Visible;
					if mode_popup.Visible then
						self.lib.base.current_keybind_menu = mode_popup;
						-- Update highlight
						for mn, ml in pairs(mode_labels) do
							ml.TextColor3 = mn == mode and library_t.theme.accent or library_t.theme.text_color;
						end;
					else
						self.lib.base.current_keybind_menu = nil;
					end;
				end;
			end);

			-- Close mode popup on click outside
			utility_t.connect(user_input_service.InputBegan, function(input)
				if mode_popup.Visible and input.UserInputType == Enum.UserInputType.MouseButton1 then
					if not utility_t.is_mouse_in_frame(mode_popup) and not utility_t.is_mouse_in_frame(keybind_button) then
						mode_popup.Visible = false;
						self.lib.base.current_keybind_menu = nil;
					end;
				end;
			end);

			utility_t.connect(user_input_service.InputBegan, function(input)
				if is_selecting and input.KeyCode == Enum.KeyCode.Escape then
					is_selecting = false;
					keybind_text.Text = current_key and ("[" .. current_key.Name:lower() .. "]") or "[none]";
					shadow.Text = current_key and ("[" .. current_key.Name:lower() .. "]") or "[none]";
					update_pos();
					return;
				end;
				if is_selecting then
					local key = nil;
					if input.UserInputType == Enum.UserInputType.Keyboard then
						key = input.KeyCode;
					elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
						-- Don't capture mouse clicks during selection to avoid conflicts
						return;
					end;
					if key then
						is_selecting = false;
						set_key(key);
					end;
					return;
				end;
				if not is_selecting and not index_mode and current_key then
					local should_trigger = false;
					if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == current_key then
						should_trigger = true;
					elseif input.UserInputType == current_key then
						should_trigger = true;
					end;
					if should_trigger then
						if mode == "toggle" then
							state = not state;
							library_t.flags[flag] = state;
							callback(state);
						elseif mode == "hold" then
							state = true;
							library_t.flags[flag] = state;
							callback(state);
						end;
						-- "always" mode doesn't need input handling, it's always true
					end;
				end;
			end);

			utility_t.connect(user_input_service.InputEnded, function(input)
				if not index_mode and current_key and mode == "hold" then
					local should_release = false;
					if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode == current_key then
						should_release = true;
					elseif input.UserInputType == current_key then
						should_release = true;
					end;
					if should_release then
						state = false;
						library_t.flags[flag] = state;
						callback(state);
					end;
				end;
			end);
		end;

