				BorderSizePixel = 0,
				TextTransparency = 1
			});

			-- Right-click mode popup
			local mode_popup = utility_t.new_instance("Frame", {
				Parent = self.lib.screen_gui,
				Size = UDim2.new(0, 80, 0, 52),
