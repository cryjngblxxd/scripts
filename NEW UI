	-- FIX #1: Function to update all accent-colored objects
	library_t.update_accent = function(self, new_accent)
		self.theme.accent = new_accent;
		for _, obj in ipairs(self._accent_objects) do
			pcall(function()
				if obj.type == "gradient" then
					obj.instance.Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0, new_accent),
						ColorSequenceKeypoint.new(1, utility_t.darken_color(new_accent, obj.darken or 0.5))
					});
				elseif obj.type == "color" then
					obj.instance[obj.property] = new_accent;
				elseif obj.type == "toggle_gradient" then
					-- Only update if the toggle is currently enabled
					if obj.get_state and obj.get_state() then
						obj.instance.Color = ColorSequence.new({
							ColorSequenceKeypoint.new(0, new_accent),
							ColorSequenceKeypoint.new(1, utility_t.darken_color(new_accent, 0.8))
						});
					end;
				elseif obj.type == "slider_gradient" then
					obj.instance.Color = ColorSequence.new({
						ColorSequenceKeypoint.new(0, new_accent),
						ColorSequenceKeypoint.new(1, utility_t.darken_color(new_accent, 0.5))
					});
				end;
			end);
		end;
		-- Update active tab button color
		if self.base and self.base.tabs then
			for _, tab in ipairs(self.base.tabs) do
				if self.base.current_tab == tab then
					pcall(function() tab.tab_button.TextColor3 = new_accent; end);
				end;
			end;
		end;
	end;

	-- Helper to register an accent-tracked object
	local function track_accent(obj_data)
		library_t._accent_objects[#library_t._accent_objects + 1] = obj_data;
	end;

	library_t.change_font = function(self, font_name)
		local font_data = self.available_fonts[font_name];
		if not font_data then return false; end;

		self.current_font_name = font_name;

		if font_data.roblox then
			self.font = Font.new(font_data.roblox, Enum.FontWeight.Regular, Enum.FontStyle.Normal);
		elseif font_data.link and not run_service:IsStudio() then
			local file_path = self.assets_dir .. "/" .. font_data.file;
			if not isfile(file_path) then
				local success, data = pcall(function()
					return game:HttpGet(font_data.link);
				end);
				if not success then return false; end;
				writefile(file_path, data);
			end;

			local custom_font = {
				name = "FONT_" .. font_name:gsub("%s", "_"),
				faces = {
					{
						name = "Regular",
						weight = 400,
						style = "normal",
						assetId = getcustomasset(file_path)
					}
				}
			};

			local font_json_path = self.assets_dir .. "/" .. font_data.file:gsub("%.[^.]+$", "") .. ".font";
			writefile(font_json_path, http_service:JSONEncode(custom_font));
			self.font = Font.new(getcustomasset(font_json_path), Enum.FontWeight.Regular, Enum.FontStyle.Normal);
		end;

		for _, inst in ipairs(instances) do
			if inst and inst.Parent then
				pcall(function()
					if inst:IsA("TextLabel") or inst:IsA("TextBox") or inst:IsA("TextButton") then
						inst.FontFace = self.font;
					end;
				end);
			end;
		end;

		return true;
	end;

