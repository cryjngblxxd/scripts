local function SetupKeybindHandler()
Library:Connection(UIS.InputBegan, function(input, gp)
if gp then return end
local key
if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode
elseif input.UserInputType == Enum.UserInputType.MouseButton1 then key = Enum.UserInputType.MouseButton1
elseif input.UserInputType == Enum.UserInputType.MouseButton2 then key = Enum.UserInputType.MouseButton2
elseif input.UserInputType == Enum.UserInputType.MouseButton3 then key = Enum.UserInputType.MouseButton3 end
if not key then return end
for _, kb in ipairs(Library._keybinds) do
if kb.Key == key and not kb.Binding and not kb._keyDown then
kb._keyDown = true
if kb.Mode == "Hold" then kb.Active = true; kb:_updateFlag(); if kb._onClick then task.spawn(pcall, kb._onClick, true) end
elseif kb.Mode == "Toggle" then kb.Active = not kb.Active; kb:_updateFlag(); if kb._onClick then task.spawn(pcall, kb._onClick, kb.Active) end
elseif kb.Mode == "Always" then kb.Active = true; kb:_updateFlag() end
end
end
end)
Library:Connection(UIS.InputEnded, function(input)
local key
if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode
elseif input.UserInputType == Enum.UserInputType.MouseButton1 then key = Enum.UserInputType.MouseButton1
elseif input.UserInputType == Enum.UserInputType.MouseButton2 then key = Enum.UserInputType.MouseButton2
elseif input.UserInputType == Enum.UserInputType.MouseButton3 then key = Enum.UserInputType.MouseButton3 end
if not key then return end
for _, kb in ipairs(Library._keybinds) do
if kb.Key == key then
kb._keyDown = false
if kb.Mode == "Hold" and kb.Active then kb.Active = false; kb:_updateFlag(); if kb._onClick then task.spawn(pcall, kb._onClick, false) end end
end
end
end)
end

local function SetupMenuToggle()
if Library._menuToggleSetup then return end
Library._menuToggleSetup = true
Library:Connection(UIS.InputBegan, function(input, gp)
if gp or not Library.Holder then return end
local key
if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode end
if not key then return end
if Library.ToggleKeybind then
local tkb = Library.ToggleKeybind
if tkb.Key and key == tkb.Key then Library.Open = not Library.Open; Library.Holder.Visible = Library.Open; return end
end
if key == Enum.KeyCode.Insert or key == Enum.KeyCode.End or key == Enum.KeyCode.RightControl then
Library.Open = not Library.Open; Library.Holder.Visible = Library.Open
end
end)
end

local function resolveKeyFromString(str)
if not str or str == "" or str == "Unknown" or str == "NONE" then return nil end
if str == "MB1" then return Enum.UserInputType.MouseButton1 end
if str == "MB2" then return Enum.UserInputType.MouseButton2 end
if str == "MB3" then return Enum.UserInputType.MouseButton3 end
for enumKey, shortName in pairs(Library.Keys) do if shortName == str then return enumKey end end
local s, r = pcall(function() return Enum.KeyCode[str] end)
if s and r then return r end
return nil
end

local function getKeyName(key)
if not key or key == Enum.KeyCode.Unknown then return "Unknown" end
if Library.Keys[key] then return Library.Keys[key] end
return tostring(key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
end

