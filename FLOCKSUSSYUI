local function getSnapZone(element)
local aP, aS = PreviewArea.AbsolutePosition, PreviewArea.AbsoluteSize; local eP, eS = element.AbsolutePosition, element.AbsoluteSize
local rx = (eP.X+eS.X/2)-(aP.X+aS.X/2); local ry = (eP.Y+eS.Y/2)-(aP.Y+aS.Y/2)
if math.abs(ry) > math.abs(rx) then return ry < 0 and "Top" or "Bottom" else return rx < 0 and "Left" or "Right" end
end
local function getElementsInZone(zone) local e = {}; for _, n in ipairs({"Name","Distance","Armor","Tool"}) do if preview._elementPositions[n] == zone then e[#e+1] = n end end; return e end
local function updateAllPositions()
local cH, cW, aS = preview._charH, preview._charW, PreviewArea.AbsoluteSize; if cH == 0 or cW == 0 or aS.X < 50 then return end; local sp = 14
for _, zone in ipairs(SNAP_ZONES) do for si, en in ipairs(getElementsInZone(zone)) do local el = preview["_"..en:lower().."ESP"]; if el then local x, y, ax, ay = 0.5, 0.5, 0.5, 0.5; local idx = si-1; if zone == "Top" then y = 0.5-(cH/2+boxPad+6+idx*sp)/aS.Y; ay = 1 elseif zone == "Bottom" then y = 0.5+(cH/2+boxPad+6+idx*sp)/aS.Y; ay = 0 elseif zone == "Left" then x = 0.5-(cW/2+boxPad+12)/aS.X; y = 0.5-(cH/2-idx*sp)/aS.Y; ax = 1; ay = 0 elseif zone == "Right" then x = 0.5+(cW/2+boxPad+12)/aS.X; y = 0.5-(cH/2-idx*sp)/aS.Y; ax = 0; ay = 0 end; el.Position = UDim2.new(x, 0, y, 0); el.AnchorPoint = Vector2.new(ax, ay) end end end
for _, info in ipairs({{preview._healthBarBG,"Health"},{preview._armorBarBG,"ArmorBar"}}) do local bar, name = info[1], info[2]; if bar and preview._elementPositions[name] then local zone = preview._elementPositions[name]; local x, ax = 0.5, 0.5; if zone == "Left" then x = 0.5-(cW/2+boxPad+6)/aS.X; ax = 1 elseif zone == "Right" then x = 0.5+(cW/2+boxPad+6)/aS.X; ax = 0 end; bar.Position = UDim2.new(x, 0, 0.5, 0); bar.AnchorPoint = Vector2.new(ax, 0.5) end end
end
