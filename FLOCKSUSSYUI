element.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then if dragging then local aC = PreviewArea.AbsolutePosition.X + PreviewArea.AbsoluteSize.X/2; preview._elementPositions[elementName] = (element.AbsolutePosition.X + element.AbsoluteSize.X/2) < aC and "Left" or "Right"; updateAllPositions() end; dragging = false end end)
