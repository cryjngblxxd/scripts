element.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then if dragging then preview._elementPositions[elementName] = getSnapZone(element); updateAllPositions() end; dragging = false end end)
