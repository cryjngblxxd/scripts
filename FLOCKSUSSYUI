function Library:GetConfig()
local cfg = {}
for idx, toggle in pairs(Toggles) do
if self._configIgnore[idx] then continue end
cfg["t_" .. idx] = toggle.Value
end
for idx, option in pairs(Options) do
if self._configIgnore[idx] then continue end
local v = option.Value
if option.Type == "ColorPicker" then
if typeof(v) == "Color3" then
cfg["o_" .. idx] = {T = "C3", R = math.floor(v.R * 255), G = math.floor(v.G * 255), B = math.floor(v.B * 255)}
end
elseif option.Type == "KeyPicker" then
local keyName = "Unknown"
if option.Value and option.Value ~= "" then keyName = tostring(option.Value) end
cfg["o_" .. idx] = {T = "KP", K = keyName, M = option.Mode or "Toggle"}
elseif option.Type == "Slider" then
cfg["o_" .. idx] = {T = "SL", V = v}
elseif option.Type == "Dropdown" then
if option.Multi then
local tbl = {}
if type(v) == "table" then
for k2, v2 in pairs(v) do if v2 then tbl[k2] = true end end
end
cfg["o_" .. idx] = {T = "DD", M = true, V = tbl}
else
cfg["o_" .. idx] = {T = "DD", M = false, V = v}
end
elseif option.Type == "Input" then
cfg["o_" .. idx] = {T = "IN", V = tostring(v or "")}
end
end
return HttpService:JSONEncode(cfg)
end

function Library:LoadConfig(cfgJson)
local ok, cfg = pcall(HttpService.JSONDecode, HttpService, cfgJson)
if not ok or type(cfg) ~= "table" then return false end
for key, data in pairs(cfg) do
local prefix = key:sub(1, 2)
local idx = key:sub(3)
if self._configIgnore[idx] then continue end
if prefix == "t_" then
local toggle = Toggles[idx]
if toggle and toggle.SetValue then
pcall(function() toggle:SetValue(data) end)
end
elseif prefix == "o_" then
local option = Options[idx]
if option and type(data) == "table" then
if data.T == "C3" and option.SetValueRGB then
pcall(function() option:SetValueRGB(Color3.fromRGB(data.R or 255, data.G or 255, data.B or 255)) end)
elseif data.T == "KP" and option.SetValue then
pcall(function() option:SetValue({data.K or "Unknown", data.M or "Toggle"}) end)
elseif data.T == "SL" and option.SetValue then
pcall(function() option:SetValue(data.V) end)
elseif data.T == "DD" and option.SetValue then
pcall(function() option:SetValue(data.V) end)
elseif data.T == "IN" and option.SetValue then
pcall(function() option:SetValue(data.V or "") end)
end
end
end
end
return true
end

function Library:SaveConfig(name)
local success = false
pcall(function()
self:InitFolders()
writefile(self:GetConfigPath() .. "/" .. name .. ".cfg", self:GetConfig())
success = true
end)
return success
end

function Library:LoadConfigFile(name)
local success = false
pcall(function()
local path = self:GetConfigPath() .. "/" .. name .. ".cfg"
if isfile(path) then
success = self:LoadConfig(readfile(path))
end
end)
return success
end

function Library:DeleteConfig(name)
local success = false
pcall(function()
local p = self:GetConfigPath() .. "/" .. name .. ".cfg"
if isfile(p) then delfile(p); success = true end
end)
return success
end

function Library:ListConfigs()
local list = {}
pcall(function()
local p = self:GetConfigPath()
if isfolder(p) then
for _, file in ipairs(listfiles(p)) do
local name = file:match("([^/\\]+)%.cfg$")
if name then list[#list + 1] = name end
end
end
end)
return list
end

function Library:ConfigExists(name)
local exists = false
pcall(function() exists = isfile(self:GetConfigPath() .. "/" .. name .. ".cfg") end)
return exists
end

function Library:LoadAutoloadConfig()
self:LoadLibrarySettings()
