            self._healthBarFill.Size = UDim2.new(1, 0, math.clamp(percent, 0, 1), 0)
            if not color then
                self._healthBarFill.BackgroundColor3 = Color3.new(1 - percent, percent, 0)
            end
        end
        if color then self._healthBarFill.BackgroundColor3 = color end
    end

    function preview:SetDistanceESP(enabled, text, color)
        self._distESP.Visible = enabled
        if text then self._distESP.Text = text end
        if color then self._distESP.TextColor3 = color end
    end

    function preview:SetSkeleton(enabled, color)
        for _, line in pairs(self._skeletonLines) do
            line.Visible = enabled
            if color then line.BackgroundColor3 = color end
        end
    end

    function preview:SetChams(enabled, color)
        self._chamsActive = enabled
        for _, part in ipairs(self._charParts) do
            if enabled then
                part.BackgroundColor3 = color or Library.Accent
                part.BackgroundTransparency = 0.3
            else
                part.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
                part.BackgroundTransparency = 0
            end
        end
    end

    function preview:Show() Panel.Visible = true end
    function preview:Hide() Panel.Visible = false end

    Library:Connection(game:GetService("RunService").Heartbeat, function()
        updatePosition()
    end)

    return preview
end

-- WRAPPER

local library = {
    flags = Library.Flags,
    _lib = Library,
}

function library:window(opts)
    local win = Library:Window({
        Name = opts.name or opts.Name or "Avenir",
        Suffix = opts.suffix or opts.Suffix or "",
        Project = opts.project or opts.Project or "",
        Size = opts.size or opts.Size or UDim2.fromOffset(650, 550),
    })

    local wrapper = {}
    wrapper._win = win

    function wrapper:tab(opts2)
        return win:Page({Name = opts2.name or opts2.Name or "tab"})
    end

    
    local sg = Library.Holder.Parent
    wrapper.esp_preview = ESPPreview.Create(library, sg)

    return wrapper
end

function library:unload() Library:Unload() end
function library:show() Library.Open = true; if Library.Holder then Library.Holder.Visible = true end end
function library:hide() Library.Open = false; if Library.Holder then Library.Holder.Visible = false end end

function library:init_config()
    Library:InitFolders()
    Library:LoadLibrarySettings()
    if Library.AutoLoadConfigName then
        local p = Library:GetConfigPath() .. "/" .. Library.AutoLoadConfigName .. ".cfg"
        pcall(function()
            if isfile(p) then Library:LoadConfig(readfile(p)) end
        end)
    end
    task.defer(function()
        Library.Open = true
        if Library.Holder then Library.Holder.Visible = true end
    end)
end

function library:get_config() return Library:GetConfig() end
function library:load_config(json) Library:LoadConfig(json) end
function library:save_config(name) Library:SaveConfig(name) end
function library:delete_config(name) Library:DeleteConfig(name) end
function library:list_configs() return Library:ListConfigs() end
function library:change_accent(color) Library:ChangeAccent(color) end
function library:on_flag_changed(flag, cb) Library:OnFlagChanged(flag, cb) end
function library:get_accent() return Library.Accent end
function library:set_auto_load(name) Library:SetAutoLoad(name) end
function library:clear_auto_load() Library:ClearAutoLoad() end
function library:get_auto_load() return Library.AutoLoadConfigName end

function library:get_flag(flag) return Library.Flags[flag] end
function library:set_flag(flag, value)
    local s = Library._Flags[flag]
    if s then
        if type(s) == "function" then pcall(s, value)
        elseif type(s) == "table" and s.Set then pcall(function() s:Set(value) end) end
    else
        Library.Flags[flag] = value
    end
end

return library
