                    OptName.FontFace = Library.UIFont
                    OptName.TextSize = Library.FontSize
                    OptName.TextXAlignment = Enum.TextXAlignment.Left
                    OptName.ZIndex = 111
                    Opt.MouseButton1Click:Connect(function()
                        if DD.Multi then
                            DD.Selected[option] = not DD.Selected[option]
                        else
                            for k in pairs(DD.Selected) do DD.Selected[k] = false end
                            DD.Selected[option] = true
                            close()
                        end
                        updateColors()
                        updateDisplay()
                    end)
                end
                updateSize()
            end

            createOptions(DD.Options)

            function DD:Set(option)
                if DD.Multi then
                    if type(option) == "table" then
                        for k in pairs(DD.Selected) do DD.Selected[k] = false end
                        if #option > 0 then for _, v in ipairs(option) do DD.Selected[v] = true end
                        else for k, v in pairs(option) do DD.Selected[k] = v end end
                    end
                else
                    for k in pairs(DD.Selected) do DD.Selected[k] = false end
                    if option and DD.OptionInsts[option] then DD.Selected[option] = true end
                end
                updateColors()
                updateDisplay()
            end

            function DD:Refresh(tbl)
                DD.Options = tbl
                for _, opt in pairs(DD.OptionInsts) do pcall(function() opt.button:Destroy() end) end
                table.clear(DD.OptionInsts)
                table.clear(DD.Selected)
                createOptions(tbl)
                updateDisplay()
            end

            function DD:GetValue()
                if DD.Multi then
                    local arr = {}
                    for k, v in pairs(DD.Selected) do if v then arr[#arr+1] = k end end
                    return arr
                else
                    for k, v in pairs(DD.Selected) do if v then return k end end
                end
            end

            local state = Props.State
            if state then
                if DD.Multi and type(state) == "table" then
                    for _, v in ipairs(state) do DD.Selected[v] = true end
                elseif type(state) == "string" then
                    DD.Selected[state] = true
                end
            end
            updateColors()
            updateDisplay()

            Flags[DD.Flag] = DD
            return DD
        end

