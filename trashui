                local c = 0
                for _ in pairs(DD.OptionInsts) do c = c + 1 end
                Content.Size = UDim2.new(1, 0, 0, math.min(c, 6) * 18)
            end

            local function close() DD.Open = false; Content.Visible = false; Arrow.Text = "▼" end
            local function open() DD.Open = true; Content.Visible = true; Arrow.Text = "▲"; updateSize() end

            F.MouseButton1Click:Connect(function() if DD.Open then close() else open() end end)
            Library:Connection(UIS.InputBegan, function(I)
                if DD.Open and I.UserInputType == Enum.UserInputType.MouseButton1 then
                    task.defer(function()
                        if not Library:IsMouseOverFrame(Content) and not Library:IsMouseOverFrame(F) then close() end
                    end)
