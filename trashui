    local function getHumanoid()
        local char = Players.LocalPlayer.Character
        if char then return char:FindFirstChildOfClass("Humanoid") end
        return nil
    end

    local function updateHealth()
        local hum = getHumanoid()
        if hum and HealthBarBG.Visible then
            local pct = math.clamp(hum.Health / hum.MaxHealth, 0, 1)
            HealthBarFill.Size = UDim2.new(1, 0, pct, 0)
            HealthBarFill.BackgroundColor3 = Color3.new(1 - pct, pct, 0)
            HealthText.Text = tostring(math.floor(hum.Health))
            HealthText.Visible = true
        end
    end

    -- Armor tracking
    local function getArmorValue()
        local char = Players.LocalPlayer.Character
        if not char then return preview._currentArmor end

        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum and hum:GetAttribute("Armor") then
            return hum:GetAttribute("Armor")
        end

        local armorVal = char:FindFirstChild("Armor") or char:FindFirstChild("ArmorValue")
        if armorVal and (armorVal:IsA("NumberValue") or armorVal:IsA("IntValue")) then
            return armorVal.Value
        end

        local player = Players.LocalPlayer
        local leaderstats = player:FindFirstChild("leaderstats")
        if leaderstats then
            local armor = leaderstats:FindFirstChild("Armor")
            if armor and (armor:IsA("NumberValue") or armor:IsA("IntValue")) then
                return armor.Value
            end
        end

        return preview._currentArmor
    end

    local function updateArmor()
        if not ArmorBarBG.Visible and not ArmorESP.Visible then return end

        local armorValue = getArmorValue()
        preview._currentArmor = armorValue

        local pct = math.clamp(armorValue / preview._maxArmor, 0, 1)
        local color = getArmorColor(armorValue)

        ArmorBarFill.Size = UDim2.new(1, 0, pct, 0)
        ArmorBarFill.BackgroundColor3 = color
        ArmorText.Text = tostring(math.floor(armorValue))
        ArmorText.TextColor3 = color

        ArmorESP.Text = "Armor: " .. tostring(math.floor(armorValue))
        ArmorESP.TextColor3 = color
    end

