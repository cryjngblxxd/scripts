            local function updateDisplay()
                if DD.Multi then
                    local names = {}
                    for _, opt in ipairs(DD.Options) do if DD.Selected[opt] then names[#names+1] = opt end end
                    Val.Text = #names > 0 and table.concat(names, ", ") or "..."
                    local arr = {}
                    for k, v in pairs(DD.Selected) do if v then arr[#arr+1] = k end end
                    Library.Flags[DD.Flag] = arr
                    DD.Callback(DD.Selected)
                    Library:FireFlagCallbacks(DD.Flag, arr)
                else
                    local sel
                    for k, v in pairs(DD.Selected) do if v then sel = k; break end end
                    Val.Text = sel or ""
                    Library.Flags[DD.Flag] = sel
                    DD.Callback(sel)
                    Library:FireFlagCallbacks(DD.Flag, sel)
                end
