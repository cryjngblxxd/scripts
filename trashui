    -- UTILITY

    function Library:FireFlagCallbacks(flag, value)
        local cbs = self._flagCallbacks[flag]
        if cbs then
            for i = 1, #cbs do
                task.spawn(pcall, cbs[i], value)
            end
        end
    end

    function Library:OnFlagChanged(flag, callback)
        local cbs = self._flagCallbacks[flag]
        if not cbs then
            cbs = {}
            self._flagCallbacks[flag] = cbs
        end
        cbs[#cbs + 1] = callback
    end

    function Library:Connection(Signal, Callback)
        local Con = Signal:Connect(Callback)
        self.Connections[#self.Connections + 1] = Con
        return Con
    end

    function Library:Round(Number, Float)
        return Float * math.floor(Number / Float)
    end

    function Library.NextFlag()
        Library.UnNamedFlags = Library.UnNamedFlags + 1
        return tostring(Library.UnNamedFlags)
    end

    function Library:OnUnload(fn)
        self.OnUnloadCallbacks[#self.OnUnloadCallbacks + 1] = fn
    end

    function Library:Unload()
        self.Unloaded = true
        for _, fn in ipairs(self.OnUnloadCallbacks) do pcall(fn) end
        for _, con in ipairs(self.Connections) do pcall(function() con:Disconnect() end) end
        self.Connections = {}
        if self.Holder and self.Holder.Parent then self.Holder.Parent:Destroy() end
    end

    function Library:SetOpen(bool)
        self.Open = bool
        if self.Holder then self.Holder.Visible = bool end
    end

    function Library:ChangeAccent(Color)
        self.Accent = Color
        for _, theme in next, self.ThemeObjects do
            pcall(function()
                if theme:IsA("Frame") or theme:IsA("TextButton") then
                    theme.BackgroundColor3 = Color
                elseif theme:IsA("TextLabel") then
                    theme.TextColor3 = Color
                end
            end)
        end
        if self.UIGradient then
            self.UIGradient.Color = ColorSequence.new{
                ColorSequenceKeypoint.new(0, Color),
                ColorSequenceKeypoint.new(1, Color3.new(0.043, 0.043, 0.043))
            }
        end
    end

    function Library:IsMouseOverFrame(Frame)
        local Mouse = LocalPlayer:GetMouse()
        local P, S = Frame.AbsolutePosition, Frame.AbsoluteSize
        return Mouse.X >= P.X and Mouse.X <= P.X + S.X and Mouse.Y >= P.Y and Mouse.Y <= P.Y + S.Y
    end

    function Library:AddDependency(element, flag, condition)
        local deps = self.Dependencies[flag]
        if not deps then
            deps = {}
            self.Dependencies[flag] = deps
        end
        deps[#deps + 1] = {element = element, condition = condition}
    end

    function Library:UpdateDependencies(flag, value)
        local deps = self.Dependencies[flag]
        if deps then
            for _, dep in ipairs(deps) do
                local show = dep.condition(value)
                if dep.element and dep.element.Holder then
                    pcall(function() dep.element.Holder.Visible = show end)
                end
            end
        end
    end

    -- CONFIG SYSTEM

    function Library:InitFolders()
        pcall(function()
            if not isfolder(self.Folders.main) then makefolder(self.Folders.main) end
            if not isfolder(self.Folders.configs) then makefolder(self.Folders.configs) end
            local p = self.Folders.configs .. "/" .. self.ProjectName
            if not isfolder(p) then makefolder(p) end
        end)
    end

    function Library:GetConfigPath()
        return self.Folders.configs .. "/" .. self.ProjectName
    end

    function Library:GetSettingsPath()
        return self:GetConfigPath() .. "/settings.json"
    end

    function Library:SaveLibrarySettings()
        pcall(function()
            self:InitFolders()
            writefile(self:GetSettingsPath(), HttpService:JSONEncode({
                auto_load_config = self.AutoLoadConfigName
            }))
        end)
    end

    function Library:LoadLibrarySettings()
        pcall(function()
            local path = self:GetSettingsPath()
            if isfile(path) then
                local data = HttpService:JSONDecode(readfile(path))
                self.AutoLoadConfigName = data.auto_load_config
            end
        end)
    end

    function Library:SetAutoLoad(name)
        self.AutoLoadConfigName = name
        self:SaveLibrarySettings()
    end

    function Library:ClearAutoLoad()
        self.AutoLoadConfigName = nil
        self:SaveLibrarySettings()
    end

    function Library:GetConfig()
        local Config = {}
        for flag, value in pairs(self.Flags) do
            if flag == "cfg_selected" or flag == "cfg_name" then continue end
            if typeof(value) == "Color3" then
                Config[flag] = {_type = "Color3", hex = value:ToHex()}
            elseif type(value) == "table" and value.mode ~= nil and value.active ~= nil then
                local keyData = {_type = "Keybind", mode = value.mode, key = "NONE", keyType = "NONE"}
                if value.key and typeof(value.key) == "EnumItem" and value.key ~= Enum.KeyCode.Unknown then
                    local ks = tostring(value.key)
                    if ks:find("Enum%.KeyCode%.") then
                        keyData.keyType = "KeyCode"
                        keyData.key = ks:gsub("Enum%.KeyCode%.", "")
                    elseif ks:find("Enum%.UserInputType%.") then
                        keyData.keyType = "UserInputType"
                        keyData.key = ks:gsub("Enum%.UserInputType%.", "")
                    end
                end
                Config[flag] = keyData
            else
                Config[flag] = value
            end
        end
        return HttpService:JSONEncode(Config)
    end

    function Library:LoadConfig(configJson)
        local ok, config = pcall(HttpService.JSONDecode, HttpService, configJson)
        if not ok then return end
        for flag, value in pairs(config) do
            if flag == "cfg_selected" or flag == "cfg_name" then continue end
            if type(value) == "table" and value._type == "Keybind" then
                local kb = nil
                for _, k in ipairs(self._keybinds) do
                    if k.Flag == flag then kb = k; break end
                end
                if not kb then
                    local s = Flags[flag]
                    if s and type(s) == "table" and s.Set then kb = s end
                end
                if kb then
                    if kb.SetMode and value.mode then
                        pcall(function() kb:SetMode(value.mode) end)
                    end
                    if value.key and value.key ~= "NONE" and value.keyType and value.keyType ~= "NONE" then
                        local key = nil
                        if value.keyType == "KeyCode" then
                            local s, r = pcall(function() return Enum.KeyCode[value.key] end)
                            if s and r and r ~= Enum.KeyCode.Unknown then key = r end
                        elseif value.keyType == "UserInputType" then
                            local s, r = pcall(function() return Enum.UserInputType[value.key] end)
                            if s and r then key = r end
                        end
                        if key and kb.Set then
                            pcall(function() kb:Set(key) end)
                        end
                    end
                end
            elseif type(value) == "table" and value._type == "Color3" then
                local s = Flags[flag]
                if s and type(s) == "function" then pcall(s, Color3.fromHex(value.hex)) end
            else
                local s = Flags[flag]
                if s then
                    if type(s) == "function" then pcall(s, value)
                    elseif type(s) == "table" and s.Set then pcall(function() s:Set(value) end) end
                end
            end
        end
    end

    function Library:SaveConfig(name)
        pcall(function()
            self:InitFolders()
            writefile(self:GetConfigPath() .. "/" .. name .. ".cfg", self:GetConfig())
        end)
    end

    function Library:DeleteConfig(name)
        pcall(function()
            local p = self:GetConfigPath() .. "/" .. name .. ".cfg"
            if isfile(p) then delfile(p) end
        end)
    end

    function Library:ListConfigs()
        local list = {}
        pcall(function()
            local p = self:GetConfigPath()
            if isfolder(p) then
                for _, file in ipairs(listfiles(p)) do
                    local name = file:match("([^/\\]+)%.cfg$")
                    if name then list[#list + 1] = name end
                end
            end
        end)
        return list
    end

