    -- Function to recalculate character sizes
    local function recalculateCharacter()
        local areaSize = PreviewArea.AbsoluteSize
        if areaSize.X < 50 or areaSize.Y < 50 then return end

        -- Use 75% of available space for character (leave room for ESP elements)
        local targetFillY = 0.65
        local targetFillX = 0.50

        local availableHeight = areaSize.Y * targetFillY
        local availableWidth = areaSize.X * targetFillX

        -- R6 proportions (in studs): Head=1x1, Torso=2x2, Arms=1x2, Legs=1x2
        -- Total height: 1 (head) + 2 (torso) + 2 (legs) = 5 studs
        -- Total width: 1 (arm) + 2 (torso) + 1 (arm) = 4 studs

        local totalHeightStuds = 5
        local totalWidthStuds = 4
        local gap = 2

        -- Calculate scale based on available space
        local scaleY = availableHeight / (totalHeightStuds * 20 + gap * 2)
        local scaleX = availableWidth / (totalWidthStuds * 20 + gap * 2)
        local scale = math.min(scaleY, scaleX)

        -- Part sizes in pixels
        local headW = 20 * scale  -- 1 stud width (not too wide)
        local headH = 20 * scale  -- 1 stud height
        local torsoW = 40 * scale -- 2 studs
        local torsoH = 40 * scale -- 2 studs
        local armW = 20 * scale   -- 1 stud
        local armH = 40 * scale   -- 2 studs
        local legW = 20 * scale   -- 1 stud
        local legH = 40 * scale   -- 2 studs

        -- Total character dimensions
        local charW = torsoW + (armW + gap) * 2
        local charH = headH + gap + torsoH + gap + legH

        -- Update CharBox size
        CharBox.Size = UDim2.new(0, charW, 0, charH)

        -- Position head (centered at top)
        Head.Size = UDim2.new(0, headW, 0, headH)
        Head.Position = UDim2.new(0.5, -headW/2, 0, 0)

        -- Position torso (centered below head)
        Torso.Size = UDim2.new(0, torsoW, 0, torsoH)
        Torso.Position = UDim2.new(0.5, -torsoW/2, 0, headH + gap)

        -- Position left arm (left of torso)
        LArm.Size = UDim2.new(0, armW, 0, armH)
        LArm.Position = UDim2.new(0.5, -torsoW/2 - gap - armW, 0, headH + gap)

        -- Position right arm (right of torso)
        RArm.Size = UDim2.new(0, armW, 0, armH)
        RArm.Position = UDim2.new(0.5, torsoW/2 + gap, 0, headH + gap)

        -- Position left leg (under left side of torso)
        LLeg.Size = UDim2.new(0, legW, 0, legH)
        LLeg.Position = UDim2.new(0.5, -torsoW/2, 0, headH + gap + torsoH + gap)

        -- Position right leg (under right side of torso)
        RLeg.Size = UDim2.new(0, legW, 0, legH)
        RLeg.Position = UDim2.new(0.5, torsoW/2 - legW, 0, headH + gap + torsoH + gap)

        -- Store for ESP positioning
        preview._charW = charW
        preview._charH = charH

        -- Update Box ESP
        if preview._boxESP then
            preview._boxESP.Size = UDim2.new(0, charW + boxPad * 2, 0, charH + boxPad * 2)
        end

        -- Update health bar height
        if preview._healthBarBG then
            preview._healthBarBG.Size = UDim2.new(0, 4, 0, charH + boxPad * 2)
        end

        -- Update armor bar height
        if preview._armorBarBG then
            preview._armorBarBG.Size = UDim2.new(0, 4, 0, charH + boxPad * 2)
        end

        return charW, charH
    end

