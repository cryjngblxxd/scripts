function library:change_accent(color) Library:ChangeAccent(color) end
function library:on_flag_changed(flag, cb) Library:OnFlagChanged(flag, cb) end
function library:get_accent() return Library.Accent end
function library:set_auto_load(name) Library:SetAutoLoad(name) end
function library:clear_auto_load() Library:ClearAutoLoad() end
function library:get_auto_load() return Library.AutoLoadConfigName end

function library:get_flag(flag) return Library.Flags[flag] end
function library:set_flag(flag, value)
    local s = Library._Flags[flag]
    if s then
        if type(s) == "function" then pcall(s, value)
        elseif type(s) == "table" and s.Set then pcall(function() s:Set(value) end) end
    else
        Library.Flags[flag] = value
    end
end

return library
