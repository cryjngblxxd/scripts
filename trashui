    -- Armor color function
    local function getArmorColor(armorValue)
        local pct = math.clamp(armorValue / 100, 0, 1)
        if pct >= 0.75 then
            return Color3.fromRGB(0, 120, 255)
        elseif pct >= 0.5 then
            return Color3.fromRGB(0, 200, 150)
        elseif pct >= 0.25 then
            return Color3.fromRGB(255, 200, 0)
        elseif pct > 0 then
            return Color3.fromRGB(255, 130, 0)
        else
            return Color3.fromRGB(255, 60, 60)
        end
    end

