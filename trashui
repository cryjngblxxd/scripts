        local areaCenterX = areaPos.X + areaSize.X / 2
        local areaCenterY = areaPos.Y + areaSize.Y / 2

        local charH = preview._charH
        local charW = preview._charW

        -- Calculate distances to each zone
        local distTop = math.abs(centerY - (areaCenterY - charH/2 - boxPad - 20))
        local distBot = math.abs(centerY - (areaCenterY + charH/2 + boxPad + 20))
        local distLeft = math.abs(centerX - (areaCenterX - charW/2 - boxPad - 30))
        local distRight = math.abs(centerX - (areaCenterX + charW/2 + boxPad + 30))

        local zones = {
            {name = "Top", dist = distTop},
            {name = "Bottom", dist = distBot},
            {name = "Left", dist = distLeft},
            {name = "Right", dist = distRight},
        }
        table.sort(zones, function(a, b) return a.dist < b.dist end)
        return zones[1].name
    end

    local function getStackIndex(elementName, zone)
        local index = 0
        local order = {"Name", "Distance", "Armor", "Tool"}
        for _, name in ipairs(order) do
            if name == elementName then break end
            if preview._elementPositions[name] == zone then
                index = index + 1
            end
        end
        return index
    end

    local function updateAllPositions()
        local charH = preview._charH
        local charW = preview._charW
        local areaSize = PreviewArea.AbsoluteSize

        if charH == 0 or charW == 0 or areaSize.X < 50 then return end

        local spacing = 16

        for name, zone in pairs(preview._elementPositions) do
            local element = preview["_" .. name:lower() .. "ESP"]
            if element and element.Visible then
                local stackIndex = getStackIndex(name, zone)
                local x, y = 0.5, 0.5
                local anchorX, anchorY = 0.5, 0.5

                if zone == "Top" then
                    y = 0.5 - (charH/2 + boxPad + 8 + stackIndex * spacing) / areaSize.Y
                    anchorY = 1
                elseif zone == "Bottom" then
                    y = 0.5 + (charH/2 + boxPad + 8 + stackIndex * spacing) / areaSize.Y
                    anchorY = 0
                elseif zone == "Left" then
                    x = 0.5 - (charW/2 + boxPad + 15) / areaSize.X
                    y = 0.5 - (charH/2 - stackIndex * spacing) / areaSize.Y
                    anchorX = 1
                    anchorY = 0
                elseif zone == "Right" then
                    x = 0.5 + (charW/2 + boxPad + 15) / areaSize.X
                    y = 0.5 - (charH/2 - stackIndex * spacing) / areaSize.Y
                    anchorX = 0
                    anchorY = 0
                end

                element.Position = UDim2.new(x, 0, y, 0)
                element.AnchorPoint = Vector2.new(anchorX, anchorY)
            end
        end

        -- Health bar
        if preview._elementPositions["Health"] then
            local zone = preview._elementPositions["Health"]
            local x = 0.5
            local anchorX = 0.5

            if zone == "Left" then
                x = 0.5 - (charW/2 + boxPad + 8) / areaSize.X
                anchorX = 1
            elseif zone == "Right" then
                x = 0.5 + (charW/2 + boxPad + 8) / areaSize.X
                anchorX = 0
            end

            preview._healthBarBG.Position = UDim2.new(x, 0, 0.5, 0)
            preview._healthBarBG.AnchorPoint = Vector2.new(anchorX, 0.5)
        end

        -- Armor bar
        if preview._elementPositions["ArmorBar"] then
            local zone = preview._elementPositions["ArmorBar"]
            local x = 0.5
            local anchorX = 0.5

            if zone == "Left" then
                x = 0.5 - (charW/2 + boxPad + 8) / areaSize.X
                anchorX = 1
            elseif zone == "Right" then
                x = 0.5 + (charW/2 + boxPad + 8) / areaSize.X
                anchorX = 0
            end

            preview._armorBarBG.Position = UDim2.new(x, 0, 0.5, 0)
            preview._armorBarBG.AnchorPoint = Vector2.new(anchorX, 0.5)
        end
    end

    -- Snap draggable for text elements
    local function makeSnapDraggable(element, elementName)
        local dragging = false
        local dragOffset = Vector2.new(0, 0)

        element.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                local ePos = element.AbsolutePosition
                dragOffset = Vector2.new(input.Position.X - ePos.X, input.Position.Y - ePos.Y)
            end
        end)

        element.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if dragging then
                    local zone = getSnapZone(element)
                    preview._elementPositions[elementName] = zone
                    pcall(function()
                        if library and library.flags then
                            library.flags["RaidESP_" .. elementName .. "Position"] = zone
                        end
                    end)
                    updateAllPositions()
                end
                dragging = false
            end
        end)

        Library:Connection(UserInputService.InputChanged, function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local areaPos = PreviewArea.AbsolutePosition
                local areaSize = PreviewArea.AbsoluteSize
                local newX = input.Position.X - dragOffset.X - areaPos.X
                local newY = input.Position.Y - dragOffset.Y - areaPos.Y

                local clampX = math.clamp(newX, 0, areaSize.X - element.AbsoluteSize.X)
                local clampY = math.clamp(newY, 0, areaSize.Y - element.AbsoluteSize.Y)

                element.Position = UDim2.new(0, clampX, 0, clampY)
                element.AnchorPoint = Vector2.new(0, 0)
            end
        end)
    end

    -- Snap draggable for bar elements
    local function makeSnapDraggableBar(element, elementName)
        local dragging = false
        local dragOffsetX = 0

        element.InputBegan:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                dragging = true
                dragOffsetX = input.Position.X - element.AbsolutePosition.X
            end
        end)

        element.InputEnded:Connect(function(input)
            if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
                if dragging then
                    local areaPos = PreviewArea.AbsolutePosition
                    local areaSize = PreviewArea.AbsoluteSize
                    local elemCenterX = element.AbsolutePosition.X + element.AbsoluteSize.X / 2
                    local areaCenterX = areaPos.X + areaSize.X / 2

                    local zone = elemCenterX < areaCenterX and "Left" or "Right"
                    preview._elementPositions[elementName] = zone
                    pcall(function()
                        if library and library.flags then
                            library.flags["RaidESP_" .. elementName .. "Position"] = zone
                        end
                    end)
                    updateAllPositions()
                end
                dragging = false
            end
        end)

        Library:Connection(UserInputService.InputChanged, function(input)
            if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
                local areaPos = PreviewArea.AbsolutePosition
                local areaSize = PreviewArea.AbsoluteSize
                local newX = input.Position.X - dragOffsetX - areaPos.X
                local clampX = math.clamp(newX, 0, areaSize.X - element.AbsoluteSize.X)

                element.Position = UDim2.new(0, clampX, 0.5, 0)
                element.AnchorPoint = Vector2.new(0, 0.5)
            end
        end)
    end

