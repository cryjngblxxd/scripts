Toggles = setmetatable({}, {
    __index = function(self, key)
        local val = library.flags[key]

        return {
            Value = (typeof(val) == "boolean") and val or false,
            SetValue = function(_, newVal)
                if typeof(newVal) == "boolean" then
                    local flagSetter = LibraryInternal.Flags[key]
                    if flagSetter then
                        if typeof(flagSetter) == "function" then
                            flagSetter(newVal)
                        elseif typeof(flagSetter) == "table" and flagSetter.Set then
                            flagSetter:Set(newVal)
                        end
                    else
                        library.flags[key] = newVal
                    end
                end
            end,
            OnChanged = function(_, cb)
                if LibraryInternal then
                    LibraryInternal:OnFlagChanged(key, function(newVal)
                        pcall(cb, newVal)
                    end)
                end
            end
        }
    end
})

Options = setmetatable({}, {
    __index = function(self, key)
        local val = library.flags[key]

        local isKeybind = typeof(val) == "table" and val.mode ~= nil
        local isColor = typeof(val) == "Color3"
        local isTable = typeof(val) == "table" and not isKeybind

        if isKeybind then
            return {
                Value = val.key,
                GetState = function()
                    local d = library.flags[key]
                    return d and d.active or false
                end,
                OnClick = function(_, cb)
                    if LibraryInternal then
                        LibraryInternal:OnFlagChanged(key, function(newData)
                            if typeof(newData) == "table" and newData.active then
                                pcall(cb)
                            end
                        end)
                    end
                end,
                OnChanged = function(_, cb)
                    if LibraryInternal then
                        LibraryInternal:OnFlagChanged(key, function(newData)
                            pcall(cb, newData)
                        end)
                    end
                end,
                SetValue = function(_, newVal)
                    local flagSetter = LibraryInternal.Flags[key]
                    if flagSetter and typeof(flagSetter) == "table" and flagSetter.Set then
                        flagSetter:Set(newVal)
                    else
                        library.flags[key] = newVal
                    end
                end
            }
        elseif isColor then
            return {
                Value = val or Color3.fromRGB(255, 255, 255),
                OnChanged = function(_, cb)
                    if LibraryInternal then
                        LibraryInternal:OnFlagChanged(key, function(newColor)
                            pcall(cb, newColor)
                        end)
                    end
                end,
                SetValue = function(_, newVal)
                    local flagSetter = LibraryInternal.Flags[key]
                    if flagSetter and typeof(flagSetter) == "function" then
                        flagSetter(newVal)
                    else
                        library.flags[key] = newVal
                    end
                end
            }
        elseif isTable then
            local dictVal = {}
            if type(val) == "table" then
                for _, item in ipairs(val) do
                    dictVal[item] = true
                end
            end
            return {
                Value = dictVal,
                SetValue = function(_, newVal)
                    local flagSetter = LibraryInternal.Flags[key]
                    if flagSetter and typeof(flagSetter) == "table" and flagSetter.Set then
                        flagSetter:Set(newVal)
                    else
                        if typeof(newVal) == "table" then
                            local arr = {}
                            for k, v in pairs(newVal) do
                                if v then
                                    table.insert(arr, k)
                                end
                            end
                            library.flags[key] = arr
                        else
                            library.flags[key] = newVal
                        end
                    end
                end,
                OnChanged = function(_, cb)
                    if LibraryInternal then
                        LibraryInternal:OnFlagChanged(key, function(newVal)
                            pcall(cb, newVal)
                        end)
                    end
                end
            }
        else
            return {
                Value = val,
                SetValue = function(_, newVal)
                    local flagSetter = LibraryInternal.Flags[key]
                    if flagSetter then
                        if typeof(flagSetter) == "function" then
                            flagSetter(newVal)
                        elseif typeof(flagSetter) == "table" and flagSetter.Set then
                            flagSetter:Set(newVal)
                        end
                    else
                        library.flags[key] = newVal
                    end
                end,
                OnChanged = function(_, cb)
                    if LibraryInternal then
                        LibraryInternal:OnFlagChanged(key, function(newVal)
                            pcall(cb, newVal)
                        end)
                    end
                end
            }
        end
    end
})

