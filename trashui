            -- Only recalculate if size changed
            local currentSize = PreviewArea.AbsoluteSize
            if math.abs(currentSize.X - lastAreaSize.X) > 1 or math.abs(currentSize.Y - lastAreaSize.Y) > 1 then
                lastAreaSize = currentSize
                recalculateCharacter()
                updateAllPositions()
            end
        else
