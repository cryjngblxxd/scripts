        -- KEYBIND - USES GLOBAL HANDLER
        function Sections:Keybind(Options)
            local Props = Options or {}
            local KB = {
                Section = self,
                Name = Props.Name or Props.name or "Keybind",
                Mode = Props.Mode or Props.mode or "Toggle",
                Callback = Props.Callback or Props.callback or nil,
                Flag = Props.Flag or Props.flag or Library.NextFlag(),
                Key = nil,
                Active = false,
                Binding = false,
                Holder = nil,
                _keyDown = false,
            }

            local initialKey = Props.State or Props.state or Props.key or Props.Key
            if initialKey and typeof(initialKey) == "EnumItem" then
                KB.Key = initialKey
            end

            local parent = Options.Side == "Right" and KB.Section.Elements.Right or KB.Section.Elements.Left

            local HolderKB = Instance.new('TextButton', parent)
            local TitleKB = Instance.new('TextLabel', HolderKB)
            local ValueKB = Instance.new('TextButton', HolderKB)
            local ModeWindow = Instance.new('Frame', HolderKB)
            local ModeList = Instance.new('UIListLayout', ModeWindow)

            KB.Holder = HolderKB

            HolderKB.Size = UDim2.new(1, 0, 0, 16)
            HolderKB.BackgroundTransparency = 1
            HolderKB.Text = ""
            HolderKB.AutoButtonColor = false

            TitleKB.Position = UDim2.new(0, 0, 0, 0)
            TitleKB.Size = UDim2.new(1, -55, 1, 0)
            TitleKB.BackgroundTransparency = 1
            TitleKB.TextColor3 = Color3.new(0.306, 0.306, 0.306)
            TitleKB.FontFace = Library.UIFont
            TitleKB.TextSize = Library.FontSize
            TitleKB.TextXAlignment = Enum.TextXAlignment.Left
            TitleKB.Text = KB.Name

            ValueKB.Position = UDim2.new(1, -50, 0, 0)
            ValueKB.Size = UDim2.new(0, 45, 1, 0)
            ValueKB.BackgroundTransparency = 1
            ValueKB.Text = "-"
            ValueKB.TextColor3 = Color3.new(0.306, 0.306, 0.306)
            ValueKB.FontFace = Library.UIFont
            ValueKB.TextSize = Library.FontSize
            ValueKB.AutoButtonColor = false
            ValueKB.TextXAlignment = Enum.TextXAlignment.Right

            ModeWindow.Position = UDim2.new(1, -60, 0, 18)
            ModeWindow.Size = UDim2.new(0, 70, 0, 0)
            ModeWindow.BackgroundColor3 = Color3.new(0.0431, 0.0431, 0.0431)
            ModeWindow.BorderColor3 = Color3.new(0.1098, 0.1098, 0.1098)
            ModeWindow.ZIndex = 1220
            ModeWindow.Visible = false
            ModeWindow.AutomaticSize = Enum.AutomaticSize.Y
            ModeList.SortOrder = Enum.SortOrder.LayoutOrder

            local modes = {"Toggle", "Hold"}
            local modeButtons = {}

            local function getKeyName(key)
                if not key then
                    return "-"
                end
                if Library.Keys[key] then
                    return Library.Keys[key]
                end
                local keyString = tostring(key)
                keyString = keyString:gsub("Enum.KeyCode.", "")
                keyString = keyString:gsub("Enum.UserInputType.", "")
                return keyString
            end

            function KB:_updateFlag()
                Library.Flags[KB.Flag] = {
                    key = KB.Key,
                    mode = KB.Mode,
                    active = KB.Active
                }
                Library:FireFlagCallbacks(KB.Flag, Library.Flags[KB.Flag])
            end

            local function updateModeColors()
                for m, btn in pairs(modeButtons) do
                    btn.TextColor3 = m == KB.Mode and Color3.fromRGB(255, 255, 255) or Color3.new(0.306, 0.306, 0.306)
                end
            end

            for _, mode in ipairs(modes) do
                local ModeBtn = Instance.new('TextButton', ModeWindow)
                ModeBtn.Size = UDim2.new(1, 0, 0, 18)
                ModeBtn.BackgroundTransparency = 1
                ModeBtn.Text = mode
                ModeBtn.TextColor3 = KB.Mode == mode and Color3.fromRGB(255, 255, 255) or Color3.new(0.306, 0.306, 0.306)
                ModeBtn.FontFace = Library.UIFont
                ModeBtn.TextSize = Library.FontSize
                ModeBtn.ZIndex = 1221
                modeButtons[mode] = ModeBtn

                ModeBtn.MouseButton1Click:Connect(function()
                    KB.Mode = mode
                    KB.Active = false
                    updateModeColors()
                    ModeWindow.Visible = false
                    KB:_updateFlag()
                end)
            end

            if KB.Key then
                ValueKB.Text = getKeyName(KB.Key)
            end
            KB:_updateFlag()

            -- Click to bind
            ValueKB.MouseButton1Click:Connect(function()
                if KB.Binding then return end
                KB.Binding = true
                ValueKB.Text = "..."
            end)

            -- Right click for mode
            ValueKB.MouseButton2Click:Connect(function()
                ModeWindow.Visible = not ModeWindow.Visible
            end)

            -- Handle binding input
            Library:Connection(game:GetService("UserInputService").InputBegan, function(input, gameProcessed)
                -- Close mode window
                if ModeWindow.Visible and input.UserInputType == Enum.UserInputType.MouseButton1 then
                    task.defer(function()
                        if not Library:IsMouseOverFrame(ModeWindow) and not Library:IsMouseOverFrame(ValueKB) then
                            ModeWindow.Visible = false
                        end
                    end)
                end

                -- Handle binding
                if KB.Binding then
                    local keyToSet = nil
                    if input.UserInputType == Enum.UserInputType.Keyboard then
                        keyToSet = input.KeyCode
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then
                        keyToSet = Enum.UserInputType.MouseButton1
                    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then
                        keyToSet = Enum.UserInputType.MouseButton2
                    elseif input.UserInputType == Enum.UserInputType.MouseButton3 then
                        keyToSet = Enum.UserInputType.MouseButton3
                    end

                    if keyToSet then
                        if keyToSet == Enum.KeyCode.Backspace or keyToSet == Enum.KeyCode.Escape then
                            KB.Key = nil
                            ValueKB.Text = "-"
                        else
                            KB.Key = keyToSet
                            ValueKB.Text = getKeyName(keyToSet)
                        end
                        KB.Active = false
                        KB._keyDown = false
                        KB:_updateFlag()
                        KB.Binding = false
                    end
                end
            end)

            function KB:Set(key)
                if typeof(key) == "EnumItem" then
                    KB.Key = key
                    ValueKB.Text = getKeyName(key)
                    KB.Active = false
                    KB._keyDown = false
                    KB:_updateFlag()
                elseif key == nil then
                    KB.Key = nil
                    ValueKB.Text = "-"
                    KB.Active = false
                    KB._keyDown = false
                    KB:_updateFlag()
                end
            end

            function KB:GetState()
                return KB.Active
            end

            function KB:SetMode(mode)
                if mode == "Toggle" or mode == "Hold" then
                    KB.Mode = mode
                    KB.Active = false
                    KB._keyDown = false
                    updateModeColors()
                    KB:_updateFlag()
                end
            end

            function KB:SetCallback(callback)
                KB.Callback = callback
            end

            -- Register this keybind with the global system
            table.insert(Library._keybinds, KB)
            print("[KEYBIND] Registered keybind:", KB.Name, "Key:", KB.Key, "Mode:", KB.Mode)

            Flags[KB.Flag] = KB
            return KB
        end
    end
end

