        -- KEYBIND
        function Sections:Keybind(Options)
            local Props = Options or {}
            local KB = {
                Section = self, Name = Props.Name or "Keybind",
                Mode = Props.Mode or "Toggle",
                Callback = Props.Callback,
                Flag = Props.Flag or Library.NextFlag(),
                Key = nil, Active = false, Binding = false,
                Holder = nil, _keyDown = false,
            }

            local initKey = Props.State or Props.Key
            if initKey and typeof(initKey) == "EnumItem" and initKey ~= Enum.KeyCode.Unknown then
                KB.Key = initKey
            end

            local parent = Props.Side == "Right" and self.Elements.Right or self.Elements.Left
            local H = Instance.new('TextButton', parent)
            local T = Instance.new('TextLabel', H)
            local V = Instance.new('TextButton', H)
            local MW = Instance.new('Frame', H)
            Instance.new('UIListLayout', MW).SortOrder = Enum.SortOrder.LayoutOrder

            KB.Holder = H

            H.Size = UDim2.new(1, 0, 0, 16)
            H.BackgroundTransparency = 1
            H.Text = ""
            H.AutoButtonColor = false

            T.Size = UDim2.new(1, -55, 1, 0)
            T.BackgroundTransparency = 1
            T.TextColor3 = Color3.new(0.306, 0.306, 0.306)
            T.FontFace = Library.UIFont
            T.TextSize = Library.FontSize
            T.TextXAlignment = Enum.TextXAlignment.Left
            T.Text = KB.Name

            V.Position = UDim2.new(1, -50, 0, 0)
            V.Size = UDim2.new(0, 45, 1, 0)
            V.BackgroundTransparency = 1
            V.Text = "Unknown"
            V.TextColor3 = Color3.new(0.306, 0.306, 0.306)
            V.FontFace = Library.UIFont
            V.TextSize = Library.FontSize
            V.AutoButtonColor = false
            V.TextXAlignment = Enum.TextXAlignment.Right

            MW.Position = UDim2.new(1, -60, 0, 18)
            MW.Size = UDim2.new(0, 70, 0, 0)
            MW.BackgroundColor3 = Color3.new(0.0431, 0.0431, 0.0431)
            MW.BorderColor3 = Color3.new(0.1098, 0.1098, 0.1098)
            MW.ZIndex = 1220
            MW.Visible = false
            MW.AutomaticSize = Enum.AutomaticSize.Y

            local modeButtons = {}

            local function getKeyName(key)
                if not key or key == Enum.KeyCode.Unknown then return "Unknown" end
                if Library.Keys[key] then return Library.Keys[key] end
                return tostring(key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
            end

            function KB:_updateFlag()
                local k = KB.Key
                if k == Enum.KeyCode.Unknown then k = nil end
                Library.Flags[KB.Flag] = {key = k, mode = KB.Mode, active = KB.Active}
                Library:FireFlagCallbacks(KB.Flag, Library.Flags[KB.Flag])
            end

            local function updateModeColors()
                for m, btn in pairs(modeButtons) do
                    btn.TextColor3 = m == KB.Mode and Color3.fromRGB(255, 255, 255) or Color3.new(0.306, 0.306, 0.306)
                end
            end

            for _, mode in ipairs({"Toggle", "Hold"}) do
                local MBtn = Instance.new('TextButton', MW)
                MBtn.Size = UDim2.new(1, 0, 0, 18)
                MBtn.BackgroundTransparency = 1
                MBtn.Text = mode
                MBtn.TextColor3 = KB.Mode == mode and Color3.fromRGB(255, 255, 255) or Color3.new(0.306, 0.306, 0.306)
                MBtn.FontFace = Library.UIFont
                MBtn.TextSize = Library.FontSize
                MBtn.ZIndex = 1221
                modeButtons[mode] = MBtn
                MBtn.MouseButton1Click:Connect(function()
                    KB.Mode = mode; KB.Active = false
                    updateModeColors(); MW.Visible = false; KB:_updateFlag()
                end)
            end

            if KB.Key then V.Text = getKeyName(KB.Key) end
            KB:_updateFlag()

            V.MouseButton1Click:Connect(function()
                if KB.Binding then return end
                KB.Binding = true; V.Text = "..."
            end)

            V.MouseButton2Click:Connect(function() MW.Visible = not MW.Visible end)

            Library:Connection(UIS.InputBegan, function(input, gp)
                if MW.Visible and input.UserInputType == Enum.UserInputType.MouseButton1 then
                    task.defer(function()
                        if not Library:IsMouseOverFrame(MW) and not Library:IsMouseOverFrame(V) then MW.Visible = false end
                    end)
                end

                if KB.Binding then
                    local key
                    if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode
                    elseif input.UserInputType == Enum.UserInputType.MouseButton1 then key = Enum.UserInputType.MouseButton1
                    elseif input.UserInputType == Enum.UserInputType.MouseButton2 then key = Enum.UserInputType.MouseButton2
                    elseif input.UserInputType == Enum.UserInputType.MouseButton3 then key = Enum.UserInputType.MouseButton3 end

                    if key then
                        if key == Enum.KeyCode.Backspace or key == Enum.KeyCode.Escape then
                            KB.Key = nil; V.Text = "Unknown"
                        else
                            KB.Key = key; V.Text = getKeyName(key)
                        end
                        KB.Active = false; KB._keyDown = false; KB:_updateFlag(); KB.Binding = false
                    end
                end
            end)

            function KB:Set(key)
                if key == nil or (typeof(key) == "EnumItem" and key == Enum.KeyCode.Unknown) then
                    KB.Key = nil; V.Text = "Unknown"
                elseif typeof(key) == "EnumItem" then
                    KB.Key = key; V.Text = getKeyName(key)
                end
                KB.Active = false; KB._keyDown = false; KB:_updateFlag()
            end

            function KB:GetState() return KB.Active end
            function KB:SetMode(mode)
                if mode == "Toggle" or mode == "Hold" then
                    KB.Mode = mode; KB.Active = false; KB._keyDown = false
                    updateModeColors(); KB:_updateFlag()
                end
            end
            function KB:SetCallback(cb) KB.Callback = cb end

            Library._keybinds[#Library._keybinds + 1] = KB
            Flags[KB.Flag] = KB
            return KB
        end
    end
end

