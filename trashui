        Window.Visible = false

        Sat.Position = UDim2.new(0, 5, 0, 5)
        Sat.Size = UDim2.new(0, 123, 0, 123)
        Sat.BackgroundColor3 = default
        Sat.BorderColor3 = Color3.new(0.1098, 0.1098, 0.1098)
        Sat.Image = "http://www.roblox.com/asset/?id=13882904626"
        Sat.AutoButtonColor = false
        Sat.ZIndex = 1220

        Hue.Position = UDim2.new(1, -15, 0, 5)
        Hue.Size = UDim2.new(0, 10, 0, 123)
        Hue.BackgroundColor3 = Color3.new(1, 1, 1)
        Hue.BorderColor3 = Color3.new(0.1098, 0.1098, 0.1098)
        Hue.Image = "http://www.roblox.com/asset/?id=13882976736"
        Hue.ZIndex = 1220
        Hue.AutoButtonColor = false

        local h, s, v = default:ToHSV()
        local slidingSat, slidingHue = false, false
        local curHue = h

        local function set(color)
            if typeof(color) == "Color3" then h, s, v = color:ToHSV() end
            local hsv = Color3.fromHSV(h, s, v)
            Icon.BackgroundColor3 = hsv
            Sat.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
            if flag then
                Library.Flags[flag] = hsv
                Library:FireFlagCallbacks(flag, hsv)
            end
            if callback then callback(hsv) end
        end

        set(default)

        Sat.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then slidingSat = true end end)
        Sat.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then slidingSat = false end end)
        Hue.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then slidingHue = true end end)
        Hue.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then slidingHue = false end end)

        Library:Connection(UIS.InputChanged, function(input)
            if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
                if slidingHue then
                    curHue = 1 - math.clamp((input.Position.Y - Hue.AbsolutePosition.Y) / Hue.AbsoluteSize.Y, 0, 1)
                    set(Color3.fromHSV(curHue, s, v))
                end
                if slidingSat then
                    local sx = math.clamp((input.Position.X - Sat.AbsolutePosition.X) / Sat.AbsoluteSize.X, 0, 1)
                    local sy = 1 - math.clamp((input.Position.Y - Sat.AbsolutePosition.Y) / Sat.AbsoluteSize.Y, 0, 1)
                    set(Color3.fromHSV(curHue, sx, sy))
                end
            end
        end)

        Icon.MouseButton1Click:Connect(function() Window.Visible = not Window.Visible end)

        Library:Connection(UIS.InputBegan, function(Input)
            if Window.Visible and (Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch) then
                if not Library:IsMouseOverFrame(Window) and not Library:IsMouseOverFrame(Icon) then
                    Window.Visible = false
                end
            end
        end)

        local cpt = {}
        function cpt:Set(color) set(color) end
        Flags[flag] = function(c) set(c) end
        return cpt
    end

    -- KEYBIND HANDLER

    local function SetupKeybindHandler()
        Library:Connection(UIS.InputBegan, function(input, gp)
            if gp then return end
            local key
            if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 then key = Enum.UserInputType.MouseButton1
            elseif input.UserInputType == Enum.UserInputType.MouseButton2 then key = Enum.UserInputType.MouseButton2
            elseif input.UserInputType == Enum.UserInputType.MouseButton3 then key = Enum.UserInputType.MouseButton3 end
            if not key then return end
            for _, kb in ipairs(Library._keybinds) do
                if kb.Key == key and not kb.Binding and not kb._keyDown then
                    kb._keyDown = true
                    if kb.Mode == "Hold" then
                        kb.Active = true
                        kb:_updateFlag()
                        if kb.Callback then task.spawn(pcall, kb.Callback, true) end
                    else
                        kb.Active = not kb.Active
                        kb:_updateFlag()
                        if kb.Callback then task.spawn(pcall, kb.Callback, kb.Active) end
                    end
                end
            end
        end)

        Library:Connection(UIS.InputEnded, function(input)
            local key
            if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 then key = Enum.UserInputType.MouseButton1
            elseif input.UserInputType == Enum.UserInputType.MouseButton2 then key = Enum.UserInputType.MouseButton2
            elseif input.UserInputType == Enum.UserInputType.MouseButton3 then key = Enum.UserInputType.MouseButton3 end
            if not key then return end
            for _, kb in ipairs(Library._keybinds) do
                if kb.Key == key then
                    kb._keyDown = false
                    if kb.Mode == "Hold" and kb.Active then
                        kb.Active = false
                        kb:_updateFlag()
                        if kb.Callback then task.spawn(pcall, kb.Callback, false) end
                    end
                end
            end
        end)
    end

    local function SetupMenuToggle()
        if Library._menuToggleSetup then return end
        Library._menuToggleSetup = true
        Library:Connection(UIS.InputBegan, function(input, gp)
            if gp or not Library.Holder then return end
            local key
            if input.UserInputType == Enum.UserInputType.Keyboard then key = input.KeyCode end
            if not key then return end
            local mk = Library.Flags["UI_MenuKeybind"]
            if mk and type(mk) == "table" and mk.key then
                if key == mk.key then
                    Library.Open = not Library.Open
                    Library.Holder.Visible = Library.Open
                end
            else
                if key == Enum.KeyCode.Insert or key == Enum.KeyCode.RightControl then
                    Library.Open = not Library.Open
                    Library.Holder.Visible = Library.Open
                end
            end
        end)
    end

