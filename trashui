    -- Helper functions for snap positioning
    local function getSnapZone(element)
        local areaPos = PreviewArea.AbsolutePosition
        local areaSize = PreviewArea.AbsoluteSize
        local elemPos = element.AbsolutePosition
        local elemSize = element.AbsoluteSize

        local centerX = elemPos.X + elemSize.X / 2
