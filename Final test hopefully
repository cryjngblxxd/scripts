            if isfile(path) then
                local data = game:GetService("HttpService"):JSONDecode(readfile(path))
                Library.AutoLoadConfigName = data.auto_load_config
            end
        end)
    end

    function Library:SetAutoLoad(configName)
        Library.AutoLoadConfigName = configName
        Library:SaveLibrarySettings()
    end

    function Library:ClearAutoLoad()
        Library.AutoLoadConfigName = nil
        Library:SaveLibrarySettings()
    end

    function Library:DoAutoLoad()
        Library:LoadLibrarySettings()
        if Library.AutoLoadConfigName then
            local configPath = Library:GetConfigPath() .. "/" .. Library.AutoLoadConfigName .. ".cfg"
            pcall(function()
                if isfile(configPath) then
                    task.spawn(function()
                        task.wait(0.5)
                        Library:LoadConfig(readfile(configPath))
                    end)
                end
            end)
        end
    end

    function Library:GetConfig()
        local Config = {}
        for flag, value in pairs(Library.Flags) do
            if flag == "cfg_selected" or flag == "cfg_name" then continue end
            if typeof(value) == "Color3" then
                Config[flag] = {_type = "Color3", hex = value:ToHex()}
            elseif type(value) == "table" and value.key ~= nil and value.mode ~= nil then
                local keyStr = "NONE"
                if value.key and tostring(value.key) ~= "NONE" then
                    keyStr = tostring(value.key)
                end
                Config[flag] = {_type = "Keybind", mode = value.mode, key = keyStr}
            else
                Config[flag] = value
            end
        end
        return game:GetService("HttpService"):JSONEncode(Config)
    end

    function Library:LoadConfig(configJson)
        local success, config = pcall(function()
            return game:GetService("HttpService"):JSONDecode(configJson)
        end)
        if not success then return end
        for flag, value in pairs(config) do
            if flag == "cfg_selected" or flag == "cfg_name" then continue end
            if type(value) == "table" and value._type == "Keybind" then
                continue
            elseif type(value) == "table" and value._type == "Color3" then
                local setter = Flags[flag]
                if setter and type(setter) == "function" then
                    pcall(function() setter(Color3.fromHex(value.hex)) end)
                end
            else
                local setter = Flags[flag]
                if setter then
                    if type(setter) == "function" then
                        pcall(function() setter(value) end)
                    elseif type(setter) == "table" and setter.Set then
                        pcall(function() setter:Set(value) end)
                    end
                end
            end
        end
    end

    function Library:SaveConfig(name)
        pcall(function()
            Library:InitFolders()
            writefile(Library:GetConfigPath() .. "/" .. name .. ".cfg", Library:GetConfig())
        end)
    end

    function Library:DeleteConfig(name)
        pcall(function()
            local path = Library:GetConfigPath() .. "/" .. name .. ".cfg"
            if isfile(path) then delfile(path) end
        end)
    end

    function Library:ListConfigs()
        local list = {}
        pcall(function()
            local path = Library:GetConfigPath()
            if isfolder(path) then
                for _, file in ipairs(listfiles(path)) do
                    local name = file:match("([^/\\]+)%.cfg$")
                    if name then table.insert(list, name) end
                end
            end
        end)
        return list
    end

