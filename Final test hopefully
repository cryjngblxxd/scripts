            function DD:Refresh(tbl)
                DD.Options = tbl
                for _, opt in next, DD.OptionInsts do pcall(function() opt.button:Destroy() end) end
                table.clear(DD.OptionInsts)
                table.clear(DD.Selected)
                createoptions(tbl)
                updateDisplay()
            end

            if DD.State then
                if DD.Multi then
                    if type(DD.State) == "table" then
                        for _, v in ipairs(DD.State) do DD.Selected[v] = true end
                    end
                else
                    if type(DD.State) == "string" then
                        DD.Selected[DD.State] = true
                    end
                end
            end
            updateOptionColors()
            updateDisplay()

            Flags[DD.Flag] = DD
            return DD
        end

