    function Library:FireFlagCallbacks(flag, value)
        if Library._flagCallbacks[flag] then
            for _, cb in ipairs(Library._flagCallbacks[flag]) do
                task.spawn(pcall, cb, value)
            end
        end
    end

    function Library:OnFlagChanged(flag, callback)
        if not Library._flagCallbacks[flag] then
            Library._flagCallbacks[flag] = {}
        end
        table.insert(Library._flagCallbacks[flag], callback)
    end

    function Library:Connection(Signal, Callback)
        local Con = Signal:Connect(Callback)
        table.insert(Library.Connections, Con)
        return Con
    end

    function Library:Disconnect(Connection)
        if Connection then Connection:Disconnect() end
    end

    function Library:Round(Number, Float)
        return Float * math.floor(Number / Float)
    end

    function Library.NextFlag()
        Library.UnNamedFlags = Library.UnNamedFlags + 1
        return string.format("%.14g", Library.UnNamedFlags)
    end

    function Library:OnUnload(fn)
        table.insert(Library.OnUnloadCallbacks, fn)
    end

    function Library:Unload()
        Library.Unloaded = true
        for _, fn in pairs(Library.OnUnloadCallbacks) do
            pcall(fn)
        end
        for _, con in pairs(Library.Connections) do
            pcall(function() con:Disconnect() end)
        end
        Library.Connections = {}
        if Library.Holder and Library.Holder.Parent then
            Library.Holder.Parent:Destroy()
        end
    end

    function Library:SetOpen(bool)
        Library.Open = bool
        if Library.Holder then
            Library.Holder.Visible = bool
        end
    end

    function Library:ChangeAccent(Color)
        Library.Accent = Color
        for _, theme in next, Library.ThemeObjects do
            pcall(function()
                if theme:IsA("Frame") or theme:IsA("TextButton") then
                    theme.BackgroundColor3 = Color
                elseif theme:IsA("TextLabel") then
                    theme.TextColor3 = Color
                end
            end)
        end
        if Library.UIGradient then
            Library.UIGradient.Color = ColorSequence.new{ColorSequenceKeypoint.new(0,Color),ColorSequenceKeypoint.new(1,Color3.new(0.043,0.043,0.043))}
        end
    end

    function Library:IsMouseOverFrame(Frame)
        local Mouse = game:GetService("Players").LocalPlayer:GetMouse()
        local AbsPos, AbsSize = Frame.AbsolutePosition, Frame.AbsoluteSize
        return Mouse.X >= AbsPos.X and Mouse.X <= AbsPos.X + AbsSize.X and Mouse.Y >= AbsPos.Y and Mouse.Y <= AbsPos.Y + AbsSize.Y
    end

    function Library:AddDependency(element, flag, condition)
        if not Library.Dependencies[flag] then
            Library.Dependencies[flag] = {}
        end
        table.insert(Library.Dependencies[flag], {element = element, condition = condition})
    end

    function Library:UpdateDependencies(flag, value)
        local deps = Library.Dependencies[flag]
        if deps then
            for _, dep in pairs(deps) do
                local shouldShow = dep.condition(value)
                if dep.element and dep.element.Holder then
                    pcall(function() dep.element.Holder.Visible = shouldShow end)
                end
            end
        end
    end

    function Library:InitFolders()
        pcall(function()
            if not isfolder(Library.Folders.main) then makefolder(Library.Folders.main) end
            if not isfolder(Library.Folders.configs) then makefolder(Library.Folders.configs) end
            local projectPath = Library.Folders.configs .. "/" .. Library.ProjectName
            if not isfolder(projectPath) then makefolder(projectPath) end
        end)
    end

    function Library:GetConfigPath()
        return Library.Folders.configs .. "/" .. Library.ProjectName
