function Library:AddTab(name, icon)
    local index = 0; for _ in pairs(TabButtons) do index = index + 1 end; index = index + 1
    local tab = Instance.new("Frame"); tab.Name = name; tab.Size = UDim2.new(0,98,1,0); tab.BackgroundColor3 = index == 1 and Colors.SurfaceLight or Colors.Background; tab.BorderSizePixel = 0; tab.ZIndex = 9; tab.Parent = TabBar
    local ta = Instance.new("Frame"); ta.Size = UDim2.new(1,0,0,2); ta.Position = UDim2.new(0,0,1,-2); ta.BackgroundColor3 = Colors.Accent; ta.BorderSizePixel = 0; ta.Visible = index == 1; ta.ZIndex = 10; ta.Parent = tab
    local ti = Instance.new("ImageLabel"); ti.Size = UDim2.new(0,16,0,16); ti.Position = UDim2.new(0,10,0.5,-8); ti.BackgroundTransparency = 1; ti.Image = icons[icon] or icons["settings"] or ""; ti.ImageColor3 = index == 1 and Colors.Accent or Colors.TextDim; ti.ImageTransparency = index == 1 and 0 or 0.3; ti.ZIndex = 10; ti.Parent = tab
    local tl = Instance.new("TextLabel"); tl.Size = UDim2.new(1,-34,1,0); tl.Position = UDim2.new(0,32,0,0); tl.BackgroundTransparency = 1; tl.Text = name; tl.TextColor3 = index == 1 and Colors.Text or Colors.TextDim; tl.TextTransparency = index == 1 and 0 or 0.3; tl.TextSize = 14; tl.FontFace = GothamMedium; tl.TextXAlignment = Enum.TextXAlignment.Left; tl.ZIndex = 10; tl.Parent = tab
    local tb = Instance.new("TextButton"); tb.Size = UDim2.new(1,0,1,0); tb.BackgroundTransparency = 1; tb.Text = ""; tb.ZIndex = 11; tb.Parent = tab
    tb.MouseEnter:Connect(function() if CurrentTab ~= name then PlayTween(ti, {ImageTransparency=0.15}, 0.15); PlayTween(tl, {TextTransparency=0.15}, 0.15) end end)
    tb.MouseLeave:Connect(function() if CurrentTab ~= name then PlayTween(ti, {ImageTransparency=0.3}, 0.15); PlayTween(tl, {TextTransparency=0.3}, 0.15) end end)
    tb.MouseButton1Down:Connect(function() PlayTween(ti, {ImageTransparency=0}, 0.1); PlayTween(tl, {TextTransparency=0}, 0.1) end)
    tb.MouseButton1Click:Connect(function() SelectTab(name) end)
    TabButtons[name] = {Frame=tab, Icon=ti, Label=tl, Accent=ta}
    local tp = Instance.new("Frame"); tp.Name = name.."Page"; tp.Size = UDim2.new(1,0,1,0); tp.BackgroundTransparency = 1; tp.Visible = index == 1; tp.ZIndex = 11; tp.Parent = ContentBg
    Tabs[name] = tp; if index == 1 then CurrentTab = name end
    local TO = {Page=tp, Subtabs={}}
    function TO:AddSubtab(sn, si2, sl2)
        local sd = {name=sn, icon=si2 or WeaponIcons.General, label=sl2 or sn:upper()}
        if not SubtabStorage[name] then SubtabStorage[name] = {} end
        local sc = 0; for _ in pairs(SubtabStorage[name]) do sc = sc + 1 end; local sx = sc + 1
        if sx == 1 then TO.SubtabBar = CreateSubtabBar(tp) end
        local ts = sc + 1
        for en, eb in pairs(SubtabStorage[name]) do
            local nw = 1/ts; local ei = 0; local tc = 0
            for n2 in pairs(SubtabStorage[name]) do tc = tc + 1; if n2 == en then ei = tc; break end end
            eb.Button.Size = UDim2.new(nw,0,1,0); eb.Button.Position = UDim2.new(nw*(ei-1),0,0,0)
        end
        local panels = CreateSubtab(TO.SubtabBar, name, sd, sx, ts, tp)
        local SO = {Left=panels.Left, Right=panels.Right}
        function SO:AddGroupbox(title, side)
            side = side or "Left"; local pp = side == "Left" and panels.Left or panels.Right
            local content = CreateGroupbox(pp, title)
            local GO = {Content = content}
            function GO:AddToggle(n,d,k,f,c) return CreateToggle(content,n,d,k,f,c) end
            function GO:AddSlider(n,mn,mx,d,f,c) return CreateSlider(content,n,mn,mx,d,f,c) end
            function GO:AddDropdown(n,o,d,f,c) return CreateDropdown(content,n,o,d,f,c) end
            function GO:AddKeybind(n,k,f,c) return CreateKeybind(content,n,k,f,c) end
            function GO:AddButton(n,c) return CreateButton(content,n,c) end
            function GO:AddTextInput(n,p,f) return CreateTextInput(content,n,p,f) end
            return GO
        end
        TO.Subtabs[sn] = SO; return SO
    end
    return TO
end


-- BUILD CONFIG SECTION


function Library:BuildConfigSection(groupObj)
    local cnb; local cst
    local _, tb = groupObj:AddTextInput("Config Name", "Enter config name...", "_ConfigName"); cnb = tb
    local cl = ConfigSystem:GetConfigs(); if #cl == 0 then cl = {"Default"} end
    groupObj:AddDropdown("Config", cl, cl[1] or "Default", "SelectedConfig", function(v) if cnb then cnb.Text = v end end)
    cst = CreateStatusLabel(groupObj.Content)
    local function SS(text, color, dur)
        dur = dur or 3; if cst then cst.Text = text; cst.TextColor3 = color or Colors.TextSub; cst.TextTransparency = 0
            task.delay(dur, function() if cst and cst.Text == text then PlayTween(cst, {TextTransparency=1}, 0.5); task.delay(0.5, function() if cst then cst.Text = ""; cst.TextTransparency = 0 end end) end end) end
    end
    local function RCD()
        local configs = ConfigSystem:GetConfigs(); if #configs == 0 then configs = {"Default"} end
        local de = Library.Elements["SelectedConfig"]
        if de and de.UI.ListInner then
            for _, c in ipairs(de.UI.ListInner:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
            de.State.options = configs
            for _, opt in ipairs(configs) do
                local ob = Instance.new("TextButton"); ob.Name = opt; ob.Size = UDim2.new(1,0,0,22); ob.BackgroundColor3 = Colors.Surface; ob.BorderSizePixel = 0; ob.Text = opt; ob.TextColor3 = opt == de.State.currentSelected and Colors.Accent or Colors.TextSub; ob.TextSize = 12; ob.FontFace = GothamRegular; ob.AutoButtonColor = false; ob.ZIndex = 202; ob.Parent = de.UI.ListInner
                ob.MouseEnter:Connect(function() if de.State.currentSelected ~= opt then PlayTween(ob, {BackgroundColor3=Colors.SurfaceLight}, 0.1) end end)
                ob.MouseLeave:Connect(function() if de.State.currentSelected ~= opt then PlayTween(ob, {BackgroundColor3=Colors.Surface}, 0.1) end end)
                ob.MouseButton1Click:Connect(function()
                    de.State.currentSelected = opt; Library.Flags["SelectedConfig"] = opt; de.UI.Selected.Text = opt
                    for _, c in ipairs(de.UI.ListInner:GetChildren()) do if c:IsA("TextButton") then c.TextColor3 = c.Name == opt and Colors.Accent or Colors.TextSub; c.BackgroundColor3 = Colors.Surface end end
                    if cnb then cnb.Text = opt end
                end)
            end
            local ddl = de.UI.ListInner.Parent; if ddl then ddl.Size = UDim2.new(1,0,0,#configs*22+4) end
            local found = false; for _, c in ipairs(configs) do if c == de.State.currentSelected then found = true; break end end
            if not found and #configs > 0 then de.State.currentSelected = configs[1]; Library.Flags["SelectedConfig"] = configs[1]; de.UI.Selected.Text = configs[1] end
        end
    end
    groupObj:AddButton("Save Config", function()
        local n = Library.Flags["_ConfigName"]; if not n or n == "" then n = Library.Flags["SelectedConfig"] or "Default" end
        local s, e = ConfigSystem:SaveConfig(n)
        if s then SS("Saved: "..n, Colors.Success); RCD(); local de = Library.Elements["SelectedConfig"]; if de then de.State.currentSelected = n; Library.Flags["SelectedConfig"] = n; de.UI.Selected.Text = n end
        else SS("Save failed: "..tostring(e), Colors.Error) end
    end)
    groupObj:AddButton("Load Config", function()
        local n = Library.Flags["SelectedConfig"] or Library.Flags["_ConfigName"]; if not n or n == "" then SS("No config selected", Colors.Error); return end
        local s, e = ConfigSystem:LoadConfig(n); if s then SS("Loaded: "..n, Colors.Success) else SS(tostring(e or "Load failed"), Colors.Error) end
    end)
    groupObj:AddButton("Delete Config", function()
        local n = Library.Flags["SelectedConfig"] or Library.Flags["_ConfigName"]; if not n or n == "" then SS("No config selected", Colors.Error); return end
        if ConfigSystem:GetAutoLoad() == n then ConfigSystem:SetAutoLoad(nil) end
        if ConfigSystem:DeleteConfig(n) then SS("Deleted: "..n, Colors.Success); RCD() else SS("Config not found", Colors.Error) end
    end)
    groupObj:AddButton("Set Auto Load", function()
        local n = Library.Flags["SelectedConfig"] or Library.Flags["_ConfigName"]; if not n or n == "" then SS("No config selected", Colors.Error); return end
        if isfile(GetConfigPath(n)) then
            if ConfigSystem:GetAutoLoad() == n then ConfigSystem:SetAutoLoad(nil); SS("Auto load cleared", Colors.Warning)
            else ConfigSystem:SetAutoLoad(n); SS("Auto load: "..n, Colors.Success) end
        else local s = ConfigSystem:SaveConfig(n); if s then ConfigSystem:SetAutoLoad(n); SS("Saved & set auto load: "..n, Colors.Success); RCD() else SS("Failed to save", Colors.Error) end end
    end)
    groupObj:AddButton("Refresh Configs", function() RCD(); SS("Refreshed", Colors.TextSub) end)
    return {RefreshDropdown=RCD, ShowStatus=SS, ConfigNameBox=cnb}
end


-- AUTO-SHOW


function Library:AutoShow()
    Layer1.BackgroundTransparency = 1; Layer1.Visible = true
    local orig = {}
    for _, desc in ipairs(Layer1:GetDescendants()) do
        local p = {}
        pcall(function()
            if desc:IsA("Frame") then p.BackgroundTransparency = desc.BackgroundTransparency; desc.BackgroundTransparency = 1
            elseif desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox") then p.BackgroundTransparency = desc.BackgroundTransparency; p.TextTransparency = desc.TextTransparency; desc.BackgroundTransparency = 1; desc.TextTransparency = 1
            elseif desc:IsA("ImageLabel") or desc:IsA("ImageButton") then p.BackgroundTransparency = desc.BackgroundTransparency; p.ImageTransparency = desc.ImageTransparency; desc.BackgroundTransparency = 1; desc.ImageTransparency = 1
            elseif desc:IsA("ScrollingFrame") then p.BackgroundTransparency = desc.BackgroundTransparency; p.ScrollBarImageTransparency = desc.ScrollBarImageTransparency; desc.BackgroundTransparency = 1; desc.ScrollBarImageTransparency = 1 end
        end)
        if next(p) then orig[desc] = p end
    end
    PlayTween(Layer1, {BackgroundTransparency=0}, 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    for d, p in pairs(orig) do pcall(function() PlayTween(d, p, 0.4, Enum.EasingStyle.Quad, Enum.EasingDirection.Out) end) end
end

