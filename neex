-- KEYBIND LIST MANAGEMENT


function Library:UpdateKeybindList()
    for _, child in ipairs(keybindListContainer:GetChildren()) do
        if child:IsA("Frame") then child:Destroy() end
    end

    local order = 0
    for flag, element in pairs(Library.Elements) do
        if element.Type == "Toggle" and element.State.currentKey then
            order = order + 1
            local enabled = element.State.isEnabled
            local name = element.DisplayName or flag
            local key = element.State.currentKey

            local entryFrame = Instance.new("Frame")
            entryFrame.Name = flag .. "Entry"
            entryFrame.Size = UDim2.new(1, 0, 0, 20)
            entryFrame.BackgroundColor3 = Colors.Surface
            entryFrame.BorderSizePixel = 0
            entryFrame.LayoutOrder = order
            entryFrame.ZIndex = 12
            entryFrame.Parent = keybindListContainer

            local entryLine = Instance.new("Frame")
            entryLine.Size = UDim2.new(1, -30, 0, 1)
            entryLine.Position = UDim2.new(0, 15, 1, -1)
            entryLine.BackgroundColor3 = Colors.Border4
            entryLine.BorderSizePixel = 0
            entryLine.ZIndex = 20
            entryLine.Parent = entryFrame

            local nameLabel = Instance.new("TextLabel")
            nameLabel.Size = UDim2.new(1, -50, 1, 0)
            nameLabel.Position = UDim2.new(0, 15, 0, 0)
            nameLabel.BackgroundTransparency = 1
            nameLabel.Text = name
            nameLabel.TextColor3 = enabled and Colors.Accent or Colors.Text
            nameLabel.Font = Enum.Font.GothamBold
            nameLabel.TextSize = 10
            nameLabel.TextXAlignment = Enum.TextXAlignment.Left
            nameLabel.TextTruncate = Enum.TextTruncate.AtEnd
            nameLabel.ZIndex = 13
            nameLabel.Parent = entryFrame

            local keyLabel = Instance.new("TextLabel")
            keyLabel.Size = UDim2.new(0, 20, 1, 0)
            keyLabel.Position = UDim2.new(1, -35, 0, 0)
            keyLabel.BackgroundTransparency = 1
            keyLabel.Text = key
            keyLabel.TextColor3 = enabled and Colors.Accent or Colors.Text
            keyLabel.Font = Enum.Font.GothamBold
            keyLabel.TextSize = 10
            keyLabel.TextXAlignment = Enum.TextXAlignment.Right
            keyLabel.ZIndex = 13
            keyLabel.Parent = entryFrame
        end
    end

    local entryCount = 0
    for _, child in ipairs(keybindListContainer:GetChildren()) do
        if child:IsA("Frame") then entryCount = entryCount + 1 end
    end
    local listHeight = math.max(entryCount * 20 + 30, 50)
    keybindBorderAccent.Size = UDim2.new(0, 160, 0, listHeight)
end


