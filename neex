function Library:Toggle()
    Library.Visible = not Library.Visible
    Layer1.Visible = Library.Visible
end

function Library:SetToggleKey(keyCode)
    if type(keyCode) == "string" then
        keyCode = Enum.KeyCode[keyCode]
    end
    Library.ToggleKey = keyCode
end

-- Menu toggle keybind
local menuToggleConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.UserInputType == Enum.UserInputType.Keyboard then
        if input.KeyCode == Library.ToggleKey then
            Library:Toggle()
        end
    end
end)
table.insert(Library.Connections, menuToggleConn)

-- Main frame dragging
local mDragging, mDragInput, mDragStart, mStartPos
TitleBar.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        mDragging = true
        mDragStart = input.Position
        mStartPos = Layer1.Position
        input.Changed:Connect(function()
            if input.UserInputState == Enum.UserInputState.End then
                mDragging = false
            end
        end)
    end
end)
TitleBar.InputChanged:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseMovement then
        mDragInput = input
    end
end)
local mDragConn = UserInputService.InputChanged:Connect(function(input)
    if input == mDragInput and mDragging then
        local delta = input.Position - mDragStart
        Layer1.Position = UDim2.new(mStartPos.X.Scale, mStartPos.X.Offset + delta.X, mStartPos.Y.Scale, mStartPos.Y.Offset + delta.Y)
    end
end)
table.insert(Library.Connections, mDragConn)

