local function SelectTab(tabName)
    for name, btn in pairs(TabButtons) do
        local isSelected = (name == tabName)
        PlayTween(btn.Frame, {BackgroundColor3 = isSelected and Colors.SurfaceLight or Colors.Background}, 0.2)
        PlayTween(btn.Label, {TextColor3 = isSelected and Colors.Text or Colors.TextDim, TextTransparency = isSelected and 0 or 0.3}, 0.2)
        if btn.Accent then
            btn.Accent.Visible = isSelected
        end
        if Tabs[name] then
            Tabs[name].Visible = isSelected
        end
    end
    CurrentTab = tabName
end

