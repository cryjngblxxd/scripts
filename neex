-- TARGET PANEL METHODS
-- ═══════════════════════════════════════════════

function Library:SetTargetPanelVisible(visible)
    Library.ShowTargetPanel = visible
    indicatorBorderAccent.Visible = visible
    if not visible then
        Library.TargetPlayer = nil
    end
end

function Library:SetShowArmor(show)
    Library.ShowArmor = show
    armorLabel.Visible = show
    armorBarOuter.Visible = show
    local h = show and 170 or 140
    indicatorBorderAccent.Size = UDim2.new(0, 280, 0, h)
end

function Library:SetTarget(targetPlayer)
    Library.TargetPlayer = targetPlayer
    if targetPlayer and Library.ShowTargetPanel then
        indicatorBorderAccent.Visible = true
        tpNameLabel.Text = targetPlayer.DisplayName or targetPlayer.Name

        local uid = targetPlayer.UserId
        if not cachedAvatars[uid] then
            cachedAvatars[uid] = "rbxthumb://type=Avatar&id=" .. uid .. "&w=150&h=150"
        end
        profileImage.Image = cachedAvatars[uid]

        local weapon = "None"
        pcall(function()
            local char = targetPlayer.Character
            if char then
                for _, item in pairs(char:GetChildren()) do
                    if item:IsA("Tool") then
                        weapon = item.Name
                        break
                    end
                end
            end
        end)
        tpWeaponLabel.Text = "Weapon: " .. weapon

        pcall(function()
            local char = targetPlayer.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    local hp = math.floor(hum.Health)
                    local maxHp = math.floor(hum.MaxHealth)
                    local pct = hum.Health / hum.MaxHealth
                    tpHealthLabel.Text = string.format("HP: %d/%d", hp, maxHp)
                    healthBarFill.Size = UDim2.new(math.clamp(pct, 0, 1), 0, 1, 0)
                    local fc, tc, bc = getHealthColor(pct)
                    healthBarFill.BackgroundColor3 = fc
                    healthBarTop.BackgroundColor3 = tc
                    healthBarBottom.BackgroundColor3 = bc
                end
            end
        end)

        if Library.ShowArmor then
            pcall(function()
                local char = targetPlayer.Character
                if char then
                    local armorVal = char:GetAttribute("Armor") or 0
                    local maxArmor = 130
                    armorLabel.Text = string.format("Armor: %d/%d", armorVal, maxArmor)
                    armorBarFill.Size = UDim2.new(math.clamp(armorVal / maxArmor, 0, 1), 0, 1, 0)
                end
            end)
        end
    elseif not targetPlayer then
        tpNameLabel.Text = "No Target"
        profileImage.Image = ""
        tpWeaponLabel.Text = "Weapon: None"
        tpHealthLabel.Text = "HP: 0/0"
        healthBarFill.Size = UDim2.new(0, 0, 1, 0)
        armorBarFill.Size = UDim2.new(0, 0, 1, 0)
        armorLabel.Text = "Armor: 0/0"
        if not Library.ShowTargetPanel then
            indicatorBorderAccent.Visible = false
        end
    end
end

function Library:ClearTarget()
    Library:SetTarget(nil)
end

function Library:SetWatermarkVisible(visible)
    Library.ShowWatermark = visible
    watermarkBorderAccent.Visible = visible
end

function Library:SetKeybindListVisible(visible)
    Library.ShowKeybindList = visible
    keybindBorderAccent.Visible = visible
end

-- ═══════════════════════════════════════════════
-- WATERMARK UPDATE LOOP
-- ═══════════════════════════════════════════════

local updateConn = RunService.Heartbeat:Connect(function()
    if Library.Unloaded then return end

    -- Watermark
    if Library.ShowWatermark and watermarkBorderAccent.Visible then
        local text = Library.Title
        if Library.Suffix and Library.Suffix ~= "" then
            text = text .. Library.Suffix
        end
        text = text .. " | " .. displayName

        watermarkText.Text = text
        local tw = watermarkText.TextBounds.X + 24
        watermarkBorderAccent.Size = UDim2.new(0, math.max(tw, 200), 0, 30)
    end

    -- Target panel health update
    if Library.ShowTargetPanel and Library.TargetPlayer then
        pcall(function()
            local tp = Library.TargetPlayer
            if not tp or not tp.Parent then
                Library:ClearTarget()
                return
            end
            local char = tp.Character
            if char then
                local hum = char:FindFirstChildOfClass("Humanoid")
                if hum then
                    local hp = math.floor(hum.Health)
                    local maxHp = math.floor(hum.MaxHealth)
                    local pct = hum.Health / hum.MaxHealth
                    tpHealthLabel.Text = string.format("HP: %d/%d", hp, maxHp)
                    PlayTween(healthBarFill, {Size = UDim2.new(math.clamp(pct, 0, 1), 0, 1, 0)}, 0.15)
                    local fc, tc, bc = getHealthColor(pct)
                    healthBarFill.BackgroundColor3 = fc
                    healthBarTop.BackgroundColor3 = tc
                    healthBarBottom.BackgroundColor3 = bc
                    if hum.Health <= 0 then
                        Library:ClearTarget()
                    end

                    local weapon = "None"
                    for _, item in pairs(char:GetChildren()) do
                        if item:IsA("Tool") then
                            weapon = item.Name
                            break
                        end
                    end
                    tpWeaponLabel.Text = "Weapon: " .. weapon
                end

                if Library.ShowArmor then
                    local armorVal = char:GetAttribute("Armor") or 0
                    local maxArmor = 130
                    armorLabel.Text = string.format("Armor: %d/%d", armorVal, maxArmor)
                    armorBarFill.Size = UDim2.new(math.clamp(armorVal / maxArmor, 0, 1), 0, 1, 0)
                end
            end
        end)
    end
end)
table.insert(Library.Connections, updateConn)

