function Library:Window(options)
    options = options or {}
    Library.Title = options.name or options.Name or "Avenir"
    Library.Suffix = options.suffix or options.Suffix or ""
    Library.GameInfo = options.gameInfo or options.GameInfo or ""

    if options.project then
        Library:SetProject(options.project)
    end

    TitleText.Text = Library.Title
    SuffixText.Text = Library.Suffix

    -- Position suffix after title with spacing
    task.defer(function()
        local titleWidth = TitleText.TextBounds.X
        SuffixText.Position = UDim2.new(0, 14 + titleWidth + 2, 0, 0)

        local suffixWidth = SuffixText.TextBounds.X
        GameInfoText.Text = Library.GameInfo
        GameInfoText.Position = UDim2.new(0, 14 + titleWidth + 2 + suffixWidth + 10, 0, 1)
    end)

    if options.size then
        Layer1.Size = options.size
        Layer1.Position = UDim2.new(0.5, -options.size.X.Offset / 2, 0.5, -options.size.Y.Offset / 2)
    end

    if options.auto_show == false then
        Layer1.Visible = false
        Library.Visible = false
    end

    -- Update watermark
    local wmText = Library.Title
    if Library.Suffix ~= "" then
        wmText = wmText .. Library.Suffix
    end
    wmText = wmText .. " | " .. displayName
    watermarkText.Text = wmText
    task.defer(function()
        local tw = watermarkText.TextBounds.X + 24
        watermarkBorderAccent.Size = UDim2.new(0, math.max(tw, 200), 0, 30)
    end)

    local WindowAPI = {}

    function WindowAPI:tab(opts)
        return Library:AddTab(opts)
    end

    -- Alias
    WindowAPI.AddTab = WindowAPI.tab

    return WindowAPI
end

-- Alias for window
Library.window = Library.Window

function Library:AddTab(options)
    options = options or {}
    local name = options.name or options.Name or "Tab"

    local index = 0
    for _ in pairs(TabButtons) do
        index = index + 1
    end
    index = index + 1

    local Tab = Instance.new("Frame")
    Tab.Name = name
    Tab.Size = UDim2.new(0, 80, 1, 0)
    Tab.BackgroundColor3 = index == 1 and Colors.SurfaceLight or Colors.Background
    Tab.BorderSizePixel = 0
