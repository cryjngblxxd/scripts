local function CreateKeybind(parent, options)
    local name = options.Name or "Keybind"
    local flag = options.Flag or name
    local default = options.State or Enum.KeyCode.Unknown
    local mode = options.Mode or "Toggle"
    local callback = options.Callback or function() end

    if typeof(default) == "EnumItem" then
        default = default.Name
    end

    local Keybind = Instance.new("Frame")
    Keybind.Name = name
    Keybind.Size = UDim2.new(1, 0, 0, 22)
    Keybind.BackgroundTransparency = 1
    Keybind.ZIndex = 17
    Keybind.Parent = parent

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(1, -60, 1, 0)
    Label.Position = UDim2.new(0, 0, 0, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Colors.Text
    Label.TextSize = 13
    Label.FontFace = GothamRegular
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 18
    Label.Parent = Keybind

    local KeyOuter = Instance.new("Frame")
    KeyOuter.Size = UDim2.new(0, 50, 0, 18)
    KeyOuter.Position = UDim2.new(1, -50, 0.5, -9)
    KeyOuter.BackgroundColor3 = Colors.InnerBorder1
    KeyOuter.BorderSizePixel = 0
    KeyOuter.ZIndex = 18
    KeyOuter.Parent = Keybind

    local KeyInner = Instance.new("Frame")
    KeyInner.Size = UDim2.new(1, -2, 1, -2)
    KeyInner.Position = UDim2.new(0, 1, 0, 1)
    KeyInner.BackgroundColor3 = Colors.SurfaceLight
    KeyInner.BorderSizePixel = 0
    KeyInner.ZIndex = 19
    KeyInner.Parent = KeyOuter

    local KeyText = Instance.new("TextLabel")
    KeyText.Size = UDim2.new(1, 0, 1, 0)
    KeyText.BackgroundTransparency = 1
    KeyText.Text = default == "Unknown" and "..." or default
    KeyText.TextColor3 = default == "Unknown" and Colors.TextDim or Colors.Accent
    KeyText.TextSize = 10
    KeyText.FontFace = GothamMedium
    KeyText.ZIndex = 20
    KeyText.Parent = KeyInner

    local KeyBtn = Instance.new("TextButton")
    KeyBtn.Size = UDim2.new(1, 0, 1, 0)
    KeyBtn.BackgroundTransparency = 1
    KeyBtn.Text = ""
    KeyBtn.ZIndex = 21
    KeyBtn.Parent = KeyOuter

    local state = {
        currentKey = default,
        currentMode = mode,
        isBinding = false,
        isActive = false
    }

    Library.Flags[flag] = default

    Library.Elements[flag] = {
        Type = "Keybind",
        State = state,
        DisplayName = name,
        Callback = callback,
    }

    -- Mode popup - rendered in PopupContainer so it's always on top
    local ModePopup = Instance.new("Frame")
    ModePopup.Name = flag .. "_ModePopup"
    ModePopup.Size = UDim2.new(0, 80, 0, 66)
    ModePopup.BackgroundColor3 = Colors.InnerBorder1
    ModePopup.BorderSizePixel = 0
    ModePopup.Visible = false
    ModePopup.ZIndex = 100000
    ModePopup.Parent = PopupContainer

    local ModePopupInner = Instance.new("Frame")
    ModePopupInner.Size = UDim2.new(1, -2, 1, -2)
    ModePopupInner.Position = UDim2.new(0, 1, 0, 1)
    ModePopupInner.BackgroundColor3 = Colors.Background
    ModePopupInner.BorderSizePixel = 0
    ModePopupInner.ZIndex = 100001
    ModePopupInner.Parent = ModePopup

    local ModeLayout = Instance.new("UIListLayout")
    ModeLayout.Padding = UDim.new(0, 0)
    ModeLayout.Parent = ModePopupInner

    local modes = {"Toggle", "Hold", "Always"}
    for i, m in ipairs(modes) do
        local ModeBtn = Instance.new("TextButton")
        ModeBtn.Name = m
        ModeBtn.Size = UDim2.new(1, 0, 0, 22)
        ModeBtn.BackgroundColor3 = Colors.Background
        ModeBtn.BorderSizePixel = 0
        ModeBtn.Text = m
        ModeBtn.TextColor3 = state.currentMode == m and Colors.Accent or Colors.TextSub
        ModeBtn.TextSize = 11
        ModeBtn.FontFace = GothamRegular
        ModeBtn.AutoButtonColor = false
        ModeBtn.ZIndex = 100002
        ModeBtn.Parent = ModePopupInner

        ModeBtn.MouseEnter:Connect(function()
            if state.currentMode ~= m then
                PlayTween(ModeBtn, {BackgroundColor3 = Colors.SurfaceLight}, 0.1)
            end
        end)
        ModeBtn.MouseLeave:Connect(function()
            if state.currentMode ~= m then
                PlayTween(ModeBtn, {BackgroundColor3 = Colors.Background}, 0.1)
            end
        end)
        ModeBtn.MouseButton1Click:Connect(function()
            state.currentMode = m
            for _, child in ipairs(ModePopupInner:GetChildren()) do
                if child:IsA("TextButton") then
                    child.TextColor3 = child.Text == m and Colors.Accent or Colors.TextSub
                    child.BackgroundColor3 = Colors.Background
                end
            end
            ModePopup.Visible = false

            if m == "Always" then
                state.isActive = true
                callback(true)
            end

            Library:UpdateKeybindList()
        end)
    end

    -- Left click to bind key
    KeyBtn.MouseButton1Click:Connect(function()
        if state.isBinding then return end
        state.isBinding = true
        KeyText.Text = "..."
        KeyText.TextColor3 = Colors.AccentLight

        local connection
        connection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.Keyboard then
                local keyName = input.KeyCode.Name
                state.currentKey = keyName
                Library.Flags[flag] = keyName
                KeyText.Text = keyName
                KeyText.TextColor3 = Colors.Accent
                state.isBinding = false
                connection:Disconnect()
                Library:UpdateKeybindList()
            elseif input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.MouseButton2 then
                if state.currentKey and state.currentKey ~= "Unknown" then
                    KeyText.Text = state.currentKey
                    KeyText.TextColor3 = Colors.Accent
                else
                    KeyText.Text = "..."
                    KeyText.TextColor3 = Colors.TextDim
                end
                state.isBinding = false
                connection:Disconnect()
            end
        end)
    end)

    -- Right click to show mode selector
    KeyBtn.MouseButton2Click:Connect(function()
        -- Close all other popups first
        for _, child in ipairs(PopupContainer:GetChildren()) do
            if child ~= ModePopup then
                child.Visible = false
            end
        end

        local pos = KeyOuter.AbsolutePosition
        local size = KeyOuter.AbsoluteSize
        ModePopup.Position = UDim2.new(0, pos.X + size.X - 80, 0, pos.Y + size.Y + 2)
        ModePopup.Visible = not ModePopup.Visible
    end)

    -- Input handling for keybind activation
    local inputBeganConn = UserInputService.InputBegan:Connect(function(input, gameProcessed)
        if gameProcessed or state.isBinding then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and state.currentKey and state.currentKey ~= "Unknown" then
            if input.KeyCode.Name == state.currentKey then
                if state.currentMode == "Toggle" then
                    state.isActive = not state.isActive
                    callback(state.isActive)
                    Library:UpdateKeybindList()
                elseif state.currentMode == "Hold" then
                    state.isActive = true
                    callback(true)
                    Library:UpdateKeybindList()
                end
            end
        end
    end)
    table.insert(Library.Connections, inputBeganConn)

    local inputEndedConn = UserInputService.InputEnded:Connect(function(input)
        if state.isBinding then return end
        if input.UserInputType == Enum.UserInputType.Keyboard and state.currentKey and state.currentKey ~= "Unknown" then
            if input.KeyCode.Name == state.currentKey then
                if state.currentMode == "Hold" then
                    state.isActive = false
                    callback(false)
                    Library:UpdateKeybindList()
                end
            end
        end
    end)
    table.insert(Library.Connections, inputEndedConn)

    return Keybind
end

local function CreateSlider(parent, options)
    local name = options.Name or "Slider"
    local flag = options.Flag or name
    local min = options.Min or 0
    local max = options.Max or 100
    local default = options.State or min
    local decimals = options.Decimals or 1
    local suffix = options.Suffix or ""
    local callback = options.Callback or function() end

    local Slider = Instance.new("Frame")
    Slider.Name = name
    Slider.Size = UDim2.new(1, 0, 0, 38)
    Slider.BackgroundTransparency = 1
    Slider.ZIndex = 17
    Slider.Parent = parent

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.6, 0, 0, 18)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Colors.Text
    Label.TextSize = 13
    Label.FontFace = GothamRegular
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 18
    Label.Parent = Slider

    local Value = Instance.new("TextLabel")
    Value.Size = UDim2.new(0.4, 0, 0, 18)
    Value.Position = UDim2.new(0.6, 0, 0, 0)
    Value.BackgroundTransparency = 1
    Value.Text = tostring(default) .. suffix
    Value.TextColor3 = Colors.Accent
    Value.TextSize = 13
    Value.FontFace = GothamMedium
    Value.TextXAlignment = Enum.TextXAlignment.Right
    Value.ZIndex = 18
    Value.Parent = Slider

    local BarOuter = Instance.new("Frame")
    BarOuter.Size = UDim2.new(1, 0, 0, 12)
    BarOuter.Position = UDim2.new(0, 0, 0, 22)
    BarOuter.BackgroundColor3 = Colors.InnerBorder1
    BarOuter.BorderSizePixel = 0
    BarOuter.ZIndex = 18
    BarOuter.Parent = Slider

    local BarInner = Instance.new("Frame")
    BarInner.Size = UDim2.new(1, -2, 1, -2)
    BarInner.Position = UDim2.new(0, 1, 0, 1)
    BarInner.BackgroundColor3 = Colors.InnerBorder2
    BarInner.BorderSizePixel = 0
    BarInner.ZIndex = 19
    BarInner.Parent = BarOuter

    local BarBg = Instance.new("Frame")
    BarBg.Size = UDim2.new(1, -2, 1, -2)
    BarBg.Position = UDim2.new(0, 1, 0, 1)
    BarBg.BackgroundColor3 = Colors.Deep
    BarBg.BorderSizePixel = 0
    BarBg.ClipsDescendants = true
    BarBg.ZIndex = 20
    BarBg.Parent = BarInner

    local Fill = Instance.new("Frame")
    Fill.Size = UDim2.new((default - min) / (max - min), 0, 1, 0)
    Fill.BackgroundColor3 = Colors.Accent
    Fill.BorderSizePixel = 0
    Fill.ZIndex = 21
    Fill.Parent = BarBg

    local FillTop = Instance.new("Frame")
    FillTop.Size = UDim2.new(1, 0, 0, 2)
    FillTop.BackgroundColor3 = Colors.AccentLight
    FillTop.BorderSizePixel = 0
    FillTop.ZIndex = 22
    FillTop.Parent = Fill

    local FillBottom = Instance.new("Frame")
    FillBottom.Size = UDim2.new(1, 0, 0, 2)
    FillBottom.Position = UDim2.new(0, 0, 1, -2)
    FillBottom.BackgroundColor3 = Colors.AccentDark
    FillBottom.BorderSizePixel = 0
    FillBottom.ZIndex = 22
    FillBottom.Parent = Fill

    local Btn = Instance.new("TextButton")
    Btn.Size = UDim2.new(1, 0, 1, 0)
    Btn.BackgroundTransparency = 1
    Btn.Text = ""
    Btn.ZIndex = 23
    Btn.Parent = BarOuter

    local sliding = false
    Library.Flags[flag] = default

    local function Update(input)
        local rel = math.clamp((input.Position.X - BarBg.AbsolutePosition.X) / BarBg.AbsoluteSize.X, 0, 1)
        local val = min + (max - min) * rel
        val = math.floor(val / decimals + 0.5) * decimals
        val = math.clamp(val, min, max)
        Fill.Size = UDim2.new((val - min) / (max - min), 0, 1, 0)
        Value.Text = tostring(val) .. suffix
        Library.Flags[flag] = val
        callback(val)
    end

    Btn.MouseButton1Down:Connect(function()
        sliding = true
    end)

    local inputEndedConn = UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sliding = false
        end
    end)
    table.insert(Library.Connections, inputEndedConn)

    local inputChangedConn = UserInputService.InputChanged:Connect(function(input)
        if sliding and input.UserInputType == Enum.UserInputType.MouseMovement then
            Update(input)
        end
    end)
    table.insert(Library.Connections, inputChangedConn)

    return Slider
end

local function CreateList(parent, options)
    local name = options.Name or "Dropdown"
    local flag = options.Flag or name
    local opts = options.Options or {}
    local default = options.State or (opts[1] or "")
    local multi = options.Multi or false
    local callback = options.Callback or function() end

    local Drop = Instance.new("Frame")
    Drop.Name = name
    Drop.Size = UDim2.new(1, 0, 0, 22)
    Drop.BackgroundTransparency = 1
    Drop.ClipsDescendants = false
    Drop.ZIndex = 17
    Drop.Parent = parent

    local Label = Instance.new("TextLabel")
    Label.Size = UDim2.new(0.42, 0, 1, 0)
    Label.BackgroundTransparency = 1
    Label.Text = name
    Label.TextColor3 = Colors.Text
    Label.TextSize = 13
    Label.FontFace = GothamRegular
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.ZIndex = 18
    Label.Parent = Drop

    local BtnOuter = Instance.new("Frame")
    BtnOuter.Size = UDim2.new(0.55, 0, 0, 20)
    BtnOuter.Position = UDim2.new(0.45, 0, 0.5, -10)
    BtnOuter.BackgroundColor3 = Colors.InnerBorder1
    BtnOuter.BorderSizePixel = 0
    BtnOuter.ZIndex = 18
    BtnOuter.Parent = Drop

    local BtnInner = Instance.new("Frame")
    BtnInner.Size = UDim2.new(1, -2, 1, -2)
    BtnInner.Position = UDim2.new(0, 1, 0, 1)
    BtnInner.BackgroundColor3 = Colors.InnerBorder2
    BtnInner.BorderSizePixel = 0
    BtnInner.ZIndex = 19
    BtnInner.Parent = BtnOuter

    local BtnBg = Instance.new("Frame")
    BtnBg.Size = UDim2.new(1, -2, 1, -2)
    BtnBg.Position = UDim2.new(0, 1, 0, 1)
    BtnBg.BackgroundColor3 = Colors.SurfaceLight
    BtnBg.BorderSizePixel = 0
    BtnBg.ZIndex = 20
    BtnBg.Parent = BtnInner

    local displayText = ""
    if multi then
        if type(default) == "table" then
            displayText = #default > 0 and table.concat(default, ", ") or "None"
        else
            displayText = "None"
            default = {}
        end
    else
        displayText = tostring(default)
    end

    local Selected = Instance.new("TextLabel")
    Selected.Size = UDim2.new(1, -20, 1, 0)
    Selected.Position = UDim2.new(0, 6, 0, 0)
    Selected.BackgroundTransparency = 1
    Selected.Text = displayText
    Selected.TextColor3 = Colors.TextSub
    Selected.TextSize = 11
    Selected.FontFace = GothamRegular
    Selected.TextXAlignment = Enum.TextXAlignment.Left
    Selected.TextTruncate = Enum.TextTruncate.AtEnd
    Selected.ZIndex = 21
    Selected.Parent = BtnBg

    local Arrow = Instance.new("TextLabel")
    Arrow.Size = UDim2.new(0, 12, 0, 12)
    Arrow.Position = UDim2.new(1, -14, 0.5, -6)
    Arrow.BackgroundTransparency = 1
    Arrow.Text = "▼"
    Arrow.TextColor3 = Colors.TextDim
    Arrow.TextSize = 8
    Arrow.FontFace = GothamRegular
    Arrow.ZIndex = 21
    Arrow.Parent = BtnBg

    -- Dropdown popup in PopupContainer (always on top)
    local DropdownPopup = Instance.new("ScrollingFrame")
    DropdownPopup.Name = flag .. "_DropdownPopup"
    DropdownPopup.Size = UDim2.new(0, 150, 0, math.min(#opts * 22 + 4, 180))
    DropdownPopup.BackgroundColor3 = Colors.InnerBorder1
    DropdownPopup.BorderSizePixel = 0
    DropdownPopup.Visible = false
    DropdownPopup.ZIndex = 100000
    DropdownPopup.ScrollBarThickness = 0
    DropdownPopup.CanvasSize = UDim2.new(0, 0, 0, #opts * 22 + 4)
    DropdownPopup.AutomaticCanvasSize = Enum.AutomaticSize.None
    DropdownPopup.ScrollingDirection = Enum.ScrollingDirection.Y
    DropdownPopup.Parent = PopupContainer

    local DropdownPopupInner = Instance.new("Frame")
    DropdownPopupInner.Size = UDim2.new(1, -2, 0, #opts * 22 + 2)
    DropdownPopupInner.Position = UDim2.new(0, 1, 0, 1)
    DropdownPopupInner.BackgroundColor3 = Colors.Surface
    DropdownPopupInner.BorderSizePixel = 0
    DropdownPopupInner.ZIndex = 100001
    DropdownPopupInner.Parent = DropdownPopup

    local ListLayout = Instance.new("UIListLayout")
    ListLayout.Padding = UDim.new(0, 0)
    ListLayout.Parent = DropdownPopupInner

    local ListPadding = Instance.new("UIPadding")
    ListPadding.PaddingTop = UDim.new(0, 1)
    ListPadding.Parent = DropdownPopupInner

    local currentSelected = multi and (type(default) == "table" and default or {}) or default
    Library.Flags[flag] = currentSelected
    Library.Options[flag] = {Value = currentSelected}

    for _, option in ipairs(opts) do
        local OptionBtn = Instance.new("TextButton")
        OptionBtn.Name = option
        OptionBtn.Size = UDim2.new(1, 0, 0, 22)
        OptionBtn.BackgroundColor3 = Colors.Surface
        OptionBtn.BorderSizePixel = 0
        OptionBtn.Text = option
        OptionBtn.TextSize = 11
        OptionBtn.FontFace = GothamRegular
        OptionBtn.AutoButtonColor = false
        OptionBtn.ZIndex = 100002
        OptionBtn.Parent = DropdownPopupInner

        local function updateOptionColor()
            if multi then
                local isSelected = false
                for _, s in ipairs(currentSelected) do
                    if s == option then
                        isSelected = true
                        break
                    end
                end
                OptionBtn.TextColor3 = isSelected and Colors.Accent or Colors.TextSub
            else
                OptionBtn.TextColor3 = currentSelected == option and Colors.Accent or Colors.TextSub
            end
        end
        updateOptionColor()

        OptionBtn.MouseEnter:Connect(function()
            PlayTween(OptionBtn, {BackgroundColor3 = Colors.SurfaceLight}, 0.1)
        end)
        OptionBtn.MouseLeave:Connect(function()
            PlayTween(OptionBtn, {BackgroundColor3 = Colors.Surface}, 0.1)
        end)
        OptionBtn.MouseButton1Click:Connect(function()
            if multi then
                local idx = nil
                for i, s in ipairs(currentSelected) do
                    if s == option then
                        idx = i
                        break
                    end
                end
                if idx then
                    table.remove(currentSelected, idx)
                else
                    table.insert(currentSelected, option)
                end
                Selected.Text = #currentSelected > 0 and table.concat(currentSelected, ", ") or "None"
            else
                currentSelected = option
                Selected.Text = option
                DropdownPopup.Visible = false
                Arrow.Text = "▼"
            end

            Library.Flags[flag] = currentSelected
            Library.Options[flag].Value = currentSelected

            -- Update all option colors
            for _, child in ipairs(DropdownPopupInner:GetChildren()) do
                if child:IsA("TextButton") then
                    if multi then
                        local sel = false
                        for _, s in ipairs(currentSelected) do
                            if s == child.Text then
                                sel = true
                                break
                            end
                        end
                        child.TextColor3 = sel and Colors.Accent or Colors.TextSub
                    else
                        child.TextColor3 = child.Text == currentSelected and Colors.Accent or Colors.TextSub
                    end
                end
            end

            callback(currentSelected)
        end)
    end

    local DropBtn = Instance.new("TextButton")
    DropBtn.Size = UDim2.new(1, 0, 1, 0)
    DropBtn.BackgroundTransparency = 1
    DropBtn.Text = ""
    DropBtn.ZIndex = 22
    DropBtn.Parent = BtnOuter

    DropBtn.MouseButton1Click:Connect(function()
        -- Close all other popups
        for _, child in ipairs(PopupContainer:GetChildren()) do
            if child ~= DropdownPopup then
                child.Visible = false
            end
        end

        local isOpen = not DropdownPopup.Visible
        DropdownPopup.Visible = isOpen
        Arrow.Text = isOpen and "▲" or "▼"

