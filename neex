    TabAccent.Position = UDim2.new(0, 0, 1, -2)
    TabAccent.BackgroundColor3 = Colors.Accent
    TabAccent.BorderSizePixel = 0
    TabAccent.Visible = index == 1
    TabAccent.ZIndex = 10
    TabAccent.Parent = Tab

    local TabLabel = Instance.new("TextLabel")
    TabLabel.Size = UDim2.new(1, 0, 1, 0)
    TabLabel.BackgroundTransparency = 1
    TabLabel.Text = name
    TabLabel.TextColor3 = index == 1 and Colors.Text or Colors.TextDim
    TabLabel.TextTransparency = index == 1 and 0 or 0.3
    TabLabel.TextSize = 13
    TabLabel.FontFace = GothamMedium
    TabLabel.ZIndex = 10
    TabLabel.Parent = Tab

    local TabBtn = Instance.new("TextButton")
    TabBtn.Size = UDim2.new(1, 0, 1, 0)
    TabBtn.BackgroundTransparency = 1
    TabBtn.Text = ""
    TabBtn.ZIndex = 11
    TabBtn.Parent = Tab

    TabBtn.MouseEnter:Connect(function()
        if CurrentTab ~= name then
            PlayTween(TabLabel, {TextTransparency = 0.15}, 0.15)
        end
    end)
    TabBtn.MouseLeave:Connect(function()
        if CurrentTab ~= name then
            PlayTween(TabLabel, {TextTransparency = 0.3}, 0.15)
        end
    end)
    TabBtn.MouseButton1Click:Connect(function()
        SelectTab(name)
    end)

    TabButtons[name] = {Frame = Tab, Label = TabLabel, Accent = TabAccent}

    local TabPage = Instance.new("Frame")
    TabPage.Name = name .. "Page"
    TabPage.Size = UDim2.new(1, 0, 1, 0)
    TabPage.BackgroundTransparency = 1
    TabPage.Visible = index == 1
    TabPage.ZIndex = 11
    TabPage.Parent = ContentBg

    Tabs[name] = TabPage

    if index == 1 then
        CurrentTab = name
    end

    local TabObj = {}

    function TabObj:Section(opts)
        return CreateSection(TabPage, opts)
    end

    return TabObj
end

