-- LIBRARY METHODS
-- ═══════════════════════════════════════════════

function Library:OnUnload(callback)
    table.insert(Library.OnUnloadCallbacks, callback)
end

function Library:Unload()
    if Library.Unloaded then return end
    Library.Unloaded = true
    for _, callback in ipairs(Library.OnUnloadCallbacks) do
        pcall(callback)
    end
    for _, conn in ipairs(Library.Connections) do
        if conn and conn.Connected then
            conn:Disconnect()
        end
    end
    if ScreenGui then
        ScreenGui:Destroy()
    end
    getgenv().library = nil
end

function Library:SetProject(projectName)
    Library.ProjectName = projectName
    EnsureFolder(Library.ConfigFolder)
    if projectName then
        EnsureFolder(Library.ConfigFolder .. "/" .. projectName)
    end
end

function Library:AutoShow()
    Layer1.BackgroundTransparency = 1
    Layer1.Visible = true
    local originals = {}
    for _, desc in ipairs(Layer1:GetDescendants()) do
        local props = {}
        pcall(function()
            if desc:IsA("Frame") then
                props.BackgroundTransparency = desc.BackgroundTransparency
                desc.BackgroundTransparency = 1
            elseif desc:IsA("TextLabel") or desc:IsA("TextButton") or desc:IsA("TextBox") then
                props.BackgroundTransparency = desc.BackgroundTransparency
                props.TextTransparency = desc.TextTransparency
                desc.BackgroundTransparency = 1
                desc.TextTransparency = 1
            elseif desc:IsA("ImageLabel") or desc:IsA("ImageButton") then
                props.BackgroundTransparency = desc.BackgroundTransparency
                props.ImageTransparency = desc.ImageTransparency
                desc.BackgroundTransparency = 1
                desc.ImageTransparency = 1
            elseif desc:IsA("ScrollingFrame") then
                props.BackgroundTransparency = desc.BackgroundTransparency
                props.ScrollBarImageTransparency = desc.ScrollBarImageTransparency
                desc.BackgroundTransparency = 1
                desc.ScrollBarImageTransparency = 1
            end
        end)
        if next(props) then
            originals[desc] = props
        end
    end
    local duration = 0.4
    PlayTween(Layer1, {BackgroundTransparency = 0}, duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
    for desc, props in pairs(originals) do
        pcall(function()
            PlayTween(desc, props, duration, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)
        end)
    end
end

