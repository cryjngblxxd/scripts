-- PROJECT FOLDER SYSTEM
-- ═══════════════════════════════════════════════

local function EnsureFolder(path)
    if not isfolder(path) then
        makefolder(path)
    end
end

local function GetProjectFolder()
    EnsureFolder(Library.ConfigFolder)
    if Library.ProjectName then
        local projectPath = Library.ConfigFolder .. "/" .. Library.ProjectName
        EnsureFolder(projectPath)
        return projectPath
    end
    return Library.ConfigFolder
end

local function GetConfigPath(configName)
    return GetProjectFolder() .. "/" .. configName .. ".json"
end

local function GetAutoLoadPath()
    return GetProjectFolder() .. "/_autoload.txt"
end

-- ═══════════════════════════════════════════════
-- CONFIG SYSTEM
-- ═══════════════════════════════════════════════

local ConfigSystem = {}
Library.ConfigSystem = ConfigSystem

function ConfigSystem:GetConfigs()
    local folder = GetProjectFolder()
    local configs = {}
    local success, files = pcall(function()
        return listfiles(folder)
    end)
    if success and files then
        for _, file in ipairs(files) do
            local name = file:match("([^/\\]+)$")
            if name and name:sub(-5) == ".json" then
                table.insert(configs, name:sub(1, -6))
            end
        end
    end
    return configs
end

function ConfigSystem:SaveConfig(configName)
    local data = {}
    for flag, value in pairs(Library.Flags) do
        if type(value) ~= "function" then
            if typeof(value) == "Color3" then
                data[flag] = {type = "Color3", r = math.floor(value.R * 255), g = math.floor(value.G * 255), b = math.floor(value.B * 255)}
            else
                data[flag] = value
            end
        end
    end
    local success, result = pcall(function()
        writefile(GetConfigPath(configName), HttpService:JSONEncode(data))
    end)
    return success, result
end

function ConfigSystem:LoadConfig(configName)
    local path = GetConfigPath(configName)
    if not isfile(path) then
        return false, "Config not found"
    end
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(path))
    end)
    if not success then
        return false, "Failed to parse config"
    end
    for flag, value in pairs(data) do
        if type(value) == "table" and value.type == "Color3" then
            Library.Flags[flag] = Color3.fromRGB(value.r, value.g, value.b)
        else
            Library.Flags[flag] = value
        end
        -- Update toggle visuals
        if Library.Toggles[flag] then
            Library.Toggles[flag]:SetValue(value)
        end
    end
    Library:UpdateKeybindList()
    return true
end

function ConfigSystem:DeleteConfig(configName)
    local path = GetConfigPath(configName)
    if isfile(path) then
        delfile(path)
        return true
    end
    return false
end

function ConfigSystem:SetAutoLoad(configName)
    if configName then
        writefile(GetAutoLoadPath(), configName)
        Library.AutoLoadConfig = configName
    else
        if isfile(GetAutoLoadPath()) then
            delfile(GetAutoLoadPath())
        end
        Library.AutoLoadConfig = nil
    end
end

function ConfigSystem:GetAutoLoad()
    if isfile(GetAutoLoadPath()) then
        local name = readfile(GetAutoLoadPath())
        if name and name ~= "" then
            return name
        end
    end
    return nil
end

function ConfigSystem:TryAutoLoad()
    local autoLoadName = ConfigSystem:GetAutoLoad()
    if autoLoadName then
        local path = GetConfigPath(autoLoadName)
        if isfile(path) then
            Library.AutoLoadConfig = autoLoadName
            return ConfigSystem:LoadConfig(autoLoadName)
        end
    end
    return false
end

