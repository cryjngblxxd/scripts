local function PlayTween(object, properties, duration, easingStyle, easingDir)
    easingStyle = easingStyle or Enum.EasingStyle.Linear
    easingDir = easingDir or Enum.EasingDirection.Out
    local tween = TweenService:Create(object, TweenInfo.new(duration, easingStyle, easingDir), properties)
    tween:Play()
    return tween
end


-- DRAGGING


local function makeDraggable(frame)
    local dragging, dragInput, dragStart, startPos
    frame.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    frame.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    local conn = UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    table.insert(Library.Connections, conn)
end


-- PROJECT FOLDER SYSTEM


local function EnsureFolder(path)
    if not isfolder(path) then makefolder(path) end
end

local function GetProjectFolder()
    EnsureFolder(Library.ConfigFolder)
    if Library.ProjectName then
        local p = Library.ConfigFolder .. "/" .. Library.ProjectName
        EnsureFolder(p)
        return p
    end
    return Library.ConfigFolder
end

local function GetConfigPath(configName)
    return GetProjectFolder() .. "/" .. configName .. ".json"
end

local function GetAutoLoadPath()
    return GetProjectFolder() .. "/_autoload.txt"
end


-- CONFIG SYSTEM


local ConfigSystem = {}
Library.ConfigSystem = ConfigSystem

function ConfigSystem:GetConfigs()
    local folder = GetProjectFolder()
    local configs = {}
    local s, files = pcall(function() return listfiles(folder) end)
    if s and files then
        for _, file in ipairs(files) do
            local name = file:match("([^/\\]+)$")
            if name and name:sub(-5) == ".json" then
                table.insert(configs, name:sub(1, -6))
            end
        end
    end
    return configs
end

function ConfigSystem:SaveConfig(configName)
    local data = {}
    for flag, element in pairs(Library.Elements) do
        local d = {type = element.Type}
        if element.Type == "Toggle" then
            d.value = element.State.isEnabled
            d.keybind = element.State.currentKey
            d.mode = element.State.currentMode
        elseif element.Type == "Slider" then
            d.value = element.State.currentVal
        elseif element.Type == "Dropdown" then
            d.value = element.State.currentSelected
        elseif element.Type == "Keybind" then
            d.value = element.State.currentKey
        end
        data[flag] = d
    end
    local s, r = pcall(function()
        writefile(GetConfigPath(configName), HttpService:JSONEncode(data))
    end)
    return s, r
end

function ConfigSystem:LoadConfig(configName)
    local path = GetConfigPath(configName)
    if not isfile(path) then return false, "Config not found" end
    local s, data = pcall(function() return HttpService:JSONDecode(readfile(path)) end)
    if not s then return false, "Failed to parse config" end
    for flag, ed in pairs(data) do
        local el = Library.Elements[flag]
        if el then
            if el.Type == "Toggle" and ed.type == "Toggle" then
                if ed.mode then
                    el.State.currentMode = ed.mode
                    for m, btn in pairs(el.ModeButtons) do
                        btn.TextColor3 = m == ed.mode and Colors.Accent or Colors.TextSub
                        btn.BackgroundColor3 = Colors.Background
                    end
                end
                if ed.keybind ~= nil then
                    el.State.currentKey = ed.keybind
                    if ed.keybind then
                        el.UI.KeybindText.Text = ed.keybind
                        el.UI.KeybindText.TextColor3 = Colors.Accent
                    else
                        el.UI.KeybindText.Text = "..."
                        el.UI.KeybindText.TextColor3 = Colors.TextDim
                    end
                end
                local nv = ed.value
                if ed.mode == "Always" then nv = true end
                el.State.isEnabled = nv
                Library.Flags[flag] = nv
                el.UI.CheckFill.BackgroundColor3 = nv and Colors.Accent or Colors.Disabled
                if el.Callback then pcall(el.Callback, nv) end
                Library:UpdateKeybindList()
            elseif el.Type == "Slider" and ed.type == "Slider" then
                local val = math.clamp(ed.value, el.State.min, el.State.max)
                local rel = (val - el.State.min) / (el.State.max - el.State.min)
                el.State.currentVal = val
                Library.Flags[flag] = val
                el.UI.Fill.Size = UDim2.new(rel, 0, 1, 0)
                el.UI.ValueLabel.Text = tostring(val)
                if el.Callback then pcall(el.Callback, val) end
            elseif el.Type == "Dropdown" and ed.type == "Dropdown" then
                local valid = false
                for _, o in ipairs(el.State.options) do if o == ed.value then valid = true; break end end
                if valid then
                    el.State.currentSelected = ed.value
                    Library.Flags[flag] = ed.value
                    el.UI.Selected.Text = ed.value
                    if el.UI.ListInner then
                        for _, c in ipairs(el.UI.ListInner:GetChildren()) do
                            if c:IsA("TextButton") then
                                c.TextColor3 = c.Name == ed.value and Colors.Accent or Colors.TextSub
                                c.BackgroundColor3 = Colors.Surface
                            end
                        end
                    end
                    if el.Callback then pcall(el.Callback, ed.value) end
                end
            elseif el.Type == "Keybind" and ed.type == "Keybind" then
                el.State.currentKey = ed.value
                Library.Flags[flag] = ed.value
                el.UI.KeyText.Text = ed.value
                if el.Callback then pcall(el.Callback, ed.value) end
            end
        end
    end
    return true
end

function ConfigSystem:DeleteConfig(configName)
    local path = GetConfigPath(configName)
    if isfile(path) then delfile(path); return true end
    return false
end

function ConfigSystem:SetAutoLoad(configName)
    if configName then
        writefile(GetAutoLoadPath(), configName)
        Library.AutoLoadConfig = configName
    else
        if isfile(GetAutoLoadPath()) then delfile(GetAutoLoadPath()) end
        Library.AutoLoadConfig = nil
    end
end

function ConfigSystem:GetAutoLoad()
    if isfile(GetAutoLoadPath()) then
        local n = readfile(GetAutoLoadPath())
        if n and n ~= "" then return n end
    end
    return nil
end

function ConfigSystem:TryAutoLoad()
    local n = ConfigSystem:GetAutoLoad()
    if n then
        local path = GetConfigPath(n)
        if isfile(path) then
            Library.AutoLoadConfig = n
            return ConfigSystem:LoadConfig(n)
        end
    end
    return false
end


