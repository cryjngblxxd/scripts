local function SelectTab(tabName)
    for name, btn in pairs(TabButtons) do
        local sel = name == tabName
        PlayTween(btn.Frame, {BackgroundColor3 = sel and Colors.SurfaceLight or Colors.Background}, 0.2)
        PlayTween(btn.Icon, {ImageColor3 = sel and Colors.Accent or Colors.TextDim, ImageTransparency = sel and 0 or 0.3}, 0.2)
        PlayTween(btn.Label, {TextColor3 = sel and Colors.Text or Colors.TextDim, TextTransparency = sel and 0 or 0.3}, 0.2)
        if btn.Accent then btn.Accent.Visible = sel end
        if Tabs[name] then Tabs[name].Visible = sel end
    end
    CurrentTab = tabName
end

local function SelectSubtab(mainTabName, subtabName)
    local subtabs = SubtabStorage[mainTabName]
    if not subtabs then return end
    for name, btn in pairs(subtabs) do
        local sel = name == subtabName
        PlayTween(btn.Icon, {ImageTransparency = sel and 0 or 0.5, ImageColor3 = sel and Colors.Accent or Colors.Text}, 0.2)
        PlayTween(btn.Label, {TextTransparency = sel and 0 or 0.5, TextColor3 = sel and Colors.Accent or Colors.Text}, 0.2)
        if btn.SelectionBar then PlayTween(btn.SelectionBar, {BackgroundTransparency = sel and 0 or 1}, 0.2) end
        if btn.ContentPage then btn.ContentPage.Visible = sel end
    end
    CurrentSubtabs[mainTabName] = subtabName
end

