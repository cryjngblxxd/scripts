    -- Reposition subtitle after title with proper spacing
    task.defer(function()
        local titleWidth = TitleText.TextBounds.X
        SubTitleText.Position = UDim2.new(0, 14 + titleWidth + 8, 0, 1)
    end)
end

function Library:OnUnload(callback)
    table.insert(Library.OnUnloadCallbacks, callback)
end

function Library:Unload()
    if Library.Unloaded then return end
    Library.Unloaded = true
    for _, cb in ipairs(Library.OnUnloadCallbacks) do pcall(cb) end
    for _, conn in ipairs(Library.Connections) do
        if conn and conn.Connected then conn:Disconnect() end
    end
    if ScreenGui then ScreenGui:Destroy() end
    getgenv().library = nil
end

function Library:SetProject(projectName)
    Library.ProjectName = projectName
    EnsureFolder(Library.ConfigFolder)
    if projectName then EnsureFolder(Library.ConfigFolder .. "/" .. projectName) end
end

