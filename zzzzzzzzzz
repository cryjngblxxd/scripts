local function tween(obj, props, dur)
    TweenService:Create(obj, TweenInfo.new(dur or 0.2, Enum.EasingStyle.Quad), props):Play()
end

local function gkn(k)
    if k == nil then return "None" end
    local s = tostring(k)
    if s:find("MouseButton1") then return "MB1"
    elseif s:find("MouseButton2") then return "MB2"
    elseif s:find("MouseButton3") then return "MB3" end
    return s:gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
end

local function parseKeyName(name)
    if name == "MB1" then return Enum.UserInputType.MouseButton1
    elseif name == "MB2" then return Enum.UserInputType.MouseButton2
    elseif name == "MB3" then return Enum.UserInputType.MouseButton3
    else
        local ok, key = pcall(function() return Enum.KeyCode[name] end)
        if ok and key then return key end
    end
    return Enum.KeyCode.Unknown
end

local function regAccent(obj, prop)
    table.insert(Library._accentElements, {obj = obj, prop = prop})
end

local function isMouseOver(obj, pos)
    local ap = obj.AbsolutePosition
    local as = obj.AbsoluteSize
    return pos.X >= ap.X and pos.X <= ap.X + as.X and pos.Y >= ap.Y and pos.Y <= ap.Y + as.Y
end

local function refreshKeybindList()
    if not Library._keybindContainer then return end
    for _, c in pairs(Library._keybindContainer:GetChildren()) do
        if c:IsA("Frame") then c:Destroy() end
    end
    local idx = 0
    for _, opt in pairs(Options) do
        if opt._type == "KeyPicker" and not opt.NoUI and opt._active then
            local showKeybind = true
            if opt._parentToggleIdx then
                local parentToggle = Toggles[opt._parentToggleIdx]
                if parentToggle and not parentToggle.Value then
                    showKeybind = false
                end
            end
            if showKeybind then
                local row = Instance.new("Frame")
                row.Size = UDim2.new(1, 0, 0, 20)
                row.Position = UDim2.new(0, 0, 0, idx * 24)
                row.BackgroundTransparency = 1
                row.ZIndex = 102
                row.Parent = Library._keybindContainer
                local nl = Instance.new("TextLabel")
                nl.Size = UDim2.new(1, -60, 1, 0)
                nl.BackgroundTransparency = 1
                nl.Text = opt.Text or opt._idx
                nl.TextColor3 = Library._accentColor
                nl.TextSize = 13
                nl.Font = Enum.Font.Gotham
                nl.TextXAlignment = Enum.TextXAlignment.Left
                nl.ZIndex = 102
                nl.Parent = row
                local ml = Instance.new("TextLabel")
                ml.Size = UDim2.new(0, 55, 1, 0)
                ml.Position = UDim2.new(1, -55, 0, 0)
                ml.BackgroundTransparency = 1
                ml.Text = "[" .. opt.Mode .. "]"
                ml.TextColor3 = Color3.fromRGB(180, 180, 180)
                ml.TextSize = 11
                ml.Font = Enum.Font.Gotham
                ml.TextXAlignment = Enum.TextXAlignment.Right
                ml.ZIndex = 102
                ml.Parent = row
                idx += 1
            end
        end
    end
    local totalH = math.max(idx * 24, 10)
    Library._keybindFrame.Size = UDim2.new(0, 200, 0, 48 + totalH + 8)
end

local ToggleClass = {}
ToggleClass.__index = ToggleClass

function ToggleClass:OnChanged(fn)
    self._changed = fn
end

function ToggleClass:OnClick(fn)
    self._onClick = fn
end

function ToggleClass:SetValue(val)
    self.Value = val
    if self._update then self._update() end
    if self._changed then self._changed(val) end
    if self.Callback then self.Callback(val) end
end

local OptionClass = {}
OptionClass.__index = OptionClass

function OptionClass:OnChanged(fn)
    self._changed = fn
end

function OptionClass:OnClick(fn)
    self._onClick = fn
end

function OptionClass:SetValue(val)
    if self._setValue then
        self._setValue(val)
    else
        self.Value = val
    end
    if self._changed then self._changed(self.Value) end
end

function OptionClass:GetState()
    return self._active or false
end

function Library:SetWatermark(text)
    Library._watermarkFormat = text
end

function Library:GetWatermarkFormat()
    return Library._watermarkFormat
end

function Library:SetWatermarkVisibility(v)
    Library._watermarkVisible = v
    if self._watermarkFrame then
        self._watermarkFrame.Visible = v
    end
end

function Library:OnUnload(fn)
    table.insert(self._onUnload, fn)
end

function Library:Unload()
    self.Unloaded = true
    for _, fn in ipairs(self._onUnload) do
        pcall(fn)
    end
    if self._screenGui then self._screenGui:Destroy() end
    if self._popupGui then self._popupGui:Destroy() end
end

