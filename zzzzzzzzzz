                lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 13
                if opts.Compact then lbl.Visible = false end

                local val = Instance.new("TextLabel", W)
                val.Size = UDim2.new(0,55,0,14); val.Position = UDim2.new(1,-57,0,0)
                val.BackgroundTransparency = 1; val.TextColor3 = accentColor
                val.TextSize = 13; val.Font = Enum.Font.Gotham
                val.TextXAlignment = Enum.TextXAlignment.Right; val.ZIndex = 13
                regAccent(val, "TextColor3")

                local barFrame = Instance.new("Frame", W)
                barFrame.Size = UDim2.new(1,-4,0,12); barFrame.Position = UDim2.new(0,2,0,16)
                barFrame.BackgroundColor3 = Color3.fromRGB(12,12,12); barFrame.BorderSizePixel = 0; barFrame.ZIndex = 13

                local barBrd = Instance.new("Frame", barFrame)
                barBrd.Size = UDim2.new(1,2,1,2); barBrd.Position = UDim2.new(0,-1,0,-1)
                barBrd.BackgroundColor3 = Color3.fromRGB(45,45,45); barBrd.BorderSizePixel = 0; barBrd.ZIndex = 12

                local barFill = Instance.new("Frame", barFrame)
                barFill.Size = UDim2.new(math.clamp((option.Value-min)/(max-min),0,1),0,1,0)
                barFill.BackgroundColor3 = accentColor; barFill.BorderSizePixel = 0; barFill.ZIndex = 14
                regAccent(barFill, "BackgroundColor3")

                local function fmt(v)
                    return string.format("%." .. rounding .. "f", v) .. suffix
                end

                local function setV(v)
                    local rounded = tonumber(string.format("%." .. rounding .. "f", math.clamp(v, min, max)))
                    option.Value = rounded
                    barFill.Size = UDim2.new(math.clamp((rounded-min)/(max-min),0,1),0,1,0)
                    if opts.HideMax or opts.Compact then
                        val.Text = fmt(rounded)
                    else
                        val.Text = fmt(rounded) .. "/" .. fmt(max)
                    end
                    if option.Callback then option.Callback(rounded) end
                    if option._changed then option._changed(rounded) end
                end

                option._setValue = function(v) setV(v) end
                setV(option.Value)

                local sliding = false
                local sBtn = Instance.new("TextButton", barFrame)
                sBtn.Size = UDim2.new(1,0,1,0); sBtn.BackgroundTransparency = 1; sBtn.Text = ""; sBtn.ZIndex = 15

                sBtn.MouseButton1Down:Connect(function()
                    sliding = true
                    local pct = math.clamp((mouse.X - barFrame.AbsolutePosition.X) / barFrame.AbsoluteSize.X, 0, 1)
                    setV(min + (max-min)*pct)
                end)

                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
                end)

                UserInputService.InputChanged:Connect(function(i)
                    if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
                        local pct = math.clamp((i.Position.X - barFrame.AbsolutePosition.X) / barFrame.AbsoluteSize.X, 0, 1)
                        setV(min + (max-min)*pct)
                    end
                end)

                return option
            end

            function Group:AddDropdown(idx, opts)
                opts = opts or {}
                local option = setmetatable({}, OptionClass)
                option._type = "Dropdown"
                option.Callback = opts.Callback

                local values = opts.Values or {}
                local multi = opts.Multi or false

                if multi then
                    if type(opts.Default) == "table" then
                        option.Value = opts.Default
                    elseif type(opts.Default) == "number" and values[opts.Default] then
                        option.Value = {[values[opts.Default]] = true}
                    elseif type(opts.Default) == "string" then
                        option.Value = {[opts.Default] = true}
                    else
                        option.Value = {}
                    end
                else
                    if type(opts.Default) == "number" and values[opts.Default] then
                        option.Value = values[opts.Default]
                    elseif type(opts.Default) == "string" then
                        option.Value = opts.Default
                    else
                        option.Value = values[1] or ""
                    end
                end
                Options[idx] = option

                local isOpen = false
                local optBtns = {}

                local W = Instance.new("Frame", sContent)
                W.Size = UDim2.new(1,0,0,22); W.BackgroundTransparency = 1; W.ZIndex = 12

                local lbl = Instance.new("TextLabel", W)
                lbl.Size = UDim2.new(0.45,0,0,22); lbl.Position = UDim2.new(0,2,0,0)
                lbl.BackgroundTransparency = 1; lbl.Text = opts.Text or idx
                lbl.TextColor3 = Color3.fromRGB(180,180,180); lbl.TextSize = 13
                lbl.Font = Enum.Font.Gotham; lbl.TextXAlignment = Enum.TextXAlignment.Left; lbl.ZIndex = 13

                local selFrame = Instance.new("Frame", W)
                selFrame.Size = UDim2.new(0.53,-4,0,16); selFrame.Position = UDim2.new(0.47,0,0,3)
                selFrame.BackgroundColor3 = Color3.fromRGB(12,12,12); selFrame.BorderSizePixel = 0; selFrame.ZIndex = 13

                local selBrd = Instance.new("Frame", selFrame)
                selBrd.Size = UDim2.new(1,2,1,2); selBrd.Position = UDim2.new(0,-1,0,-1)
                selBrd.BackgroundColor3 = Color3.fromRGB(45,45,45); selBrd.BorderSizePixel = 0; selBrd.ZIndex = 12

                local selInner = Instance.new("Frame", selFrame)
                selInner.Size = UDim2.new(1,-2,1,-2); selInner.Position = UDim2.new(0,1,0,1)
                selInner.BackgroundColor3 = Color3.fromRGB(18,18,18); selInner.BorderSizePixel = 0; selInner.ZIndex = 14

                local function getDsp()
                    if multi then
                        local s = {}
                        for _, o in ipairs(values) do
                            if option.Value[o] then table.insert(s, o) end
                        end
                        return #s > 0 and table.concat(s, ", ") or "None"
                    else
                        return tostring(option.Value)
                    end
                end

                local selLbl = Instance.new("TextLabel", selInner)
                selLbl.Size = UDim2.new(1,-16,1,0); selLbl.Position = UDim2.new(0,4,0,0)
                selLbl.BackgroundTransparency = 1; selLbl.Text = getDsp()
                selLbl.TextColor3 = accentColor; selLbl.TextSize = 11
                selLbl.Font = Enum.Font.Gotham; selLbl.TextTruncate = Enum.TextTruncate.AtEnd; selLbl.ZIndex = 15
                regAccent(selLbl, "TextColor3")

                local arrow = Instance.new("TextLabel", selInner)
                arrow.Size = UDim2.new(0,10,1,0); arrow.Position = UDim2.new(1,-12,0,0)
                arrow.BackgroundTransparency = 1; arrow.Text = "v"
                arrow.TextColor3 = Color3.fromRGB(100,100,100); arrow.TextSize = 10
                arrow.Font = Enum.Font.GothamBold; arrow.ZIndex = 15

                local selBtn = Instance.new("TextButton", selFrame)
                selBtn.Size = UDim2.new(1,0,1,0); selBtn.BackgroundTransparency = 1
                selBtn.Text = ""; selBtn.ZIndex = 16

                local function closeDD()
                    isOpen = false
                    arrow.Text = "v"
                    for _, d in ipairs(optBtns) do
                        d.btn.Visible = false
                    end
                end

                local function updateBtnColors()
                    for _, d in ipairs(optBtns) do
                        if multi then
                            d.btn.TextColor3 = option.Value[d.val] and accentColor or Color3.fromRGB(180,180,180)
                        else
                            d.btn.TextColor3 = (option.Value == d.val) and accentColor or Color3.fromRGB(180,180,180)
                        end
                    end
                end

                local function openDD()
                    isOpen = true
                    arrow.Text = "^"
                    local absPos = selFrame.AbsolutePosition
                    local absSize = selFrame.AbsoluteSize
                    for i, d in ipairs(optBtns) do
                        d.btn.Position = UDim2.fromOffset(absPos.X, absPos.Y + absSize.Y + 2 + ((i - 1) * 19))
                        d.btn.Size = UDim2.fromOffset(absSize.X, 18)
                        d.btn.Visible = true
                    end
                    updateBtnColors()
                end

                local function buildOpts()
                    for _, d in ipairs(optBtns) do
                        d.btn:Destroy()
                    end
                    optBtns = {}

                    for i, v in ipairs(values) do
                        local optVal = v
                        local btn = Instance.new("TextButton")
                        btn.Size = UDim2.new(0,100,0,18)
                        btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
                        btn.BorderSizePixel = 0
                        btn.Text = "  " .. v
                        btn.TextXAlignment = Enum.TextXAlignment.Left
                        btn.TextSize = 11
                        btn.Font = Enum.Font.Gotham
                        btn.ZIndex = 9999
                        btn.AutoButtonColor = false
                        btn.Visible = false
                        btn.Parent = Library._popupGui

                        local btnBorder = Instance.new("Frame", btn)
                        btnBorder.Size = UDim2.new(1,2,1,0)
                        btnBorder.Position = UDim2.new(0,-1,0,0)
                        btnBorder.BackgroundColor3 = Color3.fromRGB(45,45,45)
                        btnBorder.BorderSizePixel = 0
                        btnBorder.ZIndex = 9998

                        local btnInner = Instance.new("Frame", btn)
                        btnInner.Size = UDim2.new(1,0,1,0)
                        btnInner.BackgroundColor3 = Color3.fromRGB(20,20,20)
                        btnInner.BorderSizePixel = 0
                        btnInner.ZIndex = 9998

                        if multi then
                            btn.TextColor3 = option.Value[v] and accentColor or Color3.fromRGB(180,180,180)
                        else
                            btn.TextColor3 = (option.Value == v) and accentColor or Color3.fromRGB(180,180,180)
                        end

                        btn.MouseEnter:Connect(function() 
                            btn.BackgroundColor3 = Color3.fromRGB(30,30,30)
                            btnInner.BackgroundColor3 = Color3.fromRGB(30,30,30)
                        end)
                        btn.MouseLeave:Connect(function() 
                            btn.BackgroundColor3 = Color3.fromRGB(20,20,20)
                            btnInner.BackgroundColor3 = Color3.fromRGB(20,20,20)
                        end)

                        btn.MouseButton1Click:Connect(function()
                            if multi then
                                if option.Value[optVal] then
                                    option.Value[optVal] = nil
                                else
                                    option.Value[optVal] = true
                                end
                            else
                                option.Value = optVal
                            end
                            selLbl.Text = getDsp()
                            updateBtnColors()
                            if not multi then closeDD() end
                            if option.Callback then option.Callback(option.Value) end
                            if option._changed then option._changed(option.Value) end
                        end)

                        table.insert(optBtns, {btn = btn, val = v})
                    end
                end
                buildOpts()

                selBtn.MouseButton1Click:Connect(function()
                    if isOpen then closeDD() else openDD() end
                end)

                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and isOpen then
                        local mp = Vector2.new(input.Position.X, input.Position.Y)
                        task.wait()
                        if isMouseOver(selFrame, mp) then return end
                        for _, d in ipairs(optBtns) do
                            if d.btn.Visible and isMouseOver(d.btn, mp) then return end
                        end
                        closeDD()
                    end
                end)

                option._setValue = function(v)
                    option.Value = v
                    selLbl.Text = getDsp()
                    updateBtnColors()
                end

                option.Values = values

                function option:SetValues(newVals)
                    values = newVals
                    option.Values = newVals
                    closeDD()
                    buildOpts()
                    selLbl.Text = getDsp()
                end

                return option
            end

