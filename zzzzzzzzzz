                local F = Instance.new("Frame", sContent)
                F.Size = UDim2.new(1,0,0,8); F.BackgroundTransparency = 1; F.ZIndex = 12
                local L = Instance.new("Frame", F)
                L.Size = UDim2.new(1,-4,0,1); L.Position = UDim2.new(0,2,0.5,0)
                L.BackgroundColor3 = Color3.fromRGB(45,45,45); L.BorderSizePixel = 0; L.ZIndex = 13
            end

            function Group:AddKeyPicker(idx, opts, parentFrame)
                opts = opts or {}
                local option = setmetatable({}, OptionClass)
                option._type = "KeyPicker"
                option._idx = idx
                option.Text = opts.Text or idx
                option.NoUI = opts.NoUI or false
                option.Mode = opts.Mode or "Toggle"
                option.Callback = opts.Callback
                option.ChangedCallback = opts.ChangedCallback
                option._active = false
                option._parentToggleIdx = opts._parentToggleIdx
                Options[idx] = option

                if type(opts.Default) == "string" then
                    option.Value = parseKeyName(opts.Default)
                else
                    option.Value = opts.Default or Enum.KeyCode.Unknown
                end

                local mOpen = false
                local listening = false
                local toggled = false

                local container = parentFrame or Instance.new("Frame", sContent)
                if not parentFrame then
                    container.Size = UDim2.new(1,0,0,22)
                    container.BackgroundTransparency = 1
                    container.ZIndex = 12
                end

                local keyFrame = Instance.new("Frame", container)
                keyFrame.Name = "KeyPickerFrame"
                keyFrame.Size = UDim2.new(0,55,0,12)
                keyFrame.Position = UDim2.new(1,-57,0,5)
                keyFrame.BackgroundColor3 = Color3.fromRGB(12,12,12)
                keyFrame.BorderSizePixel = 0
                keyFrame.ZIndex = 13

                local keyBrd = Instance.new("Frame", keyFrame)
                keyBrd.Size = UDim2.new(1,2,1,2); keyBrd.Position = UDim2.new(0,-1,0,-1)
                keyBrd.BackgroundColor3 = Color3.fromRGB(45,45,45); keyBrd.BorderSizePixel = 0; keyBrd.ZIndex = 12

                local keyInner = Instance.new("Frame", keyFrame)
                keyInner.Size = UDim2.new(1,-2,1,-2); keyInner.Position = UDim2.new(0,1,0,1)
                keyInner.BackgroundColor3 = Color3.fromRGB(18,18,18); keyInner.BorderSizePixel = 0; keyInner.ZIndex = 14

                local keyLbl = Instance.new("TextLabel", keyInner)
                keyLbl.Size = UDim2.new(1,0,1,0); keyLbl.BackgroundTransparency = 1
                keyLbl.Text = gkn(option.Value); keyLbl.TextColor3 = accentColor
                keyLbl.TextSize = 9; keyLbl.Font = Enum.Font.Gotham; keyLbl.ZIndex = 15
                regAccent(keyLbl, "TextColor3")

                local kBtn = Instance.new("TextButton", keyFrame)
                kBtn.Size = UDim2.new(1,0,1,0); kBtn.BackgroundTransparency = 1
                kBtn.Text = ""; kBtn.ZIndex = 16

                local modeButtons = {}

                local function closeMD()
                    mOpen = false
                    for _, d in ipairs(modeButtons) do
                        d.btn.Visible = false
                    end
                end

                local function updateMC()
                    for _, d in ipairs(modeButtons) do
                        d.btn.TextColor3 = (option.Mode == d.modeName) and accentColor or Color3.fromRGB(180,180,180)
                    end
                end

                local function openMD()
                    mOpen = true
                    local absPos = keyFrame.AbsolutePosition
                    local absSize = keyFrame.AbsoluteSize
                    for i, d in ipairs(modeButtons) do
                        d.btn.Position = UDim2.fromOffset(absPos.X, absPos.Y + absSize.Y + 2 + ((i - 1) * 19))
                        d.btn.Size = UDim2.fromOffset(absSize.X, 18)
                        d.btn.Visible = true
                    end
                    updateMC()
                end

                for _, m in ipairs({"Hold", "Toggle", "Always"}) do
                    local modeVal = m
                    local mBtn = Instance.new("TextButton")
                    mBtn.Size = UDim2.new(0,55,0,18)
                    mBtn.BackgroundColor3 = Color3.fromRGB(20,20,20)
                    mBtn.BorderSizePixel = 0
                    mBtn.Text = m
                    mBtn.TextSize = 10
                    mBtn.Font = Enum.Font.Gotham
                    mBtn.TextColor3 = (option.Mode == m) and accentColor or Color3.fromRGB(180,180,180)
                    mBtn.ZIndex = 9999
                    mBtn.AutoButtonColor = false
                    mBtn.Visible = false
                    mBtn.Parent = Library._popupGui

                    local mBtnBorder = Instance.new("Frame", mBtn)
                    mBtnBorder.Size = UDim2.new(1,2,1,0)
                    mBtnBorder.Position = UDim2.new(0,-1,0,0)
                    mBtnBorder.BackgroundColor3 = Color3.fromRGB(45,45,45)
                    mBtnBorder.BorderSizePixel = 0
                    mBtnBorder.ZIndex = 9998

                    local mBtnInner = Instance.new("Frame", mBtn)
                    mBtnInner.Size = UDim2.new(1,0,1,0)
                    mBtnInner.BackgroundColor3 = Color3.fromRGB(20,20,20)
                    mBtnInner.BorderSizePixel = 0
                    mBtnInner.ZIndex = 9998

                    mBtn.MouseEnter:Connect(function() 
                        mBtn.BackgroundColor3 = Color3.fromRGB(30,30,30)
                        mBtnInner.BackgroundColor3 = Color3.fromRGB(30,30,30)
                    end)
                    mBtn.MouseLeave:Connect(function() 
                        mBtn.BackgroundColor3 = Color3.fromRGB(20,20,20)
                        mBtnInner.BackgroundColor3 = Color3.fromRGB(20,20,20)
                    end)

                    mBtn.MouseButton1Click:Connect(function()
                        option.Mode = modeVal
                        updateMC()
                        closeMD()
                        refreshKeybindList()
                    end)

                    table.insert(modeButtons, {btn = mBtn, modeName = m})
                end

                kBtn.MouseButton1Click:Connect(function()
                    if mOpen then
                        closeMD()
                        return
                    end
                    listening = true
                    keyLbl.Text = "..."
                    keyLbl.TextColor3 = Color3.fromRGB(255, 200, 100)
                end)

                kBtn.MouseButton2Click:Connect(function()
                    if mOpen then closeMD() else openMD() end
                end)

                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and mOpen then
                        local mp = Vector2.new(input.Position.X, input.Position.Y)
                        task.wait()
                        if isMouseOver(keyFrame, mp) then return end
                        for _, d in ipairs(modeButtons) do
                            if d.btn.Visible and isMouseOver(d.btn, mp) then return end
                        end
                        closeMD()
                    end
                end)

                UserInputService.InputBegan:Connect(function(input, gpe)
                    if listening then
                        if input.UserInputType == Enum.UserInputType.MouseButton1 then return end
                        if input.UserInputType == Enum.UserInputType.MouseButton2 then return end
                        local newKey
                        if input.UserInputType == Enum.UserInputType.Keyboard then
                            newKey = input.KeyCode
                        else
                            newKey = input.UserInputType
                        end
                        option.Value = newKey
                        keyLbl.Text = gkn(newKey)
                        keyLbl.TextColor3 = accentColor
                        listening = false
                        if option.ChangedCallback then option.ChangedCallback(newKey) end
                        if option._changed then option._changed(newKey) end
                        refreshKeybindList()
                        return
                    end
                    if not gpe then
                        local ik = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
                        if ik == option.Value then
                            if option.Mode == "Toggle" then
                                toggled = not toggled
                                option._active = toggled
                                refreshKeybindList()
                                if option.Callback then option.Callback(toggled) end
                                if option._onClick then option._onClick() end
                            elseif option.Mode == "Hold" then
                                option._active = true
                                refreshKeybindList()
                                if option.Callback then option.Callback(true) end
                            end
                        end
                    end
                end)

                UserInputService.InputEnded:Connect(function(input)
                    if option.Mode == "Hold" and not listening then
                        local ik = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
                        if ik == option.Value then
                            option._active = false
                            refreshKeybindList()
                            if option.Callback then option.Callback(false) end
                        end
                    end
                end)

                task.spawn(function()
                    local alwaysOn = false
                    while not Library.Unloaded do
                        task.wait(0.1)
                        if option.Mode == "Always" and not alwaysOn then
                            alwaysOn = true
                            option._active = true
                            refreshKeybindList()
                            if option.Callback then option.Callback(true) end
                        elseif option.Mode ~= "Always" and alwaysOn then
                            alwaysOn = false
                            option._active = false
                            refreshKeybindList()
                            if option.Callback then option.Callback(false) end
                        end
                    end
                end)

                option._setValue = function(val)
                    if type(val) == "table" then
                        option.Value = parseKeyName(val[1])
                        option.Mode = val[2] or "Toggle"
                        keyLbl.Text = gkn(option.Value)
                        updateMC()
                    else
                        option.Value = val
                        keyLbl.Text = gkn(val)
                    end
                    refreshKeybindList()
                end

                local kpReturn = setmetatable({}, {__index = option})
                function kpReturn:AddColorPicker(cIdx, cOpts)
                    return Group:AddColorPicker(cIdx, cOpts, container)
                end
                function kpReturn:AddKeyPicker(kIdx, kOpts)
                    return Group:AddKeyPicker(kIdx, kOpts, container)
                end
                return kpReturn
            end

            function Group:AddColorPicker(idx, opts, parentFrame)
                opts = opts or {}
                local option = setmetatable({}, OptionClass)
                option._type = "ColorPicker"
                option.Value = opts.Default or Color3.new(1,1,1)
                option.Transparency = opts.Transparency or 0
                option.Callback = opts.Callback
                Options[idx] = option

                local container = parentFrame or Instance.new("Frame", sContent)
                if not parentFrame then
                    container.Size = UDim2.new(1,0,0,22)
                    container.BackgroundTransparency = 1
                    container.ZIndex = 12
                end

                local hasKeyPicker = false
                if parentFrame then
                    for _, child in pairs(parentFrame:GetChildren()) do
                        if child.Name == "KeyPickerFrame" then
                            hasKeyPicker = true
                            break
                        end
                    end
                end

                local prevFrame = Instance.new("Frame", container)
                prevFrame.Name = "ColorPickerFrame"
                prevFrame.Size = UDim2.new(0,28,0,12)
                if hasKeyPicker then
                    prevFrame.Position = UDim2.new(1,-92,0,5)
                else
                    prevFrame.Position = UDim2.new(1,-32,0,5)
                end
                prevFrame.BackgroundColor3 = Color3.fromRGB(12,12,12)
                prevFrame.BorderSizePixel = 0
                prevFrame.ZIndex = 13

                local prevBrd = Instance.new("Frame", prevFrame)
                prevBrd.Size = UDim2.new(1,2,1,2); prevBrd.Position = UDim2.new(0,-1,0,-1)
                prevBrd.BackgroundColor3 = Color3.fromRGB(45,45,45); prevBrd.BorderSizePixel = 0; prevBrd.ZIndex = 12

                local prev = Instance.new("Frame", prevFrame)
                prev.Size = UDim2.new(1,-4,1,-4); prev.Position = UDim2.new(0,2,0,2)
                prev.BackgroundColor3 = option.Value; prev.BorderSizePixel = 0; prev.ZIndex = 14

                local pickerFrame = Instance.new("Frame")
                pickerFrame.Name = "CPicker_" .. idx
                pickerFrame.Size = UDim2.new(0, 180, 0, 100)
                pickerFrame.BackgroundColor3 = Color3.fromRGB(15,15,15)
                pickerFrame.BorderSizePixel = 0
                pickerFrame.Visible = false
                pickerFrame.ZIndex = 9998
                pickerFrame.Parent = Library._popupGui

                local pBrd = Instance.new("Frame", pickerFrame)
                pBrd.Size = UDim2.new(1,2,1,2); pBrd.Position = UDim2.new(0,-1,0,-1)
                pBrd.BackgroundColor3 = Color3.fromRGB(45,45,45); pBrd.BorderSizePixel = 0; pBrd.ZIndex = 9997

                local hueFrame = Instance.new("Frame", pickerFrame)
                hueFrame.Size = UDim2.new(1,-8,0,12); hueFrame.Position = UDim2.new(0,4,0,4)
                hueFrame.BackgroundColor3 = Color3.new(1,1,1); hueFrame.BorderSizePixel = 0; hueFrame.ZIndex = 9999

                Instance.new("UIGradient", hueFrame).Color = ColorSequence.new({
                    ColorSequenceKeypoint.new(0, Color3.fromHSV(0,1,1)),
                    ColorSequenceKeypoint.new(0.167, Color3.fromHSV(0.167,1,1)),
                    ColorSequenceKeypoint.new(0.333, Color3.fromHSV(0.333,1,1)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromHSV(0.5,1,1)),
                    ColorSequenceKeypoint.new(0.667, Color3.fromHSV(0.667,1,1)),
                    ColorSequenceKeypoint.new(0.833, Color3.fromHSV(0.833,1,1)),
                    ColorSequenceKeypoint.new(1, Color3.fromHSV(1,1,1))
                })

                local huePtr = Instance.new("Frame", hueFrame)
                huePtr.Size = UDim2.new(0,3,1,2); huePtr.Position = UDim2.new(0,0,0,-1)
                huePtr.BackgroundColor3 = Color3.new(1,1,1); huePtr.BorderSizePixel = 0; huePtr.ZIndex = 10000

                local svFrame = Instance.new("Frame", pickerFrame)
                svFrame.Size = UDim2.new(1,-8,0,68); svFrame.Position = UDim2.new(0,4,0,22)
                svFrame.BackgroundColor3 = Color3.fromHSV(0,1,1); svFrame.BorderSizePixel = 0; svFrame.ZIndex = 9999

                local wOvl = Instance.new("Frame", svFrame)
                wOvl.Size = UDim2.new(1,0,1,0); wOvl.BackgroundColor3 = Color3.new(1,1,1)
                wOvl.BorderSizePixel = 0; wOvl.ZIndex = 10000
                Instance.new("UIGradient", wOvl).Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1)
                })

                local bOvl = Instance.new("Frame", svFrame)
                bOvl.Size = UDim2.new(1,0,1,0); bOvl.BackgroundColor3 = Color3.new(0,0,0)
                bOvl.BorderSizePixel = 0; bOvl.ZIndex = 10001
                local bG = Instance.new("UIGradient", bOvl)
                bG.Rotation = 90
                bG.Transparency = NumberSequence.new({
                    NumberSequenceKeypoint.new(0, 1),
                    NumberSequenceKeypoint.new(1, 0)
                })

                local svPtr = Instance.new("Frame", svFrame)
                svPtr.Size = UDim2.new(0,6,0,6); svPtr.AnchorPoint = Vector2.new(0.5,0.5)
                svPtr.BackgroundColor3 = Color3.new(1,1,1); svPtr.BorderSizePixel = 0; svPtr.ZIndex = 10002
                Instance.new("UICorner", svPtr).CornerRadius = UDim.new(1,0)

                local h, s, v = Color3.toHSV(option.Value)
                local cpOpen = false
                local dH = false
                local dSV = false

                local function uc()
                    option.Value = Color3.fromHSV(h, s, v)
                    prev.BackgroundColor3 = option.Value
                    svFrame.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                    huePtr.Position = UDim2.new(h, -1, 0, -1)
                    svPtr.Position = UDim2.new(s, 0, 1 - v, 0)
                    if option.Callback then option.Callback(option.Value) end
                    if option._changed then option._changed(option.Value) end
                end

                local prevBtn = Instance.new("TextButton", prevFrame)
                prevBtn.Size = UDim2.new(1,0,1,0); prevBtn.BackgroundTransparency = 1
                prevBtn.Text = ""; prevBtn.ZIndex = 15

                prevBtn.MouseButton1Click:Connect(function()
                    cpOpen = not cpOpen
                    if cpOpen then
                        local absPos = prevFrame.AbsolutePosition
                        local absSize = prevFrame.AbsoluteSize
                        pickerFrame.Position = UDim2.fromOffset(absPos.X - 150, absPos.Y + absSize.Y + 4)
                        pickerFrame.Visible = true
                    else
                        pickerFrame.Visible = false
                    end
                end)

                local hueBtn = Instance.new("TextButton", hueFrame)
                hueBtn.Size = UDim2.new(1,0,1,0); hueBtn.BackgroundTransparency = 1
                hueBtn.Text = ""; hueBtn.ZIndex = 10001

                hueBtn.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dH = true
                        h = math.clamp((i.Position.X - hueFrame.AbsolutePosition.X) / hueFrame.AbsoluteSize.X, 0, 1)
                        uc()
                    end
                end)

                local svBtn = Instance.new("TextButton", svFrame)
                svBtn.Size = UDim2.new(1,0,1,0); svBtn.BackgroundTransparency = 1
                svBtn.Text = ""; svBtn.ZIndex = 10003

                svBtn.InputBegan:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dSV = true
                        s = math.clamp((i.Position.X - svFrame.AbsolutePosition.X) / svFrame.AbsoluteSize.X, 0, 1)
                        v = 1 - math.clamp((i.Position.Y - svFrame.AbsolutePosition.Y) / svFrame.AbsoluteSize.Y, 0, 1)
                        uc()
                    end
                end)

                UserInputService.InputEnded:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseButton1 then
                        dH = false
                        dSV = false
                    end
                end)

                UserInputService.InputChanged:Connect(function(i)
                    if i.UserInputType == Enum.UserInputType.MouseMovement then
                        if dH then
                            h = math.clamp((i.Position.X - hueFrame.AbsolutePosition.X) / hueFrame.AbsoluteSize.X, 0, 1)
                            uc()
                        elseif dSV then
                            s = math.clamp((i.Position.X - svFrame.AbsolutePosition.X) / svFrame.AbsoluteSize.X, 0, 1)
                            v = 1 - math.clamp((i.Position.Y - svFrame.AbsolutePosition.Y) / svFrame.AbsoluteSize.Y, 0, 1)
                            uc()
                        end
                    end
                end)

                UserInputService.InputBegan:Connect(function(input)
                    if input.UserInputType == Enum.UserInputType.MouseButton1 and cpOpen then
                        local mp = Vector2.new(input.Position.X, input.Position.Y)
                        task.wait()
                        if isMouseOver(prevFrame, mp) then return end
                        if isMouseOver(pickerFrame, mp) then return end
                        cpOpen = false
                        pickerFrame.Visible = false
                    end
                end)

                uc()

                option._setValue = function(val)
                    option.Value = val
                    h, s, v = Color3.toHSV(val)
                    uc()
                end

                function option:SetValueRGB(col)
                    option.Value = col
                    h, s, v = Color3.toHSV(col)
                    uc()
                end

                local cpReturn = setmetatable({}, {__index = option})
                function cpReturn:AddColorPicker(cIdx, cOpts)
                    return Group:AddColorPicker(cIdx, cOpts, container)
                end
                function cpReturn:AddKeyPicker(kIdx, kOpts)
                    return Group:AddKeyPicker(kIdx, kOpts, container)
                end
                return cpReturn
            end

            function Group:AddDependencyBox()
                local depBox = {}
                depBox._deps = {}

                local depFrame = Instance.new("Frame", sContent)
                depFrame.Size = UDim2.new(1,0,0,0)
                depFrame.BackgroundTransparency = 1
                depFrame.ClipsDescendants = true
                depFrame.ZIndex = 12

                local depContent = Instance.new("Frame", depFrame)
                depContent.Size = UDim2.new(1,0,0,0)
                depContent.BackgroundTransparency = 1
                depContent.ZIndex = 12

                local depLayout = Instance.new("UIListLayout", depContent)
                depLayout.Padding = UDim.new(0, 4)

                function depBox:AddToggle(i, o) return Group:AddToggle(i, o) end
                function depBox:AddSlider(i, o) return Group:AddSlider(i, o) end
                function depBox:AddDropdown(i, o) return Group:AddDropdown(i, o) end
                function depBox:AddInput(i, o) return Group:AddInput(i, o) end
                function depBox:AddButton(o) return Group:AddButton(o) end
                function depBox:AddLabel(t, w) return Group:AddLabel(t, w) end
                function depBox:AddDivider() return Group:AddDivider() end

                function depBox:SetupDependencies(deps)
                    depBox._deps = deps
                    local function check()
                        local visible = true
                        for _, dep in ipairs(deps) do
                            if dep[1].Value ~= dep[2] then
                                visible = false
                                break
                            end
                        end
                        depFrame.Visible = visible
                    end
                    for _, dep in ipairs(deps) do
                        local toggle = dep[1]
                        local oldChanged = toggle._changed
                        toggle._changed = function(val)
                            if oldChanged then oldChanged(val) end
                            check()
                        end
                    end
                    check()
                end

                return depBox
            end

            return Group
        end

        function TabObj:AddLeftGroupbox(name2)
            return createGroupbox(name2, leftCol)
        end

        function TabObj:AddRightGroupbox(name2)
            return createGroupbox(name2, rightCol)
        end

        function TabObj:AddLeftTabbox()
            local tabbox = {}
            function tabbox:AddTab(tabName) return createGroupbox(tabName, leftCol) end
            return tabbox
        end

        function TabObj:AddRightTabbox()
            local tabbox = {}
            function tabbox:AddTab(tabName) return createGroupbox(tabName, rightCol) end
            return tabbox
        end

        return TabObj
    end    

    return Window
end

return library
