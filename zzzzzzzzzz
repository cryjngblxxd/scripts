            function Group:AddSlider(idx, opts)
                opts = opts or {}
                local option = setmetatable({}, OptionClass)
                option.Value = opts.Default or opts.Min or 0
                option.Callback = opts.Callback
                option._type = "Slider"
                Options[idx] = option

                local min, max = opts.Min or 0, opts.Max or 100
                local rounding = opts.Rounding or 1
                local suffix = opts.Suffix or ""

                local W = Instance.new("Frame", sContent)
                W.Size = UDim2.new(1,0,0,30); W.BackgroundTransparency = 1
                W.ClipsDescendants = true; W.ZIndex = 12

