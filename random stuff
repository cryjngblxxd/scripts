            Tab.Visible = false; TC.Visible = false
            Anim(TB, {BackgroundTransparency = 1}, 0.25)
            Anim(TI, {ImageColor3 = Color.Text40}, 0.25)
            Anim(TN, {TextColor3 = Color.Text40}, 0.25)
            Anim(AB, {BackgroundTransparency = 1}, 0.25)
        end

        function Tab:Section(sc)
            local p = (sc.Side == "Right") and RC or LC
            return BuildSection(p, sc)
        end

        TB.MouseButton1Click:Connect(function() Tab:Show() end)
        TB.MouseEnter:Connect(function()
            if not Tab.Visible then Anim(TB, {BackgroundTransparency = 0.4}, 0.15) end
        end)
        TB.MouseLeave:Connect(function()
            if not Tab.Visible then Anim(TB, {BackgroundTransparency = 1}, 0.15) end
        end)

        table.insert(W.Tabs, Tab)
        if #W.Tabs == 1 then Tab:Show() end
        return Tab
    end

    function W:SaveConfig(n)
        local d = {}
        for f, v in pairs(Library.Flags) do
            if type(v) == "table" and v.Key then d[f] = { Key = tostring(v.Key), Mode = v.Mode, Active = v.Active }
            elseif typeof(v) == "Color3" then d[f] = { _t = "c3", h = v:ToHex() }
            else d[f] = v end
        end
        writefile(Library.Directory .. "/configs/" .. n .. ".cfg", HttpService:JSONEncode(d))
        Library:Notify({ Title = "Config", Message = "Saved: " .. n, Type = "Success" })
    end

    function W:LoadConfig(n)
        local p = Library.Directory .. "/configs/" .. n .. ".cfg"
        if not isfile(p) then Library:Notify({ Title = "Error", Message = "Config not found", Type = "Error" }); return end
        local d = HttpService:JSONDecode(readfile(p))
        for f, v in pairs(d) do
            local s = Library.ConfigFlags[f]
            if s then
                if type(v) == "table" and v._t == "c3" then s(Color3.fromHex(v.h))
                else s(v) end
            end
        end
        Library:Notify({ Title = "Config", Message = "Loaded: " .. n, Type = "Success" })
    end

    function W:DeleteConfig(n)
        local p = Library.Directory .. "/configs/" .. n .. ".cfg"
        if isfile(p) then delfile(p); Library:Notify({ Title = "Config", Message = "Deleted: " .. n, Type = "Warning" }) end
    end

    function W:GetConfigs()
        local l = {}
        for _, f in ipairs(listfiles(Library.Directory .. "/configs")) do
            local n = f:match("([^/\\]+)%.cfg$"); if n then table.insert(l, n) end
        end
        return l
    end

    function W:SetAccent(c)
        Color.Accent1 = c
        for prop, objs in pairs(ABind) do
            for _, o in ipairs(objs) do
                if o and o.Parent then Anim(o, {[prop] = c}, 0.35) end
            end
        end
    end

    function W:Settings()
        local ST = W:Tab({ Name = "Settings", Icon = "rbxassetid://7734053495" })
        local CS = ST:Section({ Name = "Configs", Side = "Left", Icon = "rbxassetid://7734053495" })
        local cl = CS:Dropdown({ Name = "Config", Flag = "_cl", Options = W:GetConfigs() })
        CS:TextBox({ Name = "Name", Flag = "_cn", Placeholder = "config name" })
        CS:Button({ Name = "Save Config", Callback = function()
            local n = Library.Flags["_cn"]; if n and n ~= "" then W:SaveConfig(n); cl.Refresh(W:GetConfigs()) end
        end })
        CS:Button({ Name = "Load Config", Callback = function()
            local n = Library.Flags["_cl"]; if n then W:LoadConfig(n) end
        end })
        CS:Button({ Name = "Delete Config", Callback = function()
            local n = Library.Flags["_cl"]; if n then W:DeleteConfig(n); cl.Refresh(W:GetConfigs()) end
        end, Separator = false })

        local AS = ST:Section({ Name = "Appearance", Side = "Right", Icon = "rbxassetid://7743870115" })
        AS:ColorPicker({ Name = "Accent", Default = Color.Accent1, Callback = function(c) W:SetAccent(c) end })
        AS:Keybind({ Name = "Toggle UI", Default = W.Key, Mode = "Toggle" })
        AS:Label({ Text = "OsamaHub v2.0", Separator = false })
        return ST
    end

    return W
end

function Library:Destroy()
    if self.GUI then self.GUI:Destroy() end
    if self.Drop then self.Drop:Destroy() end
    for _, c in ipairs(self.Connections) do c:Disconnect() end
    self.Connections = {}
end

return Library
