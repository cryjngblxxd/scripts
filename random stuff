    C("UIStroke", { Parent = nf, Color = Theme.Stroke, Thickness = 1.5, Transparency = 0.3 })
    C("UIPadding", { Parent = nf, PaddingTop = UDim.new(0, 14), PaddingBottom = UDim.new(0, 14), PaddingLeft = UDim.new(0, 16), PaddingRight = UDim.new(0, 16) })

    local glow = C("Frame", {
        Parent = nf, BackgroundColor3 = ac,
        Position = UDim2.new(0, -16, 0, -14),
        Size = UDim2.new(0, 4, 1, 28),
    })

    C("TextLabel", {
        Parent = nf, BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        Font = Enum.Font.GothamBold, Text = cfg.Title or "Notice",
        TextColor3 = Theme.Text, TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    C("TextLabel", {
        Parent = nf, BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 22),
        Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        Font = Enum.Font.Gotham, Text = cfg.Message or "",
        TextColor3 = Theme.TextSoft, TextSize = 13,
        TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
    })

    local bar = C("Frame", {
        Parent = nf, BackgroundColor3 = ac,
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, -16, 1, 14),
        Size = UDim2.new(1, 32, 0, 3),
    })
    C("UICorner", { Parent = bar, CornerRadius = UDim.new(0, 2) })

    nf.BackgroundTransparency = 1
    for _, d in ipairs(nf:GetDescendants()) do
        if d:IsA("TextLabel") then d.TextTransparency = 1 end
        if d:IsA("Frame") and d ~= nf then d.BackgroundTransparency = 1 end
    end

    T(nf, {BackgroundTransparency = 0}, 0.4)
    for _, d in ipairs(nf:GetDescendants()) do
        if d:IsA("TextLabel") then T(d, {TextTransparency = 0}, 0.4) end
        if d:IsA("Frame") and d ~= nf then T(d, {BackgroundTransparency = 0}, 0.4) end
    end

    local dur = cfg.Duration or 4
    T(bar, {Size = UDim2.new(0, 0, 0, 3)}, dur, Enum.EasingStyle.Linear)

    task.delay(dur, function()
        T(nf, {BackgroundTransparency = 1}, 0.5)
        for _, d in ipairs(nf:GetDescendants()) do
            if d:IsA("TextLabel") then T(d, {TextTransparency = 1}, 0.5) end
            if d:IsA("Frame") then T(d, {BackgroundTransparency = 1}, 0.5) end
        end
        task.wait(0.6)
        nf:Destroy()
    end)
end

