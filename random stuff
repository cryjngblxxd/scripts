            Size = UDim2.new(0.5, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = 2,
        })
        New("UIListLayout", { Parent = RC, Padding = UDim.new(0, 12), SortOrder = Enum.SortOrder.LayoutOrder })

        function Tab:Show()
            if W.Current and W.Current ~= Tab then W.Current:Hide() end
            Tab.Visible = true; TC.Visible = true; W.Current = Tab
            TabTitle.Text = Tab.Name
            BreadCrumb.Text = W.Name .. " / " .. Tab.Name
            Anim(TB, {BackgroundTransparency = 0}, 0.25)
            Anim(TI, {ImageColor3 = Color.Accent1}, 0.25)
            Anim(TN, {TextColor3 = Color.White}, 0.25)
            Anim(AB, {BackgroundTransparency = 0}, 0.25)
            Fade.BackgroundTransparency = 0
            Anim(Fade, {BackgroundTransparency = 1}, 0.35)
        end

