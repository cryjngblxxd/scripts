            Parent = CH, BackgroundTransparency = 1,
            Size = UDim2.new(0.5, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = 1,
        })
        New("UIListLayout", { Parent = LC, Padding = UDim.new(0, 12), SortOrder = Enum.SortOrder.LayoutOrder })

