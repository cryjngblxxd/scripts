                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Text = "",
            })
            
            local dragging = false
            local value = config.Default or config.Min
            
            local function UpdateSlider(input)
                local pos = math.clamp((input.Position.X - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
                value = math.floor(config.Min + (config.Max - config.Min) * pos)
                
                ValueLabel.Text = tostring(value)
                Tween(SliderFill, {Size = UDim2.new(pos, 0, 1, 0)}, 0.1, Enum.EasingStyle.Linear)
                
                if config.Callback then
                    config.Callback(value)
                end
                
                Window.Flags[config.Flag or config.Name] = value
            end
            
            SliderButton.MouseButton1Down:Connect(function()
                dragging = true
            end)
            
            UserInputService.InputEnded:Connect(function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)
            
            UserInputService.InputChanged:Connect(function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    UpdateSlider(input)
                end
            end)
            
            -- Initialize
            UpdateSlider({Position = Vector2.new(SliderBG.AbsolutePosition.X + SliderBG.AbsoluteSize.X * ((value - config.Min) / (config.Max - config.Min)), 0)})
        end
        
