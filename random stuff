-- ═══════════════════════════════════════════
-- Font Registration
-- ═══════════════════════════════════════════
local Fonts = {}
do
    local function RegisterFont(name, weight, style, asset)
        if not isfile(asset.Id) then
            writefile(asset.Id, asset.Font)
        end
        if isfile(name .. ".font") then
            delfile(name .. ".font")
        end
        local data = {
            name = name,
            faces = {{
                name = "Normal",
                weight = weight,
                style = style,
                assetId = getcustomasset(asset.Id),
            }},
        }
        writefile(name .. ".font", HttpService:JSONEncode(data))
        return getcustomasset(name .. ".font")
    end

    local Regular = RegisterFont("NebulaRegular", 200, "Normal", {
        Id = "NebulaRegular.ttf",
        Font = game:HttpGet("https://github.com/i77lhm/storage/raw/refs/heads/main/fonts/Inter_28pt-Medium.ttf"),
    })

    local Bold = RegisterFont("NebulaBold", 200, "Normal", {
        Id = "NebulaBold.ttf",
        Font = game:HttpGet("https://github.com/i77lhm/storage/raw/refs/heads/main/fonts/Inter_28pt-SemiBold.ttf"),
    })

    Fonts.Regular = Font.new(Regular, Enum.FontWeight.Regular, Enum.FontStyle.Normal)
    Fonts.Bold = Font.new(Bold, Enum.FontWeight.Regular, Enum.FontStyle.Normal)
end

-- ═══════════════════════════════════════════
-- Utility Functions
-- ═══════════════════════════════════════════
local function Create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props) do
        inst[k] = v
    end
    return inst
end

local function Tween(obj, props, duration, style)
    return TweenService:Create(obj, TweenInfo.new(
        duration or 0.25,
        style or Enum.EasingStyle.Quint,
        Enum.EasingDirection.Out
    ), props):Play()
end

local function Connect(signal, callback)
    local conn = signal:Connect(callback)
    table.insert(Nebula.Connections, conn)
    return conn
end

local function BindAccent(obj, property)
    table.insert(AccentBinds[property], obj)
end

local function NextFlag()
    return string.format("__flag_%d", #Nebula.Flags + 1)
end

local function Round(num, decimals)
    local mult = 1 / (decimals or 1)
    return math.floor(num * mult + 0.5) / mult
end

local function MouseInFrame(frame)
    local mouse = UserInputService:GetMouseLocation()
    local pos = frame.AbsolutePosition
    local size = frame.AbsoluteSize
    return mouse.X >= pos.X and mouse.X <= pos.X + size.X and
           mouse.Y >= pos.Y and mouse.Y <= pos.Y + size.Y
end

