local AccentBinds = { BackgroundColor3 = {}, TextColor3 = {}, ImageColor3 = {} }

local function C(class, props)
    local i = Instance.new(class)
    for k, v in pairs(props) do i[k] = v end
    return i
end

local function T(obj, props, dur, style)
    TweenService:Create(obj, TweenInfo.new(dur or 0.3, style or Enum.EasingStyle.Quart, Enum.EasingDirection.Out), props):Play()
end

local function Cn(signal, cb)
    local c = signal:Connect(cb)
    table.insert(Osama.Connections, c)
    return c
end

local function BA(obj, prop)
    table.insert(AccentBinds[prop], obj)
end

local function NF()
    return string.format("_f%d_%d", #Osama.Flags + 1, math.random(1000, 9999))
end

local function Rnd(n, d)
    local m = 1 / (d or 1)
    return math.floor(n * m + 0.5) / m
end

local KN = {
    [Enum.KeyCode.LeftShift] = "LSHIFT", [Enum.KeyCode.RightShift] = "RSHIFT",
    [Enum.KeyCode.LeftControl] = "LCTRL", [Enum.KeyCode.RightControl] = "RCTRL",
    [Enum.KeyCode.LeftAlt] = "LALT", [Enum.KeyCode.RightAlt] = "RALT",
    [Enum.KeyCode.CapsLock] = "CAPS", [Enum.KeyCode.Space] = "SPACE",
    [Enum.KeyCode.Return] = "ENTER", [Enum.KeyCode.Backspace] = "BKSP",
    [Enum.KeyCode.Tab] = "TAB", [Enum.KeyCode.Escape] = "ESC",
    [Enum.KeyCode.Insert] = "INS", [Enum.KeyCode.Delete] = "DEL",
    [Enum.UserInputType.MouseButton1] = "MB1",
    [Enum.UserInputType.MouseButton2] = "MB2",
    [Enum.UserInputType.MouseButton3] = "MB3",
}

local function Drag(frame, handle)
    local d, ds, sp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            d = true; ds = i.Position; sp = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end
    end)
    Cn(UserInputService.InputChanged, function(i)
        if d and i.UserInputType == Enum.UserInputType.MouseMovement then
            local dt = i.Position - ds
            local vp = workspace.CurrentCamera.ViewportSize
            T(frame, {Position = UDim2.new(0,
                math.clamp(sp.X.Offset + dt.X, 0, vp.X - frame.AbsoluteSize.X), 0,
                math.clamp(sp.Y.Offset + dt.Y, 0, vp.Y - frame.AbsoluteSize.Y))
            }, 0.06, Enum.EasingStyle.Linear)
        end
    end)
end

