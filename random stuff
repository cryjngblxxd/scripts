                    if not binding then return end
                    local nk = i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode or i.UserInputType
                    if nk == Enum.KeyCode.Escape then key = nil; KT.Text = "None"
                    else key = nk; KT.Text = KN[key] or tostring(key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "") end
                    binding = false
                    T(KB, {BackgroundColor3 = Theme.Elevated}, 0.15)
                    Osama.Flags[flag] = { Key = key, Mode = mode, Active = active }
                    cn:Disconnect()
                end)
            end)

