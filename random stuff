local NotificationHolder

function Nebula:Notify(config)
    if not NotificationHolder then
        NotificationHolder = Create("Frame", {
            Parent = self.ScreenGui,
            BackgroundTransparency = 1,
            AnchorPoint = Vector2.new(1, 1),
            Position = UDim2.new(1, -20, 1, -20),
            Size = UDim2.new(0, 280, 1, -40),
        })
        Create("UIListLayout", {
            Parent = NotificationHolder,
            SortOrder = Enum.SortOrder.LayoutOrder,
            VerticalAlignment = Enum.VerticalAlignment.Bottom,
            Padding = UDim.new(0, 8),
        })
    end

    local title = config.Title or "Notification"
    local message = config.Message or ""
    local duration = config.Duration or 4
    local notifType = config.Type or "Info"

    local accentColor = notifType == "Success" and Theme.Success
        or notifType == "Error" and Theme.Error
        or notifType == "Warning" and Theme.Warning
        or Theme.Accent

    local NotifFrame = Create("Frame", {
        Parent = NotificationHolder,
        BackgroundColor3 = Theme.Secondary,
        Size = UDim2.new(1, 0, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        ClipsDescendants = true,
    })
    Create("UICorner", { Parent = NotifFrame, CornerRadius = UDim.new(0, 8) })
    Create("UIStroke", { Parent = NotifFrame, Color = Theme.Border, Thickness = 1 })

    local AccentBar = Create("Frame", {
        Parent = NotifFrame,
        BackgroundColor3 = accentColor,
        Size = UDim2.new(0, 3, 1, 0),
    })

    local NotifTitle = Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 10),
        Size = UDim2.new(1, -26, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        FontFace = Fonts.Bold,
        Text = title,
        TextColor3 = Theme.Text,
        TextSize = 14,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    local NotifMessage = Create("TextLabel", {
        Parent = NotifFrame,
        BackgroundTransparency = 1,
        Position = UDim2.new(0, 16, 0, 30),
        Size = UDim2.new(1, -26, 0, 0),
        AutomaticSize = Enum.AutomaticSize.Y,
        FontFace = Fonts.Regular,
        Text = message,
        TextColor3 = Theme.SubText,
        TextSize = 13,
        TextWrapped = true,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    Create("UIPadding", { Parent = NotifFrame, PaddingBottom = UDim.new(0, 14) })

    local ProgressBar = Create("Frame", {
        Parent = NotifFrame,
        BackgroundColor3 = accentColor,
        AnchorPoint = Vector2.new(0, 1),
        Position = UDim2.new(0, 0, 1, 0),
        Size = UDim2.new(1, 0, 0, 2),
    })

    -- Animate in
    NotifFrame.BackgroundTransparency = 1
    NotifTitle.TextTransparency = 1
    NotifMessage.TextTransparency = 1
    AccentBar.BackgroundTransparency = 1
    ProgressBar.BackgroundTransparency = 1

    Tween(NotifFrame, {BackgroundTransparency = 0}, 0.3)
    Tween(NotifTitle, {TextTransparency = 0}, 0.3)
    Tween(NotifMessage, {TextTransparency = 0}, 0.3)
    Tween(AccentBar, {BackgroundTransparency = 0}, 0.3)
    Tween(ProgressBar, {BackgroundTransparency = 0}, 0.3)

    Tween(ProgressBar, {Size = UDim2.new(0, 0, 0, 2)}, duration, Enum.EasingStyle.Linear)

    task.delay(duration, function()
        Tween(NotifFrame, {BackgroundTransparency = 1}, 0.4)
        Tween(NotifTitle, {TextTransparency = 1}, 0.4)
        Tween(NotifMessage, {TextTransparency = 1}, 0.4)
        Tween(AccentBar, {BackgroundTransparency = 1}, 0.4)
        Tween(ProgressBar, {BackgroundTransparency = 1}, 0.4)
        task.wait(0.5)
        NotifFrame:Destroy()
    end)
end

