                FontFace = Fonts.Regular,
                Text = cfg.Name or "Toggle",
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            })

            local ToggleTrack = Create("Frame", {
                Parent = ToggleFrame,
                BackgroundColor3 = Theme.Tertiary,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -4, 0.5, 0),
                Size = UDim2.new(0, 38, 0, 20),
            })
            Create("UICorner", { Parent = ToggleTrack, CornerRadius = UDim.new(1, 0) })
            Create("UIStroke", { Parent = ToggleTrack, Color = Theme.Border, Thickness = 1 })

            local ToggleKnob = Create("Frame", {
                Parent = ToggleTrack,
                BackgroundColor3 = Theme.Dim,
                Position = UDim2.new(0, 3, 0.5, -7),
                Size = UDim2.new(0, 14, 0, 14),
            })
            Create("UICorner", { Parent = ToggleKnob, CornerRadius = UDim.new(1, 0) })

            local function UpdateToggle()
                if enabled then
                    Tween(ToggleTrack, {BackgroundColor3 = Theme.Accent}, 0.2)
                    Tween(ToggleKnob, {
                        Position = UDim2.new(1, -17, 0.5, -7),
                        BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                    }, 0.2)
                else
                    Tween(ToggleTrack, {BackgroundColor3 = Theme.Tertiary}, 0.2)
                    Tween(ToggleKnob, {
                        Position = UDim2.new(0, 3, 0.5, -7),
                        BackgroundColor3 = Theme.Dim,
                    }, 0.2)
                end
                Nebula.Flags[flag] = enabled
                if cfg.Callback then cfg.Callback(enabled) end
            end

            local ToggleBtn = Create("TextButton", {
                Parent = ToggleFrame,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 0),
                Text = "",
            })

            ToggleBtn.MouseButton1Click:Connect(function()
                enabled = not enabled
                UpdateToggle()
            end)

            UpdateToggle()

            Nebula.ConfigFlags[flag] = function(val)
                enabled = val
                UpdateToggle()
            end

            -- Separator
            if cfg.Separator ~= false then
                Create("Frame", {
                    Parent = ElementsHolder,
                    BackgroundColor3 = Theme.Border,
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundTransparency = 0.5,
                })
            end

            return {
                Set = function(val)
                    enabled = val
                    UpdateToggle()
                end,
                Get = function()
                    return enabled
                end,
            }
        end

