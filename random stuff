        -- ═══ Keybind ═══
        function Section:AddKeybind(cfg)
            local flag = cfg.Flag or NextFlag()
            local key = cfg.Default or nil
            local mode = cfg.Mode or "Toggle"
            local active = false
            local binding = false

            Nebula.Flags[flag] = { Key = key, Mode = mode, Active = active }

            local KBFrame = Create("Frame", {
                Parent = ElementsHolder,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 36),
            })

            Create("TextLabel", {
                Parent = KBFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 4, 0, 0),
                Size = UDim2.new(0.6, 0, 1, 0),
                FontFace = Fonts.Regular,
                Text = cfg.Name or "Keybind",
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            })

            local KBBtn = Create("TextButton", {
                Parent = KBFrame,
                BackgroundColor3 = Theme.Tertiary,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -4, 0.5, 0),
                Size = UDim2.new(0, 0, 0, 22),
                AutomaticSize = Enum.AutomaticSize.X,
                AutoButtonColor = false,
                Text = "",
            })
            Create("UICorner", { Parent = KBBtn, CornerRadius = UDim.new(0, 5) })

            local KBText = Create("TextLabel", {
                Parent = KBBtn,
                BackgroundTransparency = 1,
                Size = UDim2.new(0, 0, 1, 0),
                AutomaticSize = Enum.AutomaticSize.X,
                FontFace = Fonts.Regular,
                Text = key and (KeyNames[key] or tostring(key):gsub("Enum.KeyCode.", "")) or "None",
                TextColor3 = Theme.SubText,
                TextSize = 12,
            })
            Create("UIPadding", {
                Parent = KBText,
                PaddingLeft = UDim.new(0, 10),
                PaddingRight = UDim.new(0, 10),
            })

            KBBtn.MouseButton1Click:Connect(function()
                KBText.Text = "..."
                binding = true
                local conn
                conn = Connect(UserInputService.InputBegan, function(input, gpe)
                    if not binding then return end
                    local newKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
                    if newKey == Enum.KeyCode.Escape then
                        key = nil
                        KBText.Text = "None"
                    else
                        key = newKey
                        KBText.Text = KeyNames[key] or tostring(key):gsub("Enum.KeyCode.", ""):gsub("Enum.UserInputType.", "")
                    end
                    binding = false
                    Nebula.Flags[flag] = { Key = key, Mode = mode, Active = active }
                    conn:Disconnect()
                end)
            end)

            Connect(UserInputService.InputBegan, function(input, gpe)
                if gpe or binding then return end
                local inputKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
                if inputKey == key then
                    if mode == "Toggle" then
                        active = not active
                    elseif mode == "Hold" then
                        active = true
                    end
                    Nebula.Flags[flag] = { Key = key, Mode = mode, Active = active }
                    if cfg.Callback then cfg.Callback(active) end
                end
            end)

            Connect(UserInputService.InputEnded, function(input)
                if binding then return end
                local inputKey = input.KeyCode ~= Enum.KeyCode.Unknown and input.KeyCode or input.UserInputType
                if inputKey == key and mode == "Hold" then
                    active = false
                    Nebula.Flags[flag] = { Key = key, Mode = mode, Active = active }
                    if cfg.Callback then cfg.Callback(active) end
                end
            end)

            if cfg.Separator ~= false then
                Create("Frame", {
                    Parent = ElementsHolder,
                    BackgroundColor3 = Theme.Border,
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundTransparency = 0.5,
                })
            end
        end

