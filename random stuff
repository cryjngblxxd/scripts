local function MakeDrag(frame, handle)
    local d, ds, sp = false, nil, nil
    handle.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then
            d = true; ds = i.Position; sp = frame.Position
        end
    end)
    handle.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.MouseButton1 then d = false end
    end)
    Hook(UserInputService.InputChanged, function(i)
        if d and i.UserInputType == Enum.UserInputType.MouseMovement then
            local dt = i.Position - ds
            local vp = workspace.CurrentCamera.ViewportSize
            Anim(frame, {Position = UDim2.new(0,
                math.clamp(sp.X.Offset + dt.X, 0, vp.X - frame.AbsoluteSize.X), 0,
                math.clamp(sp.Y.Offset + dt.Y, 0, vp.Y - frame.AbsoluteSize.Y))
            }, 0.05, Enum.EasingStyle.Linear)
        end
    end)
end

local function PulseAnim(dot)
    task.spawn(function()
        while dot and dot.Parent do
            Anim(dot, {Size = UDim2.new(0, 10, 0, 10), BackgroundTransparency = 0.4}, 0.8, Enum.EasingStyle.Sine)
            task.wait(0.8)
            Anim(dot, {Size = UDim2.new(0, 7, 0, 7), BackgroundTransparency = 0}, 0.8, Enum.EasingStyle.Sine)
            task.wait(0.8)
        end
    end)
end

