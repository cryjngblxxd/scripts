local ABind = { BackgroundColor3 = {}, TextColor3 = {}, ImageColor3 = {} }

local function New(c, p)
    local o = Instance.new(c)
    for k, v in pairs(p) do o[k] = v end
    return o
end

local function Anim(o, p, d, s)
    return TweenService:Create(o, TweenInfo.new(d or 0.35, s or Enum.EasingStyle.Quart, Enum.EasingDirection.Out), p):Play()
end

local function Bind(o, p)
    table.insert(ABind[p], o)
end

local function Hook(s, f)
    local c = s:Connect(f)
    table.insert(Library.Connections, c)
    return c
end

local function Flag()
    return "_f" .. tostring(#Library.Flags + 1) .. "_" .. math.random(1000, 9999)
end

local function Round(n, d)
    local m = 1 / (d or 1)
    return math.floor(n * m + 0.5) / m
end

