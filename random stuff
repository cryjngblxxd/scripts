                TextSize = 11,
            })

            local Popup = Create("Frame", {
                Parent = DropdownHolder,
                BackgroundColor3 = Theme.Secondary,
                Size = UDim2.new(0, 0, 0, 0),
                ClipsDescendants = true,
                ZIndex = 100,
            })
