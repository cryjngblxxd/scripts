    New("UIPadding", { Parent = card, PaddingTop = UDim.new(0, 16), PaddingBottom = UDim.new(0, 18), PaddingLeft = UDim.new(0, 18), PaddingRight = UDim.new(0, 18) })

    local glow = New("Frame", {
        Parent = card, BackgroundColor3 = ac,
        Position = UDim2.new(0, -18, 0, -16),
        Size = UDim2.new(0, 5, 1, 34),
    })
    New("UICorner", { Parent = glow, CornerRadius = UDim.new(0, 3) })

    New("TextLabel", {
        Parent = card, BackgroundTransparency = 1,
        Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        Font = Enum.Font.GothamBold, Text = cfg.Title or "Notice",
        TextColor3 = Color.White, TextSize = 15,
        TextXAlignment = Enum.TextXAlignment.Left,
    })

    New("TextLabel", {
        Parent = card, BackgroundTransparency = 1,
        Position = UDim2.new(0, 0, 0, 24),
        Size = UDim2.new(1, 0, 0, 0), AutomaticSize = Enum.AutomaticSize.Y,
        Font = Enum.Font.Gotham, Text = cfg.Message or "",
        TextColor3 = Color.Text70, TextSize = 13,
        TextWrapped = true, TextXAlignment = Enum.TextXAlignment.Left,
    })

    local bar = New("Frame", {
        Parent = card, BackgroundColor3 = ac,
        AnchorPoint = Vector2.new(0.5, 1),
        Position = UDim2.new(0.5, 0, 1, 18),
        Size = UDim2.new(1, 0, 0, 3),
        BackgroundTransparency = 0.3,
    })
    New("UICorner", { Parent = bar, CornerRadius = UDim.new(0, 2) })

    card.BackgroundTransparency = 1
    for _, d in ipairs(card:GetDescendants()) do
        if d:IsA("TextLabel") then d.TextTransparency = 1 end
        if d:IsA("Frame") and d ~= card then d.BackgroundTransparency = 1 end
    end
    Anim(card, {BackgroundTransparency = 0}, 0.5)
    for _, d in ipairs(card:GetDescendants()) do
        if d:IsA("TextLabel") then Anim(d, {TextTransparency = 0}, 0.5) end
        if d:IsA("Frame") and d ~= card then Anim(d, {BackgroundTransparency = d == bar and 0.3 or 0}, 0.5) end
    end

    local dur = cfg.Duration or 4
    Anim(bar, {Size = UDim2.new(0, 0, 0, 3)}, dur, Enum.EasingStyle.Linear)

    task.delay(dur, function()
        Anim(card, {BackgroundTransparency = 1, Size = UDim2.new(1, 0, 0, 0)}, 0.5)
        for _, d in ipairs(card:GetDescendants()) do
            if d:IsA("TextLabel") then Anim(d, {TextTransparency = 1}, 0.4) end
            if d:IsA("Frame") then Anim(d, {BackgroundTransparency = 1}, 0.4) end
            if d:IsA("UIStroke") then Anim(d, {Transparency = 1}, 0.4) end
        end
        task.wait(0.6)
        card:Destroy()
    end)
end

