            TextXAlignment = Enum.TextXAlignment.Left,
            TextYAlignment = Enum.TextYAlignment.Top,
        })
        
        Tween(NotifFrame, {Position = UDim2.new(1, -320, 1, -100)}, 0.5)
        
        wait(config.Duration or 3)
        
        Tween(NotifFrame, {Position = UDim2.new(1, -320, 1, 100)}, 0.5)
        wait(0.5)
        NotifFrame:Destroy()
    end
    
    return Window
end

return Library
