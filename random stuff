            local flag = cfg.Flag or NextFlag()
            local min = cfg.Min or 0
            local max = cfg.Max or 100
            local increment = cfg.Increment or 1
            local value = cfg.Default or min
            local suffix = cfg.Suffix or ""
            Nebula.Flags[flag] = value

            local SliderFrame = Create("Frame", {
                Parent = ElementsHolder,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 50),
            })

            Create("TextLabel", {
                Parent = SliderFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 4, 0, 2),
                Size = UDim2.new(0.7, 0, 0, 20),
                FontFace = Fonts.Regular,
                Text = cfg.Name or "Slider",
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            })

            local ValueLabel = Create("TextLabel", {
                Parent = SliderFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0.7, 0, 0, 2),
                Size = UDim2.new(0.3, -4, 0, 20),
                FontFace = Fonts.Regular,
                Text = tostring(value) .. suffix,
                TextColor3 = Theme.Accent,
                TextSize = 13,
                TextXAlignment = Enum.TextXAlignment.Right,
            })
            BindAccent(ValueLabel, "TextColor3")

            local SliderBG = Create("Frame", {
                Parent = SliderFrame,
                BackgroundColor3 = Theme.Tertiary,
                Position = UDim2.new(0, 4, 0, 28),
                Size = UDim2.new(1, -8, 0, 6),
            })
            Create("UICorner", { Parent = SliderBG, CornerRadius = UDim.new(1, 0) })

            local SliderFill = Create("Frame", {
                Parent = SliderBG,
                BackgroundColor3 = Theme.Accent,
                Size = UDim2.new(0, 0, 1, 0),
            })
            Create("UICorner", { Parent = SliderFill, CornerRadius = UDim.new(1, 0) })
            BindAccent(SliderFill, "BackgroundColor3")

            local SliderKnob = Create("Frame", {
                Parent = SliderFill,
                BackgroundColor3 = Color3.fromRGB(255, 255, 255),
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, 0, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14),
            })
            Create("UICorner", { Parent = SliderKnob, CornerRadius = UDim.new(1, 0) })

            local dragging = false

            local function SetValue(val)
                value = math.clamp(Round(val, increment), min, max)
                local pct = (value - min) / (max - min)
                Tween(SliderFill, {Size = UDim2.new(pct, 0, 1, 0)}, 0.08, Enum.EasingStyle.Linear)
                ValueLabel.Text = tostring(value) .. suffix
                Nebula.Flags[flag] = value
                if cfg.Callback then cfg.Callback(value) end
            end

            local SliderBtn = Create("TextButton", {
                Parent = SliderBG,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 1, 20),
                Position = UDim2.new(0, 0, 0.5, -10),
                Text = "",
                ZIndex = 2,
            })

            SliderBtn.MouseButton1Down:Connect(function()
                dragging = true
            end)

            Connect(UserInputService.InputEnded, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    dragging = false
                end
            end)

            Connect(UserInputService.InputChanged, function(input)
                if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
                    local pct = math.clamp((input.Position.X - SliderBG.AbsolutePosition.X) / SliderBG.AbsoluteSize.X, 0, 1)
                    SetValue(min + (max - min) * pct)
                end
            end)

            SetValue(value)

            Nebula.ConfigFlags[flag] = SetValue

            if cfg.Separator ~= false then
                Create("Frame", {
                    Parent = ElementsHolder,
                    BackgroundColor3 = Theme.Border,
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundTransparency = 0.5,
                })
            end

            return { Set = SetValue, Get = function() return value end }
        end

        -- ═══ Dropdown ═══
        function Section:AddDropdown(cfg)
            local flag = cfg.Flag or NextFlag()
            local multi = cfg.Multi or false
            local options = cfg.Options or {}
            local selected = cfg.Default or (multi and {} or options[1])
            local open = false
            Nebula.Flags[flag] = selected

            local DropFrame = Create("Frame", {
                Parent = ElementsHolder,
                BackgroundTransparency = 1,
                Size = UDim2.new(1, 0, 0, 36),
            })

            Create("TextLabel", {
                Parent = DropFrame,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 4, 0, 0),
                Size = UDim2.new(0.45, 0, 1, 0),
                FontFace = Fonts.Regular,
                Text = cfg.Name or "Dropdown",
                TextColor3 = Theme.Text,
                TextSize = 14,
                TextXAlignment = Enum.TextXAlignment.Left,
            })

            local DropBtn = Create("TextButton", {
                Parent = DropFrame,
                BackgroundColor3 = Theme.Tertiary,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -4, 0.5, 0),
                Size = UDim2.new(0.5, 0, 0, 24),
                Text = "",
                AutoButtonColor = false,
            })
            Create("UICorner", { Parent = DropBtn, CornerRadius = UDim.new(0, 6) })
            Create("UIStroke", { Parent = DropBtn, Color = Theme.Border, Thickness = 1 })

            local SelectedText = Create("TextLabel", {
                Parent = DropBtn,
                BackgroundTransparency = 1,
                Position = UDim2.new(0, 8, 0, 0),
                Size = UDim2.new(1, -28, 1, 0),
                FontFace = Fonts.Regular,
                Text = multi and table.concat(selected, ", ") or tostring(selected),
                TextColor3 = Theme.SubText,
                TextSize = 12,
                TextXAlignment = Enum.TextXAlignment.Left,
                TextTruncate = Enum.TextTruncate.AtEnd,
            })

            local Arrow = Create("TextLabel", {
                Parent = DropBtn,
                BackgroundTransparency = 1,
                AnchorPoint = Vector2.new(1, 0.5),
                Position = UDim2.new(1, -6, 0.5, 0),
                Size = UDim2.new(0, 14, 0, 14),
                FontFace = Fonts.Bold,
                Text = "▾",
                TextColor3 = Theme.Dim,
                TextSize = 14,
            })

            -- Dropdown popup
            local DropPopup = Create("Frame", {
                Parent = DropdownHolder,
                BackgroundColor3 = Theme.Secondary,
                Size = UDim2.new(0, 0, 0, 0),
                ClipsDescendants = true,
                ZIndex = 100,
                Visible = true,
            })
            Create("UICorner", { Parent = DropPopup, CornerRadius = UDim.new(0, 8) })
            Create("UIStroke", { Parent = DropPopup, Color = Theme.Border, Thickness = 1, })

            local PopupLayout = Create("UIListLayout", {
                Parent = DropPopup,
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 2),
            })

            Create("UIPadding", {
                Parent = DropPopup,
                PaddingTop = UDim.new(0, 4),
                PaddingBottom = UDim.new(0, 4),
                PaddingLeft = UDim.new(0, 4),
                PaddingRight = UDim.new(0, 4),
            })

            local optionButtons = {}
            local totalHeight = 8

            local function UpdateDisplay()
                if multi then
                    SelectedText.Text = #selected > 0 and table.concat(selected, ", ") or "None"
                else
                    SelectedText.Text = tostring(selected)
                end
                Nebula.Flags[flag] = selected
                if cfg.Callback then cfg.Callback(selected) end
            end

            for _, option in ipairs(options) do
                local OptBtn = Create("TextButton", {
                    Parent = DropPopup,
                    BackgroundColor3 = Theme.Tertiary,
                    BackgroundTransparency = 1,
                    Size = UDim2.new(1, 0, 0, 26),
                    FontFace = Fonts.Regular,
                    Text = "  " .. option,
                    TextColor3 = Theme.SubText,
                    TextSize = 13,
                    TextXAlignment = Enum.TextXAlignment.Left,
                    AutoButtonColor = false,
                    ZIndex = 101,
                })
                Create("UICorner", { Parent = OptBtn, CornerRadius = UDim.new(0, 5) })
                totalHeight = totalHeight + 28

                optionButtons[option] = OptBtn

                OptBtn.MouseEnter:Connect(function()
                    Tween(OptBtn, {BackgroundTransparency = 0}, 0.15)
                end)
                OptBtn.MouseLeave:Connect(function()
                    local isSelected = multi and table.find(selected, option) or selected == option
                    if not isSelected then
                        Tween(OptBtn, {BackgroundTransparency = 1}, 0.15)
                    end
                end)

                OptBtn.MouseButton1Click:Connect(function()
                    if multi then
                        local idx = table.find(selected, option)
                        if idx then
                            table.remove(selected, idx)
                            Tween(OptBtn, {TextColor3 = Theme.SubText, BackgroundTransparency = 1}, 0.15)
                        else
                            table.insert(selected, option)
                            Tween(OptBtn, {TextColor3 = Theme.Accent, BackgroundTransparency = 0}, 0.15)
                        end
                    else
                        for _, btn in pairs(optionButtons) do
                            Tween(btn, {TextColor3 = Theme.SubText, BackgroundTransparency = 1}, 0.15)
                        end
                        selected = option
                        Tween(OptBtn, {TextColor3 = Theme.Accent, BackgroundTransparency = 0}, 0.15)

                        -- Close after single select
                        task.wait(0.1)
                        open = false
                        Tween(DropPopup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, 0)}, 0.2)
                        Tween(Arrow, {Rotation = 0}, 0.2)
                    end
                    UpdateDisplay()
                end)
            end

            local function ToggleDropdown()
                open = not open
                local pos = DropBtn.AbsolutePosition
                DropPopup.Position = UDim2.fromOffset(pos.X, pos.Y + DropBtn.AbsoluteSize.Y + 4)

                if open then
                    Nebula.ActiveDropdown = DropPopup
                    Tween(DropPopup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, math.min(totalHeight, 200))}, 0.25)
                    Tween(Arrow, {Rotation = 180}, 0.25)
                else
                    Tween(DropPopup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, 0)}, 0.2)
                    Tween(Arrow, {Rotation = 0}, 0.2)
                end
            end

            DropBtn.MouseButton1Click:Connect(ToggleDropdown)

            UpdateDisplay()

            -- Highlight defaults
            if multi then
                for _, opt in ipairs(selected) do
                    if optionButtons[opt] then
                        optionButtons[opt].TextColor3 = Theme.Accent
                        optionButtons[opt].BackgroundTransparency = 0
                    end
                end
            elseif optionButtons[selected] then
                optionButtons[selected].TextColor3 = Theme.Accent
                optionButtons[selected].BackgroundTransparency = 0
            end

            Nebula.ConfigFlags[flag] = function(val)
                selected = val
                UpdateDisplay()
                for _, btn in pairs(optionButtons) do
                    local isS = multi and table.find(selected, btn.Text:sub(3)) or selected == btn.Text:sub(3)
                    btn.TextColor3 = isS and Theme.Accent or Theme.SubText
                    btn.BackgroundTransparency = isS and 0 or 1
                end
            end

            if cfg.Separator ~= false then
                Create("Frame", {
                    Parent = ElementsHolder,
                    BackgroundColor3 = Theme.Border,
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundTransparency = 0.5,
                })
            end

            return {
                Set = function(val)
                    selected = val
                    UpdateDisplay()
                end,
                Refresh = function(newOptions)
                    -- Clear old buttons
                    for _, btn in pairs(optionButtons) do btn:Destroy() end
                    optionButtons = {}
                    options = newOptions
                    totalHeight = 8
                    -- Recreate
                    for _, option in ipairs(options) do
                        local OptBtn = Create("TextButton", {
                            Parent = DropPopup,
                            BackgroundColor3 = Theme.Tertiary,
                            BackgroundTransparency = 1,
                            Size = UDim2.new(1, 0, 0, 26),
                            FontFace = Fonts.Regular,
                            Text = "  " .. option,
                            TextColor3 = Theme.SubText,
                            TextSize = 13,
                            TextXAlignment = Enum.TextXAlignment.Left,
                            AutoButtonColor = false,
                            ZIndex = 101,
                        })
                        Create("UICorner", { Parent = OptBtn, CornerRadius = UDim.new(0, 5) })
                        totalHeight = totalHeight + 28
                        optionButtons[option] = OptBtn

                        OptBtn.MouseButton1Click:Connect(function()
                            if not multi then
                                for _, b in pairs(optionButtons) do
                                    Tween(b, {TextColor3 = Theme.SubText, BackgroundTransparency = 1}, 0.15)
                                end
                                selected = option
                                Tween(OptBtn, {TextColor3 = Theme.Accent, BackgroundTransparency = 0}, 0.15)
                                open = false
                                Tween(DropPopup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, 0)}, 0.2)
                            end
                            UpdateDisplay()
                        end)
                    end
                end,
            }
        end

