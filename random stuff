            })

            -- Black overlay
            local BlackOverlay = Create("TextButton", {
                Parent = SVPicker,
                BackgroundColor3 = Color3.fromRGB(0, 0, 0),
                Size = UDim2.new(1, 0, 1, 0),
                ZIndex = 103,
                Text = "",
                AutoButtonColor = false,
            })
            Create("UICorner", { Parent = BlackOverlay, CornerRadius = UDim.new(0, 6) })
            Create("UIGradient", {
                Parent = BlackOverlay,
                Rotation = 270,
                Transparency = NumberSequence.new{
                    NumberSequenceKeypoint.new(0, 0),
                    NumberSequenceKeypoint.new(1, 1),
                },
            })

            -- SV Cursor
            local SVCursor = Create("Frame", {
                Parent = SVPicker,
                BackgroundColor3 = currentColor,
                Size = UDim2.new(0, 10, 0, 10),
                Position = UDim2.new(s, -5, 1 - v, -5),
                ZIndex = 105,
            })
            Create("UICorner", { Parent = SVCursor, CornerRadius = UDim.new(1, 0) })
            Create("UIStroke", { Parent = SVCursor, Color = Color3.fromRGB(255, 255, 255), Thickness = 2 })

            -- Hue bar
            local HueBar = Create("TextButton", {
                Parent = CPPopup,
                Position = UDim2.new(0, 10, 0, 140),
                Size = UDim2.new(1, -20, 0, 12),
                Text = "",
                AutoButtonColor = false,
                ZIndex = 101,
            })
            Create("UICorner", { Parent = HueBar, CornerRadius = UDim.new(1, 0) })
            Create("UIGradient", {
                Parent = HueBar,
                Color = ColorSequence.new{
                    ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 0, 0)),
                    ColorSequenceKeypoint.new(0.17, Color3.fromRGB(255, 255, 0)),
                    ColorSequenceKeypoint.new(0.33, Color3.fromRGB(0, 255, 0)),
                    ColorSequenceKeypoint.new(0.5, Color3.fromRGB(0, 255, 255)),
                    ColorSequenceKeypoint.new(0.67, Color3.fromRGB(0, 0, 255)),
                    ColorSequenceKeypoint.new(0.83, Color3.fromRGB(255, 0, 255)),
                    ColorSequenceKeypoint.new(1, Color3.fromRGB(255, 0, 0)),
                },
            })

            local HueCursor = Create("Frame", {
                Parent = HueBar,
                BackgroundColor3 = Color3.fromHSV(h, 1, 1),
                Size = UDim2.new(0, 10, 0, 10),
                Position = UDim2.new(h, -5, 0.5, -5),
                ZIndex = 102,
            })
            Create("UICorner", { Parent = HueCursor, CornerRadius = UDim.new(1, 0) })
            Create("UIStroke", { Parent = HueCursor, Color = Color3.fromRGB(255, 255, 255), Thickness = 2 })

            local draggingSV, draggingHue = false, false

            local function UpdateColor()
                local newColor = Color3.fromHSV(h, s, v)
                Preview.BackgroundColor3 = newColor
                SVPicker.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                SVCursor.Position = UDim2.new(s, -5, 1 - v, -5)
                SVCursor.BackgroundColor3 = newColor
                HueCursor.Position = UDim2.new(h, -5, 0.5, -5)
                HueCursor.BackgroundColor3 = Color3.fromHSV(h, 1, 1)
                currentColor = newColor
                Nebula.Flags[flag] = newColor
                if cfg.Callback then cfg.Callback(newColor) end
            end

            BlackOverlay.MouseButton1Down:Connect(function()
                draggingSV = true
            end)
            HueBar.MouseButton1Down:Connect(function()
                draggingHue = true
            end)

            Connect(UserInputService.InputEnded, function(input)
                if input.UserInputType == Enum.UserInputType.MouseButton1 then
                    draggingSV = false
                    draggingHue = false
                end
            end)

            Connect(UserInputService.InputChanged, function(input)
                if input.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                local mouse = UserInputService:GetMouseLocation()

                if draggingSV then
                    s = math.clamp((mouse.X - SVPicker.AbsolutePosition.X) / SVPicker.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((mouse.Y - SVPicker.AbsolutePosition.Y) / SVPicker.AbsoluteSize.Y, 0, 1)
                    UpdateColor()
                elseif draggingHue then
                    h = math.clamp((mouse.X - HueBar.AbsolutePosition.X) / HueBar.AbsoluteSize.X, 0, 1)
                    UpdateColor()
                end
            end)

            Preview.MouseButton1Click:Connect(function()
                PopupOpen = not PopupOpen
                local pos = Preview.AbsolutePosition
                CPPopup.Position = UDim2.fromOffset(pos.X - 170, pos.Y + 30)

                if PopupOpen then
                    Tween(CPPopup, {Size = UDim2.new(0, 200, 0, 165)}, 0.25)
                else
                    Tween(CPPopup, {Size = UDim2.new(0, 200, 0, 0)}, 0.2)
                end
            end)

            UpdateColor()

            Nebula.ConfigFlags[flag] = function(color)
                h, s, v = color:ToHSV()
                UpdateColor()
            end

            if cfg.Separator ~= false then
                Create("Frame", {
                    Parent = ElementsHolder,
                    BackgroundColor3 = Theme.Border,
                    Size = UDim2.new(1, 0, 0, 1),
                    BackgroundTransparency = 0.5,
                })
            end

            return { Set = function(color) h, s, v = color:ToHSV(); UpdateColor() end }
        end

        return Section
    end

    -- ═══════════════════════════════════════════
    -- Tab Creation
    -- ═══════════════════════════════════════════
    function Window:CreateTab(config)
        local Tab = {
            Name = config.Name or "Tab",
            Icon = config.Icon or icons["home-2"],
            Sections = {},
            Visible = false,
        }

        -- Tab Button
        local TabBtn = Create("TextButton", {
            Parent = TabButtonsHolder,
            BackgroundColor3 = Theme.Tertiary,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 38),
            Text = "",
            AutoButtonColor = false,
        })
        Create("UICorner", { Parent = TabBtn, CornerRadius = UDim.new(0, 8) })

        -- Icon
        local TabIcon = Create("ImageLabel", {
            Parent = TabBtn,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 12, 0.5, -10),
            Size = UDim2.new(0, 20, 0, 20),
            Image = Tab.Icon,
            ImageColor3 = Theme.Dim,
        })

        -- Tab Name
        local TabName = Create("TextLabel", {
            Parent = TabBtn,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 42, 0, 0),
            Size = UDim2.new(1, -52, 1, 0),
            FontFace = Fonts.Regular,
            Text = Tab.Name,
            TextColor3 = Theme.Dim,
            TextSize = 14,
            TextXAlignment = Enum.TextXAlignment.Left,
        })

        -- Active indicator
        local ActiveBar = Create("Frame", {
            Parent = TabBtn,
            BackgroundColor3 = Theme.Accent,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 0, 0.5, -8),
            Size = UDim2.new(0, 3, 0, 16),
        })
        Create("UICorner", { Parent = ActiveBar, CornerRadius = UDim.new(0, 2) })
        BindAccent(ActiveBar, "BackgroundColor3")

        -- Tab Content
        local TabContent = Create("ScrollingFrame", {
            Parent = TabContentHolder,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Accent,
            Visible = false,
        })

        -- Two column layout
        local ColumnsHolder = Create("Frame", {
            Parent = TabContent,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
        })

        Create("UIListLayout", {
            Parent = ColumnsHolder,
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalFlex = Enum.UIFlexAlignment.Fill,
            Padding = UDim.new(0, 10),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })

        Create("UIPadding", {
            Parent = ColumnsHolder,
            PaddingTop = UDim.new(0, 10),
            PaddingBottom = UDim.new(0, 10),
            PaddingLeft = UDim.new(0, 15),
            PaddingRight = UDim.new(0, 15),
        })

        local LeftColumn = Create("Frame", {
            Parent = ColumnsHolder,
            BackgroundTransparency = 1,
            Size = UDim2.new(0.5, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            LayoutOrder = 1,
        })
        Create("UIListLayout", {
            Parent = LeftColumn,
            Padding = UDim.new(0, 10),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })

        local RightColumn = Create("Frame", {
            Parent = ColumnsHolder,
            BackgroundTransparency = 1,
            Size = UDim2.new(0.5, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
            LayoutOrder = 2,
        })
        Create("UIListLayout", {
            Parent = RightColumn,
            Padding = UDim.new(0, 10),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })

        function Tab:Show()
            if Window.CurrentTab and Window.CurrentTab ~= Tab then
                Window.CurrentTab:Hide()
            end

            Tab.Visible = true
            TabContent.Visible = true
            Window.CurrentTab = Tab

            TabTitle.Text = Tab.Name

            Tween(TabBtn, {BackgroundTransparency = 0}, 0.2)
            Tween(TabIcon, {ImageColor3 = Theme.Accent}, 0.2)
            Tween(TabName, {TextColor3 = Theme.Text}, 0.2)
            Tween(ActiveBar, {BackgroundTransparency = 0}, 0.2)

            -- Fade transition
            FadeOverlay.BackgroundTransparency = 0
            Tween(FadeOverlay, {BackgroundTransparency = 1}, 0.3)
        end

        function Tab:Hide()
            Tab.Visible = false
            TabContent.Visible = false

            Tween(TabBtn, {BackgroundTransparency = 1}, 0.2)
            Tween(TabIcon, {ImageColor3 = Theme.Dim}, 0.2)
            Tween(TabName, {TextColor3 = Theme.Dim}, 0.2)
            Tween(ActiveBar, {BackgroundTransparency = 1}, 0.2)
        end

        function Tab:AddSection(cfg)
            local side = cfg.Side or "Left"
            local parent = side == "Right" and RightColumn or LeftColumn
            return CreateSection(parent, cfg)
        end

        TabBtn.MouseButton1Click:Connect(function()
            Tab:Show()
        end)

        TabBtn.MouseEnter:Connect(function()
            if not Tab.Visible then
                Tween(TabBtn, {BackgroundTransparency = 0.5}, 0.15)
            end
        end)

        TabBtn.MouseLeave:Connect(function()
            if not Tab.Visible then
                Tween(TabBtn, {BackgroundTransparency = 1}, 0.15)
            end
        end)

        table.insert(Window.Tabs, Tab)

        if #Window.Tabs == 1 then
            Tab:Show()
        end

        return Tab
    end

    -- ═══════════════════════════════════════════
    -- Config System
    -- ═══════════════════════════════════════════
    function Window:SaveConfig(name)
        local data = {}
        for flag, value in pairs(Nebula.Flags) do
            if type(value) == "table" and value.Key then
                data[flag] = { Key = tostring(value.Key), Mode = value.Mode, Active = value.Active }
            elseif typeof(value) == "Color3" then
                data[flag] = { __type = "Color3", Hex = value:ToHex() }
            else
                data[flag] = value
            end
        end
        writefile(Nebula.Directory .. "/configs/" .. name .. ".cfg", HttpService:JSONEncode(data))
        Nebula:Notify({ Title = "Config", Message = "Saved: " .. name, Type = "Success" })
    end

    function Window:LoadConfig(name)
        local path = Nebula.Directory .. "/configs/" .. name .. ".cfg"
        if not isfile(path) then
            Nebula:Notify({ Title = "Config", Message = "Not found: " .. name, Type = "Error" })
            return
        end
        local data = HttpService:JSONDecode(readfile(path))
        for flag, value in pairs(data) do
            local setter = Nebula.ConfigFlags[flag]
            if setter then
                if type(value) == "table" and value.__type == "Color3" then
                    setter(Color3.fromHex(value.Hex))
                else
                    setter(value)
                end
            end
        end
        Nebula:Notify({ Title = "Config", Message = "Loaded: " .. name, Type = "Success" })
    end

    function Window:DeleteConfig(name)
        local path = Nebula.Directory .. "/configs/" .. name .. ".cfg"
        if isfile(path) then
            delfile(path)
            Nebula:Notify({ Title = "Config", Message = "Deleted: " .. name, Type = "Warning" })
        end
    end

    function Window:GetConfigs()
        local list = {}
        for _, file in ipairs(listfiles(Nebula.Directory .. "/configs")) do
            table.insert(list, file:match("([^/\\]+)%.cfg$") or "")
        end
        return list
    end

    -- ═══════════════════════════════════════════
    -- Update Theme
    -- ═══════════════════════════════════════════
    function Window:SetAccent(color)
        Theme.Accent = color
        Theme.AccentDark = Color3.fromHSV(color:ToHSV())
        for prop, objects in pairs(AccentBinds) do
            for _, obj in ipairs(objects) do
                if obj and obj.Parent then
                    Tween(obj, {[prop] = color}, 0.3)
                end
            end
        end
    end

    -- Built-in Settings Tab
    function Window:AddSettingsTab()
        local SettingsTab = Window:CreateTab({
            Name = "Settings",
            Icon = icons["settings"],
        })

        local ConfigSection = SettingsTab:AddSection({
            Name = "Configuration",
            Side = "Left",
        })

        local configList = ConfigSection:AddDropdown({
            Name = "Config File",
            Flag = "__config_list",
            Options = Window:GetConfigs(),
            Separator = true,
        })

        ConfigSection:AddTextBox({
            Name = "Config Name",
            Flag = "__config_name",
            Placeholder = "my_config",
            Separator = true,
        })

        ConfigSection:AddButton({
            Name = "💾  Save Config",
            Callback = function()
                local name = Nebula.Flags["__config_name"]
                if name and name ~= "" then
                    Window:SaveConfig(name)
                    configList.Refresh(Window:GetConfigs())
                end
            end,
        })

        ConfigSection:AddButton({
            Name = "📂  Load Config",
            Callback = function()
                local name = Nebula.Flags["__config_list"]
                if name then
                    Window:LoadConfig(name)
                end
            end,
        })

        ConfigSection:AddButton({
            Name = "🗑️  Delete Config",
            Callback = function()
                local name = Nebula.Flags["__config_list"]
                if name then
                    Window:DeleteConfig(name)
                    configList.Refresh(Window:GetConfigs())
                end
            end,
            Separator = false,
        })

        local AppearanceSection = SettingsTab:AddSection({
            Name = "Appearance",
            Side = "Right",
        })

        AppearanceSection:AddColorPicker({
            Name = "Accent Color",
            Default = Theme.Accent,
            Callback = function(color)
                Window:SetAccent(color)
            end,
        })

        AppearanceSection:AddKeybind({
            Name = "Toggle UI",
            Default = Window.ToggleKey,
            Mode = "Toggle",
            Callback = function(active)
                -- handled by the main toggle
            end,
        })

        AppearanceSection:AddLabel({
            Text = "Nebula Hub v1.0",
            Color = Theme.Dim,
            Separator = false,
        })

        return SettingsTab
    end

    return Window
end

-- ═══════════════════════════════════════════
-- Cleanup
-- ═══════════════════════════════════════════
function Nebula:Destroy()
    if self.ScreenGui then
        self.ScreenGui:Destroy()
    end
    for _, conn in ipairs(self.Connections) do
        conn:Disconnect()
    end
    self.Connections = {}
end

return Nebula
