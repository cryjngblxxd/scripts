            Create("UIStroke", { Parent = Popup, Color = Theme.Border, Thickness = 1 })

            Create("UIListLayout", {
                Parent = Popup,
                SortOrder = Enum.SortOrder.LayoutOrder,
                Padding = UDim.new(0, 1),
            })

            Create("UIPadding", {
                Parent = Popup,
                PaddingTop = UDim.new(0, 3),
                PaddingBottom = UDim.new(0, 3),
                PaddingLeft = UDim.new(0, 3),
                PaddingRight = UDim.new(0, 3),
            })

            local optionButtons = {}
            local totalHeight = 6

            local function UpdateDisplay()
                if multi then
                    SelectedText.Text = #selected > 0 and table.concat(selected, ", ") or "None"
                else
                    SelectedText.Text = tostring(selected or "")
                end
                Nebula.Flags[flag] = selected
                if cfg.Callback then cfg.Callback(selected) end
            end

            local function BuildOptions(opts)
                for _, btn in pairs(optionButtons) do btn:Destroy() end
                optionButtons = {}
                totalHeight = 6

                for _, option in ipairs(opts) do
                    local OptBtn = Create("TextButton", {
                        Parent = Popup,
                        BackgroundColor3 = Theme.Tertiary,
                        BackgroundTransparency = 1,
                        Size = UDim2.new(1, 0, 0, 24),
                        Font = Enum.Font.Gotham,
                        Text = "  " .. option,
                        TextColor3 = Theme.SubText,
                        TextSize = 12,
                        TextXAlignment = Enum.TextXAlignment.Left,
                        AutoButtonColor = false,
                        ZIndex = 101,
                    })
                    Create("UICorner", { Parent = OptBtn, CornerRadius = UDim.new(0, 4) })
                    totalHeight = totalHeight + 25
                    optionButtons[option] = OptBtn

                    OptBtn.MouseEnter:Connect(function()
                        Tween(OptBtn, {BackgroundTransparency = 0}, 0.12)
                    end)
                    OptBtn.MouseLeave:Connect(function()
                        local isS = multi and table.find(selected, option) or selected == option
                        if not isS then Tween(OptBtn, {BackgroundTransparency = 1}, 0.12) end
                    end)

                    OptBtn.MouseButton1Click:Connect(function()
                        if multi then
                            local idx = table.find(selected, option)
                            if idx then
                                table.remove(selected, idx)
                                Tween(OptBtn, {TextColor3 = Theme.SubText, BackgroundTransparency = 1}, 0.12)
                            else
                                table.insert(selected, option)
                                Tween(OptBtn, {TextColor3 = Theme.Text, BackgroundTransparency = 0}, 0.12)
                            end
                        else
                            for _, b in pairs(optionButtons) do
                                Tween(b, {TextColor3 = Theme.SubText, BackgroundTransparency = 1}, 0.12)
                            end
                            selected = option
                            Tween(OptBtn, {TextColor3 = Theme.Text, BackgroundTransparency = 0}, 0.12)
                            task.wait(0.08)
                            open = false
                            Tween(Popup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, 0)}, 0.18)
                            Tween(Arrow, {Rotation = 0}, 0.18)
                        end
                        UpdateDisplay()
                    end)

                    local isS = multi and table.find(selected, option) or selected == option
                    if isS then
                        OptBtn.TextColor3 = Theme.Text
                        OptBtn.BackgroundTransparency = 0
                    end
                end
            end

            BuildOptions(options)

            DropBtn.MouseButton1Click:Connect(function()
                open = not open
                Popup.Position = UDim2.fromOffset(DropBtn.AbsolutePosition.X, DropBtn.AbsolutePosition.Y + DropBtn.AbsoluteSize.Y + 3)
                if open then
                    Tween(Popup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, math.min(totalHeight, 180))}, 0.2)
                    Tween(Arrow, {Rotation = 180}, 0.2)
                else
                    Tween(Popup, {Size = UDim2.new(0, DropBtn.AbsoluteSize.X, 0, 0)}, 0.15)
                    Tween(Arrow, {Rotation = 0}, 0.15)
                end
            end)

            UpdateDisplay()

            Nebula.ConfigFlags[flag] = function(val)
                selected = val
                for _, b in pairs(optionButtons) do
                    local isS = multi and table.find(selected, b.Text:sub(3)) or selected == b.Text:sub(3)
                    b.TextColor3 = isS and Theme.Text or Theme.SubText
                    b.BackgroundTransparency = isS and 0 or 1
                end
                UpdateDisplay()
            end

            if cfg.Separator ~= false then AddSeparator() end

            return {
                Set = function(val) selected = val; UpdateDisplay() end,
                Refresh = function(newOpts) options = newOpts; BuildOptions(newOpts) end,
            }
        end

