                local ik = i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode or i.UserInputType
                if ik == key then
                    if mode == "Toggle" then active = not active
                    elseif mode == "Hold" then active = true end
                    Osama.Flags[flag] = { Key = key, Mode = mode, Active = active }
                    if kc.Callback then kc.Callback(active) end
                end
            end)

