            Cn(UserInputService.InputChanged, function(i)
                if i.UserInputType ~= Enum.UserInputType.MouseMovement then return end
                local m = UserInputService:GetMouseLocation()
                if dSV then
                    s = math.clamp((m.X - SV.AbsolutePosition.X) / SV.AbsoluteSize.X, 0, 1)
                    v = 1 - math.clamp((m.Y - SV.AbsolutePosition.Y) / SV.AbsoluteSize.Y, 0, 1)
                    UC()
                elseif dH then
                    h = math.clamp((m.X - HB.AbsolutePosition.X) / HB.AbsoluteSize.X, 0, 1)
                    UC()
                end
            end)

            Pv.MouseButton1Click:Connect(function()
                po = not po
                Pop.Position = UDim2.fromOffset(Pv.AbsolutePosition.X - 165, Pv.AbsolutePosition.Y + 34)
                if po then T(Pop, {Size = UDim2.new(0, 200, 0, 168)}, 0.25)
                else T(Pop, {Size = UDim2.new(0, 200, 0, 0)}, 0.18) end
            end)

            UC()
            Osama.ConfigFlags[flag] = function(c) h, s, v = c:ToHSV(); UC() end
            if cc.Separator ~= false then Sep() end
            return { Set = function(c) h, s, v = c:ToHSV(); UC() end }
        end

        return S
    end

    function W:CreateTab(tc)
        local Tab = { Name = tc.Name or "Tab", Visible = false }

        local TB = C("TextButton", {
            Parent = TabHolder, BackgroundColor3 = Theme.Elevated,
            BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 42), Text = "", AutoButtonColor = false,
        })
        C("UICorner", { Parent = TB, CornerRadius = UDim.new(0, 12) })

        local TIcon = C("ImageLabel", {
            Parent = TB, BackgroundTransparency = 1,
            Position = UDim2.new(0, 14, 0.5, -10),
            Size = UDim2.new(0, 20, 0, 20),
            Image = tc.Icon or "rbxassetid://7733960981",
            ImageColor3 = Theme.TextDim,
        })

        local TN = C("TextLabel", {
            Parent = TB, BackgroundTransparency = 1,
            Position = UDim2.new(0, 44, 0, 0),
            Size = UDim2.new(1, -54, 1, 0),
            Font = Enum.Font.GothamBold,
            Text = Tab.Name, TextColor3 = Theme.TextDim,
            TextSize = 13, TextXAlignment = Enum.TextXAlignment.Left,
        })

        local AB = C("Frame", {
            Parent = TB, BackgroundColor3 = Theme.Accent,
            BackgroundTransparency = 1,
            Position = UDim2.new(0, 4, 0.5, -10),
            Size = UDim2.new(0, 4, 0, 20),
        })
        C("UICorner", { Parent = AB, CornerRadius = UDim.new(0, 3) })
        BA(AB, "BackgroundColor3")

        local TC = C("ScrollingFrame", {
            Parent = TabContent, BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 1, 0),
            CanvasSize = UDim2.new(0, 0, 0, 0),
            AutomaticCanvasSize = Enum.AutomaticSize.Y,
            ScrollBarThickness = 3,
            ScrollBarImageColor3 = Theme.Accent,
            Visible = false,
        })

        local CH = C("Frame", {
            Parent = TC, BackgroundTransparency = 1,
            Size = UDim2.new(1, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y,
        })
        C("UIListLayout", {
            Parent = CH,
            FillDirection = Enum.FillDirection.Horizontal,
            HorizontalFlex = Enum.UIFlexAlignment.Fill,
            Padding = UDim.new(0, 10),
            SortOrder = Enum.SortOrder.LayoutOrder,
        })
        C("UIPadding", {
            Parent = CH,
            PaddingTop = UDim.new(0, 10), PaddingBottom = UDim.new(0, 10),
            PaddingLeft = UDim.new(0, 14), PaddingRight = UDim.new(0, 14),
        })

        local LC = C("Frame", {
            Parent = CH, BackgroundTransparency = 1,
            Size = UDim2.new(0.5, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = 1,
        })
        C("UIListLayout", { Parent = LC, Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder })

        local RC = C("Frame", {
            Parent = CH, BackgroundTransparency = 1,
            Size = UDim2.new(0.5, 0, 0, 0),
            AutomaticSize = Enum.AutomaticSize.Y, LayoutOrder = 2,
        })
        C("UIListLayout", { Parent = RC, Padding = UDim.new(0, 10), SortOrder = Enum.SortOrder.LayoutOrder })

        function Tab:Show()
            if W.CurrentTab and W.CurrentTab ~= Tab then W.CurrentTab:Hide() end
            Tab.Visible = true; TC.Visible = true; W.CurrentTab = Tab
            TabTitle.Text = Tab.Name
            T(TB, {BackgroundTransparency = 0}, 0.2)
            T(TIcon, {ImageColor3 = Theme.Accent}, 0.2)
            T(TN, {TextColor3 = Theme.Text}, 0.2)
            T(AB, {BackgroundTransparency = 0}, 0.2)
            Fade.BackgroundTransparency = 0
            T(Fade, {BackgroundTransparency = 1}, 0.3)
        end

        function Tab:Hide()
            Tab.Visible = false; TC.Visible = false
            T(TB, {BackgroundTransparency = 1}, 0.2)
            T(TIcon, {ImageColor3 = Theme.TextDim}, 0.2)
            T(TN, {TextColor3 = Theme.TextDim}, 0.2)
            T(AB, {BackgroundTransparency = 1}, 0.2)
        end

        function Tab:AddSection(sc)
            local p = (sc.Side == "Right") and RC or LC
            return MakeSection(p, sc)
        end

        TB.MouseButton1Click:Connect(function() Tab:Show() end)
        TB.MouseEnter:Connect(function()
            if not Tab.Visible then T(TB, {BackgroundTransparency = 0.4}, 0.12) end
        end)
        TB.MouseLeave:Connect(function()
            if not Tab.Visible then T(TB, {BackgroundTransparency = 1}, 0.12) end
        end)

        table.insert(W.Tabs, Tab)
        if #W.Tabs == 1 then Tab:Show() end
        return Tab
    end

    function W:SaveConfig(n)
        local d = {}
        for f, v in pairs(Osama.Flags) do
            if type(v) == "table" and v.Key then d[f] = { Key = tostring(v.Key), Mode = v.Mode, Active = v.Active }
            elseif typeof(v) == "Color3" then d[f] = { _t = "c3", h = v:ToHex() }
            else d[f] = v end
        end
        writefile(Osama.Directory .. "/configs/" .. n .. ".cfg", HttpService:JSONEncode(d))
        Osama:Notify({ Title = "Config", Message = "Saved: " .. n, Type = "Success" })
    end

    function W:LoadConfig(n)
        local p = Osama.Directory .. "/configs/" .. n .. ".cfg"
        if not isfile(p) then Osama:Notify({ Title = "Config", Message = "Not found", Type = "Error" }); return end
        local d = HttpService:JSONDecode(readfile(p))
        for f, v in pairs(d) do
            local s = Osama.ConfigFlags[f]
            if s then
                if type(v) == "table" and v._t == "c3" then s(Color3.fromHex(v.h))
                else s(v) end
            end
        end
        Osama:Notify({ Title = "Config", Message = "Loaded: " .. n, Type = "Success" })
    end

    function W:DeleteConfig(n)
        local p = Osama.Directory .. "/configs/" .. n .. ".cfg"
        if isfile(p) then delfile(p); Osama:Notify({ Title = "Config", Message = "Deleted: " .. n, Type = "Warning" }) end
    end

    function W:GetConfigs()
        local l = {}
        for _, f in ipairs(listfiles(Osama.Directory .. "/configs")) do
            local n = f:match("([^/\\]+)%.cfg$")
            if n then table.insert(l, n) end
        end
        return l
    end

    function W:SetAccent(c)
        Theme.Accent = c
        for prop, objs in pairs(AccentBinds) do
            for _, o in ipairs(objs) do
                if o and o.Parent then T(o, {[prop] = c}, 0.3) end
            end
        end
    end

    function W:AddSettingsTab()
        local ST = W:CreateTab({ Name = "Settings", Icon = "rbxassetid://7734053495" })
        local CS = ST:AddSection({ Name = "Configs", Side = "Left", Icon = "rbxassetid://7734053495" })
        local cl = CS:AddDropdown({ Name = "Config", Flag = "_cl", Options = W:GetConfigs() })
        CS:AddTextBox({ Name = "Name", Flag = "_cn", Placeholder = "config name" })
        CS:AddButton({ Name = "Save Config", Icon = "rbxassetid://7733717078", Callback = function()
            local n = Osama.Flags["_cn"]
            if n and n ~= "" then W:SaveConfig(n); cl.Refresh(W:GetConfigs()) end
        end })
        CS:AddButton({ Name = "Load Config", Icon = "rbxassetid://7733717078", Callback = function()
            local n = Osama.Flags["_cl"]; if n then W:LoadConfig(n) end
        end })
        CS:AddButton({ Name = "Delete Config", Icon = "rbxassetid://7733717078", Callback = function()
            local n = Osama.Flags["_cl"]; if n then W:DeleteConfig(n); cl.Refresh(W:GetConfigs()) end
        end, Separator = false })

        local AS = ST:AddSection({ Name = "Appearance", Side = "Right", Icon = "rbxassetid://7743870115" })
        AS:AddColorPicker({ Name = "Accent Color", Default = Theme.Accent, Callback = function(c) W:SetAccent(c) end })
        AS:AddKeybind({ Name = "Toggle UI", Default = W.ToggleKey, Mode = "Toggle" })
        AS:AddLabel({ Text = "OsamaHub v2.0", Separator = false })
        return ST
    end

    return W
end

function Osama:Destroy()
    if self.SG then self.SG:Destroy() end
    for _, c in ipairs(self.Connections) do c:Disconnect() end
    self.Connections = {}
end

return Osama
