					TypeBox.Text = ""
					typeOpen = false
					tween(W, {Size = UDim2.new(1, 0, 0, 34)}, 0.15)
				end)

				UserInputService.InputEnded:Connect(function(i)
					if i.UserInputType == Enum.UserInputType.MouseButton1 then sliding = false end
				end)

				UserInputService.InputChanged:Connect(function(i)
					if sliding and i.UserInputType == Enum.UserInputType.MouseMovement then
						local pct = math.clamp((i.Position.X - BarFrame.AbsolutePosition.X) / BarFrame.AbsoluteSize.X, 0, 1)
						local r = min + (max - min) * pct
						if dec >= 1 then r = math.floor(r + 0.5) else local m = 1 / dec; r = math.floor(r * m + 0.5) / m end
						setV(r)
					end
				end)

				local obj = {}
				function obj:Set(v) setV(v) end
				function obj:Get() return state end
				return obj
			end

