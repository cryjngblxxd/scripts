	function Library:SaveConfig(name)
		if not name or name == "" then return end
		local data = {}
		for k, v in pairs(Library.Flags) do
			if type(v) == "boolean" or type(v) == "number" or type(v) == "string" then
				data[k] = {type = type(v), value = v}
			elseif typeof(v) == "Color3" then
				data[k] = {type = "Color3", value = {v.R, v.G, v.B}}
			elseif typeof(v) == "EnumItem" then
				data[k] = {type = "EnumItem", value = tostring(v)}
			elseif type(v) == "table" then
				data[k] = {type = "table", value = v}
			end
		end
		local success, encoded = pcall(function()
			return game:GetService("HttpService"):JSONEncode(data)
		end)
		if success then
			pcall(function()
				writefile("Avenir/" .. name .. ".json", encoded)
			end)
		end
	end

	function Library:LoadConfig(name)
		if not name or name == "" then return end
		local success, content = pcall(function()
			return readfile("Avenir/" .. name .. ".json")
		end)
		if not success then return end
		local ok, data = pcall(function()
			return game:GetService("HttpService"):JSONDecode(content)
		end)
		if not ok then return end
		for k, info in pairs(data) do
			if info.type == "boolean" then
				Library.Flags[k] = info.value
			elseif info.type == "number" then
				Library.Flags[k] = info.value
			elseif info.type == "string" then
				Library.Flags[k] = info.value
			elseif info.type == "Color3" then
				Library.Flags[k] = Color3.new(info.value[1], info.value[2], info.value[3])
			elseif info.type == "EnumItem" then
				Library.Flags[k] = info.value
			elseif info.type == "table" then
				Library.Flags[k] = info.value
			end
		end
	end

	function Library:DeleteConfig(name)
		if not name or name == "" then return end
		pcall(function()
			delfile("Avenir/" .. name .. ".json")
		end)
	end

	function Library:GetConfigs()
		local configs = {}
		pcall(function()
			if not isfolder("Avenir") then makefolder("Avenir") end
			local files = listfiles("Avenir")
			for _, f in ipairs(files) do
				local n = f:match("Avenir/(.+)%.json$") or f:match("Avenir\\(.+)%.json$")
				if n then table.insert(configs, n) end
			end
		end)
		return configs
	end

	function Library:SetAutoLoad(name)
		pcall(function()
			if not isfolder("Avenir") then makefolder("Avenir") end
			writefile("Avenir/_autoload.txt", name or "")
		end)
	end

	function Library:GetAutoLoad()
		local name = ""
		pcall(function()
			name = readfile("Avenir/_autoload.txt")
		end)
		return name
	end

	function Library:RemoveAutoLoad()
		pcall(function()
			delfile("Avenir/_autoload.txt")
		end)
	end

	pcall(function()
		if not isfolder("Avenir") then makefolder("Avenir") end
		local autoName = Library:GetAutoLoad()
		if autoName and autoName ~= "" then
			Library:LoadConfig(autoName)
		end
	end)

	return Window
end

return Library
