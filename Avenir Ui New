local function tween(obj, props, dur)
	TweenService:Create(obj, TweenInfo.new(dur or 0.2, Enum.EasingStyle.Quad), props):Play()
end

local function formatTime(seconds)
	local hours = math.floor(seconds / 3600)
	local mins = math.floor((seconds % 3600) / 60)
	local secs = math.floor(seconds % 60)
	return string.format("%02d:%02d:%02d", hours, mins, secs)
end

local function getPing()
	local ping = 0
	pcall(function()
		ping = Stats.Network.ServerStatsItem["Data Ping"]:GetValue()
	end)
	return math.floor(ping)
end

local fpsValue = 60
local frameCount = 0
local lastFpsTime = tick()

RunService.RenderStepped:Connect(function()
	frameCount = frameCount + 1
	local currentTime = tick()
	if currentTime - lastFpsTime >= 1 then
		fpsValue = frameCount
		frameCount = 0
		lastFpsTime = currentTime
	end
end)

local function gkn(k)
	local s = tostring(k)
	if s:find("MouseButton1") then return "MB1" elseif s:find("MouseButton2") then return "MB2"
	elseif s:find("MouseButton3") then return "MB3" end
	return s:gsub("Enum.KeyCode.",""):gsub("Enum.UserInputType.","")
end

local function refreshKeybindPanel()
	if not Library._keybindPanel then return end
	local container = Library._keybindPanel:FindFirstChild("KBInnerPanel")
	if not container then return end
	local kbContainer = container:FindFirstChild("Container")
	if not kbContainer then return end

	for _, c in pairs(kbContainer:GetChildren()) do
		if c:IsA("Frame") then c:Destroy() end
	end

	local idx = 0
	for _, entry in ipairs(Library._keybindEntries) do
		if entry.active then
			local row = Instance.new("Frame")
			row.Size = UDim2.new(1, 0, 0, 20)
			row.Position = UDim2.new(0, 0, 0, idx * 24)
			row.BackgroundTransparency = 1
			row.ZIndex = 2
			row.Parent = kbContainer

			local nl = Instance.new("TextLabel")
			nl.Size = UDim2.new(1, -60, 1, 0)
			nl.BackgroundTransparency = 1
			nl.Text = entry.name
			nl.TextColor3 = Color3.fromRGB(100, 180, 255)
			nl.TextSize = 13
			nl.Font = Enum.Font.Gotham
			nl.TextXAlignment = Enum.TextXAlignment.Left
			nl.ZIndex = 2
			nl.Parent = row

			local ml = Instance.new("TextLabel")
			ml.Size = UDim2.new(0, 55, 1, 0)
			ml.Position = UDim2.new(1, -55, 0, 0)
			ml.BackgroundTransparency = 1
			ml.Text = "[" .. entry.mode .. "]"
			ml.TextColor3 = Color3.fromRGB(180, 180, 180)
			ml.TextSize = 11
			ml.Font = Enum.Font.Gotham
			ml.TextXAlignment = Enum.TextXAlignment.Right
			ml.ZIndex = 2
			ml.Parent = row

			idx = idx + 1
		end
	end

	local totalH = math.max(idx * 24, 10)
	local panelH = 48 + totalH + 8
	Library._keybindPanel.Size = UDim2.new(0, 200, 0, panelH)
end

