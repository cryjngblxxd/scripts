					sliding = true
					local pct = math.clamp((mouse.X - BarFrame.AbsolutePosition.X) / BarFrame.AbsoluteSize.X, 0, 1)
					local r = min + (max - min) * pct
					if dec >= 1 then r = math.floor(r + 0.5) else local m = 1 / dec; r = math.floor(r * m + 0.5) / m end
					setV(r)
				end)

				SClick.MouseButton2Click:Connect(function()
