						state = i.UserInputType == Enum.UserInputType.Keyboard and i.KeyCode or i.UserInputType
						Library.Flags[flag] = state
						kbEntry.key = state
						KeyLbl.Text = gkn(state)
						KeyLbl.TextColor3 = Color3.fromRGB(100, 180, 255)
						listening = false
						refreshKeybindPanel()
					elseif not gpe then
						local ik = i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode or i.UserInputType
						if ik == state then
							if mode == "Toggle" then
								toggled = not toggled
								kbEntry.active = toggled
								refreshKeybindPanel()
								cb(toggled)
							elseif mode == "Hold" then
								kbEntry.active = true
								refreshKeybindPanel()
								cb(true)
							end
						end
					end
				end)

				UserInputService.InputEnded:Connect(function(i)
					if mode == "Hold" and not listening then
						local ik = i.KeyCode ~= Enum.KeyCode.Unknown and i.KeyCode or i.UserInputType
						if ik == state then
							kbEntry.active = false
							refreshKeybindPanel()
							cb(false)
						end
					end
				end)

				task.spawn(function()
					local aa = false
					while true do
						task.wait(0.1)
						if mode == "Always" and not aa then
							aa = true
							kbEntry.active = true
							refreshKeybindPanel()
							cb(true)
						elseif mode ~= "Always" and aa then
							aa = false
							kbEntry.active = false
							refreshKeybindPanel()
							cb(false)
						end
					end
				end)

				local obj = {}
				function obj:Set(k)
					state = k
					Library.Flags[flag] = k
					kbEntry.key = k
					KeyLbl.Text = gkn(k)
					refreshKeybindPanel()
				end
				function obj:Get() return state end
				return obj
			end

