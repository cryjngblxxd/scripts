		end

		-- Divider
		function Sections:Divider(Options)
			local parent = (Options and Options.Side == "Right") and self.Elements.Right or self.Elements.Left
			local Div = Instance.new('Frame', parent)
			Div.Size = UDim2.new(1,0,0,1); Div.BackgroundColor3 = Color3.new(0.1098,0.1098,0.1098); Div.BorderSizePixel = 0
