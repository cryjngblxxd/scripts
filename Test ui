local _keybind_watchers = {}
local _keybind_states = {}
local _value_watchers = {}
local _value_states = {}

task.spawn(function()
	while true do
		task.wait(0.05)
		if Library.Unloaded then break end
		for key, callbacks in pairs(_keybind_watchers) do
			local curActive = false
			pcall(function()
				local data = Library.Flags[key]
				if data and typeof(data) == "table" and data.active ~= nil then
					curActive = data.active or false
				end
			end)
			if _keybind_states[key] == nil then _keybind_states[key] = curActive end
			if curActive ~= _keybind_states[key] then
				_keybind_states[key] = curActive
				for _, cb in ipairs(callbacks) do pcall(cb) end
			end
		end
	end
end)

task.spawn(function()
	while true do
		task.wait(0.1)
		if Library.Unloaded then break end
		for key, callbacks in pairs(_value_watchers) do
			local curVal = Library.Flags[key]
			local compareVal
			if typeof(curVal) == "table" then
				local s = ""; for k, v in pairs(curVal) do s = s .. tostring(k) .. tostring(v) end; compareVal = s
			else compareVal = curVal end
			if _value_states[key] ~= nil and compareVal ~= _value_states[key] then
				_value_states[key] = compareVal
				for _, cb in ipairs(callbacks) do pcall(cb) end
			end
			if _value_states[key] == nil then _value_states[key] = compareVal end
		end
	end
end)

Toggles = setmetatable({}, {
	__index = function(self, key)
		local val = Library.Flags[key]
		if val == nil then return nil end
		return {
			Value = (typeof(val) == "boolean") and val or false,
			SetValue = function(_, newVal) Library.Flags[key] = newVal end,
			OnChanged = function(_, cb)
				if not _value_watchers[key] then _value_watchers[key] = {}; _value_states[key] = Library.Flags[key] end
				table.insert(_value_watchers[key], cb)
			end
		}
	end
})

Options = setmetatable({}, {
	__index = function(self, key)
		local val = Library.Flags[key]
		if val == nil then return nil end
		local isKeybind = typeof(val) == "table" and val.key ~= nil and val.mode ~= nil
		local isColor = typeof(val) == "table" and val.Color ~= nil
		local isTable = typeof(val) == "table" and not isKeybind and not isColor
		if isKeybind then
			return {
				Value = val.key,
				GetState = function() local d = Library.Flags[key]; return d and d.active or false end,
				OnClick = function(_, cb)
					if not _keybind_watchers[key] then _keybind_watchers[key] = {} end
					table.insert(_keybind_watchers[key], cb)
				end,
				SetValue = function(_, newVal) Library.Flags[key] = newVal end
			}
		elseif isColor then
			return {
				Value = val.Color,
				OnChanged = function(_, cb)
					if not _value_watchers[key] then _value_watchers[key] = {}; _value_states[key] = tostring(val.Color) end
					table.insert(_value_watchers[key], cb)
				end
			}
		elseif isTable then
			local dictVal = {}; for _, item in ipairs(val) do dictVal[item] = true end
			return {
				Value = dictVal,
				SetValue = function(_, newVal)
					if typeof(newVal) == "table" then
						local arr = {}; for k, v in pairs(newVal) do if v then table.insert(arr, k) end end
						Library.Flags[key] = arr
					else Library.Flags[key] = newVal end
				end,
				OnChanged = function(_, cb)
					if not _value_watchers[key] then
						_value_watchers[key] = {}; local s = ""; for k, v in pairs(val) do s = s .. tostring(k) .. tostring(v) end; _value_states[key] = s
					end
					table.insert(_value_watchers[key], cb)
				end
			}
		else
			return {
				Value = val,
				SetValue = function(_, newVal) Library.Flags[key] = newVal end,
				OnChanged = function(_, cb)
					if not _value_watchers[key] then _value_watchers[key] = {}; _value_states[key] = val end
					table.insert(_value_watchers[key], cb)
				end
			}
		end
	end
})

