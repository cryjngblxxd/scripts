			LabelInst.TextColor3 = Color3.new(0.306,0.306,0.306); LabelInst.FontFace = Library.UIFont; LabelInst.TextSize = Library.FontSize
			LabelInst.ZIndex = 105; LabelInst.TextXAlignment = Enum.TextXAlignment.Left; LabelInst.Text = Lbl.Text; LabelInst.TextWrapped = true
			function Lbl:SetText(text) LabelInst.Text = text; Lbl.Text = text end
