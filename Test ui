		end

		-- Keybind (standalone)
		function Sections:Keybind(Options)
			local Props = Options or {}
			local KB = {
				Section = self, Name = Props.Name or Props.Title or Props.name or "Keybind",
				State = Props.default or Props.Default or Props.state or Props.State or Props.key or Props.Key or nil,
				Mode = Props.mode or Props.Mode or "Toggle",
				Callback = Props.callback or Props.Callback or function() end,
				Flag = Props.flag or Props.Flag or Library.NextFlag(),
				Binding = nil, Connection = nil,
			}
			local Key; local StateKB = false
			local parent = Options.Side == "Right" and KB.Section.Elements.Right or KB.Section.Elements.Left

			local HolderKB = Instance.new('TextButton', parent)
			local TitleKB = Instance.new('TextLabel', HolderKB)
			local ValueKB = Instance.new('TextButton', HolderKB)
			local ModeDDKB = Instance.new('Frame', HolderKB)
			local ModeListKB2 = Instance.new('UIListLayout', ModeDDKB)

			AddInstance(TitleKB); AddInstance(ValueKB)

			HolderKB.Size = UDim2.new(1,0,0,14); HolderKB.BackgroundTransparency = 1; HolderKB.Text = ""; HolderKB.AutoButtonColor = false
			TitleKB.Position = UDim2.new(0,15,0,0); TitleKB.Size = UDim2.new(1,-70,1,0); TitleKB.BackgroundTransparency = 1
			TitleKB.TextColor3 = Color3.new(0.306,0.306,0.306); TitleKB.FontFace = Library.UIFont; TitleKB.TextSize = Library.FontSize
			TitleKB.ZIndex = 105; TitleKB.TextXAlignment = Enum.TextXAlignment.Left; TitleKB.Text = KB.Name
			ValueKB.Position = UDim2.new(1,-50,0,0); ValueKB.Size = UDim2.new(0,45,1,0); ValueKB.BackgroundTransparency = 1
			ValueKB.Text = "-"; ValueKB.TextColor3 = Color3.new(0.306,0.306,0.306); ValueKB.FontFace = Library.UIFont
			ValueKB.TextSize = Library.FontSize; ValueKB.ZIndex = 105; ValueKB.AutoButtonColor = false; ValueKB.TextXAlignment = Enum.TextXAlignment.Right
			ModeDDKB.Size = UDim2.new(0,55,0,0); ModeDDKB.Position = UDim2.new(1,-55,0,16)
			ModeDDKB.BackgroundColor3 = Color3.new(0.0431,0.0431,0.0431); ModeDDKB.BorderColor3 = Color3.new(0.1098,0.1098,0.1098)
			ModeDDKB.ZIndex = 200; ModeDDKB.Visible = false; ModeDDKB.ClipsDescendants = true
			ModeListKB2.SortOrder = Enum.SortOrder.LayoutOrder

			local modeOpenKB2 = false; local modes2 = {"Hold", "Toggle", "Always"}; local modeButtons2 = {}
			for _, mode in ipairs(modes2) do
				local btn = Instance.new('TextButton', ModeDDKB)
				btn.Size = UDim2.new(1,0,0,16); btn.BackgroundTransparency = 1; btn.Text = mode
				btn.TextColor3 = mode == KB.Mode and Library.Accent or Color3.new(0.306,0.306,0.306)
				btn.FontFace = Library.UIFont; btn.TextSize = Library.FontSize - 1; btn.ZIndex = 201; btn.AutoButtonColor = false
				modeButtons2[mode] = btn
				btn.MouseButton1Click:Connect(function()
					KB.Mode = mode
					for m, b in pairs(modeButtons2) do b.TextColor3 = m == mode and Library.Accent or Color3.new(0.306,0.306,0.306) end
					if mode == "Always" then StateKB = true; Library.Flags[KB.Flag] = true; KB.Callback(true) end
					modeOpenKB2 = false; ModeDDKB.Visible = false; ModeDDKB.Size = UDim2.new(0,55,0,0)
				end)
			end

			local function setKeyKB(newkey)
				if typeof(newkey) == "EnumItem" then
					if KB.Connection then KB.Connection:Disconnect(); Library.Flags[KB.Flag] = false; KB.Callback(false) end
					if newkey == Enum.KeyCode.Backspace or newkey == Enum.KeyCode.Escape then Key = nil; ValueKB.Text = "-"
					else Key = newkey; ValueKB.Text = Library.Keys[newkey] or tostring(newkey):gsub("Enum.KeyCode.",""):gsub("Enum.UserInputType.","") end
				end
			end
			if KB.State then setKeyKB(KB.State) end

			ValueKB.MouseButton1Click:Connect(function()
				if not KB.Binding then
					ValueKB.Text = "..."
					KB.Binding = Library:Connection(game:GetService("UserInputService").InputBegan, function(input)
						setKeyKB(input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode or input.UserInputType)
						Library:Disconnect(KB.Binding); task.wait(); KB.Binding = nil
					end)
				end
			end)
			ValueKB.MouseButton2Click:Connect(function()
				modeOpenKB2 = not modeOpenKB2; ModeDDKB.Visible = modeOpenKB2
				ModeDDKB.Size = modeOpenKB2 and UDim2.new(0,55,0,48) or UDim2.new(0,55,0,0)
			end)
			Library:Connection(game:GetService("UserInputService").InputBegan, function(inp)
				if (inp.KeyCode == Key or inp.UserInputType == Key) and not KB.Binding then
					if KB.Mode == "Hold" then
						Library.Flags[KB.Flag] = true
						KB.Connection = Library:Connection(game:GetService("RunService").RenderStepped, function() KB.Callback(true) end)
					elseif KB.Mode == "Toggle" then
						StateKB = not StateKB; Library.Flags[KB.Flag] = StateKB; KB.Callback(StateKB)
					end
				end
			end)
			Library:Connection(game:GetService("UserInputService").InputEnded, function(inp)
				if KB.Mode == "Hold" and Key and (inp.KeyCode == Key or inp.UserInputType == Key) then
					if KB.Connection then KB.Connection:Disconnect(); Library.Flags[KB.Flag] = false; KB.Callback(false) end
				end
			end)
			function KB:Set(key) setKeyKB(key) end
			Flags[KB.Flag] = setKeyKB
			return KB
		end
	end
end


-- LOWERCASE API WRAPPER


local library = {
	flags = Library.Flags,
}

function library:window(opts)
	local win = Library:Window({
		Name = opts.name or opts.Name or "Avenir",
		Suffix = opts.suffix or opts.Suffix or "",
		GameInfo = opts.gameInfo or opts.GameInfo or "",
		Project = opts.project or opts.Project or "",
		Size = opts.size or opts.Size or UDim2.fromOffset(550, 500),
		auto_show = opts.auto_show,
	})

	local wrapper = {}
	wrapper._win = win

	function wrapper:tab(opts2)
		return win:Page({
			Name = opts2.name or opts2.Name or "tab",
			Icon = opts2.icon or opts2.Icon,
		})
	end

	function wrapper:init_config(w)
		task.spawn(function()
			task.wait(0.5)
			pcall(function()
				local configFolder = Library.Folders.configs or "avenir/Configs"
				if isfolder and not isfolder(configFolder) then makefolder(configFolder) end
				if isfile and isfile(configFolder .. "/autoload.txt") then
					local name = readfile(configFolder .. "/autoload.txt")
					local p = configFolder .. "/" .. name .. ".cfg"
					if isfile(p) then Library:LoadConfig(readfile(p)) end
				end
			end)
		end)
	end

	return wrapper
end

function library:unload()
	Library:Unload()
end

function library:init_config(w)
	if w and w.init_config then
		w:init_config(w)
	end
end


