local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Camera = workspace.CurrentCamera

local savedOrientation = nil

RunService:BindToRenderStep("AntiRecoil", Enum.RenderPriority.Camera.Value + 1, function()
    local delta = UserInputService:GetMouseDelta()
    if savedOrientation and delta.Magnitude == 0 then
        Camera.CFrame = CFrame.new(Camera.CFrame.Position) * savedOrientation
    end
    savedOrientation = Camera.CFrame - Camera.CFrame.Position
end)
