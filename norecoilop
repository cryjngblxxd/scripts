for _, v in pairs(getgc(true)) do
    if typeof(v) == "table" then
        pcall(function()
            if v.recoil and typeof(v.recoil) == "table" and v.recoil.func and typeof(v.recoil.func) == "function" then
                v.recoil.func = function() end
            end
        end)
    end
end

