    require(game:GetService("ReplicatedStorage").Modules.CameraShake).load = function() end
end)

local oldIndex
oldIndex = hookmetamethod(game, "__index", function(self, key)
    local result = oldIndex(self, key)
    if typeof(result) == "table" and rawget(result, "func") and rawget(result, "running") ~= nil and rawget(result, "done_hooks") then
        result.func = function() end
    end
    return result
end)
